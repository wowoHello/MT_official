<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

@*
    Blazor Server SignalR 連線中斷 / 暫停提示視窗。
    框架需要的 id 與 class 不可改名；視覺與狀態文字以晨光書房莫蘭迪色系重寫。
    visibility 控制 class 一律放在外層 <div>，避免框架 display:block 覆寫 Tailwind 排版。
*@

<dialog id="components-reconnect-modal"
        data-nosnippet
        aria-labelledby="components-reconnect-title"
        aria-describedby="components-reconnect-body">

    <div class="components-reconnect-container flex flex-col items-center gap-5 px-8 py-7 text-center">

        @* 連線中動畫：首次嘗試 / 重試中皆顯示 *@
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <div></div>
        </div>

        @* 連線失敗 / Resume 失敗 共用警示圖示 *@
        <div class="components-reconnect-failed-visible components-resume-failed-visible">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-terracotta/15">
                <svg class="h-8 w-8 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M4.93 19h14.14a2 2 0 0 0 1.74-3l-7.07-12a2 2 0 0 0-3.48 0L3.2 16a2 2 0 0 0 1.73 3Z" />
                </svg>
            </div>
        </div>

        @* 系統暫停圖示 *@
        <div class="components-pause-visible">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-morandi/15">
                <svg class="h-8 w-8 text-morandi" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <path stroke-linecap="round" d="M10 9v6M14 9v6" />
                </svg>
            </div>
        </div>

        @* 狀態文字區：aria-live 讓螢幕閱讀器朗讀狀態切換 *@
        <div id="components-reconnect-body" role="status" aria-live="polite" aria-atomic="true" class="space-y-1.5">

            @* 首次嘗試 *@
            <p id="components-reconnect-title" class="components-reconnect-first-attempt-visible text-lg font-semibold text-slate-main">
                正在重新連線伺服器…
            </p>
            <p class="components-reconnect-first-attempt-visible text-sm text-slate-main/75">
                請稍候，連線恢復後會自動繼續您的作業
            </p>

            @* 重試中（含倒數秒數） *@
            <p class="components-reconnect-repeated-attempt-visible text-lg font-semibold text-slate-main">
                連線中斷，
                <span id="components-seconds-to-next-attempt"
                      class="inline-flex h-7 min-w-[1.75rem] items-center justify-center rounded-md bg-terracotta/20 px-1.5 mx-1 font-bold tabular-nums text-slate-main"></span>
                秒後再次嘗試
            </p>
            <p class="components-reconnect-repeated-attempt-visible text-sm text-slate-main/75">
                正在嘗試恢復連線，請保持頁面開啟
            </p>

            @* 失敗 *@
            <p class="components-reconnect-failed-visible text-lg font-semibold text-slate-main">
                無法重新連線
            </p>
            <p class="components-reconnect-failed-visible text-sm text-slate-main/75">
                請點擊下方按鈕重試，或重新整理頁面後繼續
            </p>

            @* 系統暫停 *@
            <p class="components-pause-visible text-lg font-semibold text-slate-main">
                系統已暫停連線
            </p>
            <p class="components-pause-visible text-sm text-slate-main/75">
                點擊「繼續作業」即可從中斷處接續
            </p>

            @* 恢復失敗 *@
            <p class="components-resume-failed-visible text-lg font-semibold text-slate-main">
                無法恢復連線
            </p>
            <p class="components-resume-failed-visible text-sm text-slate-main/75">
                請再試一次，或重新整理頁面
            </p>
        </div>

        @* 重試按鈕（失敗時顯示） *@
        <div class="components-reconnect-failed-visible">
            <button id="components-reconnect-button"
                    type="button"
                    class="inline-flex h-12 min-w-36 items-center justify-center gap-2 rounded-lg bg-sage px-6 text-base font-semibold text-white shadow-sm transition-all hover:bg-sage/90 hover:shadow-md active:bg-sage/80 focus:outline-none focus-visible:ring-4 focus-visible:ring-sage/35">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12a9 9 0 0 1 15.5-6.36L21 8M21 3v5h-5M21 12a9 9 0 0 1-15.5 6.36L3 16M3 21v-5h5" />
                </svg>
                重試連線
            </button>
        </div>

        @* 繼續按鈕（暫停 / 恢復失敗 共用） *@
        <div class="components-pause-visible components-resume-failed-visible">
            <button id="components-resume-button"
                    type="button"
                    class="inline-flex h-12 min-w-36 items-center justify-center gap-2 rounded-lg bg-morandi px-6 text-base font-semibold text-white shadow-sm transition-all hover:bg-morandi/90 hover:shadow-md active:bg-morandi/80 focus:outline-none focus-visible:ring-4 focus-visible:ring-morandi/35">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v18l15-9L5 3Z" />
                </svg>
                繼續作業
            </button>
        </div>

        @* 重新整理頁面備援連結（失敗類狀態才顯示） *@
        <div class="components-reconnect-failed-visible components-resume-failed-visible">
            <button type="button"
                    onclick="location.reload()"
                    class="text-xs text-morandi underline-offset-4 hover:underline focus:outline-none focus-visible:underline">
                或重新整理頁面
            </button>
        </div>
    </div>
</dialog>
