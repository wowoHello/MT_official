@inherits LayoutComponentBase
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IProjectService ProjectService
@inject IRoleService RoleService
@inject IMembershipService MembershipService
@inject IAppointmentService AppointmentService
@inject ProtectedLocalStorage ProtectedLocalStorage
@inject ILogger<MainLayout> Logger
@rendermode InteractiveServer

<PageTitle>CWT 命題工作平臺</PageTitle>

<AppLoadingSplash IsHidden="@isAppReady" />

<nav class="fixed top-0 z-40 h-16 w-full bg-morandi shadow-md transition-all">
    <div class="mx-auto h-full px-4 sm:px-6 lg:px-8">
        <div class="flex h-full items-center justify-between gap-4">

            <div class="flex flex-shrink-0 items-center lg:w-1/4">
                <NavLink href="" Match="NavLinkMatch.All" class="flex items-center gap-2 text-white transition-colors hover:text-blue-100">
                    <div class="flex h-8 w-8 items-center justify-center overflow-hidden rounded-md bg-white/20">
                        <img src="img/pencil.png" alt="CWT Logo" class="h-6 w-6 object-contain drop-shadow-sm">
                    </div>
                    <span class="hidden text-lg font-bold tracking-wide sm:block">CWT 命題工作平臺</span>
                </NavLink>
            </div>

            <div class="relative flex max-w-2xl flex-grow items-center justify-center px-2 sm:px-4 lg:w-2/4">
                <button type="button"
                        @onclick="ToggleProjectDropdown"
                        @onclick:stopPropagation="true"
                        disabled="@(!availableProjects.Any())"
                        class="group flex w-full cursor-pointer items-center gap-2 rounded-xl border border-white/40 bg-white px-2 py-1 shadow-md transition-all hover:-translate-y-0.5 hover:shadow-lg focus:outline-none disabled:cursor-not-allowed disabled:opacity-70 sm:gap-3 sm:px-3">
                    @* 左側圖示槽：morandi 底色 + 資料夾黃圖示，標示「梯次切換器」身份 *@
                    <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-morandi shadow-sm">
                        <i class="fa-solid fa-folder-open text-sm text-amber-300"></i>
                    </span>

                    @* 中央雙行內容：上方 label、下方梯次資訊 *@
                    <div class="flex min-w-0 flex-1 flex-col items-start overflow-hidden text-left leading-tight">
                        <span class="text-xs font-medium text-gray-400 tracking-wide">目前梯次</span>
                        @if (currentProject is not null)
                        {
                            <div class="flex w-full min-w-0 items-center gap-1.5">
                                <span class="flex-shrink-0 whitespace-nowrap rounded-md bg-morandi/10 px-1.5 py-0.5 text-xs font-bold text-morandi">
                                    @($"{currentProject.Year}年度")
                                </span>
                                <span class="text-gray-300">|</span>
                                <span class="truncate text-sm font-bold text-slate-main">@currentProject.Name</span>
                            </div>
                        }
                        else
                        {
                            <span class="truncate text-sm font-semibold text-gray-500">目前沒有可查看的梯次</span>
                        }
                    </div>

                    <i class="fa-solid fa-chevron-down flex-shrink-0 text-xs text-morandi transition-transform group-hover:text-morandi/80 @(showProjectDropdown ? "rotate-180" : "")"></i>
                </button>

                @if (showProjectDropdown)
                {
                    <div class="fixed inset-0 z-40" @onclick="CloseProjectDropdown"></div>
                    <div class="absolute top-full z-50 mt-2 w-full min-w-[300px] overflow-hidden rounded-xl border border-gray-100 bg-white shadow-xl"
                         @onclick:stopPropagation="true">
                        <div class="border-b border-gray-100 bg-gray-50/50 p-3">
                            <DebouncedSearchInput @bind-Value="projectSearchQuery"
                                                  Placeholder="搜尋專案梯次..."
                                                  CssClass="w-full rounded-lg border border-gray-300 py-1.5 pl-9 pr-3 text-sm focus:border-morandi focus:outline-none focus:ring-morandi" />
                        </div>
                        <div class="max-h-[50vh] overflow-y-auto sm:max-h-[60vh]">
                            @{
                                var activeProjects = FilteredProjects.Where(project => !IsClosedProject(project)).ToList();
                                var closedProjects = FilteredProjects.Where(IsClosedProject).ToList();
                            }

                            @if (activeProjects.Any())
                            {
                                <div class="border-y border-gray-200 bg-gray-100 px-3 py-1 text-xs font-bold text-gray-500">進行中（包含準備中）</div>
                                @foreach (var project in activeProjects)
                                {
                                    var isSelected = currentProject?.Id == project.Id;
                                    <button type="button"
                                            @onclick="() => SelectProject(project)"
                                            title="@($"專案編號 {project.ProjectCode}")"
                                            class="flex w-full cursor-pointer items-center justify-between gap-3 border-b border-gray-50 px-4 py-2.5 text-left text-sm transition-colors hover:bg-morandi/5 @(isSelected ? "bg-blue-50/50" : "")">
                                        <div class="flex min-w-0 flex-col gap-0.5">
                                            <span class="truncate @(isSelected ? "font-bold text-morandi" : "font-medium text-gray-700")">@project.DisplayName</span>
                                            <span class="flex items-center gap-1.5 text-xs text-gray-500 tabular-nums">
                                                <i class="fa-regular fa-calendar text-xs text-gray-400"></i>
                                                @project.StartDate.ToString("yyyy/MM/dd") — @project.EndDate.ToString("yyyy/MM/dd")
                                            </span>
                                        </div>
                                        @if (isSelected)
                                        {
                                            <i class="fa-solid fa-check flex-shrink-0 text-morandi"></i>
                                        }
                                    </button>
                                }
                            }

                            @if (closedProjects.Any())
                            {
                                <div class="border-y border-gray-200 bg-gray-100 px-3 py-1 text-xs font-bold text-gray-500">已結案（歷史專案）</div>
                                @foreach (var project in closedProjects)
                                {
                                    var isSelected = currentProject?.Id == project.Id;
                                    <button type="button"
                                            @onclick="() => SelectProject(project)"
                                            title="@($"專案編號 {project.ProjectCode}")"
                                            class="flex w-full cursor-pointer items-center justify-between gap-3 border-b border-gray-50 px-4 py-2.5 text-left text-sm transition-colors hover:bg-morandi/5 @(isSelected ? "bg-blue-50/50" : "")">
                                        <div class="flex min-w-0 flex-col gap-0.5">
                                            <span class="truncate @(isSelected ? "font-bold text-morandi" : "font-medium text-gray-700")">@project.DisplayName</span>
                                            <span class="flex items-center gap-1.5 text-xs text-gray-500 tabular-nums">
                                                <i class="fa-regular fa-calendar text-xs text-gray-400"></i>
                                                @project.StartDate.ToString("yyyy/MM/dd") — @project.EndDate.ToString("yyyy/MM/dd")
                                            </span>
                                        </div>
                                        @if (isSelected)
                                        {
                                            <i class="fa-solid fa-check flex-shrink-0 text-morandi"></i>
                                        }
                                    </button>
                                }
                            }

                            @if (!FilteredProjects.Any())
                            {
                                <div class="p-4 text-center text-sm text-gray-500">找不到符合條件的梯次</div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="flex flex-shrink-0 items-center justify-end gap-3 lg:w-1/4">
                <button type="button"
                        class="relative cursor-pointer p-1 text-white/80 transition-colors hover:text-white focus:outline-none"
                        title="通知（尚未開放）">
                    <i class="fa-regular fa-bell text-lg"></i>
                </button>

                <div class="relative flex items-center gap-2">
                    <div class="flex cursor-pointer items-center gap-2 rounded-full border border-transparent p-1 transition-all hover:-translate-y-0.5 hover:border-white/10 hover:shadow-md"
                         @onclick="ToggleUserMenu">
                        <div class="flex h-8 w-8 items-center justify-center rounded-full border border-white/20 bg-sage text-sm font-bold text-white shadow-sm">
                            @UserAvatarText
                        </div>
                        <div class="hidden pr-2 text-right text-sm md:block">
                            <div class="leading-none font-bold tracking-wide text-white">@userName</div>
                        </div>
                    </div>

                    @if (isUserMenuOpen)
                    {
                        <div class="fixed inset-0 z-40 cursor-default" @onclick="CloseUserMenu"></div>
                    }

                    <div class="absolute right-0 top-full z-50 mt-2 w-48 rounded-lg border border-gray-100 bg-white shadow-lg transition-all duration-200 @(isUserMenuOpen ? "visible translate-y-0 opacity-100" : "invisible -translate-y-2 opacity-0")">
                        <div class="py-1">
                            <a href="#"
                               class="block cursor-pointer px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-morandi"
                               @onclick="OpenProfileModal"
                               @onclick:preventDefault="true">
                                <i class="fa-solid fa-user-pen mr-1 w-5 text-center"></i> 個人資料
                            </a>
                            <div class="my-1 border-t border-gray-100"></div>
                            <button type="button"
                                    @onclick="Logout"
                                    class="block w-full cursor-pointer px-4 py-2 text-left text-sm text-red-600 hover:bg-red-50">
                                <i class="fa-solid fa-arrow-right-from-bracket mr-1 w-5 text-center"></i> 登出系統
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</nav>

<!-- Profile Modal -->
<CustomModal @bind-IsVisible="showProfileModal" Type="CustomModal.ModalType.Center" Title="個人資料" CloseOnBackdropClick="true" KeepAlive="true">
    <ChildContent>
        @if (isLoadingProfile)
        {
            <div class="py-8 text-center text-gray-400 text-sm">
                <i class="fa-solid fa-spinner fa-spin mr-1"></i> 載入中...
            </div>
        }
        else if (userProfile is not null)
        {
            var hasCurrentBatchRole = currentProject is not null && userProfile.ProjectRoles.Count > 0;
            <div class="space-y-5">
                <!-- 頭部：頭像 + 姓名 + 角色 + 狀態（右側放下載聘書按鈕） -->
                <div class="flex items-center justify-between gap-3 p-4 bg-gray-50 rounded-xl">
                    <div class="flex items-center gap-4 min-w-0">
                        <div class="w-14 h-14 rounded-full flex items-center justify-center text-white font-bold text-xl flex-shrink-0 @(userProfile.Status == 1 ? "bg-morandi" : "bg-gray-400")">
                            @(string.IsNullOrEmpty(userProfile.DisplayName) ? "?" : userProfile.DisplayName[..1])
                        </div>
                        <div class="min-w-0">
                            <div class="text-lg font-bold text-slate-main truncate">@userProfile.DisplayName</div>
                            <div class="flex items-center gap-2 mt-1 flex-wrap">
                                @* 永遠顯示系統角色（如：系統管理員），再串接當前梯次的所有身分標籤；同名者去重 *@
                                <StatusBadge StatusText="@userProfile.RoleName" IsInternal="@(userProfile.RoleCategory == 0)" Compact="true" ShowIcon="false" />
                                @foreach (var role in userProfile.ProjectRoles.Where(r => !string.Equals(r.Name, userProfile.RoleName, StringComparison.Ordinal)))
                                {
                                    <StatusBadge StatusText="@role.Name" IsInternal="@(role.Category == 0)" Compact="true" ShowIcon="false" />
                                }
                                <span class="text-xs font-bold px-2 py-0.5 rounded @(userProfile.Status == 1 ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                    @(userProfile.Status == 1 ? "啟用" : "停用")
                                </span>
                            </div>
                        </div>
                    </div>
                    <!-- 下載本梯次聘書 — 直接導向 zip endpoint，多身份打包成單一 zip -->
                    @if (hasCurrentBatchRole && hasDownloadableCertsForCurrentProject && currentProject is not null)
                    {
                        <a href="@($"api/appointment-cert/download/{currentProject.Id}")"
                           target="_blank"
                           rel="noopener"
                           title="下載您在本梯次的聘書（1 份直下 jpg、多份打包 zip）"
                           class="cursor-pointer flex-shrink-0 flex items-center gap-1.5 px-3 py-2 text-xs font-bold text-sage border border-sage/40 bg-white rounded-lg hover:bg-sage/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-sage/40 transition-colors no-underline">
                            <i class="fa-solid fa-award"></i> 下載聘書
                        </a>
                    }
                </div>

                <!-- 資訊列表 -->
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between gap-4">
                        <span class="text-gray-500">登入帳號</span>
                        <span class="text-slate-main">@userProfile.Username</span>
                    </div>
                    <div class="flex justify-between gap-4">
                        <span class="text-gray-500">電子信箱</span>
                        <span class="@(string.IsNullOrWhiteSpace(userProfile.Email) ? "text-gray-400" : "text-slate-main") break-all text-right">
                            @(string.IsNullOrWhiteSpace(userProfile.Email) ? "未填寫" : userProfile.Email)
                        </span>
                    </div>
                    <div class="flex justify-between gap-4">
                        <span class="text-gray-500">公司職稱</span>
                        <span class="@(string.IsNullOrWhiteSpace(userProfile.CompanyTitle) ? "text-gray-400" : "text-slate-main")">
                            @(string.IsNullOrWhiteSpace(userProfile.CompanyTitle) ? "未填寫" : userProfile.CompanyTitle)
                        </span>
                    </div>
                    <div class="flex justify-between gap-4">
                        <span class="text-gray-500">建立日期</span>
                        <span class="text-slate-main">@userProfile.CreatedAt.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="flex justify-between gap-4">
                        <span class="text-gray-500">上次登入</span>
                        <span class="text-slate-main">@(userProfile.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "尚未登入")</span>
                    </div>
                </div>

                <!-- 變更密碼區（可折疊） -->
                <div class="border-t border-gray-200 pt-4">
                    @if (!showPasswordForm)
                    {
                        <button type="button" @onclick="() => showPasswordForm = true"
                                class="cursor-pointer w-full py-2.5 text-sm font-medium text-morandi border border-morandi/30 rounded-lg hover:bg-morandi/5 transition flex items-center justify-center gap-2">
                            <i class="fa-solid fa-key"></i> 變更密碼
                        </button>
                    }
                    else
                    {
                        <div class="space-y-3">
                            <h4 class="text-sm font-bold text-slate-main flex items-center gap-2">
                                <i class="fa-solid fa-key text-morandi"></i> 變更密碼
                            </h4>
                            @* 隱藏 username 欄位：純粹給密碼管理員識別「這個密碼是哪個帳號的」，
                               讓 Chrome / 1Password / Bitwarden 自動跳出「點一下填入舊密碼」提示。
                               帳號本身在 modal 上方已可見地顯示，所以這裡 hidden 不是隱藏資訊、是消去重複。*@
                            <input type="text" name="changePasswordUsername" value="@userProfile.Username"
                                   autocomplete="username" hidden readonly aria-hidden="true" />
                            <div>
                                <label class="block text-xs font-medium mb-1 text-gray-600">舊密碼</label>
                                <div class="relative">
                                    <input type="@(showPwdOld ? "text" : "password")" @bind="pwdOld" placeholder="請輸入目前密碼"
                                           autocomplete="current-password"
                                           class="w-full px-3 py-2 pr-10 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                                    <button type="button" tabindex="-1" @onclick="() => showPwdOld = !showPwdOld"
                                            class="absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 cursor-pointer focus:outline-none">
                                        <i class="fa-regular @(showPwdOld ? "fa-eye" : "fa-eye-slash") text-sm"></i>
                                    </button>
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-medium mb-1 text-gray-600">新密碼 <span class="text-gray-400 font-normal">(至少 6 碼)</span></label>
                                <div class="relative">
                                    <input type="@(showPwdNew ? "text" : "password")" @bind="pwdNew" placeholder="請輸入新密碼"
                                           autocomplete="new-password"
                                           class="w-full px-3 py-2 pr-10 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                                    <button type="button" tabindex="-1" @onclick="() => showPwdNew = !showPwdNew"
                                            class="absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 cursor-pointer focus:outline-none">
                                        <i class="fa-regular @(showPwdNew ? "fa-eye" : "fa-eye-slash") text-sm"></i>
                                    </button>
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-medium mb-1 text-gray-600">確認新密碼</label>
                                <div class="relative">
                                    <input type="@(showPwdConfirm ? "text" : "password")" @bind="pwdConfirm" placeholder="請再次輸入新密碼"
                                           autocomplete="new-password"
                                           class="w-full px-3 py-2 pr-10 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                                    <button type="button" tabindex="-1" @onclick="() => showPwdConfirm = !showPwdConfirm"
                                            class="absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 cursor-pointer focus:outline-none">
                                        <i class="fa-regular @(showPwdConfirm ? "fa-eye" : "fa-eye-slash") text-sm"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="flex gap-2 pt-1">
                                <button type="button" @onclick="() => { showPasswordForm = false; pwdOld = pwdNew = pwdConfirm = string.Empty; }"
                                        class="cursor-pointer flex-1 py-2 text-sm border border-gray-300 text-gray-600 rounded-lg hover:bg-gray-50 transition">
                                    取消
                                </button>
                                <button type="button" @onclick="ChangePassword" disabled="@isChangingPassword"
                                        class="cursor-pointer flex-1 py-2 text-sm bg-morandi text-white rounded-lg hover:bg-[#5b7a95] transition flex items-center justify-center gap-1 disabled:opacity-60">
                                    @if (isChangingPassword)
                                    {
                                        <i class="fa-solid fa-spinner fa-spin"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-check"></i>
                                    }
                                    <span>確認變更</span>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="CloseProfileModal"
                class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors shadow-sm">
            關閉
        </button>
    </FooterContent>
</CustomModal>

<div class="h-16 w-full shrink-0"></div>

<CascadingValue Value="moduleCards" Name="ModuleCards">
<CascadingValue Value="currentProject" Name="CurrentProject">
    <div class="mx-auto flex-grow w-full">
        @* isAppReady 守門：等 OnAfterRenderAsync 還原完 storage 才 render 子頁，
           避免 currentProject=null 時 OnParametersSetAsync 白跑一次然後第二輪又跑 *@
        @if (isAppReady)
        {
            @Body
        }
    </div>
</CascadingValue>
</CascadingValue>

<FontController />

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    // ================================================================
    // 元件狀態
    // ================================================================

    private HubConnection? hubConnection;
    private string userName = string.Empty;
    private bool isUserMenuOpen;
    private bool showProjectDropdown;
    private string projectSearchQuery = string.Empty;
    private int? currentUserId;
    private List<ProjectSwitcherItem> availableProjects = [];
    private ProjectSwitcherItem? currentProject;

    /// <summary>使用者在當前梯次下的功能模組權限清單（供子頁面 CascadingParameter 使用）。
    /// null = 尚未載入；子頁面以此判斷是否顯示骨架/Spinner，避免閃爍空狀態。</summary>
    private List<UserModuleCard>? moduleCards;

    /// <summary>已嘗試從 ProtectedLocalStorage 還原梯次的旗標，避免 OnAfterRenderAsync 重複觸發。</summary>
    private bool hasRestoredProjectFromStorage;

    /// <summary>
    /// OnInitializedAsync 是否整段跑完。用來擋住 race condition：
    /// OnAfterRenderAsync 可能在 OnInitializedAsync 的 await 期間就先觸發，
    /// 此時若直接設 hasRestoredProjectFromStorage = true 並早退，會讓 ReloadVisibleProjectsAsync
    /// 誤以為「storage 已試過」而提前 fallback 到 GetDefaultProject，造成梯次飄移到非預期項目。
    /// </summary>
    private bool isInitializationComplete;

    /// <summary>App 準備完成旗標：SignalR 連上 + Storage 還原完畢後設為 true，
    /// 觸發 AppLoadingSplash 淡出。預設 false 確保 prerender 階段就遮住閃爍。</summary>
    private bool isAppReady;

    /// <summary>儲存 key 加上 userId 前綴，避免共用瀏覽器時不同帳號互相覆蓋。</summary>
    private string ProjectStorageKey => $"mt:lastProjectId:{currentUserId}";

    // ================================================================
    // 計算屬性
    // ================================================================

    private IEnumerable<ProjectSwitcherItem> FilteredProjects =>
        string.IsNullOrWhiteSpace(projectSearchQuery)
            ? availableProjects
            : availableProjects.Where(project =>
                project.DisplayName.Contains(projectSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                project.ProjectCode.Contains(projectSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                project.Year.ToString().Contains(projectSearchQuery, StringComparison.OrdinalIgnoreCase));

    private string UserAvatarText =>
        string.IsNullOrWhiteSpace(userName) ? "?" : userName[..1];

    // ================================================================
    // 生命週期
    // ================================================================

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthState;
            var user = authState.User;

            // 首次登入未改密碼 → 任何已認證頁面進入 MainLayout 都強制踢回改密碼頁
            // 攔截「上一頁繞過 /first-login-password」的所有路徑
            if (user.HasClaim("IsFirstLogin", "true"))
            {
                Navigation.NavigateTo("first-login-password", forceLoad: false, replace: true);
                return;
            }

            userName = user.FindFirst("DisplayName")?.Value
                ?? user.Identity?.Name
                ?? string.Empty;

            var userIdText = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!int.TryParse(userIdText, out var userId))
            {
                return;
            }

            currentUserId = userId;

            await ReloadVisibleProjectsAsync();

            // Hub 連線 50~300ms，且訂閱 SignalR 廣播屬「之後才會用到」的功能，
            // 改 fire-and-forget 不阻塞首屏 render。例外靜默吞掉（內部已有 LogWarning）。
            _ = InitializeHubConnectionAsync();

            // 訂閱導航事件，後續每次路由變更時檢查模組存取權限
            Navigation.LocationChanged += OnLocationChanged;
        }
        finally
        {
            // 不論成功失敗、不論 early return，都要把旗標設好，
            // OnAfterRenderAsync 才能在下一輪 render 確定 init 已結束、可以安全讀 storage。
            isInitializationComplete = true;
        }
    }

    /// <summary>OnInitializedAsync 完整跑完後，從 ProtectedLocalStorage 還原上次選的梯次。
    /// 為何放在 OnAfterRenderAsync：ProtectedBrowserStorage 依賴 JS Interop，
    /// 在 OnInitializedAsync 的 prerender 階段呼叫會拋 InvalidOperationException。
    ///
    /// ⚠️ 不使用 firstRender 當閘門：First Render 會在 OnInitializedAsync 第一個 await yield 時就觸發，
    /// 此時 availableProjects 還是空的，會把 storage 紀錄當作「梯次已不存在」誤清掉。
    /// 改用 isInitializationComplete 確保 OnInitializedAsync 整段跑完才動。
    ///
    /// 還原完成（成功、失敗、無紀錄皆算）後將 isAppReady 設為 true 觸發 splash 淡出。</summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (hasRestoredProjectFromStorage) return;
        if (!isInitializationComplete) return;   // init 還沒跑完先放著，下次 render 再進來

        hasRestoredProjectFromStorage = true;

        if (currentUserId is null)
        {
            Logger.LogInformation("還原梯次跳過：尚無 currentUserId");
            isAppReady = true;
            StateHasChanged();
            return;
        }

        // ① 梯次還原：失敗不影響後續模組權限載入
        try
        {
            var stored = await ProtectedLocalStorage.GetAsync<int>(ProjectStorageKey);
            Logger.LogInformation("讀取 storage Key={Key} Success={Success} Value={Value}",
                ProjectStorageKey, stored.Success, stored.Success ? stored.Value : -1);

            var storedIsValid = false;
            if (stored.Success)
            {
                var match = availableProjects.FirstOrDefault(p => p.Id == stored.Value);
                if (match is null)
                {
                    Logger.LogInformation("storage 紀錄的梯次 Id={Id} 已不在可見清單，清除紀錄", stored.Value);
                    await ProtectedLocalStorage.DeleteAsync(ProjectStorageKey);
                }
                else
                {
                    Logger.LogInformation("還原梯次成功 ProjectId={Id}", match.Id);
                    currentProject = match;
                    storedIsValid = true;
                }
            }

            currentProject ??= GetDefaultProject();

            if (!storedIsValid && currentProject is not null)
            {
                await PersistSelectedProjectAsync(currentProject.Id);
            }
        }
        catch (Exception ex)
        {
            // ProtectedLocalStorage 在 IIS 第一次部署 / Data Protection key 未就緒時可能會炸，
            // 此處靜默回退到 GetDefaultProject，**絕對不能讓 moduleCards 載入連帶失敗**。
            Logger.LogWarning(ex, "還原上次選擇的梯次失敗 (UserId={UserId})", currentUserId);
            currentProject ??= GetDefaultProject();
        }

        // ② 模組權限載入：獨立 try/catch，無論 storage 是否成功都要跑。
        // 系統管理員等內部身分即便沒參與任何梯次，仍應依 MT_Users.RoleId 判定後台卡片；
        // 一般教師沒梯次則回空清單，由 Home.razor 顯示 EmptyState。
        try
        {
            await ReloadModuleCardsAsync();
            EnforceModuleAccess(Navigation.Uri);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入功能模組權限失敗 (UserId={UserId})", currentUserId);
            moduleCards ??= [];   // 保底：絕對不能讓 ModuleCards 維持 null 卡死 Home spinner
        }

        isAppReady = true;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;

        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    // ================================================================
    // 模組權限：載入與導航擋控
    // ================================================================

    /// <summary>載入使用者在當前梯次下的模組權限清單。</summary>
    private async Task ReloadModuleCardsAsync()
    {
        if (currentUserId is null) return;

        try
        {
            // 走 IMembershipService 30 秒短 TTL Cache，梯次切換 / Layout 重渲染時免重複打 DB
            moduleCards = await MembershipService.GetUserModuleCardsAsync(currentUserId.Value, currentProject?.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入功能模組權限失敗 (UserId={UserId}, ProjectId={ProjectId})",
                currentUserId, currentProject?.Id);
            moduleCards = [];
        }
    }

    /// <summary>導航事件處理：每次路由變更時檢查模組存取權限。</summary>
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => EnforceModuleAccess(e.Location);

    /// <summary>
    /// 模組存取擋控（統一入口）：
    /// 從 URL 提取頁面路徑，比對 moduleCards 中的 PageUrl，
    /// 非模組頁面（login、home 等）不受管控，模組頁面無權限則踢回首頁。
    /// </summary>
    private void EnforceModuleAccess(string absoluteUri)
    {
        var pagePath = ExtractPagePath(absoluteUri);

        // 空路徑（首頁）或無法解析 → 放行
        if (string.IsNullOrEmpty(pagePath)) return;

        // 模組清單尚未載入完成 → 放行（避免在資料未到位前誤踢）
        if (moduleCards is null) return;

        // 比對模組清單，找不到代表不是模組頁面（login、not-found 等）→ 放行
        var module = moduleCards.FirstOrDefault(m =>
            string.Equals(m.PageUrl, pagePath, StringComparison.OrdinalIgnoreCase));

        if (module is null) return;

        // 有權限放行，無權限踢回首頁
        if (!module.IsEnabled)
        {
            Navigation.NavigateTo("");
        }
    }

    /// <summary>
    /// 從完整 URL 提取頁面路徑段（去除 base path 與查詢字串）。
    /// 例如 "https://pc435.csf.org.tw/MT/projects?tab=1" → "projects"
    /// </summary>
    private string ExtractPagePath(string absoluteUri)
    {
        var baseUri = Navigation.BaseUri;
        if (!absoluteUri.StartsWith(baseUri, StringComparison.OrdinalIgnoreCase))
            return string.Empty;

        var relativePath = absoluteUri[baseUri.Length..];

        // 移除查詢字串與 hash
        var queryIndex = relativePath.IndexOfAny(['?', '#']);
        if (queryIndex >= 0)
            relativePath = relativePath[..queryIndex];

        return relativePath.Trim('/');
    }

