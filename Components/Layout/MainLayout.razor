    // ──── JS interop 安全呼叫（吞掉 circuit 斷線 / 1 分鐘 timeout，避免污染呼叫端流程）────
    // 適用：等使用者互動的 SweetAlert 等長停留呼叫；fire-and-forget 場景請直接 `_ = JS.InvokeVoidAsync(...)`
    private async Task SafeJsVoidAsync(string identifier, params object?[] args)
    {
        try { await JS.InvokeVoidAsync(identifier, args); }
        catch (JSDisconnectedException) { /* circuit 已斷，使用者已離開頁面 */ }
        catch (TaskCanceledException ex) { Logger.LogDebug(ex, "JS interop 取消或逾時：{Id}", identifier); }
    }

    private async Task<T?> SafeJsAsync<T>(string identifier, params object?[] args)
    {
        try { return await JS.InvokeAsync<T>(identifier, args); }
        catch (JSDisconnectedException) { return default; }
        catch (TaskCanceledException ex) { Logger.LogDebug(ex, "JS interop 取消或逾時：{Id}", identifier); return default; }
    }

    // ================================================================
    // SignalR 即時同步
    // ================================================================

    private async Task InitializeHubConnectionAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("hubs/projects"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<ProjectRealtimeSyncMessage>("ReceiveProjectChanged", async _ =>
        {
            await ReloadVisibleProjectsAsync();
            await InvokeAsync(StateHasChanged);
        });

        // 角色/權限變更：重載模組卡片，並檢查當前頁面是否仍有權限
        hubConnection.On("ReceiveRoleChanged", async () =>
        {
            await ReloadModuleCardsAsync();
            EnforceModuleAccess(Navigation.Uri);
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "建立梯次同步 HubConnection 失敗");
        }
    }

    // ================================================================
    // 梯次資料載入
    // ================================================================

    private async Task ReloadVisibleProjectsAsync()
    {
        if (currentUserId is null)
        {
            return;
        }

        var previousProjectId = currentProject?.Id;
        var previousProjectDisplayName = currentProject?.DisplayName;   // 靜默回退提示用

        try
        {
            availableProjects = await ProjectService.GetVisibleProjectsAsync(currentUserId.Value);

            currentProject = previousProjectId.HasValue
                ? availableProjects.FirstOrDefault(project => project.Id == previousProjectId.Value)
                : null;

            // 首次載入先不要急著套 fallback，等 OnAfterRenderAsync 從 storage 還原完再決定，
            // 才不會在 F5 時先跳到第一筆梯次，之後又被改回來。
            var silentlyFellBack = false;
            if (currentProject is null && hasRestoredProjectFromStorage)
            {
                currentProject = GetDefaultProject();
                // 原本有選定梯次、reload 後找不到（被刪除/結案/權限調整）→ 才算靜默回退
                silentlyFellBack = previousProjectId.HasValue;
            }

            // 初次載入階段（hasRestoredProjectFromStorage=false）跳過 moduleCards reload，
            // 留給 OnAfterRenderAsync 還原 currentProject 後再載一次，避免外部使用者在
            // projectId=null 下載入到「全空權限」造成 Home 閃過空狀態。
            // SignalR 推播時 hasRestoredProjectFromStorage 已是 true，照舊判斷。
            if (hasRestoredProjectFromStorage && (moduleCards is null || previousProjectId != currentProject?.Id))
            {
                await ReloadModuleCardsAsync();
            }

            // 靜默回退時主動提示使用者並更新 storage，避免畫面突然跳到另一個梯次無感
            if (silentlyFellBack && currentProject is not null)
            {
                await PersistSelectedProjectAsync(currentProject.Id);
                _ = JS.InvokeVoidAsync("mtToast.show", new
                {
                    type     = "warning",
                    title    = "原梯次已不可見",
                    subtitle = $"「{previousProjectDisplayName}」已被結案或移除，已自動切換到「{currentProject.DisplayName}」",
                    duration = 4500
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入頂部導覽列梯次資料失敗 (UserId={UserId})", currentUserId);
            availableProjects = [];
            currentProject = null;
        }
    }

    private ProjectSwitcherItem? GetDefaultProject()
        => availableProjects
            .OrderBy(project => IsClosedProject(project))
            .ThenByDescending(project => project.Year)
            .ThenByDescending(project => project.Id)
            .FirstOrDefault();

    private static bool IsClosedProject(ProjectSwitcherItem project)
        => project.IsClosed;
}
