    {
        showProjectDropdown = false;
    }

    /// <summary>切換梯次：更新權限並檢查當前頁面是否仍有存取權。</summary>
    private async Task SelectProject(ProjectSwitcherItem project)
    {
        currentProject = project;
        showProjectDropdown = false;

        // 優先持久化梯次，避免後續任何一步拋例外導致 storage 沒寫入
        await PersistSelectedProjectAsync(project.Id);

        // 切換梯次後重新載入模組權限，並檢查當前頁面是否仍有存取權
        await ReloadModuleCardsAsync();
        EnforceModuleAccess(Navigation.Uri);

        // Toast 為純通知效果，不需等待 JS 回應；fire-and-forget 避免 1 秒逾時拋 TaskCanceledException
        _ = JS.InvokeVoidAsync("mtToast.show", new
        {
            type     = "success",
            title    = "已切換梯次",
            subtitle = project.DisplayName,
            duration = 3500
        });
    }

    /// <summary>將當前梯次寫入 ProtectedLocalStorage（瀏覽器禁用 storage 時靜默忽略）。</summary>
    private async Task PersistSelectedProjectAsync(int projectId)
    {
        if (currentUserId is null) return;

        try
        {
            await ProtectedLocalStorage.SetAsync(ProjectStorageKey, projectId);
            Logger.LogInformation("梯次寫入 storage 成功 Key={Key} ProjectId={ProjectId}", ProjectStorageKey, projectId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "持久化梯次選擇失敗 (UserId={UserId}, ProjectId={ProjectId})", currentUserId, projectId);
        }
    }

