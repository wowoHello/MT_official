@* ====================================================================== *@
@*  Roles — 角色與權限管理                                                  *@
@*  路由：/roles                                                           *@
@*  功能：人員帳號管理/角色權限管理雙分頁、帳號列表與詳情、角色 CRUD         *@
@* ====================================================================== *@
@page "/roles"
@inject IRoleService RoleService
@inject ILogger<Roles> Logger

<div class="flex-grow flex flex-col w-full mx-auto h-[calc(100vh-4rem)] overflow-hidden">
    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <NavLink href="" Match="NavLinkMatch.All" class="inline-flex items-center hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-slate-main">角色與權限管理</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-id-card-clip text-morandi"></i> 角色與權限管理
                </h1>
            </div>
            <!-- 動態按鈕區（依據 Tab 切換） -->
            <div class="flex gap-2">
                @if (currentTab == "accounts")
                {
                    <button type="button" @onclick="OpenAccountModal"
                        class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                        <i class="fa-solid fa-user-plus"></i> 新增人員
                    </button>
                }
                else
                {
                    <button type="button" @onclick="OpenNewRoleModal"
                        class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                        <i class="fa-solid fa-shield-halved"></i> 新增角色
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Tab Navigation (underline style) -->
    <div class="px-4 sm:px-6 lg:px-8 pt-4 flex-shrink-0">
        <div class="flex border-b border-gray-200 mb-4">
            <button @onclick='() => currentTab = "accounts"'
                class="@(currentTab == "accounts" ? "text-morandi border-b-morandi font-bold" : "text-gray-500 border-transparent") px-5 py-2.5 text-sm border-b-2 transition-colors hover:text-morandi cursor-pointer focus:outline-none">
                <i class="fa-solid fa-users-gear mr-1.5"></i>人員帳號管理
            </button>
            <button @onclick='() => currentTab = "roles"'
                class="@(currentTab == "roles" ? "text-morandi border-b-morandi font-bold" : "text-gray-500 border-transparent") px-5 py-2.5 text-sm border-b-2 transition-colors hover:text-morandi cursor-pointer focus:outline-none">
                <i class="fa-solid fa-shield-halved mr-1.5"></i>角色權限管理
            </button>
        </div>
    </div>

    <!-- Tab Content -->
    @if (currentTab == "accounts")
    {
        <!-- Tab Panel 1: 人員帳號管理 -->
        <div class="flex-grow flex flex-col overflow-hidden px-4 sm:px-6 lg:px-8 pb-4">

            <!-- Statistics Cards -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 flex-shrink-0">
                @StatCard("帳號總數", allAccounts.Count.ToString(), "fa-users", "text-morandi", "text-slate-main")
                @StatCard("啟用中", allAccounts.Count(a => a.Status == 1).ToString(), "fa-circle-check", "text-sage", "text-sage")
                @StatCard("停用中", allAccounts.Count(a => a.Status != 1).ToString(), "fa-circle-xmark", "text-terracotta", "text-terracotta")
                @StatCard("系統管理員", allAccounts.Count(a => a.RoleName == "系統管理員").ToString(), "fa-user-shield", "text-purple-500", "text-purple-600")
            </div>

            <!-- Split Layout (Left List, Right Detail) -->
            <div class="flex-grow flex overflow-hidden bg-white rounded-xl shadow-sm border border-gray-200">

                <!-- Left Panel: Account List -->
                <div class="w-full lg:w-[380px] xl:w-[420px] border-r border-gray-200 flex flex-col z-10 flex-shrink-0">
                    <!-- Filters -->
                    <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col gap-3 flex-shrink-0">
                        <DebouncedSearchInput @bind-Value="accountKeyword"
                                              Placeholder="搜尋姓名、帳號或信箱..." />
                        <div class="flex gap-2">
                            <button type="button" @onclick='() => accountStatusFilter = "all"'
                                class="flex-1 py-1 text-xs font-bold rounded cursor-pointer transition @(accountStatusFilter == "all" ? "bg-morandi text-white" : "border border-gray-200 text-gray-500 hover:bg-gray-100")">全部</button>
                            <button type="button" @onclick='() => accountStatusFilter = "active"'
                                class="flex-1 py-1 text-xs font-bold rounded cursor-pointer transition @(accountStatusFilter == "active" ? "bg-morandi text-white" : "border border-gray-200 text-gray-500 hover:bg-gray-100")">啟用中</button>
                            <button type="button" @onclick='() => accountStatusFilter = "inactive"'
                                class="flex-1 py-1 text-xs font-bold rounded cursor-pointer transition @(accountStatusFilter == "inactive" ? "bg-morandi text-white" : "border border-gray-200 text-gray-500 hover:bg-gray-100")">停用中</button>
                        </div>
                    </div>
                    <!-- List -->
                    <div class="flex-grow overflow-y-auto custom-scroll">
                        @if (isLoadingAccounts)
                        {
                            <div class="p-6 text-center text-gray-400 text-sm">
                                <i class="fa-solid fa-spinner fa-spin mr-1"></i> 載入中...
                            </div>
                        }
                        else if (!FilteredAccounts.Any())
                        {
                            <div class="p-4 h-full">
                                <EmptyState IconClass="fa-id-badge" Message="尚無人員帳號" SubMessage="點擊右上角新增內部管理人員。" />
                            </div>
                        }
                        else
                        {
                            @foreach (var a in FilteredAccounts)
                            {
                                <button @key="a.Id" type="button" @onclick="() => SelectAccount(a.Id)"
                                    class="w-full text-left flex items-center gap-3 px-4 py-3 border-l-4 border-b border-b-gray-100 cursor-pointer @(selectedAccountId == a.Id ? "border-l-morandi bg-gray-50" : "border-l-transparent hover:bg-gray-50")">
                                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold flex-shrink-0 @(a.Status == 1 ? "bg-morandi" : "bg-gray-400")">
                                        @(string.IsNullOrEmpty(a.DisplayName) ? "?" : a.DisplayName[..1])
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-1.5">
                                            <span class="w-2 h-2 rounded-full flex-shrink-0 @(a.Status == 1 ? "bg-sage" : "bg-terracotta")"></span>
                                            <span class="text-sm font-bold text-slate-main truncate">@a.DisplayName</span>
                                            <span class="text-xs font-medium px-1.5 py-0.5 rounded flex-shrink-0 bg-purple-100 text-purple-700">@a.RoleName</span>
                                        </div>
                                        <div class="text-xs text-gray-500 font-mono truncate">@a.Username</div>
                                        @if (!string.IsNullOrWhiteSpace(a.CompanyTitle))
                                        {
                                            <div class="text-xs text-gray-400 truncate">@a.CompanyTitle</div>
                                        }
                                    </div>
                                </button>
                            }
                        }
                    </div>
                </div>

                <!-- Right Panel: Account Details -->
                <div class="hidden lg:flex flex-col flex-grow bg-[var(--color-oatmeal)] overflow-hidden">
                    @if (isLoadingAccountDetail)
                    {
                        <div class="flex-grow flex items-center justify-center text-gray-400 text-sm">
                            <i class="fa-solid fa-spinner fa-spin mr-2"></i> 載入詳情中...
                        </div>
                    }
                    else if (selectedAccount is null)
                    {
                        <div class="flex-grow flex items-center justify-center p-8">
                            <EmptyState IconClass="fa-user-gear" Message="請選擇人員" SubMessage="由左側列表選擇人員查看詳情，或點擊右上角新增一位內部人員。" />
                        </div>
                    }
                    else
                    {
                        <div class="flex-grow overflow-y-auto custom-scroll p-6 lg:p-8">
                            <!-- Top Info Row -->
                            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mb-6">
                                <div class="flex flex-col sm:flex-row justify-between items-start gap-4">
                                    <div class="flex items-start gap-4">
                                        <div class="w-16 h-16 rounded-full flex items-center justify-center text-white font-bold text-2xl flex-shrink-0 @(selectedAccount.Status == 1 ? "bg-morandi" : "bg-gray-400")">
                                            @(string.IsNullOrEmpty(selectedAccount.DisplayName) ? "?" : selectedAccount.DisplayName[..1])
                                        </div>
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <h2 class="text-2xl font-bold text-slate-main">@selectedAccount.DisplayName</h2>
                                                <span class="text-xs font-bold px-2 py-0.5 rounded @(selectedAccount.Status == 1 ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                                    @(selectedAccount.Status == 1 ? "啟用" : "停用")
                                                </span>
                                            </div>
                                            <p class="text-sm text-gray-500 font-mono mb-1">帳號：@selectedAccount.Username</p>
                                            <p class="text-sm text-gray-500 flex items-center gap-1">
                                                <i class="fa-solid fa-envelope w-4 text-center"></i>
                                                <span>@(string.IsNullOrWhiteSpace(selectedAccount.Email) ? "未填寫" : selectedAccount.Email)</span>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="flex flex-col gap-2 min-w-[140px]">
                                        <button type="button" @onclick="OpenEditAccountModal"
                                            class="cursor-pointer w-full py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 hover:text-morandi hover:border-morandi transition-colors shadow-sm flex items-center justify-center gap-2">
                                            <i class="fa-solid fa-pen-to-square"></i> 編輯資料
                                        </button>
                                        <button type="button" @onclick="ToggleAccountStatus" disabled="@isAccountActionBusy"
                                            class="cursor-pointer w-full py-2 text-white rounded-lg text-sm font-medium hover:opacity-90 transition-colors shadow-sm flex items-center justify-center gap-2 disabled:opacity-60 @(selectedAccount.Status == 1 ? "bg-terracotta" : "bg-sage")">
                                            <i class="fa-solid @(selectedAccount.Status == 1 ? "fa-user-lock" : "fa-user-check")"></i>
                                            <span>@(selectedAccount.Status == 1 ? "停用帳號" : "啟用帳號")</span>
                                        </button>
                                        <button type="button" @onclick="ResetAccountPassword" disabled="@isAccountActionBusy"
                                            class="cursor-pointer w-full py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm flex items-center justify-center gap-2 disabled:opacity-60">
                                            <i class="fa-solid fa-key"></i> 重設密碼
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Detail Info Cards -->
                            <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                                <!-- 基本資料 -->
                                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                                    <h3 class="text-lg font-bold text-slate-main mb-4 flex items-center gap-2">
                                        <i class="fa-solid fa-user text-morandi"></i> 基本資料
                                    </h3>
                                    <div class="space-y-3 text-sm">
                                        <div class="flex justify-between gap-4">
                                            <span class="text-gray-500">姓名</span>
                                            <span class="font-medium text-slate-main text-right">@selectedAccount.DisplayName</span>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <span class="text-gray-500">登入帳號</span>
                                            <span class="font-mono text-slate-main text-right">@selectedAccount.Username</span>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <span class="text-gray-500">電子信箱</span>
                                            <span class="@(string.IsNullOrWhiteSpace(selectedAccount.Email) ? "text-gray-400" : "text-slate-main") text-right break-all">
                                                @(string.IsNullOrWhiteSpace(selectedAccount.Email) ? "未填寫" : selectedAccount.Email)
                                            </span>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <span class="text-gray-500">公司職稱</span>
                                            <span class="@(string.IsNullOrWhiteSpace(selectedAccount.CompanyTitle) ? "text-gray-400" : "text-slate-main") text-right">
                                                @(string.IsNullOrWhiteSpace(selectedAccount.CompanyTitle) ? "未填寫" : selectedAccount.CompanyTitle)
                                            </span>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <span class="text-gray-500">建立日期</span>
                                            <span class="text-slate-main text-right">@selectedAccount.CreatedAt.ToString("yyyy-MM-dd")</span>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <span class="text-gray-500">首次登入</span>
                                            <span class="@(selectedAccount.IsFirstLogin ? "text-amber-600" : "text-sage") font-medium text-right">
                                                @(selectedAccount.IsFirstLogin ? "尚未登入" : "已完成")
                                            </span>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <span class="text-gray-500">備註</span>
                                            <span class="@(string.IsNullOrWhiteSpace(selectedAccount.Note) ? "text-gray-400" : "text-slate-main") text-right">
                                                @(string.IsNullOrWhiteSpace(selectedAccount.Note) ? "無" : selectedAccount.Note)
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- 權限資訊 -->
                                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                                    <h3 class="text-lg font-bold text-slate-main mb-4 flex items-center gap-2">
                                        <i class="fa-solid fa-shield-halved @(selectedAccount.RoleCategory == 0 ? "text-purple-500" : "text-amber-500")"></i> 權限資訊
                                    </h3>
                                    <div class="space-y-3 text-sm">
                                        <div class="flex justify-between items-center gap-4">
                                            <span class="text-gray-500">身份別</span>
                                            <span class="flex items-center gap-1.5">
                                                <span class="font-medium text-slate-main">@selectedAccount.RoleName</span>
                                                @if (selectedAccount.IsDefaultRole)
                                                {
                                                    <span class="text-xs px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 font-medium">預設角色</span>
                                                }
                                            </span>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <span class="text-gray-500">角色分類</span>
                                            <span class="text-slate-main">@(selectedAccount.RoleCategory == 0 ? "內部人員" : "外部人員")</span>
                                        </div>
                                        <div class="pt-3 border-t border-gray-100">
                                            <div class="text-gray-500 mb-2">可存取功能區塊</div>
                                            @if (selectedAccount.EnabledModules.Count == 0)
                                            {
                                                <div class="text-xs text-gray-400">此角色尚未開啟任何功能</div>
                                            }
                                            else
                                            {
                                                <div class="flex flex-wrap gap-1.5">
                                                    @foreach (var m in selectedAccount.EnabledModules)
                                                    {
                                                        <span class="text-xs px-2 py-1 rounded bg-gray-100 text-gray-700 flex items-center gap-1">
                                                            <i class="fa-solid @m.Icon text-xs @m.ColorClass"></i>
                                                            @m.Name
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Tab Panel 2: 角色權限管理 -->
        <div class="flex-grow flex flex-col overflow-hidden px-4 sm:px-6 lg:px-8 pb-4">

            <!-- 角色統計 -->
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-4 flex-shrink-0">
                @StatCard("角色總數", allRoles.Count.ToString(), "fa-shield-halved", "text-morandi", "text-slate-main")
                @StatCard("內部人員角色", allRoles.Count(r => r.Category == 0).ToString(), "fa-building", "text-morandi", "text-morandi")
                @StatCard("外部人員角色", allRoles.Count(r => r.Category == 1).ToString(), "fa-user-graduate", "text-sage", "text-sage")
            </div>

            <!-- Role Cards Grid -->
            <div class="flex-grow overflow-y-auto custom-scroll">
                @if (isLoadingRoles)
                {
                    <div class="text-center text-gray-400 text-sm py-8">
                        <i class="fa-solid fa-spinner fa-spin mr-2"></i> 載入角色中...
                    </div>
                }
                else if (allRoles.Count == 0)
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 pb-4">
                        <EmptyState IconClass="fa-unlock-keyhole" Message="尚無角色" SubMessage="點擊上方新增角色以定義權限。" />
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 pb-4">
                        @foreach (var role in allRoles)
                        {
                            <div @key="role.Id" class="group bg-white rounded-xl shadow-sm border-2 border-transparent hover:border-morandi hover:shadow-lg transition-all p-5 flex flex-col">
                                <!-- Header：圖示 + 名稱 + 鎖頭 -->
                                <div class="flex items-start justify-between mb-3">
                                    <div class="flex items-center gap-3 min-w-0">
                                        <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 @(role.Category == 0 ? "bg-purple-100 text-purple-600" : "bg-amber-100 text-amber-600")">
                                            <i class="fa-solid fa-shield-halved"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <div class="flex items-center gap-2">
                                                <h4 class="text-base font-bold text-slate-main truncate" title="@role.Name">@role.Name</h4>
                                                @if (role.IsDefault)
                                                {
                                                    <i class="fa-solid fa-lock text-amber-500 text-xs" title="預設角色"></i>
                                                }
                                            </div>
                                            <span class="inline-block text-xs font-medium px-2 py-0.5 rounded mt-1 @(role.Category == 0 ? "bg-blue-100 text-blue-700" : "bg-green-100 text-green-700")">
                                                @(role.Category == 0 ? "內部人員" : "外部人員")
                                            </span>
                                        </div>
                                    </div>
                                    <div class="text-morandi font-bold text-sm flex-shrink-0" title="已啟用功能 / 總功能">
                                        @role.EnabledModuleCount/@permissionToggles.Count
                                    </div>
                                </div>

                                <!-- 角色描述 -->
                                <p class="text-sm text-gray-500 mb-3 line-clamp-2 min-h-[2.5rem]">
                                    @(string.IsNullOrWhiteSpace(role.Description) ? "—" : role.Description)
                                </p>

                                <!-- 已啟用功能 Badge -->
                                <div class="flex flex-wrap gap-1 mb-3 min-h-[22px]">
                                    @foreach (var m in role.EnabledModules.Take(6))
                                    {
                                        <span class="text-xs px-2 py-0.5 rounded bg-gray-100 text-gray-600 flex items-center gap-1" title="@m.Name">
                                            <i class="fa-solid @m.Icon text-xs @m.ColorClass"></i>
                                            @m.Name
                                        </span>
                                    }
                                    @if (role.EnabledModules.Count > 6)
                                    {
                                        <span class="text-xs px-2 py-0.5 rounded bg-gray-100 text-gray-500">
                                            +@(role.EnabledModules.Count - 6)
                                        </span>
                                    }
                                </div>

                                <!-- Footer -->
                                <div class="mt-auto flex items-center justify-between pt-3 border-t border-gray-100">
                                    <button type="button" @onclick="() => OpenRoleUsersModal(role.Id, role.Name, role.Category)"
                                            disabled="@(role.UserCount == 0)"
                                            class="text-xs text-gray-500 flex items-center gap-1 @(role.UserCount > 0 ? "cursor-pointer hover:text-morandi hover:underline" : "cursor-default")"
                                            title="@(role.UserCount > 0 ? "點擊查看使用者清單" : "目前沒有使用者")">
                                        <i class="fa-solid fa-users"></i> @role.UserCount 位使用者
                                    </button>
                                    <div class="flex items-center gap-1.5">
                                        @if (!role.IsDefault)
                                        {
                                            <button type="button" @onclick="() => DeleteRole(role.Id, role.Name, role.UserCount)"
                                                    class="cursor-pointer text-xs px-2.5 py-1.5 rounded border border-gray-200 text-gray-400 hover:bg-red-50 hover:text-red-500 hover:border-red-300 transition flex items-center gap-1"
                                                    title="刪除角色">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        }
                                        <button type="button" @onclick="() => OpenRoleModalAsync(role.Id, role.IsDefault)"
                                                class="cursor-pointer text-xs px-3 py-1.5 rounded border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-morandi hover:border-morandi transition flex items-center gap-1">
                                            <i class="fa-solid @(role.IsDefault ? "fa-eye" : "fa-pen-to-square")"></i>
                                            @(role.IsDefault ? "檢視" : "編輯")
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Add / Edit Account Modal -->
<CustomModal IsVisible="showAccountModal" IsVisibleChanged="OnAccountModalVisibleChanged"
             Type="CustomModal.ModalType.SlideOver"
             Title="@(isAccountEditMode ? "編輯人員" : "新增人員")"
             HeaderIcon="@(isAccountEditMode ? "fa-solid fa-user-pen" : "fa-solid fa-user-plus")"
             MaxWidth="max-w-xl" CloseOnBackdropClick="true" KeepAlive="true">
    <ChildContent>
        <EditForm Model="newAccountModel" class="space-y-6">
            <DataAnnotationsValidator />

            <!-- 區塊 1：基本資料 -->
            <div class="space-y-4">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">1</span>
                    基本資料
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">使用者姓名 <span class="text-red-500">*</span></label>
                        <input type="text" @bind="newAccountModel.DisplayName" placeholder="如：王小明"
                               class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">
                            登入帳號 <span class="text-red-500">*</span>
                            @if (isAccountEditMode)
                            {
                                <span class="text-xs text-gray-400 font-normal ml-1">(不可修改)</span>
                            }
                        </label>
                        <input type="text" @bind="newAccountModel.Username" placeholder="如：admin01"
                               disabled="@isAccountEditMode"
                               class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">
                            電子信箱 <span class="text-gray-400 font-normal">(選填)</span>
                        </label>
                        <input type="email" @bind="newAccountModel.Email" placeholder="name@company.com.tw"
                               class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">身份別 <span class="text-red-500">*</span></label>
                        <select @bind="newAccountModel.RoleId"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                            <option value="0">-- 請選擇 --</option>
                            @foreach (var r in internalRoleOptions)
                            {
                                <option value="@r.Id">@r.Name @(r.IsDefault ? "(預設)" : "")</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">
                            公司職稱 <span class="text-gray-400 font-normal">(選填)</span>
                        </label>
                        <input type="text" @bind="newAccountModel.CompanyTitle" placeholder="如：專案經理"
                               class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                </div>
            </div>

            <!-- 區塊 2：帳號設定 -->
            <div class="space-y-4 pt-2">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">2</span>
                    帳號設定
                </h3>
                <div class="space-y-4">
                    @if (!isAccountEditMode)
                    {
                        <div class="bg-blue-50/50 p-4 rounded-lg border border-blue-100">
                            <p class="text-xs text-morandi font-medium">
                                <i class="fa-solid fa-lightbulb mr-1"></i>
                                預設密碼為公司統編 <span class="font-bold font-mono">01024304</span>，首次登入時系統會強制要求變更密碼。
                            </p>
                        </div>
                    }
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">帳號狀態</label>
                        <div class="flex gap-4">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="frmAcctStatus"
                                       checked="@(newAccountModel.Status == 1)"
                                       @onchange="() => newAccountModel.Status = 1"
                                       class="text-morandi focus:ring-morandi">
                                <span class="text-sm">啟用</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="frmAcctStatus"
                                       checked="@(newAccountModel.Status == 0)"
                                       @onchange="() => newAccountModel.Status = 0"
                                       class="text-morandi focus:ring-morandi">
                                <span class="text-sm">停用</span>
                            </label>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">備註</label>
                        <textarea @bind="newAccountModel.Note" rows="3" placeholder="如：特殊權限需求、備忘事項..."
                                  class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm resize-none"></textarea>
                    </div>
                </div>
            </div>
        </EditForm>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="CloseAccountModal" disabled="@isSavingAccount"
            class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors shadow-sm disabled:opacity-60">
            取消
        </button>
        <button type="button" @onclick="SaveAccount" disabled="@isSavingAccount"
            class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors shadow-sm flex items-center gap-2 disabled:opacity-60">
            @if (isSavingAccount)
            {
                <i class="fa-solid fa-spinner fa-spin"></i>
                <span>儲存中...</span>
            }
            else
            {
                <i class="fa-solid fa-floppy-disk"></i>
                <span>@(isAccountEditMode ? "儲存變更" : "儲存人員")</span>
            }
        </button>
    </FooterContent>
</CustomModal>

<!-- Add / Edit / View Role Modal -->
<CustomModal IsVisible="showRoleModal" IsVisibleChanged="OnRoleModalVisibleChanged"
             Type="CustomModal.ModalType.Center" Title="@RoleModalTitle" CloseOnBackdropClick="true" KeepAlive="true">
    <ChildContent>
        <EditForm Model="newRoleModel" class="space-y-6">
            <DataAnnotationsValidator />

            @if (isRoleReadOnly)
            {
                <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-xs text-amber-700 flex items-center gap-2">
                    <i class="fa-solid fa-lock"></i>
                    <span>此為系統預設角色，內容僅供檢視，無法修改。</span>
                </div>
            }

            <!-- 區塊 1：角色資訊 -->
            <div class="space-y-4">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">1</span>
                    角色資訊
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">
                            角色名稱 <span class="text-red-500">*</span>
                        </label>
                        <input type="text" @bind="newRoleModel.Name" placeholder="如:計畫主持人"
                               disabled="@isRoleReadOnly"
                               class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">
                            分類 <span class="text-red-500">*</span>
                        </label>
                        <select @bind="newRoleModel.Category" disabled="@isRoleReadOnly"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                            <option value="0">內部人員</option>
                            <option value="1">外部人員</option>
                        </select>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">角色描述</label>
                        <textarea @bind="newRoleModel.Description" rows="2" placeholder="此角色的用途描述..."
                                  disabled="@isRoleReadOnly"
                                  class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm resize-none disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed"></textarea>
                    </div>
                </div>
            </div>

            <!-- 區塊 2：功能區塊權限 -->
            <div class="space-y-4">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">2</span>
                    功能區塊權限
                </h3>
                @if (permissionToggles.Count == 0)
                {
                    <div class="text-center text-gray-400 text-sm py-4">
                        <i class="fa-solid fa-spinner fa-spin mr-1"></i> 載入模組中...
                    </div>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var t in permissionToggles)
                        {
                            <div @key="t.ModuleId" class="flex items-center justify-between p-3 border border-gray-200 rounded-lg">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-lg flex items-center justify-center @t.BgColorClass">
                                        <i class="fa-solid @t.Icon @t.ColorClass"></i>
                                    </div>
                                    <div>
                                        <div class="text-sm font-medium text-slate-main">@t.Name</div>
                                        <div class="text-xs text-gray-400 font-mono">@t.PageUrl</div>
                                    </div>
                                </div>
                                <button type="button" @onclick="() => ToggleModule(t)" disabled="@isRoleReadOnly"
                                        class="relative w-11 h-6 rounded-full transition-colors duration-150 flex-shrink-0 @(isRoleReadOnly ? "opacity-50 cursor-not-allowed" : "cursor-pointer") @(t.IsEnabled ? "bg-sage" : "bg-gray-300")">
                                    <span class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full shadow-sm transition-transform duration-150 ease-out @(t.IsEnabled ? "translate-x-5" : "translate-x-0")"></span>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </EditForm>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="CloseRoleModal" disabled="@isSavingRole"
                class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors shadow-sm disabled:opacity-60">
            @(isRoleReadOnly ? "關閉" : "取消")
        </button>
        @if (!isRoleReadOnly)
        {
            <button type="button" @onclick="SaveRole" disabled="@isSavingRole"
                    class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors shadow-sm flex items-center gap-2 disabled:opacity-60">
            @if (isSavingRole)
            {
                <i class="fa-solid fa-spinner fa-spin"></i>
                <span>儲存中...</span>
            }
            else
            {
                <i class="fa-solid fa-floppy-disk"></i>
                <span>@(isRoleEditMode ? "儲存變更" : "儲存角色")</span>
            }
            </button>
        }
    </FooterContent>
</CustomModal>

<!-- Role Users Modal：檢視使用此角色的所有人員 -->
<CustomModal @bind-IsVisible="showRoleUsersModal" Type="CustomModal.ModalType.Center"
             Title="@($"使用「{roleUsersRoleName}」的人員")" CloseOnBackdropClick="true" KeepAlive="true">
    <ChildContent>
        @if (isLoadingRoleUsers)
        {
            <div class="py-8 text-center text-gray-400 text-sm">
                <i class="fa-solid fa-spinner fa-spin mr-1"></i> 載入中...
            </div>
        }
        else if (roleUsers.Count == 0)
        {
            <div class="py-4">
                <EmptyState IconClass="fa-user-slash" Message="目前沒有使用者" SubMessage="此角色尚未指派給任何人員。" Compact="true" />
            </div>
        }
        else
        {
            <div class="space-y-2">
                @foreach (var u in roleUsers)
                {
                    <div @key="@($"{u.UserId}-{u.Source}-{u.ProjectCode}")" class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                        <div class="w-10 h-10 rounded-full bg-morandi text-white flex items-center justify-center font-bold flex-shrink-0">
                            @(string.IsNullOrEmpty(u.DisplayName) ? "?" : u.DisplayName[..1])
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="text-sm font-bold text-slate-main">@u.DisplayName</span>
                                <span class="text-xs text-gray-500 font-mono">@u.Username</span>
                                @if (u.Source == 0)
                                {
                                    @if (roleUsersCategory == 1)
                                    {
                                        <span class="text-xs px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 font-medium">教師角色</span>
                                    }
                                    else
                                    {
                                        <span class="text-xs px-1.5 py-0.5 rounded bg-purple-100 text-purple-700 font-medium">系統角色</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-xs px-1.5 py-0.5 rounded bg-blue-100 text-blue-700 font-medium">梯次指派</span>
                                }
                            </div>
                            @if (u.Source == 1 && !string.IsNullOrWhiteSpace(u.ProjectName))
                            {
                                <div class="text-xs text-gray-400 truncate">
                                    <i class="fa-solid fa-layer-group mr-1"></i>@u.ProjectName
                                    @if (!string.IsNullOrWhiteSpace(u.ProjectCode))
                                    {
                                        <span class="font-mono">（@u.ProjectCode）</span>
                                    }
                                </div>
                            }
                            else if (!string.IsNullOrWhiteSpace(u.Email))
                            {
                                <div class="text-xs text-gray-400 truncate">
                                    <i class="fa-solid fa-envelope mr-1"></i>@u.Email
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            <p class="text-xs text-gray-400 mt-4">
                <i class="fa-solid fa-circle-info mr-1"></i>
                要刪除此角色，請先至對應管理頁面（人員帳號管理 / 教師管理系統）將上述人員改派至其他角色。
            </p>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="() => showRoleUsersModal = false"
                class="cursor-pointer px-4 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors shadow-sm">
            關閉
        </button>
    </FooterContent>
</CustomModal>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private string currentTab = "accounts";
    private bool showAccountModal = false;
    private bool showRoleModal = false;

    // ──── 帳號列表與詳情（Tab A）────
    private List<InternalAccountItem> allAccounts = new();
    private AccountDetailDto? selectedAccount;
    private int? selectedAccountId;
    private string accountKeyword = "";
    private string accountStatusFilter = "all";
    private bool isLoadingAccounts = true;
    private bool isLoadingAccountDetail = false;
    private bool isAccountActionBusy = false;

    // ──── 新增/編輯人員 表單狀態 ────
    private CreateAccountRequest newAccountModel = new() { Status = 1 };
    private List<RoleOption> internalRoleOptions = new();
    private bool isSavingAccount = false;
    private bool isAccountEditMode = false;
    private int? editingAccountId = null;

    // ──── 角色卡片列表（Tab B）────
    private List<RoleCardItem> allRoles = new();
    private bool isLoadingRoles = true;

    // ──── 角色使用者清單 Modal ────
    private bool showRoleUsersModal = false;
    private List<RoleUserItem> roleUsers = new();
    private string roleUsersRoleName = "";
    private int roleUsersCategory = 0;
    private bool isLoadingRoleUsers = false;

    // ──── 新增/編輯/檢視角色 表單狀態 ────
    private CreateRoleRequest newRoleModel = new();
    private List<RolePermissionToggle> permissionToggles = new();
    private bool isSavingRole = false;
    private bool isRoleEditMode = false;
    private bool isRoleReadOnly = false;
    private int? editingRoleId = null;

    private string RoleModalTitle =>
        isRoleReadOnly ? "檢視角色" : (isRoleEditMode ? "編輯角色" : "新增角色");

    /// <summary>依搜尋關鍵字與狀態篩選左側清單。</summary>
    private IEnumerable<InternalAccountItem> FilteredAccounts =>
        allAccounts
            .Where(a => accountStatusFilter == "all"
                        || (accountStatusFilter == "active" && a.Status == 1)
                        || (accountStatusFilter == "inactive" && a.Status != 1))
            .Where(a => string.IsNullOrWhiteSpace(accountKeyword)
                        || a.DisplayName.Contains(accountKeyword, StringComparison.OrdinalIgnoreCase)
                        || a.Username.Contains(accountKeyword, StringComparison.OrdinalIgnoreCase)
                        || (a.Email?.Contains(accountKeyword, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadModulesAsync();
        await LoadInternalRoleOptionsAsync();
        await LoadRolesAsync();
        await LoadAccountsAsync();
    }

    /// <summary>載入全部角色卡片資料（含使用者數與已啟用模組摘要）。</summary>
    private async Task LoadRolesAsync()
    {
        try
        {
            isLoadingRoles = true;
            allRoles = await RoleService.GetRolesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入角色清單失敗");
            await JS.InvokeVoidAsync("Swal.fire", "載入失敗", "無法取得角色清單，請稍後再試。", "error");
        }
        finally
        {
            isLoadingRoles = false;
        }
    }

    /// <summary>載入內部人員帳號清單。</summary>
    private async Task LoadAccountsAsync()
    {
        try
        {
            isLoadingAccounts = true;
            allAccounts = await RoleService.GetInternalAccountsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入人員帳號清單失敗");
            await JS.InvokeVoidAsync("Swal.fire", "載入失敗", "無法取得人員帳號清單，請稍後再試。", "error");
        }
        finally
        {
            isLoadingAccounts = false;
        }
    }

    /// <summary>載入內部人員身份別下拉清單。</summary>
    private async Task LoadInternalRoleOptionsAsync()
    {
        try
        {
            internalRoleOptions = await RoleService.GetInternalRoleOptionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入內部角色下拉失敗");
        }
    }

    /// <summary>點擊左側列表人員後載入其詳情。</summary>
    private async Task SelectAccount(int userId)
    {
        if (selectedAccountId == userId && selectedAccount is not null) return;
        selectedAccountId = userId;
        isLoadingAccountDetail = true;
        selectedAccount = null;
        try
        {
            selectedAccount = await RoleService.GetAccountDetailAsync(userId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入人員詳情失敗 UserId={UserId}", userId);
            await JS.InvokeVoidAsync("Swal.fire", "載入失敗", "無法取得人員詳情，請稍後再試。", "error");
        }
        finally
        {
            isLoadingAccountDetail = false;
        }
    }

    /// <summary>停用/啟用當前選中的帳號。</summary>
    private async Task ToggleAccountStatus()
    {
        if (selectedAccount is null || isAccountActionBusy) return;

        var willDisable = selectedAccount.Status == 1;
        var confirmed = await ConfirmAsync(
            willDisable ? "確認停用帳號？" : "確認啟用帳號？",
            $"即將{(willDisable ? "停用" : "啟用")}人員「{selectedAccount.DisplayName}」的登入權限。",
            willDisable ? "#D98A6C" : "#8EAB94");
        if (!confirmed) return;

        isAccountActionBusy = true;
        try
        {
            var operatorId = await GetCurrentUserIdAsync();
            await RoleService.ToggleAccountStatusAsync(selectedAccount.Id, operatorId);

            await LoadAccountsAsync();
            if (selectedAccountId is int id) selectedAccount = await RoleService.GetAccountDetailAsync(id);

            await JS.InvokeVoidAsync("swalToast", "success", willDisable ? "帳號已停用" : "帳號已啟用", 2000);
        }
        catch (InvalidOperationException ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", "操作失敗", ex.Message, "warning");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "切換帳號狀態失敗");
            await JS.InvokeVoidAsync("Swal.fire", "系統錯誤", "切換狀態失敗，請稍後再試。", "error");
        }
        finally
        {
            isAccountActionBusy = false;
        }
    }

    /// <summary>重設當前選中帳號的密碼為預設值（公司統編）。</summary>
    private async Task ResetAccountPassword()
    {
        if (selectedAccount is null || isAccountActionBusy) return;

        var confirmed = await ConfirmAsync(
            "確認重設密碼？",
            $"將人員「{selectedAccount.DisplayName}」的密碼重設為公司統編 01024304，下次登入會強制變更。",
            "#6B8EAD");
        if (!confirmed) return;

        isAccountActionBusy = true;
        try
        {
            var operatorId = await GetCurrentUserIdAsync();
            await RoleService.ResetAccountPasswordAsync(selectedAccount.Id, operatorId);
            if (selectedAccountId is int id) selectedAccount = await RoleService.GetAccountDetailAsync(id);

            await JS.InvokeVoidAsync("swalToast", "success", "密碼已重設為公司統編 01024304", 2500);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "重設密碼失敗");
            await JS.InvokeVoidAsync("Swal.fire", "系統錯誤", "重設密碼失敗，請稍後再試。", "error");
        }
        finally
        {
            isAccountActionBusy = false;
        }
    }

    /// <summary>透過 swal-interop.js 顯示確認對話框並回傳使用者是否確認。</summary>
    private Task<bool> ConfirmAsync(string title, string text, string confirmColor) =>
        JS.InvokeAsync<bool>("swalConfirm", new
        {
            icon = "question",
            title,
            text,
            showCancelButton = true,
            confirmButtonText = "確認",
            cancelButtonText = "取消",
            confirmButtonColor = confirmColor,
        }).AsTask();

    private async Task<int> GetCurrentUserIdAsync()
    {
        var authState = await AuthState;
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return int.TryParse(userIdStr, out var id) ? id : 1;
    }

    // ──── 新增人員 Modal 控制 ────

    private void OpenAccountModal()
    {
        ResetAccountForm();
        isAccountEditMode = false;
        editingAccountId = null;
        showAccountModal = true;
    }

    /// <summary>以當前選中的詳情資料填充表單並開啟編輯模式。</summary>
    private void OpenEditAccountModal()
    {
        if (selectedAccount is null) return;
        newAccountModel = new CreateAccountRequest
        {
            Username = selectedAccount.Username,
            DisplayName = selectedAccount.DisplayName,
            Email = selectedAccount.Email,
            RoleId = selectedAccount.RoleId,
            Status = selectedAccount.Status,
            CompanyTitle = selectedAccount.CompanyTitle,
            Note = selectedAccount.Note,
        };
        isAccountEditMode = true;
        editingAccountId = selectedAccount.Id;
        showAccountModal = true;
    }

    private void CloseAccountModal()
    {
        showAccountModal = false;
        ResetAccountForm();
    }

    private Task OnAccountModalVisibleChanged(bool value)
    {
        showAccountModal = value;
        if (!value) ResetAccountForm();
        return Task.CompletedTask;
    }

    private void ResetAccountForm()
    {
        newAccountModel = new CreateAccountRequest { Status = 1 };
        isAccountEditMode = false;
        editingAccountId = null;
    }

    /// <summary>儲存新人員帳號或更新既有帳號：前端驗證 → 呼叫 Service → 刷新清單。</summary>
    private async Task SaveAccount()
    {
        if (isSavingAccount) return;

        if (string.IsNullOrWhiteSpace(newAccountModel.DisplayName))
        {
            await JS.InvokeVoidAsync("Swal.fire", "驗證未通過", "請輸入使用者姓名。", "warning");
            return;
        }
        if (!isAccountEditMode && string.IsNullOrWhiteSpace(newAccountModel.Username))
        {
            await JS.InvokeVoidAsync("Swal.fire", "驗證未通過", "請輸入登入帳號。", "warning");
            return;
        }
        if (newAccountModel.RoleId <= 0)
        {
            await JS.InvokeVoidAsync("Swal.fire", "驗證未通過", "請選擇身份別。", "warning");
            return;
        }

        isSavingAccount = true;
        try
        {
            newAccountModel.Username = newAccountModel.Username?.Trim() ?? "";
            newAccountModel.DisplayName = newAccountModel.DisplayName.Trim();
            newAccountModel.Email = newAccountModel.Email?.Trim();
            newAccountModel.CompanyTitle = newAccountModel.CompanyTitle?.Trim();
            newAccountModel.Note = newAccountModel.Note?.Trim();

            var operatorId = await GetCurrentUserIdAsync();
            int targetId;
            string displayName = newAccountModel.DisplayName;

            if (isAccountEditMode && editingAccountId is int id)
            {
                var update = new UpdateAccountRequest
                {
                    Id = id,
                    DisplayName = newAccountModel.DisplayName,
                    Email = newAccountModel.Email,
                    RoleId = newAccountModel.RoleId,
                    Status = newAccountModel.Status,
                    CompanyTitle = newAccountModel.CompanyTitle,
                    Note = newAccountModel.Note,
                };
                await RoleService.UpdateAccountAsync(update, operatorId);
                targetId = id;
                Logger.LogInformation("人員帳號更新成功 Id={Id}", id);
            }
            else
            {
                targetId = await RoleService.CreateAccountAsync(newAccountModel, operatorId);
                Logger.LogInformation("人員帳號建立成功 Id={Id} Username={Username}", targetId, newAccountModel.Username);
            }

            var wasEdit = isAccountEditMode;
            CloseAccountModal();
            await JS.InvokeVoidAsync("swalToast", "success",
                $"人員「{displayName}」已{(wasEdit ? "更新" : "新增")}", 2000);
            await LoadAccountsAsync();
            await LoadRolesAsync();
            await SelectAccount(targetId);
        }
        catch (InvalidOperationException ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", "無法儲存", ex.Message, "warning");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "儲存人員失敗");
            await JS.InvokeVoidAsync("Swal.fire", "系統錯誤", "儲存失敗，請稍後再試。", "error");
        }
        finally
        {
            isSavingAccount = false;
        }
    }

    /// <summary>載入啟用中的功能模組，作為 Toggle 清單的資料來源。</summary>
    private async Task LoadModulesAsync()
    {
        try
        {
            var modules = await RoleService.GetActiveModulesAsync();
            permissionToggles = modules.Select(m => new RolePermissionToggle
            {
                ModuleId = m.Id,
                ModuleKey = m.ModuleKey,
                Name = m.Name,
                Icon = m.Icon,
                PageUrl = m.PageUrl,
                Description = m.Description,
                ColorClass = m.ColorClass,
                BgColorClass = m.BgColorClass,
                SortOrder = m.SortOrder,
                IsEnabled = false,
            }).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入功能模組失敗");
            await JS.InvokeVoidAsync("Swal.fire", "載入失敗", "無法取得功能模組清單，請稍後再試。", "error");
        }
    }

    /// <summary>切換單一模組 Toggle 狀態。</summary>
    private void ToggleModule(RolePermissionToggle toggle)
    {
        toggle.IsEnabled = !toggle.IsEnabled;
    }

    /// <summary>CustomModal 雙向綁定橋接；關閉時重設表單。</summary>
    private Task OnRoleModalVisibleChanged(bool value)
    {
        showRoleModal = value;
        if (!value) ResetRoleForm();
        return Task.CompletedTask;
    }

    private void CloseRoleModal()
    {
        showRoleModal = false;
        ResetRoleForm();
    }

    /// <summary>清空表單與 Toggle 狀態，供開新表單或關閉後重用。</summary>
    private void ResetRoleForm()
    {
        newRoleModel = new CreateRoleRequest();
        foreach (var t in permissionToggles)
        {
            t.IsEnabled = false;
        }
        isRoleEditMode = false;
        isRoleReadOnly = false;
        editingRoleId = null;
    }

    /// <summary>開啟角色編輯或檢視 Modal，讀取完整角色資料並填入表單。</summary>
    private async Task OpenRoleModalAsync(int roleId, bool isDefault)
    {
        ResetRoleForm();
        try
        {
            var detail = await RoleService.GetRoleDetailAsync(roleId);
            if (detail is null)
            {
                await JS.InvokeVoidAsync("Swal.fire", "載入失敗", "找不到此角色。", "error");
                return;
            }

            newRoleModel = new CreateRoleRequest
            {
                Name = detail.Name,
                Category = detail.Category,
                Description = detail.Description,
            };
            permissionToggles = detail.Permissions;
            editingRoleId = detail.Id;
            isRoleEditMode = !isDefault;
            isRoleReadOnly = isDefault;
            showRoleModal = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入角色詳情失敗 RoleId={RoleId}", roleId);
            await JS.InvokeVoidAsync("Swal.fire", "載入失敗", "無法取得角色資料，請稍後再試。", "error");
        }
    }

    private void OpenNewRoleModal()
    {
        ResetRoleForm();
        showRoleModal = true;
    }

    /// <summary>開啟角色使用者清單 Modal。</summary>
    private async Task OpenRoleUsersModal(int roleId, string roleName, int category)
    {
        roleUsersRoleName = roleName;
        roleUsersCategory = category;
        roleUsers = new();
        showRoleUsersModal = true;
        isLoadingRoleUsers = true;
        try
        {
            roleUsers = await RoleService.GetRoleUsersAsync(roleId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入角色使用者清單失敗 RoleId={RoleId}", roleId);
            await JS.InvokeVoidAsync("Swal.fire", "載入失敗", "無法取得使用者清單，請稍後再試。", "error");
        }
        finally
        {
            isLoadingRoleUsers = false;
        }
    }

    /// <summary>刪除自訂角色：確認 → 呼叫 Service → 刷新卡片。</summary>
    private async Task DeleteRole(int roleId, string roleName, int userCount)
    {
        if (userCount > 0)
        {
            await JS.InvokeVoidAsync("Swal.fire", "無法刪除",
                $"角色「{roleName}」尚有 {userCount} 位使用者，請先將人員改派至其他角色後再刪除。", "warning");
            return;
        }

        var confirmed = await ConfirmAsync(
            "確認刪除角色？",
            $"即將永久刪除角色「{roleName}」，此操作無法復原。",
            "#D98A6C");
        if (!confirmed) return;

        try
        {
            var operatorId = await GetCurrentUserIdAsync();
            await RoleService.DeleteRoleAsync(roleId, operatorId);

            await JS.InvokeVoidAsync("swalToast", "success", $"角色「{roleName}」已刪除", 2000);
            await LoadRolesAsync();
            await LoadInternalRoleOptionsAsync();
        }
        catch (InvalidOperationException ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", "無法刪除", ex.Message, "warning");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "刪除角色失敗 RoleId={RoleId}", roleId);
            await JS.InvokeVoidAsync("Swal.fire", "系統錯誤", "刪除失敗，請稍後再試。", "error");
        }
    }

    /// <summary>儲存新角色或更新既有角色：前端驗證 → 組 DTO → 呼叫 Service → 刷新卡片。</summary>
    private async Task SaveRole()
    {
        if (isSavingRole || isRoleReadOnly) return;

        // 1. 前端必填檢查
        if (string.IsNullOrWhiteSpace(newRoleModel.Name))
        {
            await JS.InvokeVoidAsync("Swal.fire", "驗證未通過", "請輸入角色名稱。", "warning");
            return;
        }
        if (newRoleModel.Category is not (0 or 1))
        {
            await JS.InvokeVoidAsync("Swal.fire", "驗證未通過", "請選擇角色分類。", "warning");
            return;
        }

        isSavingRole = true;
        try
        {
            var operatorId = await GetCurrentUserIdAsync();

            newRoleModel.Name = newRoleModel.Name.Trim();
            newRoleModel.Description = newRoleModel.Description?.Trim();
            newRoleModel.Permissions = permissionToggles.Select(t => new RolePermissionInput
            {
                ModuleId = t.ModuleId,
                IsEnabled = t.IsEnabled,
            }).ToList();

            string roleName = newRoleModel.Name;
            if (isRoleEditMode && editingRoleId is int rid)
            {
                var update = new UpdateRoleRequest
                {
                    Id = rid,
                    Name = newRoleModel.Name,
                    Category = newRoleModel.Category,
                    Description = newRoleModel.Description,
                    Permissions = newRoleModel.Permissions,
                };
                await RoleService.UpdateRoleAsync(update, operatorId);
                Logger.LogInformation("角色更新成功 Id={Id} Name={Name}", rid, roleName);
            }
            else
            {
                var newId = await RoleService.CreateRoleAsync(newRoleModel, operatorId);
                Logger.LogInformation("角色建立成功 Id={Id} Name={Name}", newId, roleName);
            }

            var wasEdit = isRoleEditMode;
            CloseRoleModal();
            await JS.InvokeVoidAsync("swalToast", "success",
                $"角色「{roleName}」已{(wasEdit ? "更新" : "新增")}", 2000);
            await LoadRolesAsync();

            // 若當前選中的帳號使用此角色，同步刷新詳情
            if (selectedAccountId is int uid) selectedAccount = await RoleService.GetAccountDetailAsync(uid);
        }
        catch (InvalidOperationException ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", "無法儲存", ex.Message, "warning");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "儲存角色失敗");
            await JS.InvokeVoidAsync("Swal.fire", "系統錯誤", "儲存失敗，請稍後再試。", "error");
        }
        finally
        {
            isSavingRole = false;
        }
    }

    private RenderFragment StatCard(string title, string value, string icon, string iconColor, string valueColor) => __builder =>
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="text-2xl font-bold @valueColor">@value</div>
        </div>
    };
}
