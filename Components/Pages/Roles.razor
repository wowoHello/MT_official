@* ====================================================================== *@
@*  Roles — 角色與權限管理                                                  *@
@*  路由：/roles                                                           *@
@*  功能：人員帳號管理/角色權限管理雙分頁、帳號列表與詳情、角色 CRUD         *@
@* ====================================================================== *@
@page "/roles"

<div class="flex-grow flex flex-col w-full max-w-[1920px] mx-auto h-[calc(100vh-4rem)] overflow-hidden">
    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <a href="/home" class="inline-flex items-center hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </a>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-slate-main">角色與權限管理</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-id-card-clip text-morandi"></i> 角色與權限管理
                </h1>
            </div>
            <!-- 動態按鈕區（依據 Tab 切換） -->
            <div class="flex gap-2">
                @if (currentTab == "accounts")
                {
                    <button type="button" @onclick="() => showAccountModal = true"
                        class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                        <i class="fa-solid fa-user-plus"></i> 新增人員
                    </button>
                }
                else
                {
                    <button type="button" @onclick="() => showRoleModal = true"
                        class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                        <i class="fa-solid fa-shield-halved"></i> 新增角色
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Tab Navigation (underline style) -->
    <div class="px-4 sm:px-6 lg:px-8 pt-4 flex-shrink-0">
        <div class="flex border-b border-gray-200 mb-4">
            <button @onclick='() => currentTab = "accounts"'
                class="@(currentTab == "accounts" ? "text-morandi border-b-morandi font-bold" : "text-gray-500 border-transparent") px-5 py-2.5 text-sm border-b-2 transition-colors hover:text-morandi cursor-pointer focus:outline-none">
                <i class="fa-solid fa-users-gear mr-1.5"></i>人員帳號管理
            </button>
            <button @onclick='() => currentTab = "roles"'
                class="@(currentTab == "roles" ? "text-morandi border-b-morandi font-bold" : "text-gray-500 border-transparent") px-5 py-2.5 text-sm border-b-2 transition-colors hover:text-morandi cursor-pointer focus:outline-none">
                <i class="fa-solid fa-shield-halved mr-1.5"></i>角色權限管理
            </button>
        </div>
    </div>

    <!-- Tab Content -->
    @if (currentTab == "accounts")
    {
        <!-- Tab Panel 1: 人員帳號管理 -->
        <div class="flex-grow flex flex-col overflow-hidden px-4 sm:px-6 lg:px-8 pb-4">

            <!-- Statistics Cards -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 flex-shrink-0">
                @StatCard("帳號總數", "0", "fa-users", "text-morandi", "text-slate-main")
                @StatCard("啟用中", "0", "fa-circle-check", "text-sage", "text-sage")
                @StatCard("停用中", "0", "fa-circle-xmark", "text-terracotta", "text-terracotta")
                @StatCard("系統管理員", "0", "fa-user-shield", "text-purple-500", "text-purple-600")
            </div>

            <!-- Split Layout (Left List, Right Detail) -->
            <div class="flex-grow flex overflow-hidden bg-white rounded-xl shadow-sm border border-gray-200">

                <!-- Left Panel: Account List -->
                <div class="w-full lg:w-[380px] xl:w-[420px] border-r border-gray-200 flex flex-col z-10 flex-shrink-0">
                    <!-- Filters -->
                    <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col gap-3 flex-shrink-0">
                        <div class="relative">
                            <i class="fa-solid fa-magnifying-glass left-3 top-2.5 absolute text-gray-400"></i>
                            <input type="text" class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi" placeholder="搜尋姓名、帳號或信箱...">
                        </div>
                        <div class="flex gap-2">
                            <button class="flex-1 py-1 text-xs font-bold rounded bg-morandi text-white cursor-pointer">全部</button>
                            <button class="flex-1 py-1 text-xs font-bold border border-gray-200 text-gray-500 rounded hover:bg-gray-100 cursor-pointer">啟用中</button>
                            <button class="flex-1 py-1 text-xs font-bold border border-gray-200 text-gray-500 rounded hover:bg-gray-100 cursor-pointer">停用中</button>
                        </div>
                    </div>
                    <!-- List (Empty State) -->
                    <div class="flex-grow overflow-y-auto custom-scroll p-4">
                        <EmptyState IconClass="fa-id-badge" Message="尚無人員帳號" SubMessage="點擊右上角新增內部管理人員。" />
                    </div>
                </div>

                <!-- Right Panel: Account Details -->
                <div class="hidden lg:flex flex-col flex-grow bg-[var(--color-oatmeal)] overflow-hidden">
                    <div class="flex-grow flex flex-col items-center justify-center text-gray-400 p-8">
                        <i class="fa-solid fa-user-gear text-6xl mb-4 text-gray-300"></i>
                        <p class="text-lg font-medium">請由左側列表選擇人員，或新增一位內部人員。</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Tab Panel 2: 角色權限管理 -->
        <div class="flex-grow flex flex-col overflow-hidden px-4 sm:px-6 lg:px-8 pb-4">

            <!-- 角色統計 -->
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-4 flex-shrink-0">
                @StatCard("角色總數", "0", "fa-shield-halved", "text-morandi", "text-slate-main")
                @StatCard("內部人員角色", "0", "fa-building", "text-morandi", "text-morandi")
                @StatCard("外部人員角色", "0", "fa-user-graduate", "text-sage", "text-sage")
            </div>

            <!-- Role Cards Grid -->
            <div class="flex-grow overflow-y-auto custom-scroll">
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 pb-4">
                    <EmptyState IconClass="fa-unlock-keyhole" Message="尚無角色" SubMessage="點擊上方新增角色以定義權限。" />
                </div>
            </div>
        </div>
    }
</div>

<!-- Add Account Modal -->
<CustomModal @bind-IsVisible="showAccountModal" Type="CustomModal.ModalType.SlideOver" Title="新增人員" CloseOnBackdropClick="false">
    <ChildContent>
        <form class="space-y-6">
            <!-- 區塊 1: 基本資料 -->
            <div class="space-y-4">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">1</span>
                    基本資料
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">使用者姓名 <span class="text-red-500">*</span></label>
                        <input type="text" required placeholder="如：王小明" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">帳號 <span class="text-red-500">*</span></label>
                        <input type="text" required placeholder="英數字" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">電子信箱</label>
                        <input type="email" placeholder="example@mail.com" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">預設密碼 <span class="text-red-500">*</span></label>
                        <input type="password" required placeholder="至少6碼" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">帳號狀態</label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                            <option value="active">啟用</option>
                            <option value="inactive">停用</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- 區塊 2: 角色指派 -->
            <div class="space-y-4 pt-2">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">2</span>
                    角色指派
                </h3>
                <div class="bg-gray-50 p-4 rounded border border-gray-200 text-center text-gray-400 text-sm">
                    角色資料將於後端介接後產生...
                </div>
            </div>
        </form>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="() => showAccountModal = false"
            class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors shadow-sm">
            取消
        </button>
        <button type="button" @onclick="() => showAccountModal = false"
            class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors shadow-sm flex items-center gap-2">
            <i class="fa-solid fa-floppy-disk"></i> 儲存
        </button>
    </FooterContent>
</CustomModal>

<!-- Add Role Modal -->
<CustomModal @bind-IsVisible="showRoleModal" Type="CustomModal.ModalType.Center" Title="新增角色">
    <ChildContent>
        <div class="p-4 bg-gray-50 border border-gray-200 rounded text-center text-gray-500 mb-4">
            表單內容建置中...
        </div>
    </ChildContent>
</CustomModal>

@code {
    private string currentTab = "accounts";
    private bool showAccountModal = false;
    private bool showRoleModal = false;

    private RenderFragment StatCard(string title, string value, string icon, string iconColor, string valueColor) => __builder =>
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="text-2xl font-bold @valueColor">@value</div>
        </div>
    };
}
