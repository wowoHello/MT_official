@* ====================================================================== *@
@*  FirstLoginPassword — 首次登入強制改密碼頁面                              *@
@*  路由：/first-login-password | 使用 LoginLayout                         *@
@*  觸發：登入成功後，若 MT_Users.IsFirstLogin = 1 由 /auth/login 端點導向   *@
@*  功能：無需 token，透過 Cookie 驗證身份，呼叫 PasswordResetService 變更   *@
@* ====================================================================== *@
@page "/first-login-password"
@layout LoginLayout
@inject IPasswordResetService ResetService
@inject NavigationManager nav

<PageTitle>首次登入 - 設定新密碼</PageTitle>

<div class="min-h-screen flex items-center justify-center relative bg-[var(--color-oatmeal)]">
    <div class="container mx-auto px-4 z-10 flex justify-center items-center">
        <div class="glass-card w-full max-w-md p-8 sm:p-10 rounded-2xl shadow-xl bg-white/90">

            <!-- Header -->
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-[var(--color-morandi)]/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-shield-halved text-[var(--color-morandi)] text-2xl"></i>
                </div>
                <h1 tabindex="-1" class="text-2xl font-bold text-slate-main mb-2 focus:outline-none">首次登入</h1>
                <p class="text-sm text-gray-500">為確保帳號安全，請先設定您的新密碼</p>
            </div>

            <!-- Notice -->
            <div class="mb-5 p-3 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-800 flex items-start gap-2">
                <i class="fa-solid fa-triangle-exclamation mt-0.5"></i>
                <span>完成變更後將以新密碼重新登入，請妥善保管。</span>
            </div>

            <!-- Form -->
            <form class="space-y-4" @onsubmit="SaveNewPassword" @onsubmit:preventDefault>
                <div>
                    <label class="block text-sm font-medium mb-1 text-gray-700">新密碼</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <input type="@pwdType1" @bind="newPassword" disabled="@isSaving"
                            class="w-full pl-10 pr-10 py-2.5 rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all"
                            placeholder="請輸入新密碼" required>
                        <button type="button" @onclick='() => pwdType1 = pwdType1 == "password" ? "text" : "password"'
                            class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 focus:outline-none cursor-pointer">
                            <i class="fa-regular @(pwdType1 == "password" ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1 text-gray-700">確認新密碼</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <input type="@pwdType2" @bind="confirmPassword" disabled="@isSaving"
                            class="w-full pl-10 pr-10 py-2.5 rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all"
                            placeholder="請再次輸入新密碼" required>
                        <button type="button" @onclick='() => pwdType2 = pwdType2 == "password" ? "text" : "password"'
                            class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 focus:outline-none cursor-pointer">
                            <i class="fa-regular @(pwdType2 == "password" ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" disabled="@isSaving"
                    class="w-full py-3 mt-2 bg-[var(--color-morandi)] hover:bg-[#5b7a95] text-white rounded-lg font-medium transition-all shadow-md flex justify-center items-center gap-2 focus:outline-none disabled:opacity-60 cursor-pointer">
                    @if (isSaving)
                    {
                        <i class="fa-solid fa-spinner fa-spin"></i>
                        <span>儲存中...</span>
                    }
                    else
                    {
                        <i class="fa-solid fa-check"></i>
                        <span>設定新密碼</span>
                    }
                </button>
            </form>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private string newPassword = "";
    private string confirmPassword = "";
    private string pwdType1 = "password";
    private string pwdType2 = "password";
    private bool isSaving = false;

    private async Task SaveNewPassword()
    {
        if (newPassword != confirmPassword)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "錯誤", text = "兩次輸入的新密碼不同！", confirmButtonColor = "#6B8EAD" });
            return;
        }

        if (newPassword.Length < 6)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "warning", title = "提示", text = "密碼長度至少 6 碼！", confirmButtonColor = "#6B8EAD" });
            return;
        }

        // 從 Cookie 取得當前使用者 ID
        var authState = await AuthState;
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(userIdClaim, out var userId))
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "系統錯誤", text = "無法識別使用者，請重新登入。", confirmButtonColor = "#6B8EAD" });
            nav.NavigateTo("/auth/logout", forceLoad: true);
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            await ResetService.ChangePasswordAsync(userId, newPassword);

            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "success",
                title = "設定成功",
                text = "密碼已更新，請使用新密碼重新登入。",
                timer = 1000,
                showConfirmButton = false
            });
            await Task.Delay(1100);

            // 改完密碼登出，強制重新登入以使用新密碼並刷新 Cookie
            nav.NavigateTo("/auth/logout", forceLoad: true);
        }
        catch
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "系統錯誤", text = "變更失敗，請聯絡系統管理員。", confirmButtonColor = "#6B8EAD" });
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}
