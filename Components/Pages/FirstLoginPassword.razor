@* ====================================================================== *@
@*  FirstLoginPassword — 首次登入強制改密碼頁面                              *@
@*  路由：/first-login-password | 使用 LoginLayout                         *@
@*  觸發：登入成功後，若 MT_Users.IsFirstLogin = 1 由 /auth/login 端點導向   *@
@*  功能：無需 token，透過 Cookie 驗證身份，呼叫 PasswordResetService 變更   *@
@* ====================================================================== *@
@page "/first-login-password"
@layout LoginLayout
@inject IPasswordResetService ResetService
@inject NavigationManager nav

<PageTitle>首次登入 - 設定新密碼</PageTitle>

<div class="min-h-screen flex items-center justify-center relative bg-[var(--color-oatmeal)]">
    <div class="container mx-auto px-4 z-10 flex justify-center items-center">
        <div class="glass-card w-full max-w-md p-8 sm:p-10 rounded-2xl shadow-xl bg-white/90">

            <!-- Header -->
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-[var(--color-morandi)]/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-shield-halved text-[var(--color-morandi)] text-2xl"></i>
                </div>
                <h1 tabindex="-1" class="text-2xl font-bold text-slate-main mb-2 focus:outline-none">首次登入</h1>
                <p class="text-sm text-gray-500">為確保帳號安全，請先設定您的新密碼</p>
            </div>

            <!-- Notice -->
            <div class="mb-5 p-3 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-800 flex items-start gap-2">
                <i class="fa-solid fa-triangle-exclamation mt-0.5"></i>
                <span>完成變更後將以新密碼重新登入，請妥善保管。</span>
            </div>

            <!-- Form -->
            <EditForm Model="formModel" OnValidSubmit="SaveNewPassword" FormName="firstLoginPasswordForm" class="space-y-4">
                <!-- 新密碼 -->
                <div>
                    <label for="newPassword" class="block text-sm font-medium mb-1 text-gray-700">新密碼</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 pointer-events-none">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <InputText id="newPassword" type="@pwdType1" @bind-Value="formModel.NewPassword"
                            @bind-Value:after="ClearSamePasswordError"
                            disabled="@isSaving"
                            placeholder="請輸入新密碼"
                            class="@BuildInputClass(samePasswordError)" />
                        <button type="button" @onclick="TogglePwd1"
                            aria-label="切換新密碼顯示"
                            tabindex="0"
                            class="absolute inset-y-0 right-2 my-1.5 px-2 flex items-center text-gray-400 hover:text-gray-600 rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-morandi)] focus-visible:bg-[var(--color-morandi)]/5 transition-colors cursor-pointer">
                            <i class="fa-regular @(pwdType1 == "password" ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                    @if (samePasswordError)
                    {
                        <p class="mt-1 text-xs text-red-600 flex items-center gap-1">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            <span>新密碼不可與舊密碼相同</span>
                        </p>
                    }
                </div>

                <!-- 確認新密碼 -->
                <div>
                    <label for="confirmPassword" class="block text-sm font-medium mb-1 text-gray-700">確認新密碼</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 pointer-events-none">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <InputText id="confirmPassword" type="@pwdType2" @bind-Value="formModel.ConfirmPassword"
                            disabled="@isSaving"
                            placeholder="請再次輸入新密碼"
                            class="@BuildInputClass(false)" />
                        <button type="button" @onclick="TogglePwd2"
                            aria-label="切換確認密碼顯示"
                            tabindex="0"
                            class="absolute inset-y-0 right-2 my-1.5 px-2 flex items-center text-gray-400 hover:text-gray-600 rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-morandi)] focus-visible:bg-[var(--color-morandi)]/5 transition-colors cursor-pointer">
                            <i class="fa-regular @(pwdType2 == "password" ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" disabled="@isSaving"
                    class="w-full py-3 mt-2 bg-[var(--color-morandi)] hover:bg-[#5b7a95] text-white rounded-lg font-medium transition-all shadow-md flex justify-center items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-morandi)] disabled:opacity-60 cursor-pointer">
                    @if (isSaving)
                    {
                        <i class="fa-solid fa-spinner fa-spin"></i>
                        <span>儲存中...</span>
                    }
                    else
                    {
                        <i class="fa-solid fa-check"></i>
                        <span>設定新密碼</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private FirstLoginPasswordFormModel formModel = new();

    private string pwdType1 = "password";
    private string pwdType2 = "password";
    private bool isSaving = false;
    private bool samePasswordError = false;

    private const string InputBaseClass =
        "w-full pl-10 pr-10 py-2.5 rounded-lg border bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all";

    private string BuildInputClass(bool hasError)
        => $"{InputBaseClass} {(hasError ? "border-red-400" : "border-gray-300")}";

    private void TogglePwd1() => pwdType1 = pwdType1 == "password" ? "text" : "password";
    private void TogglePwd2() => pwdType2 = pwdType2 == "password" ? "text" : "password";

    private void ClearSamePasswordError()
    {
        if (samePasswordError)
        {
            samePasswordError = false;
        }
    }

    private async Task SaveNewPassword()
    {
        samePasswordError = false;

        if (formModel.NewPassword != formModel.ConfirmPassword)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "錯誤", text = "兩次輸入的新密碼不同！", confirmButtonColor = "#6B8EAD" });
            return;
        }

        if (formModel.NewPassword.Length < 6)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "warning", title = "提示", text = "密碼長度至少 6 碼！", confirmButtonColor = "#6B8EAD" });
            return;
        }

        // 從 Cookie 取得當前使用者 ID
        var authState = await AuthState;
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(userIdClaim, out var userId))
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "系統錯誤", text = "無法識別使用者，請重新登入。", confirmButtonColor = "#6B8EAD" });
            nav.NavigateTo("auth/logout", forceLoad: true);
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            var (success, _, samePassword) = await ResetService.ChangePasswordAsync(userId, formModel.NewPassword);

            if (samePassword)
            {
                samePasswordError = true;
                return;
            }

            if (!success)
            {
                await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "變更失敗", text = "請聯絡系統管理員。", confirmButtonColor = "#6B8EAD" });
                return;
            }

            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "success",
                title = "設定成功",
                text = "密碼已更新，請使用新密碼重新登入。",
                timer = 1000,
                showConfirmButton = false
            });
            await Task.Delay(1100);

            // 改完密碼登出，強制重新登入以使用新密碼並刷新 Cookie
            nav.NavigateTo("auth/logout", forceLoad: true);
        }
        catch
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "系統錯誤", text = "變更失敗，請聯絡系統管理員。", confirmButtonColor = "#6B8EAD" });
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private sealed class FirstLoginPasswordFormModel
    {
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
