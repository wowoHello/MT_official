@* ====================================================================== *@
@*  Announcements — 系統公告 / 使用說明                                     *@
@*  路由：/announcements                                                   *@
@*  功能：公告列表 CRUD、搜尋篩選、SlideOver 編輯公告表單                   *@
@* ====================================================================== *@
@page "/announcements"

<div class="flex-grow flex flex-col w-full mx-auto h-[calc(100vh-4rem)] overflow-hidden">

    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <NavLink href="" Match="NavLinkMatch.All" class="inline-flex items-center hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-slate-main">系統公告 / 使用說明</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-bullhorn text-morandi"></i> 系統公告 / 使用說明
                </h1>
            </div>
            <div class="flex gap-2">
                <a href="#" class="cursor-pointer px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-book"></i> 使用說明手冊
                </a>
                <button @onclick="OpenNewAnnouncement" type="button"
                    class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-plus"></i> 新增公告
                </button>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="px-4 sm:px-6 lg:px-8 pt-4 flex-shrink-0">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-[10px] font-bold mb-0.5 flex items-center justify-between">
                    公告總數 <i class="fa-solid fa-bullhorn text-morandi opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-slate-main">0</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-[10px] font-bold mb-0.5 flex items-center justify-between">
                    已發佈 <i class="fa-solid fa-circle-check text-sage opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-sage">0</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-[10px] font-bold mb-0.5 flex items-center justify-between">
                    草稿 <i class="fa-solid fa-file-pen text-gray-400 opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-gray-500">0</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-[10px] font-bold mb-0.5 flex items-center justify-between">
                    已下架 <i class="fa-solid fa-eye-slash text-terracotta opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-terracotta">0</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-[10px] font-bold mb-0.5 flex items-center justify-between">
                    置頂中 <i class="fa-solid fa-thumbtack text-red-500 opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-red-500">0</div>
            </div>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="flex-grow flex flex-col overflow-hidden px-4 sm:px-6 lg:px-8 pb-4">
        <div class="flex-grow flex flex-col bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

            <!-- Filters Bar -->
            <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col md:flex-row gap-3 items-center justify-between shrink-0">
                <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                    <div class="relative w-full md:w-64">
                        <i class="fa-solid fa-magnifying-glass left-3 top-2.5 absolute text-gray-400"></i>
                        <input type="text" class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi" placeholder="搜尋公告標題或內容...">
                    </div>
                    <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="all">所有分類</option>
                        <option value="system">系統公告</option>
                        <option value="compose">命題公告</option>
                        <option value="review">審題公告</option>
                        <option value="other">其它</option>
                    </select>
                    <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="all">所有狀態</option>
                        <option value="published">已發佈</option>
                        <option value="draft">草稿</option>
                        <option value="archived">已下架</option>
                    </select>
                </div>
                <div class="text-sm text-gray-500 font-medium flex-shrink-0">
                    共 <span class="text-morandi font-bold">0</span> 則公告
                </div>
            </div>

            <!-- Table Header -->
            <div class="grid grid-cols-12 gap-2 px-6 py-3 border-b border-gray-200 bg-white text-xs font-bold text-gray-500 uppercase tracking-wider shrink-0">
                <div class="col-span-1 text-center">置頂</div>
                <div class="col-span-1">分類</div>
                <div class="col-span-4 lg:col-span-5">公告標題</div>
                <div class="col-span-2 hidden lg:block">綁定梯次</div>
                <div class="col-span-2 lg:col-span-1">狀態</div>
                <div class="col-span-1 hidden md:block">發佈日</div>
                <div class="col-span-1 text-center">操作</div>
            </div>

            <!-- Announcement List -->
            <div class="flex-grow overflow-y-auto custom-scroll p-4">
                <EmptyState IconClass="fa-bullhorn" Message="目前尚無公告" SubMessage="點擊右上角「新增公告」向全站或特定梯次廣播。" />
            </div>
        </div>
    </div>
</div>

<!-- SlideOver：新增 / 編輯公告 -->
<CustomModal @bind-IsVisible="showAnnouncementModal" Type="CustomModal.ModalType.SlideOver" Title="@panelTitle" CloseOnBackdropClick="false">
    <ChildContent>
        <form class="space-y-6" @onsubmit:preventDefault>

            <!-- 區塊 1: 公告設定 -->
            <div class="space-y-4">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">1</span>
                    公告設定
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">分類 <span class="text-red-500">*</span></label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                            <option value="system">系統公告</option>
                            <option value="compose">命題公告</option>
                            <option value="review">審題公告</option>
                            <option value="other">其它</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">狀態 <span class="text-red-500">*</span></label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                            <option value="draft">草稿</option>
                            <option value="published">已發佈</option>
                            <option value="archived">已下架</option>
                        </select>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">綁定顯示梯次</label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                            <option value="ALL">全站廣播 (所有梯次)</option>
                        </select>
                        <p class="text-[10px] text-gray-400 mt-1">
                            <i class="fa-solid fa-circle-info mr-0.5"></i> 選擇「全站廣播」則所有梯次均可看到此公告；選擇特定梯次，則僅在該梯次下顯示。
                        </p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">上架日期 <span class="text-red-500">*</span></label>
                        <input type="date" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">下架日期 <span class="text-gray-400 font-normal">(選填)</span></label>
                        <input type="date" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                        <p class="text-[10px] text-gray-400 mt-1">留空表示不自動下架。超過此日期後，狀態將自動變為「已下架」。</p>
                    </div>
                    <div class="col-span-2">
                        <label class="flex items-center gap-3 cursor-pointer bg-red-50/50 px-4 py-3 rounded-lg border border-red-100 hover:bg-red-50 transition-colors">
                            <input type="checkbox" class="w-4 h-4 text-red-500 focus:ring-red-400 rounded">
                            <div>
                                <span class="text-sm font-bold text-red-600 flex items-center gap-1">
                                    <i class="fa-solid fa-thumbtack"></i> 置頂公告
                                </span>
                                <p class="text-[10px] text-gray-500 mt-0.5">開啟後此公告會在列表與首頁公告看板中優先顯示於最頂端。</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- 區塊 2: 公告內容 -->
            <div class="space-y-4">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">2</span>
                    公告內容
                </h3>
                <div>
                    <label class="block text-sm font-medium mb-1 text-gray-700">公告標題 <span class="text-red-500">*</span></label>
                    <input type="text" placeholder="請輸入公告標題" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2 text-gray-700">公告內容 <span class="text-red-500">*</span></label>
                    <!-- Quill 編輯器預留區（待 JS Interop 整合） -->
                    <div class="border border-gray-300 rounded-lg overflow-hidden min-h-[250px] bg-gray-50 flex items-center justify-center text-gray-400 text-sm">
                        <div class="text-center">
                            <i class="fa-solid fa-pen-to-square text-2xl mb-2 block"></i>
                            Quill 編輯器（待整合 JS Interop）
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </ChildContent>
    <FooterContent>
        <button type="button" class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors focus:outline-none shadow-sm flex items-center gap-2">
            <i class="fa-solid fa-file-pen"></i> 存為草稿
        </button>
        <div class="flex-grow"></div>
        <button type="button" @onclick="() => showAnnouncementModal = false" class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors focus:outline-none shadow-sm">
            取消
        </button>
        <button type="button" class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors focus:outline-none shadow-sm flex items-center gap-2">
            <i class="fa-solid fa-floppy-disk"></i> 儲存公告
        </button>
    </FooterContent>
</CustomModal>

@code {
    private bool showAnnouncementModal = false;
    private string panelTitle = "新增公告";

    private void OpenNewAnnouncement()
    {
        panelTitle = "新增公告";
        showAnnouncementModal = true;
    }
}
