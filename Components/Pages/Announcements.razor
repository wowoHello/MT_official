@page "/announcements"
@using MT.Components.Shared

<div class="flex-grow flex flex-col w-full max-w-[1920px] mx-auto h-[calc(100vh-4rem)] overflow-hidden">
    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="mb-2 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 shrink-0">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <a href="/home" class="inline-flex items-center hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </a>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-slate-main">系統公告與說明</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-bullhorn text-morandi"></i> 系統公告 / 使用說明
                </h1>
            </div>
            <div class="flex gap-2">
                <button class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 shadow-sm transition-all focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-book"></i> 使用說明手冊
                </button>
                <button @onclick="() => showAnnouncementModal = true" class="px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] shadow-sm transition-all focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-plus"></i> 發佈公告
                </button>
            </div>
        </div>
    </div>

    <!-- Main Content wrapper -->
    <div class="flex-grow p-4 sm:p-6 lg:p-8 flex flex-col overflow-hidden">

    <!-- 4 Stat Cards -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6 shrink-0">
        <div class="bg-gray-50 rounded-xl shadow-sm border border-gray-200 p-4 transition hover:shadow-md cursor-pointer">
            <div class="text-gray-500 text-xs font-bold mb-1">公告總數</div>
            <div class="text-2xl font-bold text-slate-main">0</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition hover:shadow-md cursor-pointer border-l-4 border-l-sage pt-3">
            <div class="text-sage text-xs font-bold mb-1">已發佈</div>
            <div class="text-2xl font-bold text-sage">0</div>
        </div>
    </div>

    <!-- Main Table Container -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 flex flex-col flex-grow overflow-hidden relative">
        <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col md:flex-row gap-3 items-center justify-between shrink-0">
            <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                <div class="relative w-full md:w-64">
                    <i class="fa-solid fa-magnifying-glass left-3 top-2.5 absolute text-gray-400"></i>
                    <input type="text" class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi" placeholder="搜尋標題或內容...">
                </div>
                <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg bg-white">
                    <option value="all">所有分類</option>
                </select>
                <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg bg-white">
                    <option value="all">所有狀態</option>
                </select>
            </div>
            <div class="text-sm text-gray-500 font-medium">
                共 <span class="text-morandi font-bold">0</span> 則
            </div>
        </div>

        <div class="grid grid-cols-12 gap-4 px-6 py-3 border-b border-gray-200 bg-white text-xs font-bold text-gray-500 uppercase tracking-wider shrink-0 shadow-sm">
            <div class="col-span-1 hidden lg:block">置頂</div>
            <div class="col-span-2 lg:col-span-1">分類</div>
            <div class="col-span-4 lg:col-span-5">公告標題</div>
            <div class="col-span-2">上架日期</div>
            <div class="col-span-2 text-center">狀態</div>
            <div class="col-span-1 text-right">操作</div>
        </div>

        <div class="flex-grow p-4">
            <EmptyState IconClass="fa-bullhorn" Message="目前尚無公告" SubMessage="點擊右上角「發佈公告」向全站或特定梯次廣播。" />
        </div>
    </div>
</div>
</div>

<CustomModal @bind-IsVisible="showAnnouncementModal" Type="CustomModal.ModalType.SlideOver" Title="編輯系統公告" CloseOnBackdropClick="false">
    <ChildContent>
        <div class="p-4 bg-gray-50 border border-gray-200 rounded text-center text-gray-500 mb-4">
            表單內容建置中...
        </div>
    </ChildContent>
</CustomModal>

@code {
    private bool showAnnouncementModal = false;
}
