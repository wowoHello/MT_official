@* ====================================================================== *@
@*  Announcements — 系統公告 / 使用說明                                     *@
@*  路由：/announcements                                                   *@
@*  功能：公告列表 CRUD、搜尋篩選、SlideOver 編輯公告表單                   *@
@* ====================================================================== *@
@page "/announcements"
@inject IAnnouncementService AnnouncementService
@inject NavigationManager Navigation
@inject ILogger<Announcements> Logger

<div class="flex-grow flex flex-col w-full mx-auto h-[calc(100vh-4rem)] overflow-hidden">

    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-2 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <NavLink href="" Match="NavLinkMatch.All" class="inline-flex items-center hover:text-[var(--color-morandi)] transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-[var(--color-slate-main)]">系統公告 / 使用說明</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-bullhorn text-[var(--color-morandi)]"></i> 系統公告 / 使用說明
                </h1>
                <p class="text-sm text-gray-500 mt-1">管理內部看板公告及操作手冊下載。</p>
            </div>
            <div class="flex gap-2">
                <button type="button" @onclick="ShowUserGuide"
                    class="cursor-pointer px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-book"></i> 使用說明手冊
                </button>
                <button @onclick="OpenNewAnnouncement" type="button"
                    class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-plus"></i> 新增公告
                </button>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="px-4 sm:px-6 lg:px-8 pt-4 flex-shrink-0">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-0.5 flex items-center justify-between">
                    公告總數 <i class="fa-solid fa-bullhorn text-morandi opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-slate-main">@ComputedStats.Total</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-0.5 flex items-center justify-between">
                    已發佈 <i class="fa-solid fa-circle-check text-sage opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-sage">@ComputedStats.Published</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-0.5 flex items-center justify-between">
                    草稿 <i class="fa-solid fa-file-pen text-gray-400 opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-gray-500">@ComputedStats.Draft</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-0.5 flex items-center justify-between">
                    已下架 <i class="fa-solid fa-eye-slash text-terracotta opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-terracotta">@ComputedStats.Archived</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-3 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-0.5 flex items-center justify-between">
                    置頂中（發佈狀態） <i class="fa-solid fa-thumbtack text-red-500 opacity-50"></i>
                </div>
                <div class="text-xl font-bold text-red-500">@ComputedStats.Pinned</div>
            </div>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="flex-grow flex flex-col overflow-hidden px-4 sm:px-6 lg:px-8 pb-4">
        <div class="flex-grow flex flex-col bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

            <!-- Filters Bar -->
            <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col md:flex-row gap-3 items-center justify-between shrink-0">
                <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                    <div class="w-full md:w-64">
                        <DebouncedSearchInput @bind-Value="filterKeyword"
                                              Placeholder="搜尋公告標題或內容..." />
                    </div>
                    <select @bind="filterCategory"
                        class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="0">所有分類</option>
                        <option value="1">系統公告</option>
                        <option value="2">命題公告</option>
                        <option value="3">審題公告</option>
                        <option value="4">其它</option>
                    </select>
                    <select @bind="filterDisplayStatus"
                        class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="all">所有狀態</option>
                        <option value="已發佈">已發佈</option>
                        <option value="未發佈">未發佈</option>
                        <option value="草稿">草稿</option>
                        <option value="已下架">已下架</option>
                    </select>
                </div>
                <div class="text-sm text-gray-500 font-medium flex-shrink-0">
                    共 <span class="text-morandi font-bold">@FilteredList.Count</span> 則公告
                </div>
            </div>

            <!-- Table Header -->
            <!-- 小螢幕: 置頂(1)+分類(1)+標題(7)+狀態(2)+操作(1)=12 -->
            <!-- md:     置頂(1)+分類(1)+標題(6)+狀態(1)+發佈日(2)+操作(1)=12 -->
            <!-- lg:     置頂(1)+分類(1)+標題(5)+梯次(2)+狀態(1)+發佈日(1)+操作(1)=12 -->
            <div class="grid grid-cols-12 gap-2 px-6 py-3 border-b border-gray-200 bg-white text-sm font-bold text-gray-500 tracking-wider shrink-0">
                <div class="col-span-1 text-center">置頂</div>
                <div class="col-span-1">分類</div>
                <div class="col-span-7 md:col-span-6 lg:col-span-5">公告標題</div>
                <div class="hidden lg:block lg:col-span-2">綁定梯次</div>
                <div class="col-span-2 md:col-span-1">狀態</div>
                <div class="hidden md:block md:col-span-2 lg:col-span-1">發佈日</div>
                <div class="col-span-1 text-center">操作</div>
            </div>

            <!-- Announcement List -->
            <div class="flex-grow overflow-y-auto custom-scroll">
                @if (FilteredList.Count == 0)
                {
                    <div class="h-full p-4">
                        <EmptyState IconClass="fa-bullhorn" Message="目前尚無公告" SubMessage="點擊右上角「新增公告」向全站或特定梯次廣播。" />
                    </div>
                }
                else
                {
                    @foreach (var ann in PagedList)
                    {
                        <div class="grid grid-cols-12 gap-2 px-6 py-3.5 border-b border-gray-50 hover:bg-gray-50/50 transition-colors items-center cursor-pointer"
                             @onclick="() => OpenViewModal(ann)">
                            <!-- 置頂 -->
                            <div class="col-span-1 flex justify-center">
                                @if (ann.IsPinned)
                                {
                                    <i class="fa-solid fa-thumbtack text-red-500 text-base" title="置頂中"></i>
                                }
                                else
                                {
                                    <span class="text-gray-300">—</span>
                                }
                            </div>
                            <!-- 分類 -->
                            <div class="col-span-1">
                                <span class="text-xs font-bold px-1.5 py-0.5 rounded @GetCategoryClass(ann.Category)">
                                    @GetCategoryLabel(ann.Category)
                                </span>
                            </div>
                            <!-- 標題 -->
                            <div class="col-span-7 md:col-span-6 lg:col-span-5 min-w-0">
                                <div class="flex items-center gap-2">
                                    @if (ann.IsPinned)
                                    {
                                        <span class="bg-red-50 text-red-500 text-xs font-bold px-1 py-0 rounded flex-shrink-0">TOP</span>
                                    }
                                    <span class="text-base font-bold text-slate-main truncate">@ann.Title</span>
                                </div>
                                <p class="text-sm text-gray-400 mt-0.5 truncate">@StripHtml(ann.Content, 60)</p>
                            </div>
                            <!-- 綁定梯次（複選後顯示「首梯次 +N」；hover 看完整列表） -->
                            <div class="hidden lg:block lg:col-span-2">
                                @if (ann.ProjectIds.Count == 0)
                                {
                                    <span class="text-sm text-morandi font-bold truncate block">全站廣播</span>
                                }
                                else
                                {
                                    <span class="text-sm text-gray-500 truncate block" title="@ann.ProjectBindingTooltip">
                                        @ann.ProjectNames[0]
                                        @if (ann.ProjectIds.Count > 1)
                                        {
                                            <span class="ml-1 text-xs text-gray-400 font-semibold">+@(ann.ProjectIds.Count - 1)</span>
                                        }
                                    </span>
                                }
                            </div>
                            <!-- 狀態 -->
                            <div class="col-span-2 md:col-span-1">
                                <StatusBadge StatusText="@ann.DisplayStatus" Compact="true" />
                            </div>
                            <!-- 發佈日 -->
                            <div class="hidden md:block md:col-span-2 lg:col-span-1">
                                <span class="text-sm text-gray-500">@ann.PublishDate.ToString("yyyy/MM/dd HH:mm")</span>
                            </div>
                            <!-- 操作 -->
                            <div class="col-span-1 flex justify-center gap-1">
                                <button class="w-8 h-8 rounded-full hover:bg-blue-50 text-gray-400 hover:text-morandi flex items-center justify-center transition-colors"
                                        @onclick="() => OpenEditAnnouncement(ann.Id)" @onclick:stopPropagation="true" title="編輯">
                                    <i class="fa-solid fa-pen text-sm"></i>
                                </button>
                                @if (ann.DisplayStatus is "已發佈" or "未發佈")
                                {
                                    <button class="w-8 h-8 rounded-full hover:bg-red-50 @(ann.IsPinned ? "text-red-500" : "text-gray-400 hover:text-red-500") flex items-center justify-center transition-colors"
                                            @onclick="() => HandleTogglePin(ann.Id)" @onclick:stopPropagation="true" title="@(ann.IsPinned ? "取消置頂" : "置頂")">
                                        <i class="fa-solid fa-thumbtack text-sm"></i>
                                    </button>
                                }
                                <button class="w-8 h-8 rounded-full hover:bg-red-50 text-gray-400 hover:text-red-500 flex items-center justify-center transition-colors"
                                        @onclick="() => HandleDelete(ann)" @onclick:stopPropagation="true" title="刪除">
                                    <i class="fa-solid fa-trash-can text-sm"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
            <Pagination CurrentPage="@currentPage" TotalPages="@TotalPages" OnPageChanged="GoToPage" />
        </div>
    </div>
</div>

<!-- ============================================== -->
<!-- SlideOver：新增 / 編輯公告                       -->
<!-- ============================================== -->
<CustomModal @bind-IsVisible="showSlideOver" Type="CustomModal.ModalType.SlideOver" Title="@panelTitle" MaxWidth="max-w-2xl" CloseOnBackdropClick="true" OnBackdropClose="HandleBackdropSaveDraft" KeepAlive="true">
    <ChildContent>
        <EditForm Model="formModel" class="space-y-7">

            <!-- ═══ 區塊 1：公告設定 ═══ -->
            <section>
                <div class="border-l-4 border-l-morandi pl-3 mb-5">
                    <h3 class="text-base font-bold text-slate-main">公告設定</h3>
                </div>

                <div class="space-y-5">
                    <!-- 分類 -->
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">公告分類</label>
                        <InputSelect @bind-Value="formModel.Category"
                            class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-morandi/30 focus:border-morandi focus:outline-none text-base bg-white cursor-pointer transition-shadow">
                            <option value="1">系統公告</option>
                            <option value="2">命題公告</option>
                            <option value="3">審題公告</option>
                            <option value="4">其它</option>
                        </InputSelect>
                    </div>

                    <!-- 綁定梯次（Searchable Combobox：搜尋 + 分組 + 多選 + 互斥全站） -->
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">綁定顯示梯次</label>
                        <div class="relative">
                            <button type="button" @onclick="() => showProjectComboPopover = !showProjectComboPopover"
                                    class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-morandi/30 focus:border-morandi focus:outline-none text-base bg-white cursor-pointer text-left flex items-center justify-between gap-2 transition-shadow hover:border-morandi">
                                <span class="flex items-center gap-2 min-w-0 flex-1">
                                    @if (IsGlobalBroadcast)
                                    {
                                        <i class="fa-solid fa-star text-amber-500 text-sm shrink-0"></i>
                                    }
                                    <span class="truncate text-gray-700">@ProjectComboboxDisplay</span>
                                </span>
                                <i class="fa-solid fa-chevron-down text-gray-400 text-xs shrink-0"></i>
                            </button>
                            @if (showProjectComboPopover)
                            {
                                <div class="fixed inset-0 z-[60]" @onclick="CloseProjectComboPopover"></div>
                                <div class="absolute left-0 right-0 top-full mt-1 z-[70] bg-white rounded-lg shadow-xl border border-gray-200 max-h-96 overflow-hidden flex flex-col">
                                    <!-- 搜尋框 -->
                                    <div class="p-2 border-b border-gray-100">
                                        <div class="relative">
                                            <i class="fa-solid fa-magnifying-glass text-gray-400 text-xs absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none"></i>
                                            <input @bind="comboboxSearchTerm" @bind:event="oninput"
                                                   placeholder="搜尋梯次..."
                                                   class="w-full pl-8 pr-3 py-2 border border-gray-200 rounded text-sm focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi" />
                                        </div>
                                    </div>
                                    <!-- 列表 -->
                                    <div class="overflow-y-auto custom-scroll flex-1">
                                        <!-- ★ 全站廣播（固定置頂） -->
                                        <button type="button" @onclick="SelectGlobalBroadcast"
                                                class="w-full px-3 py-2.5 flex items-center gap-3 hover:bg-morandi/5 transition-colors text-left border-b border-gray-100">
                                            <i class="fa-solid fa-star text-amber-500 text-sm w-4 shrink-0"></i>
                                            <span class="flex-1 text-sm font-semibold text-gray-700">全站廣播（所有梯次）</span>
                                            @if (IsGlobalBroadcast)
                                            {
                                                <i class="fa-solid fa-check text-morandi text-sm"></i>
                                            }
                                        </button>

                                        @{
                                            var activeFiltered    = FilterByGroup(projectDropdown.Active).ToList();
                                            var preparingFiltered = FilterByGroup(projectDropdown.Preparing).ToList();
                                            var closedFiltered    = FilterByGroup(projectDropdown.Closed).ToList();
                                        }

                                        <!-- 進行中 -->
                                        @if (activeFiltered.Count > 0)
                                        {
                                            <div class="px-3 py-1.5 text-xs font-bold text-gray-500 bg-gray-50">
                                                進行中 (@activeFiltered.Count)
                                            </div>
                                            @foreach (var proj in activeFiltered)
                                            {
                                                @RenderProjectRow(proj)
                                            }
                                        }

                                        <!-- 準備中 -->
                                        @if (preparingFiltered.Count > 0)
                                        {
                                            <div class="px-3 py-1.5 text-xs font-bold text-gray-500 bg-gray-50">
                                                準備中 (@preparingFiltered.Count)
                                            </div>
                                            @foreach (var proj in preparingFiltered)
                                            {
                                                @RenderProjectRow(proj)
                                            }
                                        }

                                        <!-- 已結案（預設摺疊） -->
                                        @if (closedFiltered.Count > 0)
                                        {
                                            <button type="button" @onclick="() => closedGroupExpanded = !closedGroupExpanded"
                                                    class="w-full px-3 py-1.5 flex items-center gap-2 bg-gray-50 hover:bg-gray-100 transition-colors">
                                                <i class="fa-solid @(closedGroupExpanded ? "fa-chevron-down" : "fa-chevron-right") text-gray-400 text-xs w-3"></i>
                                                <span class="text-xs font-bold text-gray-500">已結案 (@closedFiltered.Count)</span>
                                            </button>
                                            @if (closedGroupExpanded)
                                            {
                                                @foreach (var proj in closedFiltered)
                                                {
                                                    @RenderProjectRow(proj)
                                                }
                                            }
                                        }

                                        <!-- 空結果 -->
                                        @if (activeFiltered.Count == 0 && preparingFiltered.Count == 0 && closedFiltered.Count == 0)
                                        {
                                            <div class="px-3 py-6 text-center text-sm text-gray-400">
                                                找不到符合的梯次
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <p class="text-xs text-gray-500 mt-2 flex items-start gap-1.5">
                            <i class="fa-solid fa-circle-info mt-0.5 shrink-0"></i>
                            <span>選擇「全站廣播」則所有梯次均可看到；選擇個別梯次則僅綁定的梯次看得到（可複選）。「全站」與「個別梯次」互斥。</span>
                        </p>
                    </div>

                    <!-- 排程副卡（上下架日期合併） -->
                    <div class="bg-morandi/5 rounded-lg p-4 ring-1 ring-morandi/10">
                        <div class="flex items-center gap-2 mb-3">
                            <i class="fa-regular fa-calendar text-morandi text-sm"></i>
                            <span class="text-sm font-semibold text-gray-700">排程</span>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <!-- 上架日期 -->
                            <div>
                                <label class="block text-xs font-semibold mb-2 text-gray-600">上架日期 <span class="text-red-500">*</span></label>
                                <div class="flex gap-2">
                                    <input type="date" @bind="publishDatePart" @bind:after="OnPublishDateChanged"
                                           class="flex-1 min-w-0 px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-morandi/30 focus:border-morandi focus:outline-none text-base bg-white cursor-pointer transition-shadow" />
                                    <div class="relative shrink-0">
                                        <button type="button" @onclick="() => showPublishTimePopover = !showPublishTimePopover"
                                                class="w-24 px-3 py-2.5 border border-gray-300 rounded-lg text-base bg-white hover:border-morandi focus:ring-2 focus:ring-morandi/30 focus:outline-none flex items-center justify-between gap-1 cursor-pointer transition-all">
                                            <span class="@(formModel.PublishDate.HasValue ? "text-gray-700 font-medium" : "text-gray-400") whitespace-nowrap tabular-nums">@PublishTimeDisplay</span>
                                            <i class="fa-regular fa-clock text-gray-400 text-xs"></i>
                                        </button>
                                        @if (showPublishTimePopover)
                                        {
                                            <div class="fixed inset-0 z-[60]" @onclick="() => showPublishTimePopover = false"></div>
                                            <div class="absolute right-0 top-full mt-1 z-[70] bg-white rounded-lg shadow-xl border border-gray-200 p-3 w-64">
                                                <div class="grid grid-cols-2 gap-3">
                                                    <div>
                                                        <div class="text-xs font-bold text-gray-500 mb-1 text-center">時</div>
                                                        <div class="max-h-48 overflow-y-auto custom-scroll grid grid-cols-3 gap-1 pr-1">
                                                            @foreach (var h in HourSlots)
                                                            {
                                                                var hour = h;
                                                                var isSelected = formModel.PublishDate?.Hour == hour;
                                                                <button type="button" @onclick="() => SelectPublishTimeAsync(hour, formModel.PublishDate?.Minute ?? 0)"
                                                                        class="@($"py-1.5 text-sm rounded transition-colors cursor-pointer {(isSelected ? "bg-morandi text-white font-bold" : "text-gray-700 hover:bg-morandi/10")}")">
                                                                    @hour.ToString("00")
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <div class="text-xs font-bold text-gray-500 mb-1 text-center">分</div>
                                                        <div class="grid grid-cols-2 gap-1">
                                                            @foreach (var m in MinuteSlots)
                                                            {
                                                                var minute = m;
                                                                var isSelected = formModel.PublishDate?.Minute == minute;
                                                                <button type="button" @onclick="() => SelectPublishTimeAsync(formModel.PublishDate?.Hour ?? 0, minute)"
                                                                        class="@($"py-1.5 text-sm rounded transition-colors cursor-pointer {(isSelected ? "bg-morandi text-white font-bold" : "text-gray-700 hover:bg-morandi/10")}")">
                                                                    @minute.ToString("00")
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <!-- 下架日期 -->
                            <div>
                                <label class="block text-xs font-semibold mb-2 text-gray-600">下架日期 <span class="text-gray-400 font-normal">(選填)</span></label>
                                <div class="flex gap-2">
                                    <input type="date" @bind="unpublishDatePart" @bind:after="OnUnpublishDateChanged"
                                           class="flex-1 min-w-0 px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-morandi/30 focus:border-morandi focus:outline-none text-base bg-white cursor-pointer transition-shadow" />
                                    <div class="relative shrink-0">
                                        <button type="button" @onclick="() => showUnpublishTimePopover = !showUnpublishTimePopover"
                                                class="w-24 px-3 py-2.5 border border-gray-300 rounded-lg text-base bg-white hover:border-morandi focus:ring-2 focus:ring-morandi/30 focus:outline-none flex items-center justify-between gap-1 cursor-pointer transition-all">
                                            <span class="@(formModel.UnpublishDate.HasValue ? "text-gray-700 font-medium" : "text-gray-400") whitespace-nowrap tabular-nums">@UnpublishTimeDisplay</span>
                                            <i class="fa-regular fa-clock text-gray-400 text-xs"></i>
                                        </button>
                                        @if (showUnpublishTimePopover)
                                        {
                                            <div class="fixed inset-0 z-[60]" @onclick="() => showUnpublishTimePopover = false"></div>
                                            <div class="absolute right-0 top-full mt-1 z-[70] bg-white rounded-lg shadow-xl border border-gray-200 p-3 w-64">
                                                <div class="grid grid-cols-2 gap-3">
                                                    <div>
                                                        <div class="text-xs font-bold text-gray-500 mb-1 text-center">時</div>
                                                        <div class="max-h-48 overflow-y-auto custom-scroll grid grid-cols-3 gap-1 pr-1">
                                                            @foreach (var h in HourSlots)
                                                            {
                                                                var hour = h;
                                                                var isSelected = formModel.UnpublishDate?.Hour == hour;
                                                                <button type="button" @onclick="() => SelectUnpublishTimeAsync(hour, formModel.UnpublishDate?.Minute ?? 0)"
                                                                        class="@($"py-1.5 text-sm rounded transition-colors cursor-pointer {(isSelected ? "bg-morandi text-white font-bold" : "text-gray-700 hover:bg-morandi/10")}")">
                                                                    @hour.ToString("00")
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <div class="text-xs font-bold text-gray-500 mb-1 text-center">分</div>
                                                        <div class="grid grid-cols-2 gap-1">
                                                            @foreach (var m in MinuteSlots)
                                                            {
                                                                var minute = m;
                                                                var isSelected = formModel.UnpublishDate?.Minute == minute;
                                                                <button type="button" @onclick="() => SelectUnpublishTimeAsync(formModel.UnpublishDate?.Hour ?? 0, minute)"
                                                                        class="@($"py-1.5 text-sm rounded transition-colors cursor-pointer {(isSelected ? "bg-morandi text-white font-bold" : "text-gray-700 hover:bg-morandi/10")}")">
                                                                    @minute.ToString("00")
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 mt-3 flex items-start gap-1.5">
                            <i class="fa-solid fa-circle-info mt-0.5 shrink-0"></i>
                            <span>留空下架日期表示不自動下架。超過下架日期時間後，狀態將自動變為「已下架」。</span>
                        </p>
                    </div>

                    <!-- 置頂 toggle -->
                    <label class="flex items-center justify-between gap-4 cursor-pointer p-3 -mx-3 rounded-lg hover:bg-gray-50 transition-colors">
                        <div class="flex items-center gap-3 flex-1 min-w-0">
                            <div class="w-9 h-9 rounded-full bg-morandi/10 flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-thumbtack text-morandi text-sm"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="text-sm font-semibold text-gray-700">置頂公告</div>
                                <p class="text-xs text-gray-500 mt-0.5">開啟後此公告會在首頁與列表頂端優先顯示。</p>
                            </div>
                        </div>
                        <div class="relative shrink-0">
                            <InputCheckbox @bind-Value="formModel.IsPinned" class="sr-only peer" />
                            <div class="w-11 h-6 bg-gray-300 rounded-full peer-checked:bg-sage transition-colors"></div>
                            <div class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full shadow transition-transform peer-checked:translate-x-5"></div>
                        </div>
                    </label>
                </div>
            </section>

            <!-- ═══ 區塊 2：公告內容 ═══ -->
            <section>
                <div class="border-l-4 border-l-morandi pl-3 mb-5">
                    <h3 class="text-base font-bold text-slate-main">公告內容</h3>
                </div>

                <div class="space-y-5">
                    <!-- 標題 -->
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">公告標題 <span class="text-red-500">*</span></label>
                        <InputText @bind-Value="formModel.Title" placeholder="請輸入公告標題"
                            class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-morandi/30 focus:border-morandi focus:outline-none text-base transition-shadow" />
                    </div>
                    <!-- 內容 -->
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">公告內容 <span class="text-red-500">*</span></label>
                        <InlineQuillEditor @bind-Value="formModel.Content" EditorClass="min-h-[240px]" />
                    </div>
                </div>
            </section>
        </EditForm>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="SaveAsDraft"
            class="cursor-pointer px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 hover:border-gray-400 transition-colors focus:outline-none flex items-center gap-2">
            <i class="fa-solid fa-file-pen"></i> 存為草稿
        </button>
        <div class="flex-grow"></div>
        <button type="button" @onclick="() => showSlideOver = false"
            class="cursor-pointer px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors focus:outline-none">
            取消
        </button>
        <button type="button" @onclick="SaveAndPublish"
            class="cursor-pointer px-8 py-2.5 bg-morandi text-white rounded-lg text-sm font-semibold hover:bg-[#5b7a95] hover:shadow-md active:scale-95 transition-all focus:outline-none flex items-center gap-2">
            <i class="fa-solid fa-floppy-disk"></i> 儲存公告
        </button>
    </FooterContent>
</CustomModal>

<!-- ============================================== -->
<!-- Modal：公告檢視                                  -->
<!-- ============================================== -->
<CustomModal @bind-IsVisible="showViewModal" Type="CustomModal.ModalType.Center" Title="公告詳情">
    <ChildContent>
        @if (viewingAnnouncement is not null)
        {
            <!-- 標籤列 -->
            <div class="mb-3 flex gap-2 flex-wrap">
                <span class="text-xs font-bold px-2 py-0.5 rounded @GetCategoryClass(viewingAnnouncement.Category)">
                    @GetCategoryLabel(viewingAnnouncement.Category)
                </span>
                <StatusBadge StatusText="@viewingAnnouncement.DisplayStatus" Compact="true" />
                @if (viewingAnnouncement.IsPinned)
                {
                    <span class="bg-red-100 text-red-500 text-xs font-bold px-2 py-0.5 rounded">
                        <i class="fa-solid fa-thumbtack mr-0.5"></i>置頂
                    </span>
                }
            </div>
            <!-- 標題 -->
            <h2 class="text-xl font-bold text-slate-main leading-tight mb-2">@viewingAnnouncement.Title</h2>
            <!-- 元資料 -->
            <div class="text-xs text-gray-500 mb-4 flex items-center gap-3 flex-wrap">
                <span class="flex items-center gap-1">
                    <i class="fa-regular fa-clock"></i> 發佈：@viewingAnnouncement.PublishDate.ToString("yyyy/MM/dd HH:mm:ss")
                </span>
                @if (viewingAnnouncement.UnpublishDate.HasValue)
                {
                    <span class="flex items-center gap-1">
                        <i class="fa-solid fa-eye-slash"></i> 下架：@viewingAnnouncement.UnpublishDate.Value.ToString("yyyy/MM/dd HH:mm:ss")
                    </span>
                }
                <span class="flex items-center gap-1.5 flex-wrap">
                    <i class="fa-solid fa-folder-open"></i>
                    @if (viewingAnnouncement.ProjectIds.Count == 0)
                    {
                        <span class="bg-morandi/10 text-morandi text-xs font-bold px-2 py-0.5 rounded">全站廣播</span>
                    }
                    else
                    {
                        @foreach (var name in viewingAnnouncement.ProjectNames)
                        {
                            <span class="bg-gray-100 text-gray-700 text-xs font-bold px-2 py-0.5 rounded">@name</span>
                        }
                    }
                </span>
            </div>
            <!-- 內容 -->
            <div class="text-gray-700 leading-relaxed text-sm space-y-4 border-t border-gray-100 pt-4">
                @((MarkupString)viewingAnnouncement.Content)
            </div>
        }
    </ChildContent>
    <FooterContent>
        @if (viewingAnnouncement is not null)
        {
            <button type="button" @onclick="() => ViewToEdit(viewingAnnouncement.Id)"
                class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors focus:outline-none shadow-sm flex items-center gap-2">
                <i class="fa-solid fa-pen-to-square"></i> 編輯此公告
            </button>
        }
        <button type="button" @onclick="() => showViewModal = false"
            class="cursor-pointer px-6 py-2 bg-morandi hover:bg-[#5b7a95] text-white rounded-lg font-medium transition-colors focus:outline-none">
            確認關閉
        </button>
    </FooterContent>
</CustomModal>

@code {
    // ─── 注入與授權 ───
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    [CascadingParameter(Name = "ModuleCards")]
    private List<UserModuleCard>? ModuleCards { get; set; }

    // ─── 資料狀態 ───
    private List<AnnouncementListItem> announcements = new();
    private ProjectGroupedDropdown projectDropdown = new();   // 三分組（進行中/準備中/已結案）

    // ─── 篩選 ───
    private string _filterKeyword = "";
    private string filterKeyword
    {
        get => _filterKeyword;
        set { _filterKeyword = value; currentPage = 1; }
    }

    private byte _filterCategory = 0;
    private byte filterCategory
    {
        get => _filterCategory;
        set { _filterCategory = value; currentPage = 1; }
    }

    private string _filterDisplayStatus = "all";
    private string filterDisplayStatus
    {
        get => _filterDisplayStatus;
        set { _filterDisplayStatus = value; currentPage = 1; }
    }

    // ─── 分頁 ───
    private const int PageSize = 10;
    private int currentPage = 1;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredList.Count / (double)PageSize));
    private IEnumerable<AnnouncementListItem> PagedList =>
        FilteredList.Skip((currentPage - 1) * PageSize).Take(PageSize);
    private void GoToPage(int page)
    {
        if (page < 1 || page > TotalPages || page == currentPage) return;
        currentPage = page;
    }

    // ─── 表單 ───
    private AnnouncementFormModel formModel = new();
    private bool showSlideOver;
    private string panelTitle = "新增公告";
    private int? editingId;
    private const int SlideOverTransitionMs = 300;

    // ─── 日期/時間 facade（UI 拆兩格綁定，formModel.PublishDate/UnpublishDate 保持 DateTime? 不變） ───
    // DB MT_Announcements.PublishDate / UnpublishDate 仍是 datetime2，Service / SQL / AuditLog 0 改動
    private DateTime? publishDatePart
    {
        get => formModel.PublishDate?.Date;
        set => formModel.PublishDate = CombineDateTime(value, formModel.PublishDate?.TimeOfDay);
    }
    private TimeSpan? publishTimePart
    {
        get => formModel.PublishDate?.TimeOfDay;
        set => formModel.PublishDate = CombineDateTime(formModel.PublishDate?.Date, value);
    }
    private DateTime? unpublishDatePart
    {
        get => formModel.UnpublishDate?.Date;
        set => formModel.UnpublishDate = CombineDateTime(value, formModel.UnpublishDate?.TimeOfDay);
    }
    private TimeSpan? unpublishTimePart
    {
        get => formModel.UnpublishDate?.TimeOfDay;
        set => formModel.UnpublishDate = CombineDateTime(formModel.UnpublishDate?.Date, value);
    }

    // 兩格組裝：日期空就整個 null；只選日期沒選時間預設 00:00
    private static DateTime? CombineDateTime(DateTime? date, TimeSpan? time)
        => date is null ? null : date.Value.Date + (time ?? TimeSpan.Zero);

    // 時間 popover 顯示文字（trigger 按鈕用；未設定時用 --:-- 暗示「時:分」結構）
    private string PublishTimeDisplay   => formModel.PublishDate?.ToString("HH:mm")   ?? "--:--";
    private string UnpublishTimeDisplay => formModel.UnpublishDate?.ToString("HH:mm") ?? "--:--";

    // 時間 popover 開關狀態
    private bool showPublishTimePopover;
    private bool showUnpublishTimePopover;

    // 5 分刻度（12 個）+ 24 小時（24 個）
    private static readonly int[] HourSlots   = Enumerable.Range(0, 24).ToArray();
    private static readonly int[] MinuteSlots = [0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55];

    // 時間 popover：選取時/分 → 更新 facade → 觸發既有日期防呆
    // 不主動關 popover，讓使用者可連續調整時/分；點外側 backdrop 才關
    private async Task SelectPublishTimeAsync(int hour, int minute)
    {
        publishTimePart = new TimeSpan(hour, minute, 0);
        await OnPublishDateChanged();
    }
    private async Task SelectUnpublishTimeAsync(int hour, int minute)
    {
        unpublishTimePart = new TimeSpan(hour, minute, 0);
        await OnUnpublishDateChanged();
    }

    // ─── 梯次 Combobox 狀態與 helpers ───
    private bool showProjectComboPopover;
    private string comboboxSearchTerm = "";
    private bool closedGroupExpanded;      // 已結案分組預設摺疊

    /// <summary>是否為全站廣播（ProjectIds 空 list）。</summary>
    private bool IsGlobalBroadcast => formModel.ProjectIds.Count == 0;

    /// <summary>Combobox trigger button 顯示文字：「全站廣播」/ 單一梯次名稱 /「首梯次 +N」。</summary>
    private string ProjectComboboxDisplay
    {
        get
        {
            if (IsGlobalBroadcast) return "全站廣播";
            var firstId = formModel.ProjectIds[0];
            var name = LookupProjectName(firstId) ?? "（未知梯次）";
            return formModel.ProjectIds.Count == 1
                ? name
                : $"{name}  +{formModel.ProjectIds.Count - 1}";
        }
    }

    /// <summary>在三個分組內找梯次名稱（dropdown 載入前回 null）。</summary>
    private string? LookupProjectName(int id)
        => projectDropdown.Active.FirstOrDefault(p => p.Id == id)?.Name
        ?? projectDropdown.Preparing.FirstOrDefault(p => p.Id == id)?.Name
        ?? projectDropdown.Closed.FirstOrDefault(p => p.Id == id)?.Name;

    /// <summary>選擇全站廣播 = 清空 ProjectIds（與個別梯次互斥）。</summary>
    private void SelectGlobalBroadcast()
    {
        formModel.ProjectIds.Clear();
    }

    /// <summary>切換單一梯次的勾選狀態。</summary>
    private void ToggleProject(int projectId)
    {
        if (formModel.ProjectIds.Contains(projectId))
            formModel.ProjectIds.Remove(projectId);
        else
            formModel.ProjectIds.Add(projectId);
    }

    /// <summary>關閉 Combobox popover + 清搜尋字串。</summary>
    private void CloseProjectComboPopover()
    {
        showProjectComboPopover = false;
        comboboxSearchTerm = "";
    }

    /// <summary>分組內依搜尋字串 filter（不分大小寫）。</summary>
    private IEnumerable<ProjectDropdownItem> FilterByGroup(IReadOnlyList<ProjectDropdownItem> source)
    {
        if (string.IsNullOrWhiteSpace(comboboxSearchTerm)) return source;
        var kw = comboboxSearchTerm.Trim();
        return source.Where(p => p.Name.Contains(kw, StringComparison.OrdinalIgnoreCase));
    }

    /// <summary>渲染單一梯次列（checkbox + 名稱 + ProjectType 徽章 + 年度）。</summary>
    private RenderFragment RenderProjectRow(ProjectDropdownItem proj) => __builder =>
    {
        var p = proj;
        var selected = formModel.ProjectIds.Contains(p.Id);
        var typeBadgeClass = p.ProjectType == 1 ? "bg-purple-100 text-purple-700" : "bg-blue-100 text-blue-700";
        var typeBadgeText  = p.ProjectType == 1 ? "LCT" : "CWT";

        <label class="w-full px-3 py-2 flex items-center gap-3 hover:bg-morandi/5 cursor-pointer transition-colors">
            <input type="checkbox" checked="@selected" @onchange="() => ToggleProject(p.Id)"
                   class="w-4 h-4 text-morandi focus:ring-morandi rounded shrink-0" />
            <span class="flex-1 text-sm text-gray-700 truncate">@p.Name</span>
            <span class="text-xs font-bold px-1.5 py-0.5 rounded shrink-0 @typeBadgeClass">@typeBadgeText</span>
            <span class="text-xs text-gray-400 tabular-nums shrink-0">@p.Year</span>
        </label>
    };

    // ─── 檢視 Modal ───
    private bool showViewModal;
    private AnnouncementListItem? viewingAnnouncement;

    // ─── 前端計算統計卡片 ───
    private AnnouncementStats ComputedStats
    {
        get
        {
            var published = announcements.Count(a => a.DisplayStatus == "已發佈");
            var draft = announcements.Count(a => a.DisplayStatus == "草稿");
            var archived = announcements.Count(a => a.DisplayStatus == "已下架");
            var pinned = announcements.Count(a => a.IsPinned && a.DisplayStatus == "已發佈");
            return new AnnouncementStats
            {
                Total = announcements.Count,
                Published = published,
                Draft = draft,
                Archived = archived,
                Pinned = pinned
            };
        }
    }

    // ─── 篩選後的列表（含排序） ───
    private List<AnnouncementListItem> FilteredList
    {
        get
        {
            var query = announcements.AsEnumerable();

            // 分類篩選
            if (filterCategory > 0)
                query = query.Where(a => a.Category == filterCategory);

            // 顯示狀態篩選（依日期推導後的狀態）
            if (filterDisplayStatus != "all")
                query = query.Where(a => a.DisplayStatus == filterDisplayStatus);

            // 關鍵字篩選
            if (!string.IsNullOrWhiteSpace(filterKeyword))
            {
                var kw = filterKeyword.Trim();
                query = query.Where(a =>
                    a.Title.Contains(kw, StringComparison.OrdinalIgnoreCase) ||
                    a.Content.Contains(kw, StringComparison.OrdinalIgnoreCase));
            }

            // 排序：置頂 > 顯示狀態優先（已發佈>未發佈>草稿>已下架）> 分類順序 > 發佈日新到舊
            return query
                .OrderByDescending(a => a.IsPinned)
                .ThenBy(a => a.DisplayStatus switch { "已發佈" => 0, "未發佈" => 1, "草稿" => 2, "已下架" => 3, _ => 4 })
                .ThenBy(a => a.Category)
                .ThenByDescending(a => a.PublishDate)
                .ToList();
        }
    }

    // ─── 生命週期 ───
    // 權限判斷放 OnParametersSetAsync：CascadingParameter ModuleCards 由 MainLayout async 載入，
    // OnInitializedAsync 階段往往還是 null，此時若直接踢人會誤殺有權限的管理員。
    private bool hasInitialized;

    protected override async Task OnParametersSetAsync()
    {
        // ModuleCards 尚未載入 → 等待父層下一次 CascadingValue 推送，先不動作
        if (ModuleCards is null) return;

        // 已載入：明確判定無權限才踢回首頁
        if (!HasAnnouncementPermission())
        {
            Navigation.NavigateTo("/", forceLoad: false);
            return;
        }

        // 通過權限 + 尚未初始化過 → 載入資料（避免 OnParametersSetAsync 重覆觸發時重抓）
        if (!hasInitialized)
        {
            hasInitialized = true;
            await RunAnnouncementMaintenanceAsync();
            await LoadDataAsync();
        }
    }

    // 使用 PageUrl 比對（與 MainLayout.EnforceModuleAccess 一致），
    // 避免因 ModuleKey 大小寫或值不同而誤判無權限。
    private bool HasAnnouncementPermission()
        => ModuleCards?.Any(m =>
               string.Equals(m.PageUrl, "announcements", StringComparison.OrdinalIgnoreCase)
               && m.IsEnabled) == true;

    private async Task RunAnnouncementMaintenanceAsync()
    {
        try
        {
            var userId = await GetCurrentUserIdAsync();
            await AnnouncementService.AutoUnpinExpiredAsync(userId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "公告自動清理失敗");
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            announcements = await AnnouncementService.GetAnnouncementListAsync();
            projectDropdown = await AnnouncementService.GetProjectDropdownAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入公告資料失敗");
        }
    }

    // ─── 取得當前使用者 ID ───
    private async Task<int> GetCurrentUserIdAsync()
    {
        if (AuthState is null) return 0;
        var authState = await AuthState;
        var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return int.TryParse(idClaim, out var id) ? id : 0;
    }

    // ─── 新增公告 ───
    private void OpenNewAnnouncement()
    {
        editingId = null;
        formModel = new AnnouncementFormModel { PublishDate = TruncateSeconds(DateTime.Now) };
        panelTitle = "新增公告";
        showSlideOver = true;
    }

    // ─── 編輯公告 ───
    private async Task OpenEditAnnouncement(int id)
    {
        try
        {
            var dto = await AnnouncementService.GetAnnouncementEditAsync(id);
            if (dto is null) return;

            editingId = id;
            formModel = new AnnouncementFormModel
            {
                Category = dto.Category,
                Status = dto.Status,
                ProjectIds = dto.ProjectIds.ToList(),    // 從 DB 載入的複選綁定
                PublishDate = dto.PublishDate,
                UnpublishDate = dto.UnpublishDate,
                IsPinned = dto.IsPinned,
                Title = dto.Title,
                Content = dto.Content
            };
            panelTitle = "編輯公告";
            showSlideOver = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入公告編輯資料失敗 Id={Id}", id);
        }
    }

    // ─── 日期即時防呆 ───
    private async Task OnPublishDateChanged()
    {
        if (formModel.PublishDate.HasValue && formModel.UnpublishDate.HasValue
            && formModel.PublishDate.Value > formModel.UnpublishDate.Value)
        {
            formModel.UnpublishDate = null;
            _ = JS.InvokeVoidAsync("Swal.fire", new { icon = "info", title = "下架日期已清除", text = "上架日期晚於原下架日期，請重新設定。", toast = true, position = "top-end", showConfirmButton = false, timer = 2500 });
        }
    }

    private async Task OnUnpublishDateChanged()
    {
        if (formModel.PublishDate.HasValue && formModel.UnpublishDate.HasValue
            && formModel.UnpublishDate.Value < formModel.PublishDate.Value)
        {
            formModel.UnpublishDate = null;
            _ = JS.InvokeVoidAsync("Swal.fire", new { icon = "info", title = "下架日期不可早於上架日期", text = "已自動清除，請重新選擇。", toast = true, position = "top-end", showConfirmButton = false, timer = 2500 });
        }
    }

    // ─── 前端驗證 ───
    private async Task<bool> ValidateFormAsync()
    {
        if (string.IsNullOrWhiteSpace(formModel.Title))
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請填寫公告標題", confirmButtonColor = "#6B8EAD" });
            return false;
        }
        if (formModel.PublishDate is null)
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請設定上架日期", confirmButtonColor = "#6B8EAD" });
            return false;
        }
        if (formModel.UnpublishDate.HasValue && formModel.PublishDate.HasValue
            && formModel.UnpublishDate.Value < formModel.PublishDate.Value)
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "下架日期不可早於上架日期", confirmButtonColor = "#6B8EAD" });
            return false;
        }
        if (IsContentEmpty(formModel.Content))
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請填寫公告內容", confirmButtonColor = "#6B8EAD" });
            return false;
        }
        return true;
    }

    // ─── 儲存公告（Status=1 發佈） ───
    private async Task SaveAndPublish()
    {
        if (!await ValidateFormAsync()) return;

        // 勾了置頂但日期算出來會是已下架 → 提示並取消置頂
        if (formModel.IsPinned && formModel.UnpublishDate.HasValue && DateTime.Now > formModel.UnpublishDate.Value)
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "已下架狀態無法置頂", text = "下架時間已過，已自動取消置頂設定。", confirmButtonColor = "#6B8EAD" });
            formModel.IsPinned = false;
            return;
        }

        formModel.Status = (byte)AnnouncementStatus.Published;
        await DoSaveAsync("公告已儲存");
    }

    // ─── 存為草稿（Status=0） ───
    private async Task SaveAsDraft()
    {
        if (!await ValidateFormAsync()) return;

        if (formModel.IsPinned)
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "草稿狀態無法置頂", text = "已自動取消置頂設定。", confirmButtonColor = "#6B8EAD" });
            formModel.IsPinned = false;
            return;
        }

        formModel.Status = (byte)AnnouncementStatus.Draft;
        await DoSaveAsync("已存為草稿");
    }

    // ─── 日期秒數歸零（datetime-local 精度到分鐘，避免秒數造成狀態判斷誤差） ───
    private static DateTime TruncateSeconds(DateTime dt) => new(dt.Year, dt.Month, dt.Day, dt.Hour, dt.Minute, 0);

    // ─── 共用儲存邏輯（先收合面板，避開轉場後再儲存與重載列表） ───
    private async Task DoSaveAsync(string successMsg)
    {
        try
        {
            // 秒數歸零，與 datetime-local 輸入精度一致
            if (formModel.PublishDate.HasValue)
                formModel.PublishDate = TruncateSeconds(formModel.PublishDate.Value);
            if (formModel.UnpublishDate.HasValue)
                formModel.UnpublishDate = TruncateSeconds(formModel.UnpublishDate.Value);

            await CloseSlideOverAndWaitAsync();

            var userId = await GetCurrentUserIdAsync();

            if (editingId.HasValue)
                await AnnouncementService.UpdateAsync(editingId.Value, formModel, userId);
            else
                await AnnouncementService.CreateAsync(formModel, userId);

            _ = JS.InvokeVoidAsync("Swal.fire", new { icon = "success", title = successMsg, toast = true, position = "top-end", showConfirmButton = false, timer = 2000 });
            await LoadDataAsync();
        }
        catch (UnauthorizedAccessException ex)
        {
            Logger.LogWarning(ex, "公告寫入權限不足");
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "權限不足", text = ex.Message, confirmButtonColor = "#6B8EAD" });
            Navigation.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "儲存公告失敗");
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "error", title = "儲存失敗", text = "請稍後再試。", confirmButtonColor = "#6B8EAD" });
        }
    }

    // ─── Backdrop 點擊：自動存為草稿（僅當標題 + 內容皆有值時才執行） ───
    private async Task HandleBackdropSaveDraft()
    {
        // 任一必填欄位空白就不自動存草稿（含上架日期）
        if (string.IsNullOrWhiteSpace(formModel.Title)) return;
        if (formModel.PublishDate is null) return;
        if (IsContentEmpty(formModel.Content)) return;

        try
        {
            await WaitForSlideOverTransitionAsync();

            formModel.PublishDate = TruncateSeconds(formModel.PublishDate.Value);
            if (formModel.UnpublishDate.HasValue)
                formModel.UnpublishDate = TruncateSeconds(formModel.UnpublishDate.Value);

            formModel.Status = (byte)AnnouncementStatus.Draft;
            formModel.IsPinned = false;
            var userId = await GetCurrentUserIdAsync();

            if (editingId.HasValue)
                await AnnouncementService.UpdateAsync(editingId.Value, formModel, userId);
            else
                await AnnouncementService.CreateAsync(formModel, userId);

            _ = JS.InvokeVoidAsync("Swal.fire", new { icon = "success", title = "已自動存為草稿", toast = true, position = "top-end", showConfirmButton = false, timer = 2000 });
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "自動存草稿失敗");
        }
    }

    // ─── Quill 內容空白判斷（去 HTML 標籤後看是否有純文字） ───
    private static bool IsContentEmpty(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return true;
        var plain = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]+>", "").Trim();
        return string.IsNullOrWhiteSpace(plain);
    }

    private async Task CloseSlideOverAndWaitAsync()
    {
        showSlideOver = false;
        await WaitForSlideOverTransitionAsync();
    }

    private async Task WaitForSlideOverTransitionAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Delay(SlideOverTransitionMs);
    }

    // ─── 置頂切換 ───
    private async Task HandleTogglePin(int id)
    {
        try
        {
            // 先更新前端狀態，立即反映 UI
            var target = announcements.Find(a => a.Id == id);
            if (target is not null) target.IsPinned = !target.IsPinned;
            var msg = target?.IsPinned == true ? "已置頂" : "已取消置頂";

            // Toast 不等待
            _ = JS.InvokeVoidAsync("Swal.fire", new { icon = "success", title = msg, toast = true, position = "top-end", showConfirmButton = false, timer = 1500 });

            // 後端同步
            var userId = await GetCurrentUserIdAsync();
            await AnnouncementService.TogglePinAsync(id, userId);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "置頂切換失敗 Id={Id}", id);
            await LoadDataAsync(); // 失敗時重新載入還原正確狀態
        }
    }

    // ─── 刪除公告 ───
    private async Task HandleDelete(AnnouncementListItem ann)
    {
        var confirmed = await JS.InvokeAsync<bool>("swalConfirm", new
        {
            title = "確認刪除?",
            html = $"將刪除公告「<b>{ann.Title}</b>」，此操作無法復原。",
            icon = "warning",
            showCancelButton = true,
            confirmButtonColor = "#D98A6C",
            cancelButtonColor = "#6B8EAD",
            confirmButtonText = "確認刪除",
            cancelButtonText = "取消"
        });

        if (!confirmed) return;

        try
        {
            var userId = await GetCurrentUserIdAsync();
            await AnnouncementService.DeleteAsync(ann.Id, userId);
            await LoadDataAsync();
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "success", title = "已刪除", toast = true, position = "top-end", showConfirmButton = false, timer = 1500 });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "刪除公告失敗 Id={Id}", ann.Id);
        }
    }

    // ─── 檢視 Modal ───
    private void OpenViewModal(AnnouncementListItem ann)
    {
        viewingAnnouncement = ann;
