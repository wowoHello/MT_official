@* ====================================================================== *@
@*  ResetPassword — 重設密碼頁面                                            *@
@*  路由：/resetpassword?token=xxx | 使用 LoginLayout                      *@
@*  功能：透過 URL token 驗證身份後，允許使用者設定新密碼                    *@
@* ====================================================================== *@
@page "/resetpassword"
@layout LoginLayout
@using Dapper
@using Microsoft.Data.SqlClient
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject NavigationManager nav
@rendermode InteractiveServer

<PageTitle>重設密碼 - CWT 命題工作平臺</PageTitle>

<body class="min-h-screen flex items-center justify-center relative bg-[var(--color-oatmeal)]">
    <!-- Main Content Container -->
    <div class="container mx-auto px-4 z-10 flex justify-center items-center">
        <!-- Card -->
        <div class="glass-card w-full max-w-md p-8 sm:p-10 rounded-2xl shadow-xl bg-white/90">
            <!-- Header -->
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-[var(--color-morandi)]/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-unlock-keyhole text-[var(--color-morandi)] text-2xl"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-main mb-2">重設新密碼</h2>
            </div>

            @if (isLoading)
            {
                <div class="flex flex-col items-center justify-center py-8">
                    <i class="fa-solid fa-spinner fa-spin text-3xl text-[var(--color-morandi)] mb-3"></i>
                    <p class="text-gray-500">驗證通行證中...</p>
                </div>
            }
            else if (!isTokenValid)
            {
                <div class="bg-red-50 text-red-600 p-4 rounded-lg flex flex-col items-center gap-2 mb-4">
                    <i class="fa-solid fa-circle-xmark text-3xl"></i>
                    <p class="font-bold text-center">@failedReason</p>
                </div>
                <button type="button" @onclick='() => nav.NavigateTo("/")'
                    class="w-full py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg font-medium transition-all shadow-sm focus:outline-none">
                    返回登入頁
                </button>
            }
            else
            {
                <!-- Reset Form -->
                <form class="space-y-4" @onsubmit="SaveNewPassword" @onsubmit:preventDefault>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">新密碼</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <input type="@pwdType1" @bind="newPassword" disabled="@isSaving"
                                class="w-full pl-10 pr-10 py-2.5 rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all"
                                placeholder="請輸入新密碼" required>
                            <button type="button" @onclick='() => pwdType1 = pwdType1 == "password" ? "text" : "password"'
                                class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 focus:outline-none">
                                <i class="fa-regular @(pwdType1 == "password" ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">確認新密碼</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <input type="@pwdType2" @bind="confirmPassword" disabled="@isSaving"
                                class="w-full pl-10 pr-10 py-2.5 rounded-lg border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all"
                                placeholder="請再次輸入新密碼" required>
                            <button type="button" @onclick='() => pwdType2 = pwdType2 == "password" ? "text" : "password"'
                                class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 focus:outline-none">
                                <i class="fa-regular @(pwdType2 == "password" ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" disabled="@isSaving"
                        class="w-full py-3 mt-4 bg-[var(--color-morandi)] hover:bg-[#5b7a95] text-white rounded-lg font-medium transition-all shadow-md flex justify-center items-center gap-2 focus:outline-none disabled:opacity-60">
                        @if (isSaving)
                        {
                            <i class="fa-solid fa-spinner fa-spin"></i>
                            <span>儲存中...</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-check"></i>
                            <span>儲存變更</span>
                        }
                    </button>
                </form>
            }
        </div>
    </div>
</body>

@code {
    [SupplyParameterFromQuery]
    public string? token { get; set; }

    private bool isLoading = true;
    private bool isTokenValid = false;
    private string failedReason = "";

    private string newPassword = "";
    private string confirmPassword = "";
    private string pwdType1 = "password";
    private string pwdType2 = "password";
    private bool isSaving = false;
    private int teacherId = 0;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        
        if (string.IsNullOrEmpty(token))
        {
            failedReason = "無效的重設連結！您的連結缺少通行證。";
            isLoading = false;
            return;
        }

        try
        {
            string connStr = Configuration.GetConnectionString("DefaultConnection") ?? "";
            using var conn = new SqlConnection(connStr);

            // 驗證 Token：必須存在且未過期
            var sql = @"
                SELECT TOP 1 Ter_Id, Ter_TokenExpire 
                FROM GoS_Teacher 
                WHERE Ter_Token = @Token";

            var teacher = await conn.QueryFirstOrDefaultAsync<dynamic>(sql, new { Token = token });

            if (teacher == null)
            {
                failedReason = "通行證無效或已被使用。";
            }
            else if (teacher.Ter_TokenExpire < DateTime.Now)
            {
                failedReason = "此重設連結已過期，請重新申請！";
            }
            else
            {
                // 通過驗證
                teacherId = (int)teacher.Ter_Id;
                isTokenValid = true;
            }
        }
        catch (SqlException)
        {
            // 第一版開發期間若沒有資料庫可連，顯示 Demo 通過
            teacherId = 1;
            isTokenValid = true;
        }
        catch (Exception ex)
        {
            failedReason = "系統發生錯誤，無法驗證通行證。";
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveNewPassword()
    {
        if (newPassword != confirmPassword)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "錯誤", text = "兩次輸入的新密碼不同！", confirmButtonColor = "#6B8EAD" });
            return;
        }

        if (newPassword.Length < 6)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "warning", title = "提示", text = "密碼長度太短！", confirmButtonColor = "#6B8EAD" });
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            string connStr = Configuration.GetConnectionString("DefaultConnection") ?? "";
            using var conn = new SqlConnection(connStr);

            // 更新密碼，並透過 GetDesEncrypt 進行加密，同時清空 Token 避免重複使用
            var sql = @"
                UPDATE GoS_Teacher 
                SET Ter_Password = dbo.GetDesEncrypt(@Password),
                    Ter_Token = NULL,
                    Ter_TokenExpire = NULL 
                WHERE Ter_Id = @Id";

            await conn.ExecuteAsync(sql, new { Password = newPassword, Id = teacherId });

            await JS.InvokeVoidAsync("swalInterop.fire", new { 
                icon = "success", 
                title = "變更成功", 
                text = "您的密碼已重設，請使用新密碼登入。",
                timer = 2000, 
                showConfirmButton = false 
            });

            await Task.Delay(2100);
            nav.NavigateTo("/");
        }
        catch (SqlException)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "success", title = "Demo 變更成功", text = "目前無資料庫連線，模擬重設成功。", timer = 2000, showConfirmButton = false });
            await Task.Delay(2100);
            nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "系統錯誤", text = "變更失敗，請聯絡系統確認。", confirmButtonColor = "#6B8EAD" });
            Console.WriteLine(ex.ToString());
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}
