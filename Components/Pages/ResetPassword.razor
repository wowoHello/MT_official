@* ====================================================================== *@
@*  ResetPassword — 重設密碼頁面                                            *@
@*  路由：/resetpassword?token=xxx | 使用 LoginLayout                      *@
@*  功能：透過 URL token 驗證身份後，允許使用者設定新密碼                    *@
@* ====================================================================== *@
@page "/resetpassword"
@attribute [AllowAnonymous]
@layout LoginLayout
@inject IPasswordResetService ResetService
@inject NavigationManager nav

<PageTitle>重設密碼 - CWT 命題工作平臺</PageTitle>

<div class="min-h-screen flex items-center justify-center relative bg-[var(--color-oatmeal)]">
    <!-- Main Content Container -->
    <div class="container mx-auto px-4 z-10 flex justify-center items-center">
        <!-- Card -->
        <div class="glass-card w-full max-w-md p-8 sm:p-10 rounded-2xl shadow-xl bg-white/90">
            <!-- Header -->
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-[var(--color-morandi)]/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-unlock-keyhole text-[var(--color-morandi)] text-2xl"></i>
                </div>
                <h2 tabindex="-1" class="text-2xl font-bold text-slate-main mb-2 focus:outline-none">重設新密碼</h2>
            </div>

            @if (isLoading)
            {
                <div class="flex flex-col items-center justify-center py-8">
                    <i class="fa-solid fa-spinner fa-spin text-3xl text-[var(--color-morandi)] mb-3"></i>
                    <p class="text-gray-500">驗證通行證中...</p>
                </div>
            }
            else if (!isTokenValid)
            {
                <div class="bg-red-50 text-red-600 p-4 rounded-lg flex flex-col items-center gap-2 mb-4">
                    <i class="fa-solid fa-circle-xmark text-3xl"></i>
                    <p class="font-bold text-center">@failedReason</p>
                </div>
                <button type="button" @onclick='() => nav.NavigateTo("login")'
                    class="w-full py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg font-medium transition-all shadow-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-morandi)] cursor-pointer">
                    返回登入頁
                </button>
            }
            else
            {
                <!-- Reset Form -->
                <EditForm Model="formModel" OnValidSubmit="SaveNewPassword" FormName="resetPasswordForm" class="space-y-4">
                    <!-- 新密碼 -->
                    <div>
                        <label for="newPassword" class="block text-sm font-medium mb-1 text-gray-700">新密碼</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 pointer-events-none">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <InputText id="newPassword" type="@pwdType1" @bind-Value="formModel.NewPassword"
                                @bind-Value:after="ClearSamePasswordError"
                                disabled="@isSaving"
                                placeholder="請輸入新密碼"
                                class="@BuildInputClass(samePasswordError)" />
                            <button type="button" @onclick="TogglePwd1"
                                aria-label="切換新密碼顯示"
                                tabindex="0"
                                class="absolute inset-y-0 right-2 my-1.5 px-2 flex items-center text-gray-400 hover:text-gray-600 rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-morandi)] focus-visible:bg-[var(--color-morandi)]/5 transition-colors cursor-pointer">
                                <i class="fa-regular @(pwdType1 == "password" ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        @if (samePasswordError)
                        {
                            <p class="mt-1 text-xs text-red-600 flex items-center gap-1">
                                <i class="fa-solid fa-circle-exclamation"></i>
                                <span>新密碼不可與舊密碼相同</span>
                            </p>
                        }
                    </div>

                    <!-- 確認新密碼 -->
                    <div>
                        <label for="confirmPassword" class="block text-sm font-medium mb-1 text-gray-700">確認新密碼</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 pointer-events-none">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <InputText id="confirmPassword" type="@pwdType2" @bind-Value="formModel.ConfirmPassword"
                                disabled="@isSaving"
                                placeholder="請再次輸入新密碼"
                                class="@BuildInputClass(false)" />
                            <button type="button" @onclick="TogglePwd2"
                                aria-label="切換確認密碼顯示"
                                tabindex="0"
                                class="absolute inset-y-0 right-2 my-1.5 px-2 flex items-center text-gray-400 hover:text-gray-600 rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-morandi)] focus-visible:bg-[var(--color-morandi)]/5 transition-colors cursor-pointer">
                                <i class="fa-regular @(pwdType2 == "password" ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" disabled="@isSaving"
                        class="w-full py-3 mt-4 bg-[var(--color-morandi)] hover:bg-[#5b7a95] text-white rounded-lg font-medium transition-all shadow-md flex justify-center items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-morandi)] disabled:opacity-60 cursor-pointer">
                        @if (isSaving)
                        {
                            <i class="fa-solid fa-spinner fa-spin"></i>
                            <span>儲存中...</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-check"></i>
                            <span>儲存變更</span>
                        }
                    </button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? token { get; set; }

    private ResetPasswordFormModel formModel = new();

    private bool isLoading = true;
    private bool isTokenValid = false;
    private string failedReason = "";

    private string pwdType1 = "password";
    private string pwdType2 = "password";
    private bool isSaving = false;
    private bool hasShownInvalidTokenAlert = false;
    private bool samePasswordError = false;

    private const string InputBaseClass =
        "w-full pl-10 pr-10 py-2.5 rounded-lg border bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all";

    private string BuildInputClass(bool hasError)
        => $"{InputBaseClass} {(hasError ? "border-red-400" : "border-gray-300")}";

    private void TogglePwd1() => pwdType1 = pwdType1 == "password" ? "text" : "password";
    private void TogglePwd2() => pwdType2 = pwdType2 == "password" ? "text" : "password";

    private void ClearSamePasswordError()
    {
        if (samePasswordError)
        {
            samePasswordError = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(token))
        {
            failedReason = "無效的重設連結！您的連結缺少通行證。";
            isLoading = false;
            return;
        }

        try
        {
            var (success, message, _, _) = await ResetService.ValidateTokenAsync(token);
            if (!success)
                failedReason = message;
            else
                isTokenValid = true;
        }
        catch
        {
            failedReason = "系統發生錯誤，無法驗證通行證。";
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && !isTokenValid && !hasShownInvalidTokenAlert)
        {
            hasShownInvalidTokenAlert = true;

            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "warning",
                title = "重設連結已失效",
                text = failedReason,
                confirmButtonColor = "#6B8EAD"
            });

            nav.NavigateTo("login", forceLoad: true);
        }
    }

    private async Task SaveNewPassword()
    {
        samePasswordError = false;

        if (formModel.NewPassword != formModel.ConfirmPassword)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "錯誤", text = "兩次輸入的新密碼不同！", confirmButtonColor = "#6B8EAD" });
            return;
        }

        if (formModel.NewPassword.Length < 6)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "warning", title = "提示", text = "密碼長度太短！", confirmButtonColor = "#6B8EAD" });
            return;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            var (success, message, samePassword) = await ResetService.ResetPasswordAsync(token!, formModel.NewPassword);

            if (samePassword)
            {
                samePasswordError = true;
                return;
            }

            if (success)
            {
                await JS.InvokeVoidAsync("swalInterop.fire", new
                {
                    icon = "success",
                    title = "變更成功",
                    text = "您的密碼已重設，請使用新密碼登入。",
                    timer = 1000,
                    showConfirmButton = false
                });
                await Task.Delay(1100);
                nav.NavigateTo("login", forceLoad: true);
            }
            else
            {
                await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "重設失敗", text = message, confirmButtonColor = "#6B8EAD" });
            }
        }
        catch
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new { icon = "error", title = "系統錯誤", text = "變更失敗，請聯絡系統確認。", confirmButtonColor = "#6B8EAD" });
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private sealed class ResetPasswordFormModel
    {
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
