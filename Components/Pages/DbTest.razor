@page "/db-test"
@layout LoginLayout
@inject IDatabaseService DbService
@rendermode InteractiveServer

<div class="min-h-screen flex items-center justify-center bg-gray-100 p-4">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
        <div class="text-center mb-6">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 mb-4">
                <i class="fa-solid fa-database text-blue-600 text-2xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-gray-800">資料庫連線測試</h2>
            <p class="text-gray-500 text-sm mt-1">此頁面僅供開發階段驗證連線設定</p>
        </div>

        <div class="space-y-4">
            <button @onclick="RunTest" disabled="@isTesting"
                    class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold transition-all shadow-md flex justify-center items-center gap-2 disabled:opacity-50">
                @if (isTesting)
                {
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    <span>測試中...</span>
                }
                else
                {
                    <i class="fa-solid fa-vial"></i>
                    <span>執行連線測試</span>
                }
            </button>

            @if (result != null)
            {
                <div class="mt-6 p-4 rounded-lg @(result.Value.Success ? "bg-green-50 border border-green-100" : "bg-red-50 border border-red-100")">
                    <div class="flex items-start gap-3">
                        <i class="fa-solid @(result.Value.Success ? "fa-circle-check text-green-500" : "fa-circle-xmark text-red-500") mt-1"></i>
                        <div>
                            <p class="font-bold @(result.Value.Success ? "text-green-800" : "text-red-800")">
                                @(result.Value.Success ? "測試成功" : "測試失敗")
                            </p>
                            <pre class="text-xs mt-2 overflow-auto max-h-40 whitespace-pre-wrap @(result.Value.Success ? "text-green-700" : "text-red-700")">@result.Value.Message</pre>
                            
                            @if (result.Value.Success && tables != null && tables.Any())
                            {
                                <div class="mt-4 pt-4 border-t border-green-200">
                                    <p class="text-sm font-bold text-green-800 mb-2">偵測到以下資料表：</p>
                                    <div class="grid grid-cols-2 gap-1">
                                        @foreach (var table in tables)
                                        {
                                            <div class="text-[10px] bg-green-100 text-green-800 px-2 py-1 rounded">
                                                <i class="fa-solid fa-table mr-1 opacity-50"></i>@table
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-8 pt-6 border-t border-gray-100 flex justify-center">
            <a href="/" class="text-sm text-gray-500 hover:text-blue-600 transition-colors">
                <i class="fa-solid fa-arrow-left mr-1"></i> 返回登入頁面
            </a>
        </div>
    </div>
</div>

@code {
    private bool isTesting = false;
    private (bool Success, string Message)? result;
    private IEnumerable<string>? tables;

    private async Task RunTest()
    {
        isTesting = true;
        result = null;
        tables = null;
        StateHasChanged();

        // 稍微延遲一下讓使用者有感覺在測試
        await Task.Delay(500);
        
        result = await DbService.TestConnectionAsync();
        
        if (result.Value.Success)
        {
            try
            {
                tables = await DbService.GetTableListAsync();
            }
            catch (Exception ex)
            {
                result = (false, "連線雖然成功，但取得資料表清單發生錯誤：\n" + ex.Message);
            }
        }
        
        isTesting = false;
        StateHasChanged();
    }
}
