@* ====================================================================== *@
@*  Reviews — 審題任務清單                                                  *@
@*  路由：/reviews                                                         *@
@*  功能：審題作業區/審核結果雙分頁、七階段時程燈號條、統計摘要、題目列表     *@
@* ====================================================================== *@
@page "/reviews"
@using MT.Components.Shared.ReviewForms
@inject IQuestionService QuestionService
@inject IProjectService ProjectService
@inject IReviewService ReviewService
@inject NavigationManager Navigation

<div class="flex-grow flex flex-col w-full mx-auto h-[calc(100vh-4rem)] overflow-hidden">

    <!-- Header: Breadcrumb + Title -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur-sm border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1">
                        <li>
                            <NavLink href="" Match="NavLinkMatch.All" class="hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1.5"></i>
                                <span class="text-slate-main">審題任務</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <div class="flex items-center gap-3">
                    <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                        <i class="fa-solid fa-magnifying-glass-chart text-terracotta"></i> 審題任務
                    </h1>
                    @* 當前階段指示燈：與 CwtList 一致 — 進行中 sage（綠）；急迫倒數 ≤5 天才轉 terracotta 警示 *@
                    @if (currentPhase is not null)
                    {
                        @* 三段式視覺：已結案=橘、即將截止=橘呼吸、進行中=綠呼吸 *@
                        var pillCss = currentPhase.IsClosed
                            ? "bg-terracotta/15 text-terracotta border-terracotta/30"
                            : currentPhase.IsUrgent
                                ? "bg-terracotta/15 text-terracotta border-terracotta/30"
                                : "bg-sage/15 text-sage border-sage/30";
                        var dotCss = currentPhase.IsClosed || currentPhase.IsUrgent ? "bg-terracotta" : "bg-sage";
                        var pulseCss = currentPhase.IsClosed ? "" : "animate-pulse";
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1 rounded-full border @pillCss">
                            <span class="w-2 h-2 rounded-full @dotCss @pulseCss"></span>
                            @currentPhase.PhaseName
                            @if (currentPhase.IsClosed)
                            {
                                <span>已結案</span>
                            }
                            else
                            {
                                <span>進行中</span>
                                @if (currentPhase.IsUrgent)
                                {
                                    <span>（剩 @currentPhase.DaysLeft 天）</span>
                                }
                            }
                        </span>
                    }
                    else if (!isLoadingPhases)
                    {
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1 rounded-full bg-gray-100 text-gray-400 border border-gray-200">
                            <span class="w-2 h-2 rounded-full bg-gray-300"></span>
                            目前無進行中階段
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Scrollable Body -->
    <div class="flex-grow overflow-y-auto custom-scroll">

        <!-- 二大 Tab 工作區 -->
        <div class="px-4 sm:px-6 lg:px-8 py-5">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

                <!-- Tab Bar -->
                <div class="flex border-b border-gray-200 bg-white sticky top-0 z-20 overflow-x-auto">
                    <button @onclick='() => SwitchTab("review")'
                        class="@(currentTab == "review" ? "text-terracotta border-b-terracotta font-bold" : "text-gray-500 border-transparent") px-5 py-3 text-sm border-b-2 transition-colors hover:text-terracotta cursor-pointer focus:outline-none whitespace-nowrap">
                        <i class="fa-solid fa-clipboard-check mr-1.5 text-terracotta"></i>審題作業區
                        <span class="ml-2 text-xs bg-terracotta/15 text-terracotta px-2 py-0.5 rounded-full font-bold">@assignments.Count</span>
                    </button>
                    <button @onclick='() => SwitchTab("history")'
                        class="@(currentTab == "history" ? "text-morandi border-b-morandi font-bold" : "text-gray-500 border-transparent") px-5 py-3 text-sm border-b-2 transition-colors hover:text-morandi cursor-pointer focus:outline-none whitespace-nowrap">
                        <i class="fa-solid fa-box-archive mr-1.5 text-morandi"></i>審核結果與歷史
                        <span class="ml-2 text-xs bg-morandi/15 text-morandi px-2 py-0.5 rounded-full font-bold">@historyItems.Count</span>
                    </button>
                </div>

                <!-- Tab 內容區 -->
                <div class="p-4 border-b border-gray-100 bg-gray-50/50 flex-shrink-0">
                    @if (currentTab == "review")
                    {
                        <!-- 七階段時程燈號條（資料來源：MT_ProjectPhases，PhaseCode 1~7） -->
                        <div class="mb-4">
                            <div class="stage-timeline relative">
                                @for (int i = 0; i < phases.Count; i++)
                                {
                                    var phase = phases[i];
                                    var stateCss = phase.DisplayState switch
                                    {
                                        PhaseDisplayState.Done     => "done",
                                        PhaseDisplayState.Active   => "active",
                                        PhaseDisplayState.Closed   => "closed",
                                        _                          => "upcoming"
                                    };
                                    var icon = phase.DisplayState switch
                                    {
                                        PhaseDisplayState.Done     => "fa-solid fa-check",
                                        PhaseDisplayState.Active   => "fa-solid fa-location-dot",
                                        PhaseDisplayState.Closed   => "fa-solid fa-flag-checkered",
                                        _                          => "fa-solid fa-ellipsis"
                                    };

                                    <div class="stage-node">
                                        @if (i > 0)
                                        {
                                            @* 連線著色：前段 Done 才接綠線，其餘皆灰 *@
                                            var prev = phases[i - 1].DisplayState;
                                            var lineCss = prev == PhaseDisplayState.Done ? "done" : "upcoming";
                                            <div class="stage-line @lineCss"></div>
                                        }
                                        <div class="stage-dot @stateCss" title="@phase.PhaseName：@phase.StartDate.ToString("yyyy/MM/dd") ~ @phase.EndDate.ToString("yyyy/MM/dd")">
                                            <i class="@icon text-xs"></i>
                                        </div>
                                        <div class="stage-label @stateCss">@phase.PhaseName</div>
                                    </div>
                                }
                            </div>
                            <div class="text-center text-xs text-gray-500 mt-3 font-medium">
                                @if (currentPhase is not null)
                                {
                                    if (currentPhase.IsClosed)
                                    {
                                        <span>
                                            <i class="fa-solid fa-flag-checkered mr-1 text-terracotta"></i>
                                            專案已於 <strong class="text-terracotta">@currentPhase.ClosedAt!.Value.ToString("yyyy/MM/dd")</strong>
                                            於「<strong class="text-terracotta">@currentPhase.PhaseName</strong>」階段結案
                                        </span>
                                    }
                                    else
                                    {
                                        var daysCss = currentPhase.IsUrgent ? "text-terracotta" : "text-morandi";
                                        <span>
                                            <i class="fa-solid fa-location-dot mr-1 @daysCss"></i> 目前階段：<strong>@currentPhase.PhaseName</strong>（剩餘 <strong class="@daysCss">@currentPhase.DaysLeft</strong> 天）
                                        </span>
                                    }
                                }
                                else if (phases.Any() && phases.All(p => p.DisplayState == PhaseDisplayState.Done))
                                {
                                    <span><i class="fa-solid fa-circle-check mr-1 text-sage"></i> 所有審題階段已完成</span>
                                }
                            </div>
                        </div>

                        @* 命題階段（PhaseCode=2）= 題目尚未進入審題流程，顯示等待狀態取代統計列 *@
                        @if (!IsCompositionPhase)
                        {
                            <!-- 統計摘要條 -->
                            <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 bg-white rounded-xl border border-gray-200 px-5 py-3 text-sm font-medium shadow-sm">
                                <div class="flex items-center gap-1.5 text-gray-700">
                                    <i class="fa-solid fa-list-check text-morandi"></i>
                                    本區題目
                                    <span class="text-lg font-bold text-slate-main ml-0.5">@assignments.Count</span>
                                </div>
                                <span class="text-gray-300">|</span>
                                <div class="flex items-center gap-1.5 text-gray-700">
                                    <i class="fa-solid fa-hourglass-half text-terracotta"></i>
                                    待處理
                                    <span class="text-lg font-bold text-terracotta ml-0.5">@assignments.Count(a => !a.IsCompleted)</span>
                                </div>
                                <span class="text-gray-300">|</span>
                                <div class="flex items-center gap-1.5 text-gray-700">
                                    <i class="fa-solid fa-circle-check text-sage"></i>
                                    已完成
                                    <span class="text-lg font-bold text-sage ml-0.5">@assignments.Count(a => a.IsCompleted)</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- 歷史 Tab 統計卡片 -->
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                            @HistoryStatCard("全部題目", historyItems.Count.ToString(), "fa-layer-group", "text-morandi", "text-slate-main")
                            @HistoryStatCard("已採用", historyItems.Count(h => h.FinalStatus == QuestionStatus.Adopted).ToString(), "fa-circle-check", "text-sage", "text-sage")
                            @HistoryStatCard("不採用", historyItems.Count(h => h.FinalStatus is QuestionStatus.Rejected or QuestionStatus.ClosedNotAdopted).ToString(), "fa-circle-xmark", "text-gray-400", "text-gray-400")
                        </div>
                    }
                </div>

                @* 命題階段：篩選列無意義（沒有題目可篩） *@
                @if (currentTab == "history" || !IsCompositionPhase)
                {
                    <!-- 篩選列 -->
                    <div class="p-4 border-b border-gray-100 bg-white flex flex-col xl:flex-row gap-3 items-start xl:items-center justify-between flex-shrink-0">
                        <div class="flex flex-wrap items-center gap-3 w-full xl:w-auto">
                            <div class="w-full md:w-56">
                                <DebouncedSearchInput Value="@(queryKeyword ?? "")" ValueChanged="OnKeywordChanged"
                                    Placeholder="搜尋題號或關鍵字..." />
                            </div>
                            <select value="@queryType" @onchange="OnTypeFilterChanged"
                                class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                <option value="all">所有題型</option>
                                @foreach (var kv in QuestionConstants.TypeLabels)
                                {
                                    <option value="@kv.Key">@kv.Value</option>
                                }
                            </select>
                            <select value="@queryLevel" @onchange="OnLevelFilterChanged"
                                class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                <option value="all">所有等級</option>
                                @foreach (var kv in QuestionConstants.GeneralLevelLabels)
                                {
                                    <option value="@kv.Key">@kv.Value</option>
                                }
                            </select>
                            <select value="@queryStatus" @onchange="OnStatusFilterChanged"
                                class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                @if (currentTab == "review")
                                {
                                    <option value="all">所有狀態</option>
                                    <option value="pending">待審</option>
                                    <option value="completed">已完成</option>
                                }
                                else
                                {
                                    <option value="all">所有狀態</option>
                                    <option value="adopted">已採用</option>
                                    <option value="rejected">不採用</option>
                                }
                            </select>
                        </div>
                        <div class="flex flex-wrap items-center justify-between gap-3 w-full xl:w-auto xl:justify-end">
                            <label class="flex items-center gap-2 text-sm text-gray-500 font-medium whitespace-nowrap">
                                每頁顯示
                                <select value="@pageSize" @onchange="OnPageSizeChanged"
                                    class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                    <option value="12">12 題</option>
                                    <option value="24">24 題</option>
                                    <option value="48">48 題</option>
                                </select>
                            </label>
                            <div class="text-sm text-gray-500 font-medium flex-shrink-0">
                                共 <span class="text-morandi font-bold">@FilteredCount</span> 題
                            </div>
                        </div>
                    </div>
                }

                <!-- 題目列表 / 階段等待狀態 -->
                @if (currentTab == "review" && IsCompositionPhase)
                {
                    @* 命題階段專用空狀態：四層次 — 圖示／主訊息／倒數連結／引導動作 *@
                    <div class="p-6 sm:p-8">
                        <div class="bg-white rounded-2xl border-2 border-dashed border-morandi/30 px-8 py-16 text-center shadow-sm">

                            @* 第一層：大型情境圖示（莫蘭迪光暈） *@
                            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-morandi/10 mb-6">
                                <i class="fa-solid fa-feather-pointed text-3xl text-morandi"></i>
                            </div>

                            @* 第二層：主訊息 — 為什麼空白 *@
                            <h3 class="text-xl font-bold text-slate-main mb-3">
                                命題階段進行中
                            </h3>
                            <p class="text-base text-gray-600 mb-6 max-w-md mx-auto leading-relaxed">
                                老師們正在努力命題中。待
                                <strong class="text-morandi">@currentPhase!.EndDate.ToString("yyyy/MM/dd")</strong>
                                命題截止後，系統將自動把題目平均分配給每位審題教師。
                            </p>

                            @* 第三層：倒數情緒連結 — 讓等待有方向感（≤5 天才轉 terracotta 警示） *@
                            @{
                                var dotColor = currentPhase!.IsUrgent ? "bg-terracotta" : "bg-sage";
                                var pillCss = currentPhase!.IsUrgent
                                    ? "text-terracotta border-terracotta/20 bg-terracotta/10"
                                    : "text-sage border-sage/20 bg-sage/10";
                            }
                            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border @pillCss">
                                <span class="w-2 h-2 rounded-full @dotColor animate-pulse"></span>
                                <span class="text-sm font-bold">
                                    距離命題結束剩餘 @currentPhase!.DaysLeft 天
                                </span>
                            </div>
                        </div>
                    </div>
                }
                else if (currentTab == "review")
                {
                    @* 審題作業區列表（自己被分配且階段對應的題目） *@
                    @if (isLoadingList)
                    {
                        <div class="p-8 text-center text-gray-400 text-sm">
                            <i class="fa-solid fa-spinner fa-spin mr-2"></i>載入中…
                        </div>
                    }
                    else if (FilteredAssignments.Count == 0)
                    {
                        <div class="p-8">
                            <EmptyState IconClass="fa-clipboard-check"
                                Message="@(assignments.Count == 0 ? "目前無待審試題" : "查無符合條件的試題")"
                                SubMessage="@(assignments.Count == 0 ? "當有試題分配給您審查時將顯示於此。" : "請調整搜尋或篩選條件。")" />
                        </div>
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="text-xs text-gray-500 uppercase font-bold bg-gray-50 border-b border-gray-200">
                                    <tr>
                                        <th class="px-4 py-2 text-left whitespace-nowrap">題號</th>
                                        <th class="px-4 py-2 text-left whitespace-nowrap">題型</th>
                                        <th class="px-4 py-2 text-left">題目摘要</th>
                                        <th class="px-4 py-2 text-center whitespace-nowrap">階段</th>
                                        <th class="px-4 py-2 text-center whitespace-nowrap">狀態</th>
                                        <th class="px-4 py-2 text-left whitespace-nowrap">分配時間</th>
                                        <th class="px-4 py-2 text-center whitespace-nowrap">操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Page(FilteredAssignments))
                                    {
                                        <tr @onclick="() => OpenReviewModal(item.QuestionId)"
                                            class="border-b border-gray-100 relative hover:z-10 hover:bg-blue-50/40 hover:shadow-[inset_4px_0_0_var(--color-morandi),0_6px_16px_-4px_rgba(0,0,0,0.18)] transition-all cursor-pointer group">
                                            <td class="px-4 py-3 font-bold text-slate-main group-hover:text-morandi whitespace-nowrap transition-colors">@item.QuestionCode</td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <span class="inline-block px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs font-bold border border-gray-200">
                                                    @QuestionConstants.TypeLabels.GetValueOrDefault(item.TypeKey, "未知")
                                                </span>
                                            </td>
                                            <td class="px-4 py-3 max-w-md">
                                                <div class="text-gray-700 truncate" title="@item.SummaryText">
                                                    @(string.IsNullOrEmpty(item.SummaryText) ? "（尚未填寫題幹）" : item.SummaryText)
                                                </div>
                                            </td>
                                            <td class="px-4 py-3 text-center whitespace-nowrap">
                                                @{
                                                    var stageCss = item.Stage switch
                                                    {
                                                        ReviewStage.Mutual => "bg-morandi/15 text-morandi border-morandi/30",
                                                        ReviewStage.Expert => "bg-terracotta/15 text-terracotta border-terracotta/30",
                                                        ReviewStage.Final  => "bg-red-50 text-red-700 border-red-200",
                                                        _                  => "bg-gray-100 text-gray-500 border-gray-300"
                                                    };
                                                    var stageName = item.Stage switch
                                                    {
                                                        ReviewStage.Mutual => "互審",
                                                        ReviewStage.Expert => "專審",
                                                        ReviewStage.Final  => "總審",
                                                        _                  => ""
                                                    };
                                                }
                                                <span class="inline-block px-2 py-0.5 rounded text-xs font-bold border @stageCss">@stageName</span>
                                            </td>
                                            <td class="px-4 py-3 text-center whitespace-nowrap">
                                                @if (item.IsCompleted)
                                                {
                                                    <span class="inline-block px-2 py-0.5 rounded text-xs font-bold bg-sage/15 text-sage border border-sage/30">已完成</span>
                                                }
                                                else
                                                {
                                                    <span class="inline-block px-2 py-0.5 rounded text-xs font-bold bg-terracotta/15 text-terracotta border border-terracotta/30">待審</span>
                                                }
                                            </td>
                                            <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">@item.AssignedAt.ToString("yyyy/MM/dd HH:mm")</td>
                                            <td class="px-4 py-3 text-center whitespace-nowrap" @onclick:stopPropagation="true">
                                                <button @onclick="() => OpenReviewModal(item.QuestionId)"
                                                        class="text-morandi hover:underline text-xs font-bold cursor-pointer focus:outline-none">
                                                    <i class="@(item.IsCompleted ? "fa-solid fa-pen-to-square" : "fa-solid fa-clipboard-check") mr-0.5"></i> @(item.IsCompleted ? "編輯" : "審題")
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @* 分頁器 *@
                        @if (TotalPages > 1)
                        {
                            <div class="flex items-center justify-center gap-2 py-4 border-t border-gray-100">
                                <button @onclick="() => GoToPage(currentPage - 1)" disabled="@(currentPage <= 1)"
                                    class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>
                                <span class="text-sm text-gray-600 font-medium">第 @currentPage / @TotalPages 頁</span>
                                <button @onclick="() => GoToPage(currentPage + 1)" disabled="@(currentPage >= TotalPages)"
                                    class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </div>
                        }
                    }
                }
                else
                {
                    @* 審核結果與歷史 Tab — 已採用 / 不採用題目，唯讀檢視 *@
                    @if (isLoadingHistory)
                    {
                        <div class="p-8 text-center text-gray-400 text-sm">
                            <i class="fa-solid fa-spinner fa-spin mr-2"></i>載入中…
                        </div>
                    }
                    else if (FilteredHistory.Count == 0)
                    {
                        <div class="p-8">
                            <EmptyState IconClass="fa-box-archive"
                                Message="@(historyItems.Count == 0 ? "尚無審核結果" : "查無符合條件的試題")"
                                SubMessage="@(historyItems.Count == 0 ? "總審判決後的題目將顯示於此。" : "請調整搜尋或篩選條件。")" />
                        </div>
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="text-xs text-gray-500 uppercase font-bold bg-gray-50 border-b border-gray-200">
                                    <tr>
                                        <th class="px-4 py-2 text-left whitespace-nowrap">題號</th>
                                        <th class="px-4 py-2 text-left whitespace-nowrap">題型</th>
                                        <th class="px-4 py-2 text-left whitespace-nowrap">等級</th>
                                        <th class="px-4 py-2 text-left">題目摘要</th>
                                        <th class="px-4 py-2 text-center whitespace-nowrap">最終狀態</th>
                                        <th class="px-4 py-2 text-left whitespace-nowrap">決策時間</th>
                                        <th class="px-4 py-2 text-center whitespace-nowrap">操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Page(FilteredHistory))
                                    {
                                        <tr @onclick="() => OpenReviewModal(item.QuestionId)"
                                            class="border-b border-gray-100 relative hover:z-10 hover:bg-blue-50/40 hover:shadow-[inset_4px_0_0_var(--color-morandi),0_6px_16px_-4px_rgba(0,0,0,0.18)] transition-all cursor-pointer group">
                                            <td class="px-4 py-3 font-bold text-slate-main group-hover:text-morandi whitespace-nowrap transition-colors">@item.QuestionCode</td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <span class="inline-block px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs font-bold border border-gray-200">
                                                    @QuestionConstants.TypeLabels.GetValueOrDefault(item.TypeKey, "未知")
                                                </span>
                                            </td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                @if (item.Level is byte lv)
                                                {
                                                    <span class="text-xs text-morandi font-bold">@(item.TypeKey == QuestionTypeCodes.Listen ? QuestionConstants.ListenLevelLabels.GetValueOrDefault(lv, "") : QuestionConstants.GeneralLevelLabels.GetValueOrDefault(lv, ""))</span>
                                                }
                                                @if (item.Difficulty is byte d)
                                                {
                                                    <span class="text-xs text-terracotta font-bold ml-2">@QuestionConstants.DifficultyLabels.GetValueOrDefault(d, "")</span>
                                                }
                                            </td>
                                            <td class="px-4 py-3 max-w-md">
                                                <div class="text-gray-700 truncate" title="@item.SummaryText">
                                                    @(string.IsNullOrEmpty(item.SummaryText) ? "（尚未填寫題幹）" : item.SummaryText)
                                                </div>
                                            </td>
                                            <td class="px-4 py-3 text-center whitespace-nowrap">
                                                <StatusBadge StatusText="@QuestionStatus.Labels.GetValueOrDefault(item.FinalStatus, "未知")" Compact="true" />
                                            </td>
                                            <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">@item.FinalDecidedAt.ToString("yyyy/MM/dd HH:mm")</td>
                                            <td class="px-4 py-3 text-center whitespace-nowrap" @onclick:stopPropagation="true">
                                                <button @onclick="() => OpenReviewModal(item.QuestionId)"
                                                        class="text-morandi hover:underline text-xs font-bold cursor-pointer focus:outline-none">
                                                    <i class="fa-solid fa-eye mr-0.5"></i> 檢視
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @* 分頁器 *@
                        @if (TotalPages > 1)
                        {
                            <div class="flex items-center justify-center gap-2 py-4 border-t border-gray-100">
                                <button @onclick="() => GoToPage(currentPage - 1)" disabled="@(currentPage <= 1)"
                                    class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>
                                <span class="text-sm text-gray-600 font-medium">第 @currentPage / @TotalPages 頁</span>
                                <button @onclick="() => GoToPage(currentPage + 1)" disabled="@(currentPage >= TotalPages)"
                                    class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </div>
                        }
                    }
                }
            </div>
        </div>
    </div>
</div>

@* ====== 審題 Modal ====== *@
<ReviewModal @bind-IsVisible="showReviewModal"
             QuestionId="@selectedQuestionId"
             CurrentUserId="@(currentUserId ?? 0)"
             OnDecisionMade="OnDecisionMadeAsync" />

@code {
    [CascadingParameter(Name = "CurrentProject")]
    private ProjectSwitcherItem? CurrentProject { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private string currentTab = "review";

    // 後備防線：硬打 URL 進來但非專案成員 → 旗標化等 OnAfterRenderAsync 才彈 Swal
    private bool needNoPermissionRedirect;
    private bool permissionChecked;

    // 七階段資料（資料來源：MT_ProjectPhases，PhaseCode 2~8；排除 PhaseCode=1 產學區間）
    private ProjectPhaseInfo? currentPhase;
    private List<ProjectPhaseInfo> phases = new();
    private bool isLoadingPhases = true;

    // 命題階段判定：題目尚未進入待審佇列，審題作業區應顯示等待狀態而非空表格
    private bool IsCompositionPhase => currentPhase?.PhaseCode == 2;

    // 列表狀態（審題作業區）
    private List<ReviewListItem> assignments = new();
    private bool isLoadingList;
    private int? currentUserId;

    // 列表狀態（審核結果與歷史）
    private List<ReviewHistoryItem> historyItems = new();
    private bool isLoadingHistory;

    // 篩選與分頁狀態（兩個 Tab 共用，切 Tab 不重置篩選但重置頁碼）
    private string? queryKeyword;
    private string queryType   = "all";  // 題型 key 或 "all"
    private string queryLevel  = "all";  // byte 字串或 "all"
    private string queryStatus = "all";  // 作業區: all/pending/completed；歷史: all/adopted/rejected
    private int pageSize       = 12;
    private int currentPage    = 1;

    // ReviewModal 開關
    private bool showReviewModal;
    private int? selectedQuestionId;

    /// <summary>當前階段對應的審題 stage（命題/修題階段時為 null，列表為空）</summary>
    private ReviewStage? CurrentReviewStage => currentPhase?.PhaseCode switch
    {
        3 => ReviewStage.Mutual,   // 交互審題
        5 => ReviewStage.Expert,   // 專家審題
        7 => ReviewStage.Final,    // 總召審題
        _ => null                   // 命題階段、各修題階段、產學區間 → 列表空
    };

    protected override async Task OnParametersSetAsync()
    {
        if (CurrentProject is null)
        {
            phases = new();
            currentPhase = null;
            isLoadingPhases = false;
            return;
        }

        // Plan_002b：與 CwtList 並列為兩個觸發點，避免審題專家不進 CwtList 時分配卡住。
        // EnsureCompositionPhaseClosedAsync 為 Idempotent，重複呼叫安全且短路。
        try
        {
            await QuestionService.EnsureCompositionPhaseClosedAsync(CurrentProject.Id);
        }
        catch (InvalidOperationException ex)
        {
            // 命題教師不足 2 人 → 警示但仍載入頁面（讓總召看得到當前狀態）
            await ShowToastAsync("warning", ex.Message);
        }

        // 階段資料：每次 CurrentProject 變更都需要重新載入（切換梯次）
        await LoadPhasesAsync(CurrentProject.Id);

        // 取得當前登入者 Id（每次進頁面都會取，但 currentUserId 一旦取得就快取）
        if (currentUserId is null)
        {
            var authState = await AuthState;
            var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(claim, out var uid)) currentUserId = uid;
        }

        // 載入審題作業區列表（依當前階段對應的 ReviewStage）+ 審核結果與歷史
        await Task.WhenAll(LoadAssignmentsAsync(), LoadHistoryAsync());

        // 權限檢查：每位使用者每次進頁面只跑一次
        if (permissionChecked) return;
        permissionChecked = true;

        if (currentUserId is null) return;
        var isMember = await QuestionService.IsProjectMemberAsync(currentUserId.Value, CurrentProject.Id);
        if (!isMember) needNoPermissionRedirect = true;
    }

    private async Task LoadAssignmentsAsync()
    {
        if (CurrentProject is null || currentUserId is null || CurrentReviewStage is null)
        {
            assignments = new();
            return;
        }

        isLoadingList = true;
        try
        {
            assignments = await ReviewService.GetMyAssignmentsAsync(
                CurrentProject.Id, currentUserId.Value, CurrentReviewStage.Value);
        }
        finally
        {
            isLoadingList = false;
        }
    }

    private async Task LoadHistoryAsync()
    {
        if (CurrentProject is null) { historyItems = new(); return; }

        isLoadingHistory = true;
        try
        {
            historyItems = await ReviewService.GetHistoryAsync(CurrentProject.Id);
        }
        finally
        {
            isLoadingHistory = false;
        }
    }

    private void OpenReviewModal(int questionId)
    {
        selectedQuestionId = questionId;
        showReviewModal = true;
    }

    private async Task OnDecisionMadeAsync()
    {
        // 決策完成後重新載入兩邊列表（作業區 + 歷史）
        await Task.WhenAll(LoadAssignmentsAsync(), LoadHistoryAsync());
    }

    // ============================================================
    //  篩選與分頁
    // ============================================================

    /// <summary>切 Tab：保留篩選條件，僅重置頁碼到第 1 頁</summary>
    private void SwitchTab(string tab)
    {
        currentTab  = tab;
        currentPage = 1;
    }

    private void OnKeywordChanged(string? keyword) { queryKeyword = keyword; currentPage = 1; }

    private void OnTypeFilterChanged(ChangeEventArgs e)   { queryType   = e.Value?.ToString() ?? "all"; currentPage = 1; }
    private void OnLevelFilterChanged(ChangeEventArgs e)  { queryLevel  = e.Value?.ToString() ?? "all"; currentPage = 1; }
    private void OnStatusFilterChanged(ChangeEventArgs e) { queryStatus = e.Value?.ToString() ?? "all"; currentPage = 1; }
    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n) && n > 0) pageSize = n;
        currentPage = 1;
    }

    private void GoToPage(int page)
    {
        var total = TotalPages;
        if (page < 1 || page > total || page == currentPage) return;
        currentPage = page;
    }

    // ----- 共用 Filter 述詞 -----
    private bool MatchKeywordOn(string code, string summary) =>
        string.IsNullOrWhiteSpace(queryKeyword) ||
        (code?.Contains(queryKeyword, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (summary?.Contains(queryKeyword, StringComparison.OrdinalIgnoreCase) ?? false);

    private bool MatchType(string typeKey)
        => queryType == "all" || string.Equals(queryType, typeKey, StringComparison.Ordinal);

    private bool MatchLevel(byte? level)
    {
        if (queryLevel == "all") return true;
        if (!byte.TryParse(queryLevel, out var lv)) return true;
        return level == lv;
    }

    // ----- 計算屬性：套篩選後的結果 -----
    private IReadOnlyList<ReviewListItem> FilteredAssignments => assignments
        .Where(a => MatchKeywordOn(a.QuestionCode, a.SummaryText))
        .Where(a => MatchType(a.TypeKey))
        .Where(a => MatchLevel(a.Level))
        .Where(a => queryStatus switch
        {
            "pending"   => !a.IsCompleted,
            "completed" =>  a.IsCompleted,
            _           =>  true
        })
        .ToList();

    private IReadOnlyList<ReviewHistoryItem> FilteredHistory => historyItems
        .Where(h => MatchKeywordOn(h.QuestionCode, h.SummaryText))
        .Where(h => MatchType(h.TypeKey))
        .Where(h => MatchLevel(h.Level))
        .Where(h => queryStatus switch
        {
            "adopted"  => h.FinalStatus == QuestionStatus.Adopted,
            "rejected" => h.FinalStatus is QuestionStatus.Rejected or QuestionStatus.ClosedNotAdopted,
            _          => true
        })
        .ToList();

    private int FilteredCount => currentTab == "review" ? FilteredAssignments.Count : FilteredHistory.Count;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredCount / (double)pageSize));

    private IEnumerable<T> Page<T>(IReadOnlyList<T> src) =>
        src.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private async Task LoadPhasesAsync(int projectId)
    {
        isLoadingPhases = true;
        try
        {
            var phasesTask = ProjectService.GetPhasesAsync(projectId);
            var currentTask = ProjectService.GetCurrentPhaseAsync(projectId);
            await Task.WhenAll(phasesTask, currentTask);
            phases = phasesTask.Result;
            currentPhase = currentTask.Result;
        }
        finally
        {
            isLoadingPhases = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!needNoPermissionRedirect) return;
        needNoPermissionRedirect = false;
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = "warning",
            title = "此身分在該專案沒有審題任務",
            text = "您目前的角色身分在此專案梯次未被指派為成員。",
            confirmButtonColor = "#6B8EAD"
        });
        Navigation.NavigateTo("/");
    }

    private ValueTask ShowToastAsync(string icon, string title) =>
        JS.InvokeVoidAsync("Swal.fire", new
        {
            icon,
            title,
            toast = true,
            position = "top-end",
            showConfirmButton = false,
            timer = 2000
        });

    private RenderFragment HistoryStatCard(string title, string value, string icon, string iconColor, string valueColor) => __builder =>
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="text-2xl font-bold @valueColor">@value</div>
        </div>
    };
}
