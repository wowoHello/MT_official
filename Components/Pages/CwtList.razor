@* 相似題比對結果彈窗 *@
<SimilarityCheckModal @bind-IsVisible="showSimilarityModal"
                      Loading="@isCheckingSimilarity"
                      Results="@similarityResults"
                      SourceCode="@(string.IsNullOrEmpty(formData.QuestionCode) ? "新題目" : formData.QuestionCode)" />

@code {
    [CascadingParameter(Name = "CurrentProject")]
    private ProjectSwitcherItem? CurrentProject { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private int? currentUserId;
    private List<QuotaProgressItem> quotaProgress = [];
    private ProjectPhaseInfo? currentPhase;
    private bool isLoadingQuota = true;

    private string currentTab = "compose";
    private bool showComposeModal = false;
    private bool sidebarCollapsed = false;
    private string composeModalTitle = "新增試題";

    // Plan_010：審修作業區的修題 Slide-Over
    private bool showRevisionSlideOver = false;
    private int? revisionQuestionId;
    // Stage B-4-2：開啟修題 Slide-Over 時帶的子題單元 Id（NULL = 母題列）
    private int? revisionSubQuestionId;

    // 預覽 Modal
    private bool showPreviewModal = false;

    // 相似題比對 Modal（Plan A）
    private bool showSimilarityModal = false;
    private bool isCheckingSimilarity = false;
    private IReadOnlyList<MT.Models.SimilarityCompareResult> similarityResults = Array.Empty<MT.Models.SimilarityCompareResult>();

    // 表單狀態統一收攏（題型 / 等級 / 難度 / 8 屬性 / 主題內容 / 子題清單）
    private QuestionFormData formData = new();

    // Modal 表單目前顯示的狀態（決定 Header 標籤文字）
    private byte currentFormStatus = QuestionStatus.Draft;

    // 編輯時顯示的「最後修改時間」（新增時為 null 不顯示）
    private DateTime? currentFormUpdatedAt;

    // 儲存中防呆：避免重複送出
    private bool isSaving;
    private byte? pendingStatus;   // 哪一個按鈕觸發的（影響 spinner 顯示位置）

    // 表單欄位錯誤集合：由 SaveAsync 驗證填入；子元件以 [Parameter] 接收用以畫紅框
    private HashSet<string> invalidFields = new();

    // 列表狀態
    private QuestionListResult listResult = new();
    private Dictionary<byte, int> statusCounts = [];
    // 審修作業區：子題層級 status 計數（與母題分開計算，搭配 ListAsync 拆 N+1 列）
    private Dictionary<byte, int> subStatusCounts = [];
    private bool isLoadingList;
    private int currentPage = 1;
    private int pageSize = 10;

    // 審修作業區「已修題」卡片計數（本人在 Status∈{4,6,8} 已送出 RevisionReplies 的題目數）
    private int revisionRepliedCount;
    // 子題層級的「已修題」計數
    private int subRevisionRepliedCount;

    // 篩選條件
    private string? queryKeyword;
    private string queryTypeId = "";   // "" or "1"~"7"
    private string queryLevel = "";    // "" or "0"~"5"

    // 後備防線：硬打 URL 進來但無配額 → 旗標化等 OnAfterRenderAsync 才彈 Swal（避免 prerender JS 錯誤）
    private bool needNoPermissionRedirect;

    // 已載入的 ProjectId 守門 —— 避免父層重渲染時重跑 LoadPageDataAsync 導致配額卡片骨架閃爍
    private int? loadedProjectId;

    // Plan_008：命題階段結束相關
    private DateTime? compositionPhaseEndDate;
    private bool IsCompositionPhaseClosed
        => compositionPhaseEndDate.HasValue && compositionPhaseEndDate.Value.Date < DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(claim, out var uid))
            currentUserId = uid;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (CurrentProject is null || currentUserId is null) return;
        if (loadedProjectId == CurrentProject.Id) return;   // 同專案重派 → 不重載
        loadedProjectId = CurrentProject.Id;

        // 立即用「目前 DB 狀態」渲染：配額 / 階段 / 列表
        // 不再等 PhaseCoordinator.EnsureAsync 完成（互審 / 專審 / 總審分配可能跑 5~10 秒）
        await LoadPageDataAsync();

        // 階段轉換改背景跑：完成後自動 reload 配額與列表（漸進式 UX）
        _ = RunPhaseCoordinatorBackgroundAsync(CurrentProject.Id);
    }

    /// <summary>
    /// 背景觸發 PhaseCoordinator 階段轉換（idempotent；60 秒內 cache hit 即刻返回）。
    /// 若有實際升級 Status / 寫入新分配，跑完後切回 UI thread reload 頁面資料，畫面自動補上變化。
    /// </summary>
    private async Task RunPhaseCoordinatorBackgroundAsync(int projectId)
    {
        try
        {
            await PhaseCoordinator.EnsureAsync(projectId);

            // 跑完後靜默刷新（用 InvokeAsync 切回 UI thread）
            // silent=true：使用者已看到首次載入結果，背景補資料時不再觸發 spinner 閃爍
            await InvokeAsync(async () =>
            {
                if (CurrentProject?.Id != projectId) return;  // 已切到別的專案 → 不污染當前畫面
                await LoadPageDataAsync(silent: true);
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Background PhaseCoordinator failed for project {ProjectId}", projectId);
        }
    }

    private async Task LoadPageDataAsync(bool silent = false)
    {
        // silent=true：背景刷新（如 PhaseCoordinator 跑完）— 不切 isLoadingQuota，
        // 避免使用者已看到的卡片被 spinner 取代造成二次閃爍。
        if (!silent) isLoadingQuota = true;
        try
        {
            // 全部並行（含 LoadListAsync 內部的 ListAsync），降低空白→有內容的延遲
            // 子題計數與「已修題」計數一律永遠載入：
            //   - 子題狀態計數會餵到 [審修作業區] tab badge（母 + 子 合計），lazy 載入會讓 user 切 tab 前看到錯誤 badge
            //   - 計數 SQL 都是輕量 COUNT GROUP BY；Task.WhenAll 並行下總時間取決於最慢的 ListAsync，不會變慢
            var quotaTask       = QuestionService.GetMyQuotaProgressAsync(currentUserId!.Value, CurrentProject!.Id);
            var phaseTask       = QuestionService.GetCurrentPhaseAsync(CurrentProject!.Id);
            var countsTask      = QuestionService.GetStatusCountsAsync(CurrentProject!.Id, currentUserId!.Value);
            var phaseEndTask    = QuestionService.GetCompositionPhaseEndAsync(CurrentProject!.Id);
            var repliedTask     = QuestionService.GetMyRevisionRepliedCountAsync(CurrentProject!.Id, currentUserId!.Value);
            var subCountsTask   = QuestionService.GetSubQuestionStatusCountsAsync(CurrentProject!.Id, currentUserId!.Value);
            var subRepliedTask  = QuestionService.GetMySubQuestionRevisionRepliedCountAsync(CurrentProject!.Id, currentUserId!.Value);
            var listTask        = LoadListAsync(silent: silent);

            await Task.WhenAll(quotaTask, phaseTask, countsTask, phaseEndTask, repliedTask, subCountsTask, subRepliedTask, listTask);

            quotaProgress             = quotaTask.Result;
            currentPhase              = phaseTask.Result;
            statusCounts              = countsTask.Result;
            compositionPhaseEndDate   = phaseEndTask.Result;
            revisionRepliedCount      = repliedTask.Result;
            subStatusCounts           = subCountsTask.Result;
            subRevisionRepliedCount   = subRepliedTask.Result;
        }
        finally
        {
            if (!silent) isLoadingQuota = false;
        }

        // 後備防線：硬打 URL 進來但沒命題配額 → 設旗標等 firstRender 後才 Swal+redirect
        if (quotaProgress.Count == 0)
        {
            needNoPermissionRedirect = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!needNoPermissionRedirect) return;
        needNoPermissionRedirect = false;
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = "warning",
            title = "此身分在該專案沒有命題任務",
            text = "您目前的角色身分在此專案梯次未被分配命題配額。",
            confirmButtonColor = "#6B8EAD"
        });
        Navigation.NavigateTo("/");
    }

    private async Task LoadListAsync(bool silent = false)
    {
        if (CurrentProject is null || currentUserId is null) return;

        // silent=true：背景刷新（如 PhaseCoordinator 跑完）— 不切 isLoadingList，
        // 避免使用者已看到的列表被 spinner 取代造成閃爍。
        if (!silent) isLoadingList = true;
        try
        {
            var filter = new QuestionListFilter
            {
                ProjectId        = CurrentProject.Id,
                CreatorId        = currentUserId.Value,
                Tab              = currentTab,
                StatusFilter     = ResolveStatusFilter(),
                StatusesOverride = ResolveStatusesOverride(),
                HasReplied       = ResolveHasReplied(),
                QuestionTypeId   = int.TryParse(queryTypeId, out var t) ? t : null,
                Level            = byte.TryParse(queryLevel, out var l) ? l : null,
                Keyword          = string.IsNullOrWhiteSpace(queryKeyword) ? null : queryKeyword.Trim(),
                Page             = currentPage,
                PageSize         = pageSize
            };
            listResult = await QuestionService.ListAsync(filter);
        }
        finally
        {
            if (!silent) isLoadingList = false;
            StateHasChanged();
        }
    }

    /// <summary>把 activeFilter 字串對應到 QuestionListFilter.StatusFilter（單一 byte 或 null）。</summary>
    private byte? ResolveStatusFilter() => (currentTab, activeFilter) switch
    {
        ("compose",  "draft")     => QuestionStatus.Draft,
        ("compose",  "done")      => QuestionStatus.Completed,
        // compose 的「已送審」涵蓋 Status 2-8（送審後尚未結案的快照），由 StatusesOverride 處理
        // history 的「已採用」涵蓋 Status 9 / 12（首輪通過 / 兩輪通過 / 結案入庫），由 StatusesOverride 處理
        ("history",  "rejected")  => QuestionStatus.Rejected,
        // revision 子分類（locked/editing）涉及多 status，由 ListAsync 用 Tab 範圍處理；此處不單一過濾
        _                         => null
    };

    /// <summary>多狀態 filter override（如「已送審」card 涵蓋 Status 2-8）。</summary>
    private byte[]? ResolveStatusesOverride() => (currentTab, activeFilter) switch
    {
        ("compose",  "submitted") => QuestionStatus.SubmittedSnapshotStatuses,
        // 審題鎖定：送審 + 三個審查中（2,3,5,7），不含修題中的 4,6,8
        ("revision", "locked")    => [QuestionStatus.Submitted,
                                      QuestionStatus.PeerReviewing,
                                      QuestionStatus.ExpertReviewing,
                                      QuestionStatus.FinalReviewing],
        // editing/replied 都對齊修題狀態 (4,6,8)，差異由 ResolveHasReplied 處理
        ("revision", "editing")   => [QuestionStatus.PeerEditing,
                                      QuestionStatus.ExpertEditing,
                                      QuestionStatus.FinalEditing],
        ("revision", "replied")   => [QuestionStatus.PeerEditing,
                                      QuestionStatus.ExpertEditing,
                                      QuestionStatus.FinalEditing],
        // 已採用：首輪總審通過 (9) + 次輪通過或結案入庫 (12)
        ("history",  "adopted")   => [QuestionStatus.Adopted, QuestionStatus.Archived],
        _                         => null
    };

    /// <summary>把 activeFilter 對應到 QuestionListFilter.HasReplied
    /// （editing=未送出、replied=已送出、其餘=不限）。</summary>
    private bool? ResolveHasReplied() => (currentTab, activeFilter) switch
    {
        ("revision", "editing") => false,
        ("revision", "replied") => true,
        _                       => null
    };

    private async Task SwitchTab(string tab)
    {
        currentTab    = tab;
        activeFilter  = "all";
        currentPage   = 1;

        // 計數已在 LoadPageDataAsync 進站時全載入，切 tab 只需重抓列表（篩選條件變了）
        await LoadListAsync();
    }

    private async Task OnFilterChanged(string filterKey)
    {
        activeFilter = filterKey;
        currentPage  = 1;
        await LoadListAsync();
    }

    private async Task OnKeywordChanged(string? keyword)
    {
        queryKeyword = keyword;
        currentPage  = 1;
        await LoadListAsync();
    }

    private async Task OnTypeFilterChanged(ChangeEventArgs e)
    {
        queryTypeId  = e.Value?.ToString() ?? "";
        currentPage  = 1;
        await LoadListAsync();
    }

    private async Task OnLevelFilterChanged(ChangeEventArgs e)
    {
        queryLevel   = e.Value?.ToString() ?? "";
        currentPage  = 1;
        await LoadListAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        if (page < 1 || page > listResult.PageCount || page == currentPage) return;
        currentPage = page;
        await LoadListAsync();
    }

    private int CountOf(byte status) => statusCounts.GetValueOrDefault(status, 0);
    private int SumCounts(byte[] statuses) => statuses.Sum(s => statusCounts.GetValueOrDefault(s, 0));

    // 子題層級的同義 helper（搭配 ListAsync revision tab 拆 N+1 列的設計）
    private int SubSumCounts(byte[] statuses) => statuses.Sum(s => subStatusCounts.GetValueOrDefault(s, 0));

    /// <summary>「修題中」(尚未送出) 的計數 = 全部修題狀態 (4,6,8) 扣除已送出修題回覆。</summary>
    private int RevisionEditingActiveCount =>
        SumCounts([QuestionStatus.PeerEditing, QuestionStatus.ExpertEditing, QuestionStatus.FinalEditing])
        - revisionRepliedCount;

    private int SubRevisionEditingActiveCount =>
        SubSumCounts([QuestionStatus.PeerEditing, QuestionStatus.ExpertEditing, QuestionStatus.FinalEditing])
        - subRevisionRepliedCount;

    private bool IsEditableStatus(byte status)
    {
        // 命題作業區（compose）：Status >= 2 都是「已送審」唯讀快照，不開放從此 tab 編輯
        // 修題請至審修作業區操作（不同的 Slide-Over）
        if (currentTab == "compose" && status >= QuestionStatus.Submitted)
            return false;

        // 命題階段結束後，草稿與命題完成皆視為唯讀
        if (IsCompositionPhaseClosed && status is QuestionStatus.Draft or QuestionStatus.Completed)
            return false;

        // 修題狀態必須與當前階段對齊才開放編輯
        //   PeerEditing(4)→PhaseCode=4 / ExpertEditing(6)→PhaseCode=6 / FinalEditing(8)→PhaseCode=8
        if (status == QuestionStatus.PeerEditing)
            return currentPhase?.PhaseCode == 4;
        if (status == QuestionStatus.ExpertEditing)
            return currentPhase?.PhaseCode == 6;
        if (status == QuestionStatus.FinalEditing)
            return currentPhase?.PhaseCode == 8;

        return status is QuestionStatus.Draft or QuestionStatus.Completed;
    }

    /// <summary>EmptyState 文案依當前 Tab 與階段提供更具脈絡的提示。</summary>
    private (string Icon, string Message, string SubMessage) GetEmptyStateContent()
    {
        if (currentTab == "compose")
            return ("fa-file-circle-plus", "目前此區沒有試題", "點擊上方「新增試題」開始命題。");

        if (currentTab == "history")
            return ("fa-box-archive", "尚無審核結果", "總審判決後的題目將顯示於此。");

        // revision tab：先依使用者點擊的卡片 filter 提示，再 fallback 到階段提示。
        switch (activeFilter)
        {
            case "locked":
                return ("fa-lock", "目前沒有審題鎖定中的題目", "進行審題的階段時，待審題目會在此顯示。");
            case "editing":
                return ("fa-pen", "目前沒有等待修題的題目", "審題人退回的題目會在此顯示，等待您修改。");
            case "replied":
                return ("fa-circle-check", "目前沒有已修題的題目", "您送出修題說明後，題目會在此顯示。");
        }

        // activeFilter == "all" 或其他：依當前階段給予整體脈絡提示。
        var code = currentPhase?.PhaseCode;
        return code switch
        {
            3 or 5 or 7 => ("fa-lock", "目前沒有需要您處理的題目", "審題進行中，題目已鎖定。"),
            4 or 6 or 8 => ("fa-circle-check", "目前沒有需要修題的題目", "若有審題意見退回的題目會出現於此。"),
            _ when code is null or 1 or 2 && !IsCompositionPhaseClosed
                        => ("fa-hourglass-start", "審題尚未開始", "待命題階段結束後將自動進入互審。"),
            _           => ("fa-flag-checkered", "審修作業已結束", "目前無進行中的審題或修題階段。")
        };
    }

