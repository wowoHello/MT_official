@* ====================================================================== *@
@*  CwtList — 命題任務（題目列表）                                          *@
@*  路由：/cwt-list                                                        *@
@*  功能：命題/審修/歷史三分頁、統計卡片、題目 CRUD、FullScreen 命題編輯器   *@
@* ====================================================================== *@
@page "/cwt-list"
@using MT.Components.Shared.QuestionForms
@using MT.Components.Shared.QuestionPreviews
@inject IQuestionService QuestionService
@inject NavigationManager Navigation

<div class="flex-grow flex flex-col w-full mx-auto h-[calc(100vh-4rem)] overflow-hidden">

    <!-- Header: Breadcrumb + Title + Actions -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur-sm border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1">
                        <li>
                            <NavLink href="" Match="NavLinkMatch.All" class="hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1.5"></i>
                                <span class="text-slate-main">命題任務</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <div class="flex items-center gap-3">
                    <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                        <i class="fa-solid fa-pen-ruler text-morandi"></i> 命題任務
                    </h1>
                    <!-- 當前階段指示燈 -->
                    @if (currentPhase is not null)
                    {
                        var urgentCss = currentPhase.IsUrgent
                            ? "bg-terracotta/15 text-terracotta border-terracotta/30"
                            : "bg-sage/15 text-sage border-sage/30";
                        var dotCss = currentPhase.IsUrgent ? "bg-terracotta" : "bg-sage";
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1 rounded-full border @urgentCss">
                            <span class="w-2 h-2 rounded-full @dotCss animate-pulse"></span>
                            @currentPhase.PhaseName 進行中
                            @if (currentPhase.IsUrgent)
                            {
                                <span>（剩 @currentPhase.DaysLeft 天）</span>
                            }
                        </span>
                    }
                    else if (!isLoadingQuota)
                    {
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1 rounded-full bg-gray-100 text-gray-400 border border-gray-200">
                            <span class="w-2 h-2 rounded-full bg-gray-300"></span>
                            目前無進行中階段
                        </span>
                    }
                </div>
            </div>
            <button @onclick="() => OpenComposeModal(null)"
                disabled="@IsCompositionPhaseClosed"
                title="@(IsCompositionPhaseClosed ? "命題階段已結束，無法再新增題目" : null)"
                class="px-5 py-2.5 bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold text-sm transition-colors shadow-sm flex items-center gap-2 cursor-pointer focus:outline-none disabled:bg-gray-300 disabled:text-gray-500 disabled:cursor-not-allowed disabled:hover:bg-gray-300">
                <i class="fa-solid fa-plus"></i> 新增試題
            </button>
        </div>
    </div>

    <!-- Scrollable Body -->
    <div class="flex-grow overflow-y-auto custom-scroll">

        <!-- 配額進度卡片區 -->
        <div class="px-4 sm:px-6 lg:px-8 pt-5 pb-3">
            <div class="flex items-center gap-2 mb-3 flex-wrap">
                <h2 class="text-sm font-bold text-gray-500"><i class="fa-solid fa-chart-pie mr-1"></i> 我的命題配額進度</h2>
                <span class="text-xs text-gray-400 font-medium">
                    @quotaProgress.Sum(q => q.Completed) / @quotaProgress.Sum(q => q.Target)
                </span>
                @if (IsCompositionPhaseClosed)
                {
                    <span class="inline-flex items-center gap-1 text-xs text-terracotta font-bold ml-2">
                        <i class="fa-solid fa-lock"></i>
                        命題階段已於 @compositionPhaseEndDate!.Value.ToString("yyyy-MM-dd") 結束，配額不再變動
                    </span>
                }
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
                @if (isLoadingQuota)
                {
                    @for (int i = 0; i < 7; i++)
                    {
                        <div class="bg-white rounded-lg border border-gray-200 p-3 shadow-sm animate-pulse">
                            <div class="h-3 bg-gray-200 rounded w-3/4 mb-2"></div>
                            <div class="h-6 bg-gray-200 rounded w-1/2 mb-2"></div>
                            <div class="h-1.5 bg-gray-200 rounded-full"></div>
                        </div>
                    }
                }
                else if (quotaProgress.Any())
                {
                    @foreach (var q in quotaProgress)
                    {
                        @QuotaCard(q.QuestionTypeId, q.TypeName, q.Completed, q.Target)
                    }
                }
                else
                {
                    <div class="col-span-7 text-sm text-gray-400 text-center py-2">
                        <i class="fa-solid fa-circle-info mr-1"></i> 尚未分配命題配額
                    </div>
                }
            </div>
        </div>

        <!-- 三大 Tab 工作區 -->
        <div class="px-4 sm:px-6 lg:px-8 pb-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

                <!-- Tab Bar -->
                <div class="flex border-b border-gray-200 bg-white sticky top-0 z-20 overflow-x-auto">
                    <button @onclick='() => SwitchTab("compose")'
                        class="@(currentTab == "compose" ? "text-sage border-b-sage font-bold" : "text-gray-500 border-transparent") px-5 py-3 text-sm border-b-2 transition-colors hover:text-sage cursor-pointer focus:outline-none whitespace-nowrap">
                        <i class="fa-solid fa-pen-nib mr-1.5 text-sage"></i>命題作業區
                        <span class="ml-2 text-xs bg-sage/15 text-sage px-2 py-0.5 rounded-full font-bold">@SumCounts(QuestionStatus.ComposeTabStatuses)</span>
                    </button>
                    <button @onclick='() => SwitchTab("revision")'
                        class="@(currentTab == "revision" ? "text-terracotta border-b-terracotta font-bold" : "text-gray-500 border-transparent") px-5 py-3 text-sm border-b-2 transition-colors hover:text-terracotta cursor-pointer focus:outline-none whitespace-nowrap">
                        <i class="fa-solid fa-rotate-left mr-1.5 text-terracotta"></i>審修作業區
                        <span class="ml-2 text-xs bg-terracotta/15 text-terracotta px-2 py-0.5 rounded-full font-bold">@SumCounts(QuestionStatus.RevisionTabStatuses)</span>
                    </button>
                    <button @onclick='() => SwitchTab("history")'
                        class="@(currentTab == "history" ? "text-morandi border-b-morandi font-bold" : "text-gray-500 border-transparent") px-5 py-3 text-sm border-b-2 transition-colors hover:text-morandi cursor-pointer focus:outline-none whitespace-nowrap">
                        <i class="fa-solid fa-box-archive mr-1.5 text-morandi"></i>審核結果與歷史
                        <span class="ml-2 text-xs bg-morandi/15 text-morandi px-2 py-0.5 rounded-full font-bold">@SumCounts(QuestionStatus.HistoryTabStatuses)</span>
                    </button>
                </div>

                <!-- Tab 統計卡片區 -->
                <div class="p-4 border-b border-gray-100 bg-gray-50/50 flex-shrink-0">
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                        @if (currentTab == "compose")
                        {
                            @StatCard("命題總計", SumCounts(QuestionStatus.ComposeTabStatuses), "fa-layer-group", "text-morandi", "text-slate-main", "all", "顯示全部題目")
                            @StatCard("命題草稿", CountOf(QuestionStatus.Draft), "fa-file-pen", "text-gray-400", "text-slate-main", "draft", "點一下套用篩選")
                            @StatCard("命題完成", CountOf(QuestionStatus.Completed), "fa-circle-check", "text-sage", "text-sage", "done", "點一下套用篩選")
                            @StatCard("已送審", CountOf(QuestionStatus.Submitted), "fa-paper-plane", "text-morandi", "text-morandi", "submitted", "點一下套用篩選")
                        }
                        else if (currentTab == "revision")
                        {
                            @StatCard("審題總計", SumCounts(QuestionStatus.RevisionTabStatuses), "fa-layer-group", "text-terracotta", "text-slate-main", "all", "顯示全部題目")
                            @StatCard("審題鎖定", SumCounts([QuestionStatus.Submitted, QuestionStatus.PeerReviewing, QuestionStatus.ExpertReviewing, QuestionStatus.FinalReviewing]), "fa-lock", "text-morandi", "text-morandi", "locked", "點一下套用篩選")
                            @StatCard("修題中", SumCounts([QuestionStatus.PeerEditing, QuestionStatus.ExpertEditing, QuestionStatus.FinalEditing]), "fa-lock-open", "text-terracotta", "text-terracotta", "editing", "點一下套用篩選")
                        }
                        else
                        {
                            @StatCard("全部題目", SumCounts(QuestionStatus.HistoryTabStatuses), "fa-layer-group", "text-morandi", "text-slate-main", "all", "顯示全部題目")
                            @StatCard("已採用", CountOf(QuestionStatus.Adopted), "fa-circle-check", "text-sage", "text-sage", "adopted", "點一下套用篩選")
                            @StatCard("不採用", CountOf(QuestionStatus.Rejected) + CountOf(QuestionStatus.ClosedNotAdopted), "fa-circle-xmark", "text-gray-400", "text-gray-400", "rejected", "點一下套用篩選")
                        }
                    </div>
                </div>

                <!-- 篩選列 -->
                <div class="p-4 border-b border-gray-100 bg-white flex flex-col xl:flex-row gap-3 items-start xl:items-center justify-between flex-shrink-0">
                    <div class="flex flex-wrap items-center gap-3 w-full xl:w-auto">
                        <div class="w-full md:w-56">
                            <DebouncedSearchInput Value="@(queryKeyword ?? "")" ValueChanged="OnKeywordChanged"
                                Placeholder="搜尋題號或關鍵字..." />
                        </div>
                        <select value="@queryTypeId" @onchange="OnTypeFilterChanged"
                            class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="">所有題型</option>
                            @foreach (var (id, key) in QuestionConstants.TypeIdToKey)
                            {
                                <option value="@id">@QuestionConstants.TypeLabels.GetValueOrDefault(key, key)</option>
                            }
                        </select>
                        <select value="@queryLevel" @onchange="OnLevelFilterChanged"
                            class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="">所有等級</option>
                            @foreach (var kv in QuestionConstants.GeneralLevelLabels)
                            {
                                <option value="@kv.Key">@kv.Value</option>
                            }
                        </select>
                    </div>
                    <div class="flex flex-wrap items-center justify-between gap-3 w-full xl:w-auto xl:justify-end">
                        <label class="flex items-center gap-2 text-sm text-gray-500 font-medium whitespace-nowrap">
                            每頁顯示
                            <select value="@pageSize" @onchange="OnPageSizeChanged"
                                class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                <option value="12">12 題</option>
                                <option value="24">24 題</option>
                                <option value="48">48 題</option>
                            </select>
                        </label>
                        <div class="text-sm text-gray-500 font-medium flex-shrink-0">
                            共 <span class="text-morandi font-bold">@listResult.TotalCount</span> 題
                        </div>
                    </div>
                </div>

                <!-- 題目列表 -->
                @if (isLoadingList)
                {
                    <div class="p-8 text-center text-gray-400 text-sm">
                        <i class="fa-solid fa-spinner fa-spin mr-2"></i>載入中…
                    </div>
                }
                else if (listResult.Items.Count == 0)
                {
                    <div class="p-8">
                        <EmptyState IconClass="fa-file-circle-plus" Message="目前此區沒有試題" SubMessage="點擊上方「新增試題」開始命題。" />
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="text-xs text-gray-500 uppercase font-bold bg-gray-50 border-b border-gray-200">
                                <tr>
                                    <th class="px-4 py-2 text-left whitespace-nowrap">題號</th>
                                    <th class="px-4 py-2 text-left whitespace-nowrap">題型</th>
                                    <th class="px-4 py-2 text-left whitespace-nowrap">等級 / 難度</th>
                                    <th class="px-4 py-2 text-left">題目摘要</th>
                                    <th class="px-4 py-2 text-center whitespace-nowrap">狀態</th>
                                    <th class="px-4 py-2 text-left whitespace-nowrap">最後修改</th>
                                    <th class="px-4 py-2 text-center whitespace-nowrap">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in listResult.Items)
                                {
                                    <tr @onclick="() => OpenEditAsync(item.Id)"
                                        class="border-b border-gray-100 relative hover:z-10 hover:bg-blue-50/40 hover:shadow-[inset_4px_0_0_var(--color-morandi),0_6px_16px_-4px_rgba(0,0,0,0.18)] transition-all cursor-pointer group">
                                        <td class="px-4 py-3 font-bold text-slate-main group-hover:text-morandi whitespace-nowrap transition-colors">@item.QuestionCode</td>
                                        <td class="px-4 py-3 whitespace-nowrap">
                                            <span class="inline-block px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs font-bold border border-gray-200">
                                                @QuestionConstants.TypeLabels.GetValueOrDefault(item.TypeKey, "未知")
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 whitespace-nowrap">
                                            <span class="text-xs text-morandi font-bold">@LevelLabel(item.TypeKey, item.Level)</span>
                                            @if (item.Difficulty is byte d)
                                            {
                                                <span class="text-xs text-terracotta font-bold ml-2">@QuestionConstants.DifficultyLabels.GetValueOrDefault(d, "")</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 max-w-md">
                                            <div class="text-gray-700 truncate flex items-center gap-2" title="@StripHtml(item.SummaryHtml)">
                                                @if (item.SubQuestionCount > 0)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 bg-morandi/10 text-morandi rounded text-xs font-bold border border-morandi/20 whitespace-nowrap shrink-0">
                                                        @item.SubQuestionCount 子題
                                                    </span>
                                                }
                                                <span class="truncate">@(string.IsNullOrWhiteSpace(item.SummaryHtml) ? "（尚未填寫題幹）" : StripHtml(item.SummaryHtml))</span>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 text-center whitespace-nowrap">
                                            <StatusBadge StatusText="@RowStatusLabel(item.Status)" Compact="true" />
                                        </td>
                                        <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">@item.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                                        <td class="px-4 py-3 text-center whitespace-nowrap" @onclick:stopPropagation="true">
                                            <div class="inline-flex items-center gap-3">
                                                <button @onclick="() => OpenEditAsync(item.Id)"
                                                    class="text-morandi hover:underline text-xs font-bold cursor-pointer focus:outline-none">
                                                    <i class="fa-solid fa-pen-to-square mr-0.5"></i> @(IsEditableStatus(item.Status) ? "編輯" : "檢視")
                                                </button>
                                                @if (item.Status == QuestionStatus.Draft && !IsCompositionPhaseClosed)
                                                {
                                                    <button @onclick="() => DeleteAsync(item.Id, item.QuestionCode)"
                                                        title="刪除草稿"
                                                        class="text-terracotta hover:text-red-600 text-xs font-bold cursor-pointer focus:outline-none">
                                                        <i class="fa-solid fa-trash mr-0.5"></i> 刪除
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* 分頁器 *@
                    @if (listResult.PageCount > 1)
                    {
                        <div class="flex items-center justify-center gap-2 py-4 border-t border-gray-100">
                            <button @onclick="() => GoToPageAsync(currentPage - 1)" disabled="@(currentPage <= 1)"
                                class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed">
                                <i class="fa-solid fa-chevron-left"></i>
                            </button>
                            <span class="text-sm text-gray-600 font-medium">第 @currentPage / @listResult.PageCount 頁</span>
                            <button @onclick="() => GoToPageAsync(currentPage + 1)" disabled="@(currentPage >= listResult.PageCount)"
                                class="px-3 py-1 text-sm border border-gray-300 rounded hover:bg-gray-50 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed">
                                <i class="fa-solid fa-chevron-right"></i>
                            </button>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- FullScreen 命題表單 Modal -->
<CustomModal @bind-IsVisible="showComposeModal" Type="CustomModal.ModalType.FullScreen" Title="@composeModalTitle" CloseOnBackdropClick="false" KeepAlive="true">
    <TitleSubtitle>
        @if (currentFormUpdatedAt is not null)
        {
            <span class="inline-flex items-center gap-1">
                <i class="fa-regular fa-clock"></i>
                最後修改：@currentFormUpdatedAt.Value.ToString("yyyy/MM/dd HH:mm")
            </span>
            <span class="mx-1 text-gray-300">•</span>
        }
        <StatusBadge StatusText="@QuestionStatus.Labels.GetValueOrDefault(currentFormStatus, "命題草稿")" Compact="true" />
    </TitleSubtitle>
    <HeaderActions>
        <button @onclick="() => showPreviewModal = true" disabled="@isSaving"
            class="px-4 py-2 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-1.5">
            <i class="fa-regular fa-eye"></i> 預覽
        </button>
        @if (IsEditableStatus(currentFormStatus))
        {
            <button @onclick="() => SaveAsync(QuestionStatus.Draft)" disabled="@isSaving"
                class="px-4 py-2 text-sm border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
                @if (isSaving && pendingStatus == QuestionStatus.Draft)
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1"></i> <span>儲存中…</span>
                }
                else
                {
                    <span>存為草稿</span>
                }
            </button>
            <button @onclick="() => SaveAsync(QuestionStatus.Completed)" disabled="@isSaving"
                class="px-5 py-2 text-sm bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-1.5">
                @if (isSaving && pendingStatus == QuestionStatus.Completed)
                {
                    <i class="fa-solid fa-spinner fa-spin"></i> <span>提交中…</span>
                }
                else
                {
                    <i class="fa-solid fa-check"></i> <span>命題完成</span>
                }
            </button>
        }
    </HeaderActions>
    <ChildContent>
        <QuillEditorHost>
            @{ var isFormReadOnly = !IsEditableStatus(currentFormStatus); }
            <CascadingValue Name="IsFormReadOnly" Value="@isFormReadOnly" IsFixed="false">
            <div class="flex-grow flex overflow-hidden relative min-h-0 h-full">
                <!-- 伸縮標籤按鈕（外置於 fieldset 之上，避免檢視模式被一併禁用） -->
                <button type="button" @onclick="() => sidebarCollapsed = !sidebarCollapsed"
                    class="absolute top-1/2 -translate-y-1/2 z-20 bg-white border border-gray-200 border-l-0 rounded-r-lg shadow-sm px-1.5 py-3 flex flex-col items-center gap-1 text-gray-400 hover:text-morandi hover:bg-gray-50 transition-all duration-300 cursor-pointer focus:outline-none @(sidebarCollapsed ? "left-0" : "left-60 lg:left-72")"
                    title="@(sidebarCollapsed ? "展開屬性欄" : "收合屬性欄")">
                    <i class="fa-solid @(sidebarCollapsed ? "fa-chevron-right" : "fa-chevron-left") text-xs"></i>
                    <span class="text-xs font-bold writing-vertical">屬性</span>
                    <i class="fa-solid @(sidebarCollapsed ? "fa-chevron-right" : "fa-chevron-left") text-xs"></i>
                </button>

                <fieldset disabled="@isFormReadOnly"
                    class="flex-grow flex overflow-hidden min-h-0 h-full m-0 p-0 border-0 disabled:opacity-95">
                    <!-- 左側邊欄：屬性設定（可收合） -->
                    <div class="@(sidebarCollapsed ? "w-0" : "w-60 lg:w-72") flex-shrink-0 bg-white border-r border-gray-200 overflow-hidden flex flex-col transition-all duration-300 ease-in-out">
                        <QuestionAttributesSidebar IsCollapsed="sidebarCollapsed"
                            QuestionType="@formData.QuestionType" QuestionTypeChanged="OnQuestionTypeChanged"
                            @bind-Level="formData.Level" @bind-Difficulty="formData.Difficulty"
                            @bind-Topic="formData.Topic" @bind-Subtopic="formData.Subtopic"
                            @bind-WritingMode="formData.WritingMode" @bind-Genre="formData.Genre"
                            @bind-AudioType="formData.AudioType" @bind-Material="formData.Material"
                            @bind-CoreAbility="formData.CoreAbility" @bind-DetailIndicator="formData.DetailIndicator" />
                    </div>

                <!-- 右側：主要編輯區 -->
                <div class="flex-grow overflow-y-auto custom-scroll bg-oatmeal min-h-0">
                    @switch (formData.QuestionType)
                    {
                        case QuestionTypeCodes.Single:
                        case QuestionTypeCodes.Select:
                            <QuestionFormSingle @bind-Stem="formData.Stem" @bind-Options="formData.Options" @bind-Answer="formData.Answer" @bind-Analysis="formData.Analysis" />
                            break;
                        case QuestionTypeCodes.LongText:
                            <QuestionFormLongText @bind-Stem="formData.Stem" @bind-Passage="formData.ArticleContent" @bind-GradingNote="formData.GradingNote" />
                            break;
                        case QuestionTypeCodes.ReadGroup:
                            <QuestionFormReadGroup Status="@currentFormStatus" @bind-Stem="formData.Stem" @bind-Passage="formData.ArticleContent" @bind-SubQuestions="formData.ReadSubQuestions" />
                            break;
                        case QuestionTypeCodes.ShortGroup:
                            <QuestionFormShortGroup Status="@currentFormStatus" @bind-Stem="formData.Stem" @bind-Passage="formData.ArticleContent" @bind-SubQuestions="formData.ShortSubQuestions" />
                            break;
                        case QuestionTypeCodes.Listen:
                            <QuestionFormListen @bind-AudioFileName="formData.AudioUrl" @bind-Stem="formData.Stem" @bind-Options="formData.Options" @bind-Answer="formData.Answer" @bind-Analysis="formData.Analysis" />
                            break;
                        case QuestionTypeCodes.ListenGroup:
                            <QuestionFormListenGroup @bind-AudioFileName="formData.AudioUrl" @bind-Passage="formData.ArticleContent" @bind-SubQuestions="formData.ListenGroupSubQuestions" />
                            break;
                    }
                </div>
                </fieldset>
            </div>
            </CascadingValue>
        </QuillEditorHost>
    </ChildContent>
</CustomModal>

<!-- 考卷預覽 Modal -->
<QuestionPreviewModal Visible="showPreviewModal" OnClose="() => showPreviewModal = false">
    @switch (formData.QuestionType)
    {
        case QuestionTypeCodes.Single:
        case QuestionTypeCodes.Select:
            <PreviewSingle QuestionType="@QuestionConstants.TypeLabels.GetValueOrDefault(formData.QuestionType, "")" Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel"
                Tags="@GetPreviewTags()" Stem="@formData.Stem" Options="@formData.Options" Answer="@formData.Answer" />
            break;
        case QuestionTypeCodes.ReadGroup:
            <PreviewReadGroup Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel" Tags="@GetPreviewTags()"
                Stem="@formData.Stem" Passage="@formData.ArticleContent"
                SubQuestions="@formData.ReadSubQuestions.Select(sq => new PreviewReadGroup.SubQuestionData { Stem = sq.Stem, Options = sq.Options, Answer = sq.Answer }).ToList()" />
            break;
        case QuestionTypeCodes.LongText:
            <PreviewLongText Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel" Tags="@GetPreviewTags()"
                Stem="@formData.Stem" Passage="@formData.ArticleContent" />
            break;
        case QuestionTypeCodes.ShortGroup:
            <PreviewShortGroup Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel" Tags="@GetPreviewTags()"
                Stem="@formData.Stem" Passage="@formData.ArticleContent"
                SubQuestions="@formData.ShortSubQuestions.Select(sq => new PreviewShortGroup.SubQuestionData {
                    Stem = sq.Stem,
                    Dimension = QuestionConstants.DecodeSubCoreAbility(sq.CoreAbility, QuestionTypeCodes.ShortGroup),
                    Indicator = QuestionConstants.DecodeSubIndicator(sq.Indicator, QuestionTypeCodes.ShortGroup) }).ToList()" />
            break;
        case QuestionTypeCodes.Listen:
            <PreviewListen Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel" Tags="@GetPreviewTags()"
                AudioFileName="@formData.AudioUrl" Stem="@formData.Stem" Options="@formData.Options" Answer="@formData.Answer" />
            break;
        case QuestionTypeCodes.ListenGroup:
            <PreviewListenGroup Tags="@GetPreviewTags()" AudioFileName="@formData.AudioUrl" Passage="@formData.ArticleContent"
                SubQuestions="@formData.ListenGroupSubQuestions.Select(sq => new PreviewListenGroup.SubQuestionData {
                    Level = QuestionConstants.ListenLevelLabels.GetValueOrDefault(sq.FixedDifficulty, ""),
                    CoreAbility = QuestionConstants.DecodeSubCoreAbility(sq.CoreAbility, QuestionTypeCodes.ListenGroup),
                    DetailIndicator = QuestionConstants.DecodeSubIndicator(sq.DetailIndicator, QuestionTypeCodes.ListenGroup),
                    Stem = sq.Stem, Options = sq.Options, Answer = sq.Answer }).ToList()" />
            break;
    }
</QuestionPreviewModal>

@code {
    [CascadingParameter(Name = "CurrentProject")]
    private ProjectSwitcherItem? CurrentProject { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private int? currentUserId;
    private List<QuotaProgressItem> quotaProgress = [];
    private ProjectPhaseInfo? currentPhase;
    private bool isLoadingQuota = true;

    private string currentTab = "compose";
    private bool showComposeModal = false;
    private bool sidebarCollapsed = false;
    private string composeModalTitle = "新增試題";

    // 預覽 Modal
    private bool showPreviewModal = false;

    // 表單狀態統一收攏（題型 / 等級 / 難度 / 8 屬性 / 主題內容 / 子題清單）
    private QuestionFormData formData = new();

    // Modal 表單目前顯示的狀態（決定 Header 標籤文字）
    private byte currentFormStatus = QuestionStatus.Draft;

    // 編輯時顯示的「最後修改時間」（新增時為 null 不顯示）
    private DateTime? currentFormUpdatedAt;

    // 儲存中防呆：避免重複送出
    private bool isSaving;
    private byte? pendingStatus;   // 哪一個按鈕觸發的（影響 spinner 顯示位置）

    // 列表狀態
    private QuestionListResult listResult = new();
    private Dictionary<byte, int> statusCounts = [];
    private bool isLoadingList;
    private int currentPage = 1;
    private int pageSize = 12;

    // 篩選條件
    private string? queryKeyword;
    private string queryTypeId = "";   // "" or "1"~"7"
    private string queryLevel = "";    // "" or "0"~"5"

    // 後備防線：硬打 URL 進來但無配額 → 旗標化等 OnAfterRenderAsync 才彈 Swal（避免 prerender JS 錯誤）
    private bool needNoPermissionRedirect;

    // 已載入的 ProjectId 守門 —— 避免父層重渲染時重跑 LoadPageDataAsync 導致配額卡片骨架閃爍
    private int? loadedProjectId;

    // Plan_008：命題階段結束相關
    private DateTime? compositionPhaseEndDate;
    private bool IsCompositionPhaseClosed
        => compositionPhaseEndDate.HasValue && compositionPhaseEndDate.Value.Date < DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(claim, out var uid))
            currentUserId = uid;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (CurrentProject is null || currentUserId is null) return;
        if (loadedProjectId == CurrentProject.Id) return;   // 同專案重派 → 不重載
        loadedProjectId = CurrentProject.Id;

        // Plan_008：進入頁面前先觸發命題階段結束的批次轉換 + 互審分配（Idempotent）
        try
        {
            await QuestionService.EnsureCompositionPhaseClosedAsync(CurrentProject.Id);
        }
        catch (InvalidOperationException ex)
        {
            // 命題教師不足 2 人時 throw —— 提示後仍繼續載入頁面（讓總召看到草稿/完成題目）
            await ShowToastAsync("warning", ex.Message);
        }

        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        isLoadingQuota = true;
        try
        {
            var quotaTask    = QuestionService.GetMyQuotaProgressAsync(currentUserId!.Value, CurrentProject!.Id);
            var phaseTask    = QuestionService.GetCurrentPhaseAsync(CurrentProject!.Id);
            var countsTask   = QuestionService.GetStatusCountsAsync(CurrentProject!.Id, currentUserId!.Value);
            var phaseEndTask = QuestionService.GetCompositionPhaseEndAsync(CurrentProject!.Id);
            await Task.WhenAll(quotaTask, phaseTask, countsTask, phaseEndTask);
            quotaProgress             = quotaTask.Result;
            currentPhase              = phaseTask.Result;
            statusCounts              = countsTask.Result;
            compositionPhaseEndDate   = phaseEndTask.Result;
        }
        finally
        {
            isLoadingQuota = false;
        }

        // 後備防線：硬打 URL 進來但沒命題配額 → 設旗標等 firstRender 後才 Swal+redirect
        if (quotaProgress.Count == 0)
        {
            needNoPermissionRedirect = true;
            return;
        }

        await LoadListAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!needNoPermissionRedirect) return;
        needNoPermissionRedirect = false;
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = "warning",
            title = "此身分在該專案沒有命題任務",
            text = "您目前的角色身分在此專案梯次未被分配命題配額。",
            confirmButtonColor = "#6B8EAD"
        });
        Navigation.NavigateTo("/");
    }

    private async Task LoadListAsync()
    {
        if (CurrentProject is null || currentUserId is null) return;

        isLoadingList = true;
        try
        {
            var filter = new QuestionListFilter
            {
                ProjectId      = CurrentProject.Id,
                CreatorId      = currentUserId.Value,
                Tab            = currentTab,
                StatusFilter   = ResolveStatusFilter(),
                QuestionTypeId = int.TryParse(queryTypeId, out var t) ? t : null,
                Level          = byte.TryParse(queryLevel, out var l) ? l : null,
                Keyword        = string.IsNullOrWhiteSpace(queryKeyword) ? null : queryKeyword.Trim(),
                Page           = currentPage,
                PageSize       = pageSize
            };
            listResult = await QuestionService.ListAsync(filter);
        }
        finally
        {
            isLoadingList = false;
            StateHasChanged();
        }
    }

    /// <summary>把 activeFilter 字串對應到 QuestionListFilter.StatusFilter（單一 byte 或 null）。</summary>
    private byte? ResolveStatusFilter() => (currentTab, activeFilter) switch
    {
        ("compose",  "draft")     => QuestionStatus.Draft,
        ("compose",  "done")      => QuestionStatus.Completed,
        ("compose",  "submitted") => QuestionStatus.Submitted,
        ("history",  "adopted")   => QuestionStatus.Adopted,
        ("history",  "rejected")  => QuestionStatus.Rejected,
        // revision 子分類（locked/editing）涉及多 status，由 ListAsync 用 Tab 範圍處理；此處不單一過濾
        _                         => null
    };

    private async Task SwitchTab(string tab)
    {
        currentTab    = tab;
        activeFilter  = "all";
        currentPage   = 1;
        await LoadListAsync();
    }

    private async Task OnFilterChanged(string filterKey)
    {
        activeFilter = filterKey;
        currentPage  = 1;
        await LoadListAsync();
    }

    private async Task OnKeywordChanged(string? keyword)
    {
        queryKeyword = keyword;
        currentPage  = 1;
        await LoadListAsync();
    }

    private async Task OnTypeFilterChanged(ChangeEventArgs e)
    {
        queryTypeId  = e.Value?.ToString() ?? "";
        currentPage  = 1;
        await LoadListAsync();
    }

    private async Task OnLevelFilterChanged(ChangeEventArgs e)
    {
        queryLevel   = e.Value?.ToString() ?? "";
        currentPage  = 1;
        await LoadListAsync();
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var n)) pageSize = n;
        currentPage = 1;
        await LoadListAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        if (page < 1 || page > listResult.PageCount || page == currentPage) return;
        currentPage = page;
        await LoadListAsync();
    }

    private int CountOf(byte status) => statusCounts.GetValueOrDefault(status, 0);
    private int SumCounts(byte[] statuses) => statuses.Sum(s => statusCounts.GetValueOrDefault(s, 0));

    private bool IsEditableStatus(byte status)
    {
        // Plan_008：命題階段結束後，草稿與命題完成皆視為唯讀
        if (IsCompositionPhaseClosed && status is QuestionStatus.Draft or QuestionStatus.Completed)
            return false;
        return status is QuestionStatus.Draft or QuestionStatus.Completed
                      or QuestionStatus.PeerEditing or QuestionStatus.ExpertEditing or QuestionStatus.FinalEditing;
    }

    /// <summary>
    /// 列表狀態欄顯示文字。
    /// 在「審修作業區」內，命題教師只需區分「審題鎖定 / 修題中」；
    /// 互審/專審/總審的階段差異在後台處理，老師不需要在這顆 pill 上看到。
    /// </summary>
    private string RowStatusLabel(byte status)
    {
        if (currentTab == "revision")
        {
            return status switch
            {
                QuestionStatus.Submitted
                or QuestionStatus.PeerReviewing
                or QuestionStatus.ExpertReviewing
                or QuestionStatus.FinalReviewing  => "審題鎖定",
                QuestionStatus.PeerEditing
                or QuestionStatus.ExpertEditing
                or QuestionStatus.FinalEditing    => "修題中",
                _                                 => QuestionStatus.Labels.GetValueOrDefault(status, "未知")
            };
        }
        return QuestionStatus.Labels.GetValueOrDefault(status, "未知");
    }

    private static string LevelLabel(string typeKey, byte? level)
    {
        if (level is null) return "";
        return typeKey is QuestionTypeCodes.Listen or QuestionTypeCodes.ListenGroup
            ? QuestionConstants.ListenLevelLabels.GetValueOrDefault(level.Value, "")
            : QuestionConstants.GeneralLevelLabels.GetValueOrDefault(level.Value, "");
    }

    /// <summary>HTML 摘要去標籤，僅給列表預覽用（不做進階淨化，因為內容是自家 Quill 產出）。</summary>
    private static string StripHtml(string html)
    {
        if (string.IsNullOrWhiteSpace(html)) return "";
        var text = System.Text.RegularExpressions.Regex.Replace(html, "<.*?>", " ");
        text = System.Net.WebUtility.HtmlDecode(text).Trim();
        return text.Length > 100 ? text[..100] + "…" : text;
    }

    private async Task OpenEditAsync(int questionId)
    {
        var data = await QuestionService.GetByIdAsync(questionId);
        if (data is null)
        {
            await ShowToastAsync("error", "題目不存在或已刪除");
            return;
        }
        var listItem = listResult.Items.FirstOrDefault(x => x.Id == questionId);
        formData             = data;
        currentFormStatus    = listItem?.Status ?? QuestionStatus.Draft;
        currentFormUpdatedAt = listItem?.UpdatedAt;
        composeModalTitle    = IsEditableStatus(currentFormStatus) ? "編輯試題" : "檢視試題";
        showComposeModal     = true;
    }

    /// <summary>軟刪除草稿題目（二次確認後呼叫 SoftDeleteAsync）。</summary>
    private async Task DeleteAsync(int questionId, string questionCode)
    {
        if (currentUserId is null) return;

        var confirm = await JS.InvokeAsync<SwalResult>("Swal.fire", new
        {
            icon = "warning",
            title = $"確定刪除 {questionCode}？",
            text  = "刪除後若要復原請聯繫管理員",
            showCancelButton  = true,
            confirmButtonText = "確定刪除",
            cancelButtonText  = "取消",
            confirmButtonColor = "#D98A6C",
            cancelButtonColor  = "#6B8EAD"
        });

        if (!confirm.IsConfirmed) return;

        var ok = await QuestionService.SoftDeleteAsync(questionId, currentUserId.Value);
        if (ok)
        {
            await ShowToastAsync("success", "已刪除");
            await LoadPageDataAsync();
        }
        else
        {
            await ShowToastAsync("error", "刪除失敗，題目可能已不在草稿狀態");
        }
    }

    private record SwalResult(bool IsConfirmed, bool IsDenied, bool IsDismissed);

    // 切題型時保留題型本身、重置其他欄位（避免帶舊資料）
    private void OnQuestionTypeChanged(string newType)
    {
        formData = new() { QuestionType = newType };
    }

    private void OpenComposeModal(string? presetTypeKey = null)
    {
        formData = new();
        if (!string.IsNullOrEmpty(presetTypeKey) && QuestionConstants.TypeKeyToId.ContainsKey(presetTypeKey))
        {
            formData.QuestionType = presetTypeKey;
        }
        currentFormStatus = QuestionStatus.Draft;
        currentFormUpdatedAt = null;
        composeModalTitle = "新增試題";
        showComposeModal = true;
    }

    /// <summary>
    /// 存為草稿（status=0）或命題完成（status=1）。
    /// formData.Id == 0 → CreateAsync；> 0 → UpdateAsync。
    /// Service 層自動寫入 MT_AuditLogs。
    /// </summary>
    private async Task SaveAsync(byte targetStatus)
    {
        if (isSaving) return;
        if (CurrentProject is null || currentUserId is null)
        {
            await ShowToastAsync("error", "找不到當前專案或使用者");
            return;
        }

        isSaving = true;
        pendingStatus = targetStatus;
        try
        {
            if (formData.Id == 0)
            {
                var newId = await QuestionService.CreateAsync(
                    formData, currentUserId.Value, CurrentProject.Id, targetStatus);
                formData.Id = newId;
            }
            else
            {
                var ok = await QuestionService.UpdateAsync(
                    formData.Id, formData, targetStatus, currentUserId.Value);
                if (!ok)
                {
                    await ShowToastAsync("error", "題目不存在或已被刪除");
                    return;
                }
            }

            currentFormStatus    = targetStatus;
            currentFormUpdatedAt = DateTime.Now;
            await ShowToastAsync("success",
                targetStatus == QuestionStatus.Completed ? "命題完成已儲存" : "已存為草稿");

            showComposeModal = false;
            await LoadPageDataAsync();
        }
        catch (Exception ex)
        {
            await ShowToastAsync("error", $"儲存失敗：{ex.Message}");
        }
        finally
        {
            isSaving = false;
            pendingStatus = null;
        }
    }

    private ValueTask ShowToastAsync(string icon, string title) =>
        JS.InvokeVoidAsync("Swal.fire", new
        {
            icon,
            title,
            toast = true,
            position = "top-end",
            showConfirmButton = false,
            timer = 2000
        });

    // 將 byte? 解碼為對應的中文標籤；若為 null 回傳 fallback
    private static string Label(byte? value, IReadOnlyDictionary<byte, string> map, string fallback) =>
        value is null ? fallback : map.GetValueOrDefault(value.Value, fallback);

    private Dictionary<string, string> GetPreviewTags()
    {
        var tags = new Dictionary<string, string>();
        const string fallback = "未設定";

        switch (formData.QuestionType)
        {
            case QuestionTypeCodes.Single:
            case QuestionTypeCodes.Select:
                tags["主類"] = Label(formData.Topic, QuestionConstants.TopicLabels, fallback);
                tags["次類"] = Label(formData.Subtopic, QuestionConstants.SubtopicLabels, fallback);
                break;
            case QuestionTypeCodes.LongText:
                tags["寫作模式"] = Label(formData.WritingMode, QuestionConstants.WritingModeLabels, fallback);
                break;
            case QuestionTypeCodes.ReadGroup:
                tags["文體"] = Label(formData.Genre, QuestionConstants.GenreLabels, fallback);
                break;
            case QuestionTypeCodes.ShortGroup:
                // 短文題組固定主類=文意判讀(6) / 次類=篇章辨析(17)
                tags["主類"] = "文意判讀";
                tags["次類"] = "篇章辨析";
                tags["文體"] = Label(formData.Genre, QuestionConstants.GenreLabels, fallback);
                break;
            case QuestionTypeCodes.Listen:
                tags["核心能力"] = Label(formData.CoreAbility, QuestionConstants.CoreAbilityLabels, fallback);
                tags["細目指標"] = Label(formData.DetailIndicator, QuestionConstants.DetailIndicatorLabels, fallback);
                tags["語音類型"] = Label(formData.AudioType, QuestionConstants.AudioTypeLabels, fallback);
                tags["素材分類"] = Label(formData.Material, QuestionConstants.MaterialLabels, fallback);
                break;
            case QuestionTypeCodes.ListenGroup:
                tags["語音類型"] = Label(formData.AudioType, QuestionConstants.AudioTypeLabels, fallback);
                tags["素材分類"] = Label(formData.Material, QuestionConstants.MaterialLabels, fallback);
                break;
        }
        return tags;
    }

    // 等級顯示用：聽力與一般題型的等級標籤系統不同
    private string SelectedLevelLabel
    {
        get
        {
            if (formData.Level is null) return "";
            return formData.QuestionType is QuestionTypeCodes.Listen or QuestionTypeCodes.ListenGroup
                ? QuestionConstants.ListenLevelLabels.GetValueOrDefault(formData.Level.Value, "")
                : QuestionConstants.GeneralLevelLabels.GetValueOrDefault(formData.Level.Value, "");
        }
    }

    private string SelectedDifficultyLabel =>
        formData.Difficulty is null ? "" : QuestionConstants.DifficultyLabels.GetValueOrDefault(formData.Difficulty.Value, "");

    private string activeFilter = "all";

    private RenderFragment StatCard(string title, int value, string icon, string iconColor, string valueColor, string filterKey, string subtitle) => __builder =>
    {
        var isActive = activeFilter == filterKey;
        <div @onclick="() => OnFilterChanged(filterKey)"
            class="@(isActive ? "ring-2 ring-morandi border-morandi bg-morandi/5" : "bg-white border-gray-200 hover:shadow-md") rounded-xl shadow-sm border p-4 transition duration-200 cursor-pointer select-none">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="text-2xl font-bold @valueColor">@value</div>
            <div class="text-xs text-gray-400 mt-1">@subtitle</div>
        </div>
    };

    private RenderFragment QuotaCard(int questionTypeId, string typeName, int current, int target) => __builder =>
    {
        var percent  = target > 0 ? (int)((double)current / target * 100) : 0;
        var barColor = percent >= 100 ? "bg-sage" : percent > 0 ? "bg-morandi" : "bg-gray-200";
        var typeKey  = QuestionConstants.TypeIdToKey.GetValueOrDefault(questionTypeId, "single");
        var locked   = IsCompositionPhaseClosed;
        var reached  = target > 0 && current >= target;
        var tooltip  = locked  ? "命題階段已結束，無法新增題目"
                     : reached ? $"已達標，仍可超量命題（{current}/{target}）"
                               : $"點擊新增「{typeName}」題目";

        <button type="button"
            @onclick="() => OpenComposeModal(typeKey)"
            disabled="@locked"
            title="@tooltip"
            class="@(locked
                ? "bg-gray-50 border border-gray-200 cursor-not-allowed opacity-70"
                : "bg-white border border-gray-200 hover:border-morandi/60 hover:shadow-md hover:-translate-y-0.5 cursor-pointer")
                relative text-left rounded-lg p-3 shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-morandi/40 group">

            @if (reached && !locked)
            {
                <span class="absolute top-1.5 right-1.5 inline-flex items-center gap-0.5 text-[10px] font-bold text-sage bg-sage/10 px-1.5 py-0.5 rounded-full border border-sage/20">
                    <i class="fa-solid fa-check text-[9px]"></i>已達標
                </span>
            }
            <div class="text-xs font-bold text-gray-600 mb-1 truncate pr-12">@typeName</div>
            <div class="flex items-baseline gap-1 mb-2">
                <span class="text-lg font-black text-slate-main">@current</span>
                <span class="text-xs text-gray-400">/ @target</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="@barColor h-1.5 rounded-full transition-all" style="width: @(percent)%"></div>
            </div>
            @if (!locked)
            {
                <span class="absolute bottom-1.5 right-2 text-[10px] text-morandi font-bold opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-0.5">
                    <i class="fa-solid fa-plus text-[9px]"></i>新增
                </span>
            }
        </button>
    };
}
