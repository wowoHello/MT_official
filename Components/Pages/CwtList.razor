@* ====================================================================== *@
@*  CwtList — 命題任務（題目列表）                                          *@
@*  路由：/cwt-list                                                        *@
@*  功能：命題/審修/歷史三分頁、統計卡片、題目 CRUD、FullScreen 命題編輯器   *@
@* ====================================================================== *@
@page "/cwt-list"
@using MT.Components.Shared.QuestionForms
@using MT.Components.Shared.QuestionPreviews
@inject IQuestionService QuestionService

<div class="flex-grow flex flex-col w-full mx-auto h-[calc(100vh-4rem)] overflow-hidden">

    <!-- Header: Breadcrumb + Title + Actions -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur-sm border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1">
                        <li>
                            <NavLink href="" Match="NavLinkMatch.All" class="hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1.5"></i>
                                <span class="text-slate-main">命題任務</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <div class="flex items-center gap-3">
                    <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                        <i class="fa-solid fa-pen-ruler text-morandi"></i> 命題任務
                    </h1>
                    <!-- 當前階段指示燈 -->
                    @if (currentPhase is not null)
                    {
                        var urgentCss = currentPhase.IsUrgent
                            ? "bg-terracotta/15 text-terracotta border-terracotta/30"
                            : "bg-sage/15 text-sage border-sage/30";
                        var dotCss = currentPhase.IsUrgent ? "bg-terracotta" : "bg-sage";
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1 rounded-full border @urgentCss">
                            <span class="w-2 h-2 rounded-full @dotCss animate-pulse"></span>
                            @currentPhase.PhaseName 進行中
                            @if (currentPhase.IsUrgent)
                            {
                                <span>（剩 @currentPhase.DaysLeft 天）</span>
                            }
                        </span>
                    }
                    else if (!isLoadingQuota)
                    {
                        <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1 rounded-full bg-gray-100 text-gray-400 border border-gray-200">
                            <span class="w-2 h-2 rounded-full bg-gray-300"></span>
                            目前無進行中階段
                        </span>
                    }
                </div>
            </div>
            <button @onclick="OpenComposeModal"
                class="px-5 py-2.5 bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold text-sm transition-colors shadow-sm flex items-center gap-2 cursor-pointer focus:outline-none">
                <i class="fa-solid fa-plus"></i> 新增試題
            </button>
        </div>
    </div>

    <!-- Scrollable Body -->
    <div class="flex-grow overflow-y-auto custom-scroll">

        <!-- 配額進度卡片區 -->
        <div class="px-4 sm:px-6 lg:px-8 pt-5 pb-3">
            <div class="flex items-center gap-2 mb-3">
                <h2 class="text-sm font-bold text-gray-500"><i class="fa-solid fa-chart-pie mr-1"></i> 我的命題配額進度</h2>
                <span class="text-xs text-gray-400 font-medium">
                    @quotaProgress.Sum(q => q.Completed) / @quotaProgress.Sum(q => q.Target)
                </span>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
                @if (isLoadingQuota)
                {
                    @for (int i = 0; i < 7; i++)
                    {
                        <div class="bg-white rounded-lg border border-gray-200 p-3 shadow-sm animate-pulse">
                            <div class="h-3 bg-gray-200 rounded w-3/4 mb-2"></div>
                            <div class="h-6 bg-gray-200 rounded w-1/2 mb-2"></div>
                            <div class="h-1.5 bg-gray-200 rounded-full"></div>
                        </div>
                    }
                }
                else if (quotaProgress.Any())
                {
                    @foreach (var q in quotaProgress)
                    {
                        @QuotaCard(q.TypeName, q.Completed, q.Target)
                    }
                }
                else
                {
                    <div class="col-span-7 text-sm text-gray-400 text-center py-2">
                        <i class="fa-solid fa-circle-info mr-1"></i> 尚未分配命題配額
                    </div>
                }
            </div>
        </div>

        <!-- 三大 Tab 工作區 -->
        <div class="px-4 sm:px-6 lg:px-8 pb-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

                <!-- Tab Bar -->
                <div class="flex border-b border-gray-200 bg-white sticky top-0 z-20 overflow-x-auto">
                    <button @onclick='() => { currentTab = "compose"; activeFilter = "all"; }'
                        class="@(currentTab == "compose" ? "text-sage border-b-sage font-bold" : "text-gray-500 border-transparent") px-5 py-3 text-sm border-b-2 transition-colors hover:text-sage cursor-pointer focus:outline-none whitespace-nowrap">
                        <i class="fa-solid fa-pen-nib mr-1.5 text-sage"></i>命題作業區
                        <span class="ml-2 text-xs bg-sage/15 text-sage px-2 py-0.5 rounded-full font-bold">0</span>
                    </button>
                    <button @onclick='() => { currentTab = "revision"; activeFilter = "all"; }'
                        class="@(currentTab == "revision" ? "text-terracotta border-b-terracotta font-bold" : "text-gray-500 border-transparent") px-5 py-3 text-sm border-b-2 transition-colors hover:text-terracotta cursor-pointer focus:outline-none whitespace-nowrap">
                        <i class="fa-solid fa-rotate-left mr-1.5 text-terracotta"></i>審修作業區
                        <span class="ml-2 text-xs bg-terracotta/15 text-terracotta px-2 py-0.5 rounded-full font-bold">0</span>
                    </button>
                    <button @onclick='() => { currentTab = "history"; activeFilter = "all"; }'
                        class="@(currentTab == "history" ? "text-morandi border-b-morandi font-bold" : "text-gray-500 border-transparent") px-5 py-3 text-sm border-b-2 transition-colors hover:text-morandi cursor-pointer focus:outline-none whitespace-nowrap">
                        <i class="fa-solid fa-box-archive mr-1.5 text-morandi"></i>審核結果與歷史
                        <span class="ml-2 text-xs bg-morandi/15 text-morandi px-2 py-0.5 rounded-full font-bold">0</span>
                    </button>
                </div>

                <!-- Tab 統計卡片區 -->
                <div class="p-4 border-b border-gray-100 bg-gray-50/50 flex-shrink-0">
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                        @if (currentTab == "compose")
                        {
                            @StatCard("命題總計", "0", "fa-layer-group", "text-morandi", "text-slate-main", "all", "顯示全部題目")
                            @StatCard("命題草稿", "0", "fa-file-pen", "text-gray-400", "text-slate-main", "draft", "點一下套用篩選")
                            @StatCard("命題完成", "0", "fa-circle-check", "text-sage", "text-sage", "done", "點一下套用篩選")
                            @StatCard("已送審", "0", "fa-paper-plane", "text-morandi", "text-morandi", "submitted", "點一下套用篩選")
                        }
                        else if (currentTab == "revision")
                        {
                            @StatCard("審題總計", "0", "fa-layer-group", "text-terracotta", "text-slate-main", "all", "顯示全部題目")
                            @StatCard("審題鎖定", "0", "fa-lock", "text-morandi", "text-morandi", "locked", "點一下套用篩選")
                            @StatCard("修題中", "0", "fa-lock-open", "text-terracotta", "text-terracotta", "editing", "點一下套用篩選")
                        }
                        else
                        {
                            @StatCard("全部題目", "0", "fa-layer-group", "text-morandi", "text-slate-main", "all", "顯示全部題目")
                            @StatCard("已採用", "0", "fa-circle-check", "text-sage", "text-sage", "adopted", "點一下套用篩選")
                            @StatCard("不採用", "0", "fa-circle-xmark", "text-gray-400", "text-gray-400", "rejected", "點一下套用篩選")
                        }
                    </div>
                </div>

                <!-- 篩選列 -->
                <div class="p-4 border-b border-gray-100 bg-white flex flex-col xl:flex-row gap-3 items-start xl:items-center justify-between flex-shrink-0">
                    <div class="flex flex-wrap items-center gap-3 w-full xl:w-auto">
                        <div class="relative w-full md:w-56">
                            <i class="fa-solid fa-magnifying-glass left-3 top-2.5 absolute text-gray-400"></i>
                            <input type="text" class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi" placeholder="搜尋題號或關鍵字...">
                        </div>
                        <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="all">所有題型</option>
                            <option value="single">一般單選題</option>
                            <option value="select">精選單選題</option>
                            <option value="readGroup">閱讀題組</option>
                            <option value="longText">長文題目</option>
                            <option value="shortGroup">短文題組</option>
                            <option value="listen">聽力測驗</option>
                            <option value="listenGroup">聽力題組</option>
                        </select>
                        <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="all">所有等級</option>
                            <option value="初級">初級</option>
                            <option value="中級">中級</option>
                            <option value="中高級">中高級</option>
                            <option value="高級">高級</option>
                            <option value="優級">優級</option>
                        </select>
                        <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="all">所有狀態</option>
                        </select>
                    </div>
                    <div class="flex flex-wrap items-center justify-between gap-3 w-full xl:w-auto xl:justify-end">
                        <label class="flex items-center gap-2 text-sm text-gray-500 font-medium whitespace-nowrap">
                            每頁顯示
                            <select class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                <option value="12">12 題</option>
                                <option value="24">24 題</option>
                                <option value="48">48 題</option>
                            </select>
                        </label>
                        <div class="text-sm text-gray-500 font-medium flex-shrink-0">
                            共 <span class="text-morandi font-bold">0</span> 題
                        </div>
                    </div>
                </div>

                <!-- 題目列表（空狀態） -->
                <div class="p-8">
                    <EmptyState IconClass="fa-file-circle-plus" Message="目前此區沒有試題" SubMessage="點擊上方「新增試題」開始命題。" />
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FullScreen 命題表單 Modal -->
<CustomModal @bind-IsVisible="showComposeModal" Type="CustomModal.ModalType.FullScreen" Title="@composeModalTitle" CloseOnBackdropClick="false" KeepAlive="true">
    <HeaderActions>
        <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 font-bold border border-gray-200">草稿</span>
        <button @onclick="() => showPreviewModal = true" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition-colors cursor-pointer">
            <i class="fa-solid fa-eye mr-1"></i> 預覽
        </button>
        <button class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition-colors cursor-pointer">
            <i class="fa-regular fa-floppy-disk mr-1"></i> 存為草稿
        </button>
        <button class="px-4 py-1.5 text-sm bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold transition-colors cursor-pointer">
            <i class="fa-solid fa-check mr-1"></i> 命題完成
        </button>
    </HeaderActions>
    <ChildContent>
        <QuillEditorHost>
            <div class="flex-grow flex overflow-hidden relative min-h-0 h-full">
                <!-- 左側邊欄：屬性設定（可收合） -->
                <div class="@(sidebarCollapsed ? "w-0" : "w-60 lg:w-72") flex-shrink-0 bg-white border-r border-gray-200 overflow-hidden flex flex-col transition-all duration-300 ease-in-out">
                    <QuestionAttributesSidebar IsCollapsed="sidebarCollapsed"
                        QuestionType="@selectedType" QuestionTypeChanged="OnQuestionTypeChanged"
                        @bind-Level="selectedLevel" @bind-Difficulty="selectedDifficulty"
                        @bind-Topic="attrTopic" @bind-Subtopic="attrSubtopic"
                        @bind-WritingMode="attrWritingMode" @bind-Genre="attrGenre"
                        @bind-AudioType="attrAudioType" @bind-Material="attrMaterial"
                        @bind-CoreAbility="attrCoreAbility" @bind-DetailIndicator="attrDetailIndicator" />
                </div>

                <!-- 伸縮標籤按鈕（浮動在邊欄邊緣） -->
                <div class="relative flex-shrink-0">
                    <button @onclick="() => sidebarCollapsed = !sidebarCollapsed"
                        class="absolute top-1/2 -translate-y-1/2 -left-px z-10 bg-white border border-gray-200 border-l-0 rounded-r-lg shadow-sm px-1.5 py-3 flex flex-col items-center gap-1 text-gray-400 hover:text-morandi hover:bg-gray-50 transition-colors cursor-pointer focus:outline-none"
                        title="@(sidebarCollapsed ? "展開屬性欄" : "收合屬性欄")">
                        <i class="fa-solid @(sidebarCollapsed ? "fa-chevron-right" : "fa-chevron-left") text-xs"></i>
                        <span class="text-xs font-bold writing-vertical">屬性</span>
                        <i class="fa-solid @(sidebarCollapsed ? "fa-chevron-right" : "fa-chevron-left") text-xs"></i>
                    </button>
                </div>

                <!-- 右側：主要編輯區 -->
                <div class="flex-grow overflow-y-auto custom-scroll bg-oatmeal min-h-0">
                    @switch (selectedType)
                    {
                        case QuestionTypeCodes.Single:
                        case QuestionTypeCodes.Select:
                            <QuestionFormSingle @bind-Stem="formStem" @bind-Options="formOptions" @bind-Answer="formAnswer" @bind-Analysis="formAnalysis" />
                            break;
                        case QuestionTypeCodes.LongText:
                            <QuestionFormLongText @bind-Stem="formStem" @bind-Passage="formPassage" @bind-GradingNote="formGradingNote" />
                            break;
                        case QuestionTypeCodes.ReadGroup:
                            <QuestionFormReadGroup @bind-Stem="formStem" @bind-Passage="formPassage" @bind-SubQuestions="formReadSubQuestions" />
                            break;
                        case QuestionTypeCodes.ShortGroup:
                            <QuestionFormShortGroup @bind-Stem="formStem" @bind-Passage="formPassage" @bind-SubQuestions="formShortSubQuestions" />
                            break;
                        case QuestionTypeCodes.Listen:
                            <QuestionFormListen @bind-AudioFileName="formAudioFileName" @bind-Stem="formStem" @bind-Options="formOptions" @bind-Answer="formAnswer" @bind-Analysis="formAnalysis" />
                            break;
                        case QuestionTypeCodes.ListenGroup:
                            <QuestionFormListenGroup @bind-AudioFileName="formAudioFileName" @bind-Passage="formPassage" @bind-SubQuestions="formListenGroupSubQuestions" />
                            break;
                    }
                </div>
            </div>
        </QuillEditorHost>
    </ChildContent>
</CustomModal>

<!-- 考卷預覽 Modal -->
<QuestionPreviewModal Visible="showPreviewModal" OnClose="() => showPreviewModal = false">
    @switch (selectedType)
    {
        case QuestionTypeCodes.Single:
        case QuestionTypeCodes.Select:
            <PreviewSingle QuestionType="@QuestionConstants.TypeLabels.GetValueOrDefault(selectedType, "")" Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel"
                Tags="@GetPreviewTags()" Stem="@formStem" Options="@formOptions" Answer="@formAnswer" />
            break;
        case QuestionTypeCodes.ReadGroup:
            <PreviewReadGroup Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel" Tags="@GetPreviewTags()"
                Stem="@formStem" Passage="@formPassage"
                SubQuestions="@formReadSubQuestions.Select(sq => new PreviewReadGroup.SubQuestionData { Stem = sq.Stem, Options = sq.Options, Answer = sq.Answer }).ToList()" />
            break;
        case QuestionTypeCodes.LongText:
            <PreviewLongText Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel" Tags="@GetPreviewTags()"
                Stem="@formStem" Passage="@formPassage" />
            break;
        case QuestionTypeCodes.ShortGroup:
            <PreviewShortGroup Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel" Tags="@GetPreviewTags()"
                Stem="@formStem" Passage="@formPassage"
                SubQuestions="@formShortSubQuestions.Select(sq => new PreviewShortGroup.SubQuestionData {
                    Stem = sq.Stem,
                    Dimension = QuestionConstants.DecodeSubCoreAbility(sq.CoreAbility, QuestionTypeCodes.ShortGroup),
                    Indicator = QuestionConstants.DecodeSubIndicator(sq.Indicator, QuestionTypeCodes.ShortGroup) }).ToList()" />
            break;
        case QuestionTypeCodes.Listen:
            <PreviewListen Level="@SelectedLevelLabel" Difficulty="@SelectedDifficultyLabel" Tags="@GetPreviewTags()"
                AudioFileName="@formAudioFileName" Stem="@formStem" Options="@formOptions" Answer="@formAnswer" />
            break;
        case QuestionTypeCodes.ListenGroup:
            <PreviewListenGroup Tags="@GetPreviewTags()" AudioFileName="@formAudioFileName" Passage="@formPassage"
                SubQuestions="@formListenGroupSubQuestions.Select(sq => new PreviewListenGroup.SubQuestionData {
                    Level = QuestionConstants.ListenLevelLabels.GetValueOrDefault(sq.FixedDifficulty, ""),
                    CoreAbility = QuestionConstants.DecodeSubCoreAbility(sq.CoreAbility, QuestionTypeCodes.ListenGroup),
                    DetailIndicator = QuestionConstants.DecodeSubIndicator(sq.DetailIndicator, QuestionTypeCodes.ListenGroup),
                    Stem = sq.Stem, Options = sq.Options, Answer = sq.Answer }).ToList()" />
            break;
    }
</QuestionPreviewModal>

@code {
    [CascadingParameter(Name = "CurrentProject")]
    private ProjectSwitcherItem? CurrentProject { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private int? currentUserId;
    private List<QuotaProgressItem> quotaProgress = [];
    private ProjectPhaseInfo? currentPhase;
    private bool isLoadingQuota = true;

    private string currentTab = "compose";
    private bool showComposeModal = false;
    private bool sidebarCollapsed = false;
    private string composeModalTitle = "新增試題";

    // 預覽 Modal
    private bool showPreviewModal = false;

    // 題型表單屬性（屬性 enum 改用 byte? 配合 MT_Questions schema）
    private string selectedType = QuestionTypeCodes.Single;
    private byte? selectedLevel;
    private byte? selectedDifficulty;
    private byte? attrTopic;
    private byte? attrSubtopic;
    private byte? attrWritingMode;
    private byte? attrGenre;
    private byte? attrAudioType;
    private byte? attrMaterial;
    private byte? attrCoreAbility;
    private byte? attrDetailIndicator;

    // 表單資料（所有題型共用欄位，子題類別來自 MT.Models）
    private string formStem = "";
    private string formPassage = "";
    private string formAnalysis = "";
    private string formGradingNote = "";
    private string[] formOptions = ["", "", "", ""];
    private string formAnswer = "";
    private string formAudioFileName = "";
    private List<SubQuestionChoice> formReadSubQuestions = [new()];
    private List<SubQuestionFreeResponse> formShortSubQuestions = [new()];
    private List<ListenGroupSubQuestion> formListenGroupSubQuestions =
        [new() { FixedDifficulty = 3 }, new() { FixedDifficulty = 4 }];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        var claim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(claim, out var uid))
            currentUserId = uid;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (CurrentProject is null || currentUserId is null) return;
        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        isLoadingQuota = true;
        try
        {
            var quotaTask = QuestionService.GetMyQuotaProgressAsync(currentUserId!.Value, CurrentProject!.Id);
            var phaseTask = QuestionService.GetCurrentPhaseAsync(CurrentProject!.Id);
            await Task.WhenAll(quotaTask, phaseTask);
            quotaProgress = quotaTask.Result;
            currentPhase = phaseTask.Result;
        }
        finally
        {
            isLoadingQuota = false;
            StateHasChanged();
        }
    }

    private void OnQuestionTypeChanged(string newType)
    {
        selectedType = newType;
        selectedLevel = null;
        selectedDifficulty = null;
        attrTopic = null; attrSubtopic = null;
        attrWritingMode = null; attrGenre = null;
        attrAudioType = null; attrMaterial = null;
        attrCoreAbility = null; attrDetailIndicator = null;
    }

    private void OpenComposeModal()
    {
        selectedType = QuestionTypeCodes.Single;
        selectedLevel = null;
        selectedDifficulty = null;
        attrTopic = null; attrSubtopic = null;
        attrWritingMode = null; attrGenre = null;
        attrAudioType = null; attrMaterial = null;
        attrCoreAbility = null; attrDetailIndicator = null;
        // 重置表單資料
        formStem = ""; formPassage = ""; formAnalysis = ""; formGradingNote = "";
        formOptions = ["", "", "", ""];
        formAnswer = ""; formAudioFileName = "";
        formReadSubQuestions = [new()];
        formShortSubQuestions = [new()];
        formListenGroupSubQuestions = [new() { FixedDifficulty = 3 }, new() { FixedDifficulty = 4 }];
        composeModalTitle = "新增試題";
        showComposeModal = true;
    }

    // 將 byte? 解碼為對應的中文標籤；若為 null 回傳 fallback
    private static string Label(byte? value, IReadOnlyDictionary<byte, string> map, string fallback) =>
        value is null ? fallback : map.GetValueOrDefault(value.Value, fallback);

    private Dictionary<string, string> GetPreviewTags()
    {
        var tags = new Dictionary<string, string>();
        const string fallback = "未設定";

        switch (selectedType)
        {
            case QuestionTypeCodes.Single:
            case QuestionTypeCodes.Select:
                tags["主類"] = Label(attrTopic, QuestionConstants.TopicLabels, fallback);
                tags["次類"] = Label(attrSubtopic, QuestionConstants.SubtopicLabels, fallback);
                break;
            case QuestionTypeCodes.LongText:
                tags["寫作模式"] = Label(attrWritingMode, QuestionConstants.WritingModeLabels, fallback);
                break;
            case QuestionTypeCodes.ReadGroup:
                tags["文體"] = Label(attrGenre, QuestionConstants.GenreLabels, fallback);
                break;
            case QuestionTypeCodes.ShortGroup:
                // 短文題組固定主類=文意判讀(6) / 次類=篇章辨析(17)
                tags["主類"] = "文意判讀";
                tags["次類"] = "篇章辨析";
                tags["文體"] = Label(attrGenre, QuestionConstants.GenreLabels, fallback);
                break;
            case QuestionTypeCodes.Listen:
                tags["核心能力"] = Label(attrCoreAbility, QuestionConstants.CoreAbilityLabels, fallback);
                tags["細目指標"] = Label(attrDetailIndicator, QuestionConstants.DetailIndicatorLabels, fallback);
                tags["語音類型"] = Label(attrAudioType, QuestionConstants.AudioTypeLabels, fallback);
                tags["素材分類"] = Label(attrMaterial, QuestionConstants.MaterialLabels, fallback);
                break;
            case QuestionTypeCodes.ListenGroup:
                tags["語音類型"] = Label(attrAudioType, QuestionConstants.AudioTypeLabels, fallback);
                tags["素材分類"] = Label(attrMaterial, QuestionConstants.MaterialLabels, fallback);
                break;
        }
        return tags;
    }

    // 等級顯示用：聽力與一般題型的等級標籤系統不同
    private string SelectedLevelLabel
    {
        get
        {
            if (selectedLevel is null) return "";
            return selectedType is QuestionTypeCodes.Listen or QuestionTypeCodes.ListenGroup
                ? QuestionConstants.ListenLevelLabels.GetValueOrDefault(selectedLevel.Value, "")
                : QuestionConstants.GeneralLevelLabels.GetValueOrDefault(selectedLevel.Value, "");
        }
    }

    private string SelectedDifficultyLabel =>
        selectedDifficulty is null ? "" : QuestionConstants.DifficultyLabels.GetValueOrDefault(selectedDifficulty.Value, "");

    private string activeFilter = "all";

    private RenderFragment StatCard(string title, string value, string icon, string iconColor, string valueColor, string filterKey, string subtitle) => __builder =>
    {
        var isActive = activeFilter == filterKey;
        <div @onclick="() => activeFilter = filterKey"
            class="@(isActive ? "ring-2 ring-morandi border-morandi bg-morandi/5" : "bg-white border-gray-200 hover:shadow-md") rounded-xl shadow-sm border p-4 transition duration-200 cursor-pointer select-none">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="text-2xl font-bold @valueColor">@value</div>
            <div class="text-xs text-gray-400 mt-1">@subtitle</div>
        </div>
    };

    private RenderFragment QuotaCard(string typeName, int current, int target) => __builder =>
    {
        var percent = target > 0 ? (int)((double)current / target * 100) : 0;
        var barColor = percent >= 100 ? "bg-sage" : percent > 0 ? "bg-morandi" : "bg-gray-200";

        <div class="bg-white rounded-lg border border-gray-200 p-3 shadow-sm hover:shadow-md transition-all">
            <div class="text-xs font-bold text-gray-600 mb-1 truncate">@typeName</div>
            <div class="flex items-baseline gap-1 mb-2">
                <span class="text-lg font-black text-slate-main">@current</span>
                <span class="text-xs text-gray-400">/ @target</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="@barColor h-1.5 rounded-full transition-all" style="width: @(percent)%"></div>
            </div>
        </div>
    };
}
