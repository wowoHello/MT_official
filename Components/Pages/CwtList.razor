    /// <summary>軟刪除草稿題目（二次確認後呼叫 SoftDeleteAsync）。</summary>
    private async Task DeleteAsync(int questionId, string questionCode)
    {
        if (currentUserId is null) return;

        var confirm = await JS.InvokeAsync<SwalResult>("Swal.fire", new
        {
            icon = "warning",
            title = $"確定刪除 {questionCode}？",
            text  = "刪除後若要復原請聯繫管理員",
            showCancelButton  = true,
            confirmButtonText = "確定刪除",
            cancelButtonText  = "取消",
            confirmButtonColor = "#D98A6C",
            cancelButtonColor  = "#6B8EAD"
        });

        if (!confirm.IsConfirmed) return;

        var ok = await QuestionService.SoftDeleteAsync(questionId, currentUserId.Value);
        if (ok)
        {
            await ShowToastAsync("success", "已刪除");
            await LoadPageDataAsync();
        }
        else
        {
            await ShowToastAsync("error", "刪除失敗，題目可能已不在草稿狀態");
        }
    }

    private record SwalResult(bool IsConfirmed, bool IsDenied, bool IsDismissed);

    // 切題型時保留題型本身、重置其他欄位（避免帶舊資料）
    private void OnQuestionTypeChanged(string newType)
    {
        formData = new() { QuestionType = newType };
        // CWT 統一等級：題型切換不重置 Level（題目 Level 強制 = 專案 ExamLevel）
        if (CurrentProject?.ProjectType == ProjectType.Cwt && CurrentProject.ExamLevel.HasValue)
        {
            formData.Level = CurrentProject.ExamLevel.Value;
        }
        // 重要：清掉前一題型留下的紅框（Stem / Options / Analysis 等共用 FieldKey
        // 在新題型仍會命中，造成切過去就一片紅）
        invalidFields.Clear();
    }

    private void OpenComposeModal(string? presetTypeKey = null, byte? presetLevel = null)
    {
        formData = new();
        if (!string.IsNullOrEmpty(presetTypeKey) && QuestionConstants.TypeKeyToId.ContainsKey(presetTypeKey))
        {
            formData.QuestionType = presetTypeKey;
        }
        else if (CurrentProject?.ProjectType == ProjectType.Lct)
        {
            // LCT 專案沒給 preset 時預設為「聽力測驗」（一般單選題不在 LCT 可命題型清單內，
            // 留住 model 預設值 Single 會讓題型下拉顯示空白且表單錯渲染為「一般單選題分類」）
            formData.QuestionType = QuestionTypeCodes.Listen;
        }
        else
        {
            // CWT 沒給 preset：清空題型讓使用者主動選擇
            // 題型 select 渲染 placeholder option「請選擇題型」，避免 model 預設 Single 在不相容等級顯示空白
            formData.QuestionType = string.Empty;
        }
        // CWT 統一等級：開新題時自動帶入專案 ExamLevel；
        // LCT：由配額卡（如「聽力測驗 - 難度三」）帶入對應 Level，避免老師手動再選
        if (CurrentProject?.ProjectType == ProjectType.Cwt && CurrentProject.ExamLevel.HasValue)
        {
            formData.Level = CurrentProject.ExamLevel.Value;
        }
        else if (presetLevel.HasValue)
        {
            formData.Level = presetLevel.Value;
            // 聽力測驗：preset 等級時補跑 OnLevelChanged 等價的級聯邏輯，
            // 把單一核心能力自動帶入（難度一~三各只有一個），否則細目指標下拉會卡在
            // 「先選等級」disabled 狀態。
            if (formData.QuestionType == QuestionTypeCodes.Listen
                && QuestionConstants.ListenLevelCoreAbilityMap.TryGetValue(presetLevel.Value, out var abilities)
                && abilities.Length == 1)
            {
                formData.CoreAbility = abilities[0];
                formData.DetailIndicator = null;
            }
        }
        currentFormStatus = QuestionStatus.Draft;
        currentFormUpdatedAt = null;
        composeModalTitle = "新增試題";
        invalidFields.Clear();
        showComposeModal = true;
    }

    /// <summary>
    /// 存為草稿（status=0）或命題完成（status=1）。
    /// formData.Id == 0 → CreateAsync；> 0 → UpdateAsync。
    /// Service 層自動寫入 MT_AuditLogs。
    ///
    /// 開啟「相似題比對」彈窗 — Plan A 即時計算（不寫 DB）
    /// 從當前 formData 組裝 QuestionDraftSnapshot 給 SimilarityService 比對
    /// </summary>
    private async Task OpenSimilarityCheckAsync()
    {
        if (isCheckingSimilarity || CurrentProject is null) return;

        // 1. 立即開啟彈窗 + Loading 狀態
        isCheckingSimilarity = true;
        similarityResults = Array.Empty<MT.Models.SimilarityCompareResult>();
        showSimilarityModal = true;
        StateHasChanged();

        try
        {
            // 2. 用 extension method 組裝 snapshot（共用邏輯放在 SimilarityModels.cs）
            var snapshot = formData.ToDraftSnapshot(CurrentProject.Id);
            // 3. 呼叫 Service 計算 Top-5
            var results = await SimilarityService.ComputeOnDemandAsync(snapshot, topN: 5);
            similarityResults = results;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "OpenSimilarityCheckAsync 失敗：FormDataId={Id}", formData.Id);
            similarityResults = Array.Empty<MT.Models.SimilarityCompareResult>();
        }
        finally
        {
            isCheckingSimilarity = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// 進入儲存前先以 QuestionFormValidator 做欄位完整性檢查：
    ///   - Draft  → 寬鬆驗證（題型 + 等級）
    ///   - Other  → 嚴格驗證（依題型逐欄）
    /// 失敗時：Swal 條列訊息 + 表單欄位畫紅框 + 滾動到第一個錯誤欄位。
    /// </summary>
    private async Task SaveAsync(byte targetStatus)
    {
        if (isSaving) return;
        if (CurrentProject is null || currentUserId is null)
        {
            await ShowToastAsync("error", "找不到當前專案或使用者");
            return;
        }

        // 欄位驗證（前端第一道防線；server-side 第二道防線目前未啟用）
        var errors = targetStatus == QuestionStatus.Draft
            ? QuestionFormValidator.ValidateForDraft(formData)
            : QuestionFormValidator.ValidateForCompletion(formData);
        if (errors.Count > 0)
        {
            await ShowValidationErrorsAsync(errors);
            return;
        }

        // 通過驗證 → 清空紅框，繼續走儲存流程
        invalidFields.Clear();

        isSaving = true;
        pendingStatus = targetStatus;
        try
        {
            if (formData.Id == 0)
            {
                var newId = await QuestionService.CreateAsync(
                    formData, currentUserId.Value, CurrentProject.Id, targetStatus);
                formData.Id = newId;
            }
            else
            {
                var ok = await QuestionService.UpdateAsync(
                    formData.Id, formData, targetStatus, currentUserId.Value);
                if (!ok)
                {
                    await ShowToastAsync("error", "題目不存在或已被刪除");
                    return;
                }
            }

            currentFormStatus    = targetStatus;
            currentFormUpdatedAt = DateTime.Now;
            await ShowToastAsync("success",
                targetStatus == QuestionStatus.Completed ? "命題完成已儲存" : "已存為草稿");

            showComposeModal = false;
            await LoadPageDataAsync();
        }
        catch (Exception ex)
        {
            await ShowToastAsync("error", $"儲存失敗：{ex.Message}");
        }
        finally
        {
            isSaving = false;
            pendingStatus = null;
        }
    }

    private ValueTask ShowToastAsync(string icon, string title) =>
        JS.InvokeVoidAsync("Swal.fire", new
        {
            icon,
            title,
            toast = true,
            position = "top-end",
            showConfirmButton = false,
            timer = 2000
        });

    /// <summary>
    /// 把 QuestionFormValidator 的錯誤集合顯示給使用者：
    ///   1. invalidFields 填入所有 FieldKey，子元件依此畫紅框
    ///   2. SweetAlert2 條列所有錯誤訊息（warning icon）
    ///   3. 透過 JS interop 滾動到第一個錯誤欄位
    /// </summary>
    private async Task ShowValidationErrorsAsync(List<ValidationError> errors)
    {
        // 1. 重建紅框集合（Clear → 重新加入，避免殘留上次驗證的舊欄位）
        invalidFields.Clear();
        foreach (var err in errors)
        {
            invalidFields.Add(err.FieldKey);
        }

        // 2. 組 <ul> HTML 條列訊息（FieldKey 不顯示給使用者，只用於畫紅框）
        var listItems = string.Concat(errors.Select(e =>
            $"<li class='text-left'>{System.Net.WebUtility.HtmlEncode(e.Message)}</li>"));
        var html = $"<ul class='text-sm text-gray-700 leading-relaxed pl-5 list-disc space-y-1'>{listItems}</ul>";

        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = "warning",
            title = "尚有未填寫欄位",
            html,
            confirmButtonText = "我知道了",
            confirmButtonColor = "#6B8EAD"
        });

        // 3. 滾動到第一個錯誤欄位（前提：表單元件以 data-field 屬性標註）
        var firstKey = errors[0].FieldKey;
        if (!string.IsNullOrEmpty(firstKey))
        {
            await JS.InvokeVoidAsync("scrollToFirstInvalid", firstKey);
        }

        StateHasChanged();
    }

    // 將 byte? 解碼為對應的中文標籤；若為 null 回傳 fallback
    private static string Label(byte? value, IReadOnlyDictionary<byte, string> map, string fallback) =>
        value is null ? fallback : map.GetValueOrDefault(value.Value, fallback);

    private Dictionary<string, string> GetPreviewTags()
    {
        var tags = new Dictionary<string, string>();
        const string fallback = "未設定";

        switch (formData.QuestionType)
        {
            case QuestionTypeCodes.Single:
            case QuestionTypeCodes.Select:
                tags["主類"] = Label(formData.Topic, QuestionConstants.TopicLabels, fallback);
                tags["次類"] = Label(formData.Subtopic, QuestionConstants.SubtopicLabels, fallback);
                break;
            case QuestionTypeCodes.LongText:
                tags["寫作模式"] = Label(formData.WritingMode, QuestionConstants.WritingModeLabels, fallback);
                break;
            case QuestionTypeCodes.ReadGroup:
                // 閱讀題組母題固定主類=文意判讀(6) / 次類=篇章辨析(17)（與短文題組一致）
                tags["主類"] = "文意判讀";
                tags["次類"] = "篇章辨析";
                tags["文體"] = Label(formData.Genre, QuestionConstants.GenreLabels, fallback);
                break;
            case QuestionTypeCodes.ShortGroup:
                // 短文題組固定主類=文意判讀(6) / 次類=篇章辨析(17)
                tags["主類"] = "文意判讀";
                tags["次類"] = "篇章辨析";
                tags["文體"] = Label(formData.Genre, QuestionConstants.GenreLabels, fallback);
                break;
            case QuestionTypeCodes.Listen:
                tags["核心能力"] = Label(formData.CoreAbility, QuestionConstants.CoreAbilityLabels, fallback);
                tags["細目指標"] = Label(formData.DetailIndicator, QuestionConstants.DetailIndicatorLabels, fallback);
                tags["語音類型"] = Label(formData.AudioType, QuestionConstants.AudioTypeLabels, fallback);
                tags["素材分類"] = Label(formData.Material, QuestionConstants.MaterialLabels, fallback);
                break;
            case QuestionTypeCodes.ListenGroup:
                tags["語音類型"] = Label(formData.AudioType, QuestionConstants.AudioTypeLabels, fallback);
                tags["素材分類"] = Label(formData.Material, QuestionConstants.MaterialLabels, fallback);
                break;
        }
        return tags;
    }

    // 等級顯示用：聽力與一般題型的等級標籤系統不同
    private string SelectedLevelLabel
    {
        get
        {
            if (formData.Level is null) return "";
            return formData.QuestionType is QuestionTypeCodes.Listen or QuestionTypeCodes.ListenGroup
                ? QuestionConstants.ListenLevelLabels.GetValueOrDefault(formData.Level.Value, "")
                : QuestionConstants.GeneralLevelLabels.GetValueOrDefault(formData.Level.Value, "");
        }
    }

    private string SelectedDifficultyLabel =>
        formData.Difficulty is null ? "" : QuestionConstants.DifficultyLabels.GetValueOrDefault(formData.Difficulty.Value, "");

    private string activeFilter = "all";

    private RenderFragment StatCard(string title, int value, string icon, string iconColor, string valueColor, string filterKey, string subtitle) => __builder =>
    {
        var isActive = activeFilter == filterKey;
        <div @onclick="() => OnFilterChanged(filterKey)"
            class="@(isActive ? "ring-2 ring-morandi border-morandi bg-morandi/5" : "bg-white border-gray-200 hover:shadow-md") rounded-xl shadow-sm border p-4 transition duration-200 cursor-pointer select-none">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="text-2xl font-bold @valueColor">@value</div>
            <div class="text-xs text-gray-400 mt-1">@subtitle</div>
        </div>
    };

    /// <summary>
    /// 審修作業區專用統計卡：母題（masterValue）/ 子題（subValue）分開顯示。
    /// 視覺結構：左母題 + 中央分隔線 + 右子題；保留與 StatCard 一致的 hover / active 樣式。
    /// </summary>
    private RenderFragment RevisionStatCard(string title, int masterValue, int subValue,
        string icon, string iconColor, string valueColor, string filterKey, string subtitle) => __builder =>
    {
        var isActive = activeFilter == filterKey;
        <div @onclick="() => OnFilterChanged(filterKey)"
            class="@(isActive ? "ring-2 ring-morandi border-morandi bg-morandi/5" : "bg-white border-gray-200 hover:shadow-md") rounded-xl shadow-sm border p-4 transition duration-200 cursor-pointer select-none">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="flex items-baseline gap-3">
                <div class="flex items-baseline gap-1">
                    <span class="text-xs text-gray-400 font-medium">母題</span>
                    <span class="text-2xl font-bold @valueColor">@masterValue</span>
                </div>
                <span class="text-gray-300 text-base">/</span>
                <div class="flex items-baseline gap-1">
                    <span class="text-xs text-gray-400 font-medium">子題</span>
                    <span class="text-2xl font-bold @valueColor">@subValue</span>
                </div>
            </div>
            <div class="text-xs text-gray-400 mt-1">@subtitle</div>
        </div>
    };

    private RenderFragment QuotaCard(QuotaProgressItem q) => __builder =>
    {
        var percent     = q.Percent;
        var barColor    = percent >= 100 ? "bg-sage" : percent > 0 ? "bg-morandi" : "bg-gray-200";
        var typeKey     = QuestionConstants.TypeIdToKey.GetValueOrDefault(q.QuestionTypeId, "single");
        var locked      = IsCompositionPhaseClosed;
        var reached     = q.Target > 0 && q.Completed >= q.Target;
        var displayName = q.TypeName + GetQuotaSuffix(q);
        var tooltip     = locked  ? "命題階段已結束，無法新增題目"
                        : reached ? $"已達標，仍可超量命題（{q.Completed}/{q.Target}）"
                                  : $"點擊新增「{displayName}」題目";

        <button type="button"
            @onclick="() => OpenComposeModal(typeKey, q.Level)"
            disabled="@locked"
            title="@tooltip"
            class="@(locked
                ? "bg-gray-50 border border-gray-200 cursor-not-allowed opacity-70"
                : "bg-white border border-gray-200 hover:border-morandi/60 hover:shadow-md hover:-translate-y-0.5 cursor-pointer")
                relative text-left rounded-lg p-3 shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-morandi/40 group h-full">

            @if (reached && !locked)
            {
                <span class="absolute top-1.5 right-1.5 inline-flex items-center gap-0.5 text-xs font-bold text-sage bg-sage/10 px-1.5 py-0.5 rounded-full border border-sage/20">
                    <i class="fa-solid fa-check text-xs"></i>已達標
                </span>
            }
            <div class="text-xs font-bold text-gray-600 mb-1 truncate pr-12">@displayName</div>
            <div class="flex items-baseline gap-1 mb-2">
                <span class="text-lg font-black text-slate-main">@q.Completed</span>
                <span class="text-xs text-gray-400">/ @q.Target</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="@barColor h-1.5 rounded-full transition-all" style="width: @(percent)%"></div>
            </div>
            @if (!locked)
            {
                <span class="absolute bottom-1.5 right-2 text-xs text-morandi font-bold opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-0.5">
                    <i class="fa-solid fa-plus text-xs"></i>新增
                </span>
            }
        </button>
    };

    /// <summary>配額卡片標題後綴：LCT 聽力測驗按難度標示；題組類母/子若意外單獨出現才補標籤（正常會被合併卡吸收）。</summary>
    private static string GetQuotaSuffix(QuotaProgressItem q)
    {
        if (q.Level.HasValue)
            return $" - {QuestionConstants.ListenLevelLabels.GetValueOrDefault(q.Level.Value, "")}";
        if (q.Granularity == 1)
            return " - 子題";
        if (q.QuestionTypeId is 3 or 5 && q.Granularity == 0)
            return " - 母題";
        return "";
    }

    /// <summary>
    /// 把 quotaProgress 重新組合成「呈現用配對」：
    ///   - 題組類（TypeId 3 閱讀 / 5 短文）母+子兩列合併為一張雙段卡
    ///   - 其他配額列維持一列一卡
    /// 表單上母+子同一次送出，分兩張卡會讓使用者誤以為要分別動作。
    /// </summary>
    private IEnumerable<(QuotaProgressItem Master, QuotaProgressItem? Sub)> BuildQuotaCardEntries()
    {
        var consumed = new HashSet<int>();
        for (int i = 0; i < quotaProgress.Count; i++)
        {
            if (consumed.Contains(i)) continue;
            var q = quotaProgress[i];

            // 題組類母題：找對應子題合併
            if (q.QuestionTypeId is 3 or 5 && q.Granularity == 0)
            {
                var subIdx = quotaProgress.FindIndex(s =>
                    s.QuestionTypeId == q.QuestionTypeId && s.Granularity == 1);
                if (subIdx > i)
                {
                    consumed.Add(subIdx);
                    yield return (q, quotaProgress[subIdx]);
                    continue;
                }
            }
            yield return (q, null);
        }
    }

    /// <summary>題組類雙段配額卡：上下兩段進度條（母題 / 子題），達標 badge 需兩段皆達成。</summary>
    private RenderFragment QuotaCardWithSub(QuotaProgressItem master, QuotaProgressItem sub) => __builder =>
    {
        var typeKey = QuestionConstants.TypeIdToKey.GetValueOrDefault(master.QuestionTypeId, "single");
        var locked  = IsCompositionPhaseClosed;
        var masterReached = master.Target > 0 && master.Completed >= master.Target;
        var subReached    = sub.Target > 0 && sub.Completed >= sub.Target;
        var bothReached   = masterReached && subReached;
        var tooltip = locked
            ? "命題階段已結束，無法新增題目"
            : bothReached
                ? $"已達標（母 {master.Completed}/{master.Target}、子 {sub.Completed}/{sub.Target}）"
                : $"點擊新增「{master.TypeName}」題目";

        <button type="button"
            @onclick="() => OpenComposeModal(typeKey)"
            disabled="@locked"
            title="@tooltip"
            class="@(locked
                ? "bg-gray-50 border border-gray-200 cursor-not-allowed opacity-70"
                : "bg-white border border-gray-200 hover:border-morandi/60 hover:shadow-md hover:-translate-y-0.5 cursor-pointer")
                relative text-left rounded-lg p-3 shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-morandi/40 group h-full">

            @if (bothReached && !locked)
            {
                <span class="absolute top-1.5 right-1.5 inline-flex items-center gap-0.5 text-xs font-bold text-sage bg-sage/10 px-1.5 py-0.5 rounded-full border border-sage/20">
                    <i class="fa-solid fa-check text-xs"></i>已達標
                </span>
            }
            <div class="text-xs font-bold text-gray-600 mb-2 truncate pr-12">@master.TypeName</div>

            @* 母題段 *@
            <div class="mb-1.5">
                <div class="flex items-baseline justify-between text-xs mb-0.5">
                    <span class="text-gray-500 font-medium">母題</span>
                    <span><span class="text-sm font-black text-slate-main">@master.Completed</span><span class="text-gray-400"> / @master.Target</span></span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-1.5">
                    <div class="@(SegmentBarColor(master)) h-1.5 rounded-full transition-all" style="width: @(master.Percent)%"></div>
                </div>
            </div>

            @* 子題段 *@
            <div>
                <div class="flex items-baseline justify-between text-xs mb-0.5">
                    <span class="text-gray-500 font-medium">子題</span>
                    <span><span class="text-sm font-black text-slate-main">@sub.Completed</span><span class="text-gray-400"> / @sub.Target</span></span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-1.5">
                    <div class="@(SegmentBarColor(sub)) h-1.5 rounded-full transition-all" style="width: @(sub.Percent)%"></div>
                </div>
            </div>

            @if (!locked)
            {
                <span class="absolute bottom-1.5 right-2 text-xs text-morandi font-bold opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-0.5">
                    <i class="fa-solid fa-plus text-xs"></i>新增
                </span>
            }
        </button>
    };

    /// <summary>單段進度條配色：滿色 sage、進行中 morandi、空白 gray。</summary>
    private static string SegmentBarColor(QuotaProgressItem seg)
    {
        if (seg.Target <= 0) return "bg-gray-200";
        var p = seg.Completed * 100 / seg.Target;
        return p >= 100 ? "bg-sage" : p > 0 ? "bg-morandi" : "bg-gray-200";
    }
}
