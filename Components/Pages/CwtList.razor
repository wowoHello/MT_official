    /// <summary>
    /// 列表狀態欄顯示文字。
    /// - 命題作業區：Status 0/1 顯示原文；Status 2-8 一律顯示「已送審」（命題端視角的唯讀快照）
    /// - 審修作業區：審題鎖定 / 修題中 / 已修題（依 HasRepliedThisStage 切換）
    /// </summary>
    private string RowStatusLabel(QuestionListItem item)
    {
        if (currentTab == "compose")
        {
            return item.Status switch
            {
                QuestionStatus.Draft     => QuestionStatus.Labels[QuestionStatus.Draft],
                QuestionStatus.Completed => QuestionStatus.Labels[QuestionStatus.Completed],
                _                        => "已送審"   // 2-8 統一視為命題端的「已送審」快照
            };
        }
        if (currentTab == "revision")
        {
            return item.Status switch
            {
                QuestionStatus.Submitted
                or QuestionStatus.PeerReviewing
                or QuestionStatus.ExpertReviewing
                or QuestionStatus.FinalReviewing  => "審題鎖定",
                QuestionStatus.PeerEditing
                or QuestionStatus.ExpertEditing
                or QuestionStatus.FinalEditing    => item.HasRepliedThisStage ? "已修題" : "修題中",
                _                                 => QuestionStatus.Labels.GetValueOrDefault(item.Status, "未知")
            };
        }
        return QuestionStatus.Labels.GetValueOrDefault(item.Status, "未知");
    }

