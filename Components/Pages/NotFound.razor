@page "/not-found"
@layout MainLayout
@attribute [AllowAnonymous]
@inject NavigationManager Navigation

<PageTitle>找不到頁面</PageTitle>

<div class="relative overflow-hidden px-4 py-8 sm:px-6 lg:px-8">
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-[#f5f0e8] via-[#f8f5ef] to-[#edf3f6]"></div>
    <div class="absolute left-[-6rem] top-10 -z-10 h-40 w-40 rounded-full bg-sage/15 blur-3xl"></div>
    <div class="absolute bottom-0 right-[-5rem] -z-10 h-56 w-56 rounded-full bg-morandi/15 blur-3xl"></div>

    <div class="mx-auto flex min-h-[calc(100vh-8rem)] max-w-5xl items-center">
        <div class="grid w-full gap-6 lg:grid-cols-[1.1fr_0.9fr]">

            <section class="rounded-[2rem] border border-white/70 bg-white/80 p-8 shadow-[0_18px_60px_rgba(88,104,122,0.12)] backdrop-blur sm:p-10">
                <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-terracotta/20 bg-terracotta/10 px-4 py-1.5 text-sm font-semibold text-terracotta">
                    <i class="fa-solid fa-map-location-dot"></i>
                    <span>404 找不到頁面</span>
                </div>

                <div class="space-y-4">
                    <h1 tabindex="-1" class="text-4xl font-black tracking-tight text-slate-main focus:outline-none sm:text-5xl">
                        這個頁面好像先去散步了
                    </h1>
                    <p class="max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
                        你要找的內容可能已經搬家、網址輸入錯誤，或是目前沒有開放這個路徑。
                        先別急，我們還是可以很溫柔地把你帶回正路上。
                    </p>
                </div>

                <div class="mt-8 rounded-2xl border border-gray-200/80 bg-[#fbfaf7] p-5">
                    <div class="mb-2 flex items-center gap-2 text-sm font-semibold text-slate-main">
                        <i class="fa-solid fa-link text-morandi"></i>
                        <span>目前路徑</span>
                    </div>
                    <code class="block break-all rounded-xl bg-white px-4 py-3 text-sm text-slate-600 shadow-inner">
                        @CurrentPath
                    </code>
                </div>

                <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                    <button type="button"
                            @onclick="GoHome"
                            class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl bg-morandi px-5 py-3 text-sm font-semibold text-white shadow-md transition-all hover:-translate-y-0.5 hover:bg-[#5b7a95] focus:outline-none focus:ring-2 focus:ring-morandi/40">
                        <i class="fa-solid fa-house"></i>
                        <span>回首頁</span>
                    </button>

                    <button type="button"
                            @onclick="GoProjects"
                            class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-xl border border-gray-300 bg-white px-5 py-3 text-sm font-semibold text-slate-main transition-all hover:-translate-y-0.5 hover:border-morandi hover:text-morandi focus:outline-none focus:ring-2 focus:ring-morandi/20">
                        <i class="fa-solid fa-box-archive"></i>
                        <span>前往命題專案管理</span>
                    </button>
                </div>
            </section>

            <aside class="rounded-[2rem] border border-white/70 bg-white/70 p-6 shadow-[0_18px_60px_rgba(88,104,122,0.10)] backdrop-blur sm:p-8">
                <div class="flex h-full flex-col">
                    <div class="mb-6 flex items-center justify-between">
                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-sage/15 text-2xl text-sage shadow-sm">
                            <i class="fa-solid fa-compass"></i>
                        </div>
                        <div class="text-right">
                            <div class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-400">Page Lost</div>
                            <div class="text-3xl font-black text-slate-main">404</div>
                        </div>
                    </div>

                    <div class="rounded-2xl bg-gradient-to-br from-sage/10 via-white to-morandi/10 p-5">
                        <div class="mb-3 text-sm font-bold text-slate-main">你現在可以這樣走</div>
                        <div class="space-y-3">
                            @foreach (var item in suggestions)
                            {
                                <div class="flex items-start gap-3 rounded-xl border border-white/80 bg-white/80 px-4 py-3">
                                    <div class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-morandi/10 text-morandi">
                                        <i class="@item.Icon"></i>
                                    </div>
                                    <div>
                                        <div class="text-sm font-bold text-slate-main">@item.Title</div>
                                        <div class="mt-0.5 text-sm leading-6 text-slate-500">@item.Description</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mt-6 rounded-2xl border border-dashed border-gray-300 bg-white/80 p-5">
                        <div class="mb-2 text-sm font-bold text-slate-main">小提醒</div>
                        <p class="text-sm leading-7 text-slate-500">
                            如果你是從書籤、舊連結或外部通知點進來，這個網址可能已經改版。
                            這種時候不是你走錯，是網址自己長大了。
                        </p>
                    </div>
                </div>
            </aside>

        </div>
    </div>
</div>

@code {
    private readonly SuggestionItem[] suggestions =
    [
        new("fa-solid fa-house", "先回首頁看看", "從系統首頁重新進入，通常最快找到正確入口。"),
        new("fa-solid fa-box-archive", "回到命題專案", "如果你剛剛是在處理梯次或專案資料，這裡最常用。"),
        new("fa-solid fa-magnifying-glass", "檢查網址是否有誤", "特別是手動輸入路徑時，少一碼就很容易迷路。")
    ];

    private string CurrentPath => Navigation.ToBaseRelativePath(Navigation.Uri) switch
    {
        "" => "/",
        var path => $"/{path}"
    };

    private void GoHome() => Navigation.NavigateTo("/");

    private void GoProjects() => Navigation.NavigateTo("/projects");

    private sealed record SuggestionItem(string Icon, string Title, string Description);
}
