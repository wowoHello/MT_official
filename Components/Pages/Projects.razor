@* ====================================================================== *@
@*  Projects — 命題專案（梯次）管理                                         *@
@*  路由：/projects                                                        *@
@*  功能：左右分割佈局，左側專案列表搜尋/篩選，右側詳情；SlideOver 新增表單  *@
@* ====================================================================== *@
@page "/projects"
@inject IProjectService ProjectService
@inject IAppointmentService AppointmentService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ILogger<Projects> Logger

<div class="mx-auto flex w-full flex-grow flex-col min-h-[calc(100vh-4rem)] lg:h-[calc(100vh-4rem)] lg:overflow-hidden">
    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-2 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <NavLink href="" Match="NavLinkMatch.All" class="inline-flex items-center hover:text-[var(--color-morandi)] transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-[var(--color-slate-main)]">命題專案(梯次)管理</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-box-archive text-[var(--color-morandi)]"></i> 命題專案(梯次)管理
                </h1>
                <p class="text-sm text-gray-500 mt-1">梯次設定、派發工作與階段時程管控。</p>
            </div>
            <button type="button" @onclick="OpenNewProjectModal"
                class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                <i class="fa-solid fa-plus"></i> 新增梯次
            </button>
        </div>
    </div>

    <!-- Split Layout (Left List, Right Detail) -->
    <div class="flex flex-col flex-grow lg:flex-row lg:overflow-hidden">
        <!-- Left Panel: Project List -->
        <div class="z-10 flex w-full flex-col border-b border-gray-200 bg-white lg:w-1/3 lg:flex-shrink-0 lg:border-r lg:border-b-0 xl:w-1/4">
            <!-- Filters -->
            <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col gap-3 flex-shrink-0">
                <DebouncedSearchInput @bind-Value="searchKeyword"
                                      Placeholder="搜尋專案名稱 / 年度 / 合作學校..." />
                <div class="flex gap-2">
                    @foreach (var f in filterOptions)
                    {
                        var isActive = currentFilter == f.Key;
                        var btnClass = isActive
                            ? "flex-1 py-1 text-xs font-bold rounded bg-morandi text-white cursor-pointer"
                            : "flex-1 py-1 text-xs font-bold border border-gray-200 text-gray-500 rounded hover:bg-gray-100 cursor-pointer";
                        <button type="button" class="@btnClass" @onclick="() => currentFilter = f.Key">@f.Label</button>
                    }
                </div>
            </div>
            <!-- List -->
            <div class="overflow-y-auto custom-scroll lg:flex-grow">
                @{ var filtered = GetFilteredProjects(); }
                @if (filtered.Count == 0)
                {
                    <div class="flex flex-col items-center justify-center py-12 px-6">
                        @if (allProjects.Count == 0)
                        {
                            <!-- 全空狀態：歡迎風格 -->
                            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-morandi/20 to-sage/20 flex items-center justify-center mb-4 animate-[bounce_3s_ease-in-out_infinite]">
                                <i class="fa-solid fa-folder-plus text-3xl text-morandi/60"></i>
                            </div>
                            <p class="text-sm font-bold text-gray-500 mb-1">目前尚無專案梯次</p>
                            <p class="text-xs text-gray-400 mb-4 text-center leading-relaxed">
                                還沒有建立任何命題專案，<br/>點擊下方按鈕開始第一個梯次吧！
                            </p>
                            <button type="button" @onclick="OpenNewProjectModal"
                                class="cursor-pointer px-4 py-2 bg-sage text-white rounded-lg text-xs font-bold hover:bg-[#7b9c81] transition-all shadow-sm flex items-center gap-1.5">
                                <i class="fa-solid fa-plus"></i> 建立第一個梯次
                            </button>
                        }
                        else
                        {
                            <!-- 搜尋/篩選後查無結果 -->
                            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-terracotta/10 to-amber-100 flex items-center justify-center mb-4">
                                <i class="fa-solid fa-magnifying-glass text-2xl text-terracotta/50"></i>
                            </div>
                            <p class="text-sm font-bold text-gray-500 mb-1">找不到符合的專案</p>
                            <p class="text-xs text-gray-400 text-center leading-relaxed">
                                目前的搜尋條件或篩選沒有對應的專案，<br/>請嘗試調整關鍵字或切換篩選條件。
                            </p>
                            @if (!string.IsNullOrWhiteSpace(searchKeyword))
                            {
                                <button type="button" @onclick="() => searchKeyword = string.Empty"
                                    class="cursor-pointer mt-3 px-3 py-1.5 bg-white border border-gray-200 text-gray-500 rounded-lg text-xs font-medium hover:bg-gray-50 transition-colors flex items-center gap-1.5">
                                    <i class="fa-solid fa-xmark"></i> 清除搜尋
                                </button>
                            }
                        }
                    </div>
                }
                else
                {
                    @foreach (var p in filtered)
                    {
                        var isSelected = selectedProjectId == p.Id;
                        var itemClass = isSelected
                            ? "px-5 py-4 cursor-pointer border-b border-gray-100 flex flex-col gap-1 transition-colors bg-[#f0f4f8] border-l-4 border-l-morandi"
                            : "px-5 py-4 cursor-pointer border-b border-gray-100 hover:bg-gray-50 flex flex-col gap-1 transition-colors";
                        var nameClass = isSelected ? "text-sm font-bold text-morandi line-clamp-1" : "text-sm font-bold text-gray-800 line-clamp-1";
                        var chevronClass = isSelected ? "fa-solid fa-chevron-right text-xs text-morandi" : "fa-solid fa-chevron-right text-xs text-gray-300";

                        <div class="@itemClass" @onclick="async () => await SelectProject(p.Id)">
                            <div class="flex justify-between items-start">
                                <span class="@nameClass">@p.Name</span>
                                <StatusBadge StatusText="@GetProjectStatusText((byte)p.EffectiveStatus)" Compact="true" ShowIcon="false" />
                            </div>
                            <div class="flex justify-between items-center mt-1">
                                <span class="text-xs text-gray-500">@(p.Year)年度 / @(string.IsNullOrEmpty(p.School) ? "無 (自辦)" : p.School)</span>
                                <i class="@chevronClass"></i>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Right Panel: Project Details -->
        <div class="flex min-h-[320px] flex-col bg-[var(--color-oatmeal)] lg:min-h-0 lg:w-2/3 lg:overflow-hidden xl:w-3/4">
            @if (selectedDetail == null)
            {
                <!-- 空狀態 -->
                <div class="flex flex-1 flex-col items-center justify-center p-8 text-gray-400 lg:flex-grow">
                    <i class="fa-solid fa-folder-open text-6xl mb-4 text-gray-300"></i>
                    <p class="text-lg font-medium">請由左側列表選擇專案，或建立新梯次。</p>
                </div>
            }
            else
            {
                <!-- 詳情內容 -->
                <div class="custom-scroll lg:flex-grow lg:overflow-y-auto">
                    <!-- 頂部資訊卡 -->
                    <div class="px-8 pt-6 pb-2">
                        <div class="flex flex-col items-start justify-between gap-4 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm sm:flex-row sm:items-start">
                            <div class="flex flex-col gap-1">
                                <div class="flex items-center gap-2 mb-1 flex-wrap">
                                    <StatusBadge StatusText="@GetProjectStatusText((byte)selectedDetail.EffectiveStatus)" Compact="true" ShowIcon="false" />
                                    <span class="text-xs text-gray-500">@(selectedDetail.Year)年度</span>
                                    @* 專案類型徽章 — 兩色區分 CWT / LCT，讓使用者快速分辨 *@
                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-bold border @(selectedDetail.ProjectType == ProjectType.Lct ? "bg-terracotta/10 text-terracotta border-terracotta/30" : "bg-morandi/10 text-morandi border-morandi/30")">
                                        @(selectedDetail.ProjectType == ProjectType.Lct ? "LCT" : "CWT")
                                    </span>
                                    @* CWT 模式才顯示命題等級徽章；LCT 等級為每題各自設定，不在頂部顯示 *@
                                    @if (selectedDetail.ProjectType == ProjectType.Cwt && selectedDetail.ExamLevel.HasValue
                                         && QuestionConstants.GeneralLevelLabels.TryGetValue(selectedDetail.ExamLevel.Value, out var lvLabel))
                                    {
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-bold border bg-sage/10 text-sage border-sage/30">
                                            <i class="fa-solid fa-layer-group mr-1"></i> 命題等級：@lvLabel
                                        </span>
                                    }
                                </div>
                                <h2 class="text-2xl font-black text-slate-main">@selectedDetail.Name</h2>
                                <div class="flex flex-col gap-0.5 text-sm text-gray-500 mt-1">
                                    <span><i class="fa-solid fa-school w-4 text-center"></i> 合作學校：@(string.IsNullOrEmpty(selectedDetail.School) ? "無 (自辦)" : selectedDetail.School)</span>
                                    <span><i class="fa-solid fa-user-gear w-4 text-center"></i> 建立者：@selectedDetail.CreatorName</span>
                                </div>
                            </div>
                            <!-- 操作按鈕 -->
                            @if (!selectedDetail.IsClosed)
                            {
                                <div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-shrink-0 sm:items-end">
                                    <button type="button" @onclick="OpenEditProjectModalAsync"
                                        class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-bold hover:bg-gray-50 transition-colors shadow-sm flex items-center gap-2">
                                        <i class="fa-solid fa-pen-to-square text-morandi"></i> 編輯專案
                                    </button>
                                    <button type="button" @onclick="HandleCloseProject"
                                        class="cursor-pointer px-4 py-2 bg-slate-main text-white rounded-lg text-sm font-bold hover:opacity-90 transition-colors shadow-sm flex items-center gap-2">
                                        <i class="fa-solid fa-box-archive"></i> 結案入庫
                                    </button>
                                    <button type="button" @onclick="HandleDeleteProject"
                                        class="cursor-pointer px-4 py-2 bg-white border border-red-300 text-red-500 rounded-lg text-sm font-bold hover:bg-red-50 transition-colors shadow-sm flex items-center gap-2">
                                        <i class="fa-solid fa-trash-can"></i> 移除專案
                                    </button>
                                </div>
                            }
                            else
                            {
                                @* 已結案的梯次不可移除，右側單顆主角按鈕：card-button 撐滿左側資訊高度 *@
                                <button type="button" @onclick="HandleDownloadClosedDataAsync" disabled="@isDownloadingClosedData"
                                    class="group cursor-pointer w-full sm:w-auto sm:self-stretch sm:min-w-[200px] px-6 py-5 bg-sage text-white rounded-xl shadow-sm hover:shadow-lg hover:bg-[#7b9c81] focus:outline-none focus-visible:ring-2 focus-visible:ring-sage/40 focus-visible:ring-offset-2 transition-all flex flex-col items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-wait">
                                    @if (isDownloadingClosedData)
                                    {
                                        <i class="fa-solid fa-spinner fa-spin text-3xl"></i>
                                        <span class="text-base font-bold tracking-wide">下載中…</span>
                                        <span class="text-xs font-normal opacity-90">Excel 含採用題目與統計</span>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-file-arrow-down text-3xl group-hover:scale-110 group-hover:-translate-y-0.5 transition-transform duration-200"></i>
                                        <span class="text-base font-bold tracking-wide">下載結案資料</span>
                                        <span class="text-xs font-normal opacity-90">Excel 含採用題目與統計</span>
                                    }
                                </button>
                            }
                        </div>

                        @* 過期未結案提示：產學區間 EndDate 已過但 ClosedAt 仍是 null —— 引導管理員手動點擊結案入庫 *@
                        @if (selectedDetail.IsExpired)
                        {
                            <div class="mt-4 rounded-lg border border-terracotta/40 bg-terracotta/10 px-4 py-3 flex items-start gap-3 text-sm">
                                <i class="fa-solid fa-triangle-exclamation text-terracotta text-base mt-0.5 shrink-0"></i>
                                <div class="flex-1 min-w-0">
                                    <p class="font-semibold text-terracotta">此梯次已超過產學計畫結束日</p>
                                    <p class="text-xs text-gray-600 mt-0.5">
                                        請點擊右側「結案入庫」按鈕完成結案：採用題目入庫、其餘非採用題目歸檔。
                                    </p>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- 主要內容：時程 + 題型 + 成員 -->
                    <div class="px-8 pb-8 grid grid-cols-1 xl:grid-cols-2 gap-6 items-start">
                        <!-- 時程規劃設定 -->
                        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
                            <h3 class="text-base font-black text-slate-main mb-1 flex items-center gap-2">
                                <i class="fa-solid fa-clock text-morandi"></i> 時程規劃設定
                            </h3>
                            <p class="text-xs text-gray-400 mb-4">深色標記為當前進行中之階段。</p>

                            @if (selectedDetail.Phases.Count == 0)
                            {
                                <p class="text-sm text-gray-400 text-center py-4">尚未設定時程</p>
                            }
                            else
                            {
                                <div class="relative">
                                    @{
                                        // 第 0 階段「產學計畫區間」是涵蓋全期的總階段，視為 umbrella；
                                        // 真正的子階段從 index 1 開始，找出 ClosedAt 落在哪一個子階段。
                                        var closedAtDate = selectedDetail.ClosedAt?.Date;
                                        var closedSubPhaseIndex = -1;
                                        if (closedAtDate.HasValue)
                                        {
                                            for (int j = 1; j < selectedDetail.Phases.Count; j++)
                                            {
                                                var p = selectedDetail.Phases[j];
                                                if (closedAtDate.Value >= p.StartDate && closedAtDate.Value <= p.EndDate)
                                                {
                                                    closedSubPhaseIndex = j;
                                                    break;
                                                }
                                            }
                                            // 邊界保護：ClosedAt 落於子階段範圍外時，依日期靠近哪一端
                                            if (closedSubPhaseIndex == -1 && selectedDetail.Phases.Count > 1)
                                            {
                                                closedSubPhaseIndex = closedAtDate.Value < selectedDetail.Phases[1].StartDate
                                                    ? 1
                                                    : selectedDetail.Phases.Count - 1;
                                            }
                                        }
                                        // 「準時或延遲結案」：ClosedAt 在產學計畫結束日（Phase[0].EndDate）當天或之後 → 視為正常完工，不標橘色
                                        var isClosedAfterScheduledEnd = closedAtDate.HasValue
                                            && selectedDetail.Phases.Count > 0
                                            && closedAtDate.Value >= selectedDetail.Phases[0].EndDate.Date;
                                    }
                                    @for (int i = 0; i < selectedDetail.Phases.Count; i++)
                                    {
                                        var phase = selectedDetail.Phases[i];
                                        var isLast = i == selectedDetail.Phases.Count - 1;
                                        var today = DateTime.Today;
                                        var isPast = phase.EndDate < today;
                                        var isCurrent = !isPast && phase.StartDate <= today;

                                        string nodeColor;
                                        string lineColor;
                                        string textColor;
                                        string dateColor;

                                        if (isClosedAfterScheduledEnd)
                                        {
                                            // 準時/延遲結案：全部走「已完成」綠色樣式，不顯示橘色
                                            nodeColor = "bg-sage";
                                            lineColor = "border-sage";
                                            textColor = "text-gray-500";
                                            dateColor = "text-gray-400";
                                        }
                                        else if (closedSubPhaseIndex >= 0)
                                        {
                                            // 提早結案：產學計畫區間（i==0）+ 結案發生子階段都標 terracotta
                                            if (i == 0 || i == closedSubPhaseIndex)
                                            {
                                                nodeColor = "bg-terracotta ring-4 ring-orange-50";
                                                lineColor = "border-gray-200 border-dashed";
                                                textColor = "text-terracotta font-bold";
                                                dateColor = "text-terracotta font-bold";
                                            }
                                            else if (i < closedSubPhaseIndex)
                                            {
                                                nodeColor = "bg-sage";
                                                lineColor = "border-sage";
                                                textColor = "text-gray-500";
                                                dateColor = "text-gray-400";
                                            }
                                            else
                                            {
                                                nodeColor = "bg-gray-200";
                                                lineColor = "border-gray-200 border-dashed";
                                                textColor = "text-gray-400";
                                                dateColor = "text-gray-400";
                                            }
                                        }
                                        else
                                        {
                                            // 進行中：依今日判斷
                                            nodeColor = isPast ? "bg-sage" : (isCurrent ? "bg-morandi ring-4 ring-blue-50" : "bg-gray-200");
                                            lineColor = isPast ? "border-sage" : "border-gray-200 border-dashed";
                                            textColor = isCurrent ? "text-morandi font-bold" : (isPast ? "text-gray-500" : "text-gray-400");
                                            dateColor = isCurrent ? "text-morandi font-bold" : (isPast ? "text-gray-400" : "text-gray-400");
                                        }

                                        <div class="relative pb-6">
                                            @if (!isLast)
                                            {
                                                <div class="absolute top-4 left-[5px] -ml-px h-full w-0.5 @lineColor border-l-[2px]"></div>
                                            }
                                            <div class="relative flex items-center space-x-3">
                                                <div>
                                                    <span class="h-3 w-3 rounded-full flex items-center justify-center ring-8 ring-white @nodeColor"></span>
                                                </div>
                                                <div class="flex justify-between w-full pr-4">
                                                    <span class="text-sm @textColor">@(i + 1). @phase.PhaseName</span>
                                                    <span class="text-xs @dateColor">@phase.StartDate.ToString("yyyy-MM-dd") ~ @phase.EndDate.ToString("yyyy-MM-dd")</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- 右側：題型目標 + 成員 -->
                        <div class="flex flex-col gap-6">
                            <!-- 題型目標數量 -->
                            <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
                                <h3 class="text-base font-black text-slate-main mb-3 flex items-center gap-2">
                                    <i class="fa-solid fa-bullseye text-terracotta"></i> 題型目標數量
                                </h3>
                                @if (selectedDetail.Targets.Count == 0)
                                {
                                    <EmptyState IconClass="fa-bullseye" Message="尚未設定題型目標"
                                        SubMessage="請透過編輯專案來設定各題型的目標數量。" Compact="true" />
                                }
                                else if (selectedDetail.ProjectType == ProjectType.Lct)
                                {
                                    @* LCT 模式：5 個聽力題目（難度一~五）+ 1 個聽力題組（不分難度，以「組」計）
                                       聽力題組視覺上稍作區隔（淡莫蘭迪邊框）以暗示「整組固定 2 子題：難三+難四」 *@
                                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
                                        @foreach (var t in selectedDetail.Targets)
                                        {
                                            var isGroup = t.QuestionTypeId == 7;
                                            var cardClass = isGroup
                                                ? "bg-morandi/5 border border-morandi/30 rounded-xl p-3 text-center"
                                                : "bg-gray-50 border border-gray-200 rounded-xl p-3 text-center";
                                            var unitText = isGroup ? "組" : "題";
                                            <div class="@cardClass">
                                                <div class="text-xs text-gray-500 mb-1">@t.DisplayLabel</div>
                                                <div class="text-lg font-black @(isGroup ? "text-morandi" : "text-slate-main")">@t.TargetCount</div>
                                                <div class="text-xs text-gray-400">@unitText</div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    @* CWT 模式：依 QuestionTypeId 分組
                                       —— 單體題型（1 列）用普通卡；題組類（2 列：母+子）用複合卡，視覺上「黏在一起」。
                                       Service 已 ORDER BY (QuestionTypeId, Granularity)，分組後同一 TypeId 的 [0]=母題、[1]=子題 *@
                                    var typeGroups = selectedDetail.Targets
                                        .GroupBy(t => t.QuestionTypeId)
                                        .OrderBy(g => g.Key)
                                        .Select(g => g.OrderBy(t => t.Granularity).ToList())
                                        .ToList();
                                    <div class="grid grid-cols-3 gap-3">
                                        @foreach (var grp in typeGroups)
                                        {
                                            var isGroupType = grp.Count == 2; // 題組類有母+子兩列
                                            var typeName = grp[0].TypeName; // ProjectService 端已用 QuestionTypeCatalog 補上

                                            @if (isGroupType)
                                            {
                                                @* 複合卡：外殼漸層 + 內部兩泡泡 + 中間 link icon，視覺暗示「母題與子題環環相扣」 *@
                                                <div class="col-span-3 sm:col-span-2 relative rounded-2xl p-4 border-2 border-morandi/25 bg-gradient-to-r from-morandi/10 via-white to-morandi/10 shadow-sm">
                                                    @* 浮在左上角的題組標題：用較重的 badge 區隔單體與題組 *@
                                                    <div class="absolute -top-2.5 left-4 bg-morandi text-white text-xs font-bold px-2 py-0.5 rounded-full shadow-sm flex items-center gap-1">
                                                        <i class="fa-solid fa-link-simple text-xs"></i> @typeName
                                                    </div>
                                                    <div class="flex items-center gap-2 mt-2">
                                                        @* 母題泡泡 *@
                                                        <div class="flex-1 bg-white rounded-xl border border-morandi/30 py-2.5 text-center shadow-sm">
                                                            <div class="text-xs text-gray-500 mb-0.5">母題</div>
                                                            <div class="text-xl font-black text-morandi leading-none">@grp[0].TargetCount</div>
                                                            <div class="text-xs text-gray-400 mt-0.5">組</div>
                                                        </div>
                                                        @* 連結圖示：環環相扣的視覺核心 *@
                                                        <i class="fa-solid fa-link text-morandi/60 shrink-0"></i>
                                                        @* 子題泡泡 *@
                                                        <div class="flex-1 bg-white rounded-xl border border-morandi/30 py-2.5 text-center shadow-sm">
                                                            <div class="text-xs text-gray-500 mb-0.5">子題</div>
                                                            <div class="text-xl font-black text-morandi leading-none">@grp[1].TargetCount</div>
                                                            <div class="text-xs text-gray-400 mt-0.5">題</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                @* 單體題型：簡潔卡片，與複合卡視覺份量明顯區分 *@
                                                <div class="col-span-3 sm:col-span-1 bg-gray-50 border border-gray-200 rounded-2xl p-4 text-center flex flex-col justify-center">
                                                    <div class="text-xs text-gray-500 mb-1">@typeName</div>
                                                    <div class="text-xl font-black text-slate-main">@grp[0].TargetCount</div>
                                                    <div class="text-xs text-gray-400 mt-0.5">題</div>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </div>

                            <!-- 指派人員 -->
                            <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
                                <div class="flex justify-between items-center mb-3">
                                    <h3 class="text-base font-black text-slate-main flex items-center gap-2">
                                        <i class="fa-solid fa-users text-morandi"></i> 指派人員
                                    </h3>
                                    <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full font-bold">共 @selectedDetail.Members.Count 人</span>
                                </div>
                                @if (selectedDetail.Members.Count == 0)
                                {
                                    <EmptyState IconClass="fa-user-plus" Message="尚未指派人員"
                                        SubMessage="請先至「教師管理系統」建立教師名單，再透過編輯專案指派人員。" Compact="true" />
                                }
                                else
                                {
                                    <div class="divide-y divide-gray-50">
                                        @foreach (var m in selectedDetail.Members)
                                        {
                                            <div class="flex items-center justify-between p-3 hover:bg-gray-50 transition-colors">
                                                <div class="flex items-center gap-2">
                                                    <div class="w-8 h-8 rounded-full bg-morandi/10 text-morandi flex items-center justify-center font-bold text-xs">
                                                        @(m.DisplayName.Length > 0 ? m.DisplayName[0].ToString() : "?")
                                                    </div>
                                                    <div>
                                                        <div class="text-sm font-bold text-gray-700">@m.DisplayName</div>
                                                        <div class="text-xs text-gray-500">@(m.TeacherCode ?? "")</div>
                                                    </div>
                                                </div>
                                                <div class="flex items-center gap-2 max-w-[60%]">
                                                    <div class="flex flex-wrap justify-end gap-1 flex-1 min-w-0">
                                                        @if (m.Roles.Count == 0)
                                                        {
                                                            <span class="text-xs px-2 py-0.5 rounded bg-gray-50 border border-gray-200 text-gray-400 font-bold whitespace-nowrap">未指定</span>
                                                        }
                                                        else
                                                        {
                                                            @foreach (var role in m.Roles)
                                                            {
                                                                <StatusBadge StatusText="@role.Name" IsInternal="@(role.Category == 0)" Compact="true" ShowIcon="false" />
                                                            }
                                                        }
                                                    </div>
                                                    @if (selectedDetail is not null && m.HasDownloadableCerts)
                                                    {
                                                        <button type="button" @onclick="() => OpenEditPeriodModal(m.UserId, selectedDetail.Id)"
                                                                aria-label="編輯聘期"
                                                                title="編輯此成員在本梯次的聘期（儲存後自動重產聘書）"
                                                                class="cursor-pointer flex-shrink-0 w-9 h-9 flex items-center justify-center text-slate-main/70 hover:text-slate-main hover:bg-slate-main/10 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-main/40 transition-colors">
                                                            <i class="fa-solid fa-pen-to-square text-sm"></i>
                                                        </button>
                                                        <a href="@($"api/appointment-cert/download/{selectedDetail.Id}/user/{m.UserId}")"
                                                           target="_blank"
                                                           rel="noopener"
                                                           aria-label="下載聘書"
                                                           title="下載此成員在本梯次的聘書（1 份直下 jpg、多份打包 zip）"
                                                           class="cursor-pointer flex-shrink-0 w-9 h-9 flex items-center justify-center text-morandi/70 hover:text-morandi hover:bg-morandi/10 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-morandi/40 transition-colors no-underline">
                                                            <i class="fa-solid fa-award text-sm"></i>
                                                        </a>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Slide-over panel: 新增 / 編輯專案 -->
<CustomModal @bind-IsVisible="showProjectModal" Type="CustomModal.ModalType.SlideOver" Title="@(isEditMode ? "編輯專案 (梯次)" : "新增專案 (梯次)")"
    MaxWidth="max-w-2xl" HeaderIcon="fa-solid fa-layer-group" CloseOnBackdropClick="true">
    <ChildContent>
        <EditForm Model="formModel" OnValidSubmit="SaveProject" class="space-y-8">

            <!-- ═══ 區塊 1: 基本資料 ═══ -->
            <div class="space-y-4">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">1</span>
                    基本設定
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">所屬年度 <span class="text-red-500">*</span></label>
                        <input type="text" value="@formModel.Year" readonly
                            placeholder="由產學計畫區間自動帶入"
                            class="w-full px-3 py-2 border border-gray-200 rounded bg-gray-50 text-sm text-gray-600 cursor-not-allowed">
                    </div>
                    @* 專案類型：新增模式可選 CWT/LCT；編輯模式 disabled（題目配額已寫入，切換會資料污染）*@
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">專案類型 <span class="text-red-500">*</span></label>
                        <select value="@formModel.ProjectType" @onchange="OnProjectTypeChanged"
                            disabled="@isEditMode"
                            title="@(isEditMode ? "專案類型一經建立不可變更" : null)"
                            class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:outline-none text-sm bg-white cursor-pointer disabled:bg-gray-50 disabled:text-gray-600 disabled:cursor-not-allowed">
                            <option value="@ProjectType.Cwt">CWT（全民中檢）</option>
                            <option value="@ProjectType.Lct">LCT（聽力中文檢定）</option>
                        </select>
                    </div>
                    @* 命題等級：僅 CWT 模式顯示；LCT 模式各題自選聽力難度。
                       編輯模式同步 disabled — 命題已開始後改變等級會造成 Level 不一致（教師命的初等卻被改為優等）。 *@
                    @if (formModel.ProjectType == ProjectType.Cwt)
                    {
                        <div class="col-span-2">
                            <label class="block text-sm font-medium mb-1 text-gray-700">命題等級 <span class="text-red-500">*</span></label>
                            <select value="@(formModel.ExamLevel?.ToString() ?? "0")" @onchange="OnExamLevelChanged"
                                disabled="@isEditMode"
                                title="@(isEditMode ? "命題等級一經建立不可變更" : "整個專案統一命題等級，命題教師命題時無需自選")"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:outline-none text-sm bg-white cursor-pointer disabled:bg-gray-50 disabled:text-gray-600 disabled:cursor-not-allowed">
                                @foreach (var kv in QuestionConstants.GeneralLevelLabels)
                                {
                                    <option value="@kv.Key">@kv.Value</option>
                                }
                            </select>
                            <p class="text-xs text-gray-500 mt-1 flex items-center gap-1">
                                <i class="fa-solid fa-circle-info text-morandi"></i>
                                此專案的所有題目皆採此等級命題；新增題目時題型下拉會自動隱藏不相容的題型。
                            </p>
                        </div>
                    }
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">專案名稱 <span class="text-red-500">*</span></label>
                        <input type="text" @bind="formModel.Name" required placeholder="如: 春季全民中檢"
                            class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:outline-none text-sm">
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">合作學校 (非必填)</label>
                        <input type="text" @bind="formModel.School" placeholder="留白表示為本局自辦梯次"
                            class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:outline-none text-sm">
                    </div>
                </div>
            </div>

            <!-- ═══ 區塊 2: 8 大階段連動時程 ═══ -->
            <div class="space-y-4 pt-2">
                <div class="border-b border-morandi/30 pb-2 mb-2">
                    <h3 class="text-base font-bold text-gray-800 flex items-center gap-2">
                        <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">2</span>
                        時程規劃設定
                    </h3>
                </div>

                <!-- 操作提示 -->
                <div class="text-xs text-morandi bg-blue-50/50 p-2 rounded border border-blue-100 font-medium">
                    <i class="fa-solid fa-lightbulb mr-1"></i>
                    只要設定第一階段「產學計畫區間」的「開始日」，系統就自動推算半年內的 7 階段日程！<br />
                    此外，手動變更任一階段日期的「結束日」，皆會自動將「下一階段的開始日」連動推進為隔天。
                </div>

                <!-- 8 階段日期列表 -->
                <div class="space-y-2">
                    @for (int i = 0; i < stages.Length; i++)
                    {
                        var idx = i;
                        var isMain = idx == 0;
                        var bgClass = isMain ? "bg-morandi/5 border-morandi/20" : "bg-white border-gray-200";
                        var numClass = isMain ? "bg-morandi" : "bg-gray-300";

                        <div class="@bgClass border p-3 rounded flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-4 transition-colors">
                            <div class="w-full sm:w-5/12 flex items-center gap-2">
                                <span class="w-5 h-5 rounded-full @numClass text-white flex justify-center items-center text-xs flex-shrink-0">@(idx + 1)</span>
                                <div class="flex flex-col">
                                    <span class="font-bold text-sm text-slate-main">@stages[idx].Name</span>
                                    <span class="text-xs text-gray-500 leading-none mt-0.5">@stages[idx].Hint</span>
                                </div>
                            </div>
                            <div class="flex-grow flex items-center gap-2 w-full">
                                <input type="date" value="@stages[idx].Start?.ToString("yyyy-MM-dd")"
                                    @key="@($"start-{idx}-{stages[idx].StartKey}")"
                                    @onchange="(e) => OnStageStartChanged(idx, e)"
                                    class="flex-1 px-2 py-1.5 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-morandi" />
                                <span class="text-gray-400 text-xs text-center"><i class="fa-solid fa-arrow-right"></i></span>
                                <input type="date" value="@stages[idx].End?.ToString("yyyy-MM-dd")"
                                    @key="@($"end-{idx}-{stages[idx].EndKey}")"
                                    @onchange="(e) => OnStageEndChanged(idx, e)"
                                    class="flex-1 px-2 py-1.5 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-morandi" />
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- ═══ 區塊 3: 目標題數與人員指派 ═══ -->
            <div class="space-y-4 pt-2">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">3</span>
                    目標題數與人員指派
                    @if (IsCompositionPhaseEnded)
                    {
                        <span class="inline-flex items-center gap-1 text-xs text-gray-500 font-medium ml-2">
                            <i class="fa-solid fa-lock text-gray-400"></i> 已鎖定（命題階段已結束）
                        </span>
                    }
                </h3>

                <!-- 專案需求題數 / 組數 -->
                <div class="@(IsCompositionPhaseEnded ? "bg-gray-100 p-3 rounded border border-gray-300 cursor-not-allowed" : "bg-white p-3 rounded border border-morandi/30")"
                     title="@(IsCompositionPhaseEnded ? "命題階段已結束，題數需求不可再修改" : null)">
                    <label class="block text-sm font-bold text-gray-700 mb-3">專案需求題數 / 組數</label>
                    @* 設計與「專案詳細 / 題型目標數量」同款：
                       CWT — 題組類（閱讀/短文）用複合卡（母題 ↔ 子題環環相扣），單體題型用簡潔卡。
                       LCT — 5 難度卡 + 1 聽力題組卡（題組以淡莫蘭迪邊框暗示「整組固定 2 子題」）。 *@
                    @if (formModel.ProjectType == ProjectType.Lct)
                    {
                        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 items-stretch">
                            @foreach (var qt in questionTypes)
                            {
                                if (!IsTypeVisibleForLevel(qt)) { continue; }
                                var isLctGroup = qt.QuestionTypeId == 7;
                                @if (isLctGroup)
                                {
                                    @* 聽力題組：呼應 CWT 複合卡的設計語言（漸層 + badge），暗示「整組 = 1 母題 + 2 固定子題」 *@
                                    <div class="relative rounded-2xl px-2 pt-5 pb-2 border-2 border-morandi/40 bg-gradient-to-br from-morandi/15 via-white to-morandi/10 shadow-sm flex flex-col justify-between">
                                        <div class="absolute -top-2.5 left-1/2 -translate-x-1/2 bg-morandi text-white text-xs font-bold px-2 py-0.5 rounded-full shadow-sm whitespace-nowrap flex items-center gap-1">
                                            <i class="fa-solid fa-link-simple text-xs"></i> 聽力題組
                                        </div>
                                        <div class="relative">
                                            <input type="number" min="0" @bind="qt.Count" placeholder="0"
                                                disabled="@IsCompositionPhaseEnded"
                                                class="w-full pl-1 pr-6 py-1.5 bg-white border border-gray-300 rounded text-sm text-center font-bold text-morandi focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed" />
                                            <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400 pointer-events-none">@qt.Unit</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    @* 5 難度單卡 *@
                                    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-2 flex flex-col justify-center">
                                        <div class="text-xs text-gray-500 text-center mb-1 truncate" title="@qt.Label">@qt.Label</div>
                                        <div class="relative">
                                            <input type="number" min="0" @bind="qt.Count" placeholder="0"
                                                disabled="@IsCompositionPhaseEnded"
                                                class="w-full pl-1 pr-6 py-1.5 bg-white border border-gray-300 rounded text-sm text-center font-bold text-slate-main focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed" />
                                            <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400 pointer-events-none">@qt.Unit</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        var visibleGroups = questionTypes.Where(IsTypeVisibleForLevel)
                            .GroupBy(t => t.QuestionTypeId)
                            .OrderBy(g => g.Key)
                            .Select(g => g.OrderBy(t => t.Granularity).ToList())
                            .ToList();
                        // 4 個 → sm 4 欄；5 個 → sm 5 欄；複合卡 col-span-2，arithmetic 剛好填滿。
                        var cwtGridCols = VisibleTypeCount switch
                        {
                            <= 4 => "grid-cols-1 sm:grid-cols-4",
                            5    => "grid-cols-1 sm:grid-cols-5",
                            _    => "grid-cols-1 sm:grid-cols-6",
                        };
                        <div class="grid @cwtGridCols gap-3 items-stretch">
                            @foreach (var grp in visibleGroups)
                            {
                                var isCompound = grp.Count == 2;
                                var typeName = GetTypeName(grp[0].QuestionTypeId);

                                if (isCompound)
                                {
                                    var master = grp[0];
                                    var sub = grp[1];
                                    // 防呆：子題數應 ≥ 母題數
                                    var invalid = (sub.Count ?? 0) < (master.Count ?? 0);
                                    var shellBorder = invalid ? "border-terracotta/60" : "border-morandi/25";
                                    var shellBg = invalid
                                        ? "bg-gradient-to-r from-terracotta/10 via-white to-terracotta/10"
                                        : "bg-gradient-to-r from-morandi/10 via-white to-morandi/10";
                                    var badgeBg = invalid ? "bg-terracotta" : "bg-morandi";
                                    var linkIcon = invalid ? "fa-link-slash text-terracotta/70" : "fa-link text-morandi/60";
                                    var bubbleBorder = invalid ? "border-terracotta/40" : "border-morandi/30";
                                    var bubbleText = invalid ? "text-terracotta" : "text-morandi";
                                    var inputRing = invalid ? "focus:ring-terracotta" : "focus:ring-morandi";

                                    @* 複合卡：外殼漸層 + 內部兩泡泡 + 中央 link icon；子題<母題時整卡改紅色警示 *@
                                    <div class="sm:col-span-2 relative rounded-2xl px-3 pt-5 pb-3 border-2 @shellBorder @shellBg shadow-sm transition-colors">
                                        @* 浮在左上角的題組標題 badge *@
                                        <div class="absolute -top-2.5 left-4 @badgeBg text-white text-xs font-bold px-2 py-0.5 rounded-full shadow-sm flex items-center gap-1">
                                            <i class="fa-solid fa-link-simple text-xs"></i> @typeName
                                        </div>
                                        <div class="flex items-center gap-2">
                                            @* 母題泡泡 *@
                                            <div class="flex-1 bg-white rounded-xl border @bubbleBorder px-2 pt-1.5 pb-2 text-center shadow-sm">
                                                <div class="text-xs text-gray-500 mb-1">母題</div>
                                                <div class="relative">
                                                    <input type="number" min="0" @bind="master.Count" placeholder="0"
                                                        disabled="@IsCompositionPhaseEnded"
                                                        class="w-full pl-1 pr-6 py-1 bg-white border border-gray-300 rounded text-sm text-center font-bold @bubbleText focus:outline-none focus:ring-1 @inputRing focus:border-morandi disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed" />
                                                    <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400 pointer-events-none">@master.Unit</span>
                                                </div>
                                            </div>
                                            @* 連結圖示：環環相扣（鎖鏈）／環脫節（破鏈）依驗證狀態切換 *@
                                            <i class="fa-solid @linkIcon shrink-0"></i>
                                            @* 子題泡泡 *@
                                            <div class="flex-1 bg-white rounded-xl border @bubbleBorder px-2 pt-1.5 pb-2 text-center shadow-sm">
                                                <div class="text-xs text-gray-500 mb-1">子題</div>
                                                <div class="relative">
                                                    <input type="number" min="0" @bind="sub.Count" placeholder="0"
                                                        disabled="@IsCompositionPhaseEnded"
                                                        class="w-full pl-1 pr-6 py-1 bg-white border border-gray-300 rounded text-sm text-center font-bold @bubbleText focus:outline-none focus:ring-1 @inputRing focus:border-morandi disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed" />
                                                    <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400 pointer-events-none">@sub.Unit</span>
                                                </div>
                                            </div>
                                        </div>
                                        @if (invalid)
                                        {
                                            <div class="mt-2 text-xs text-terracotta font-bold flex items-center justify-center gap-1">
                                                <i class="fa-solid fa-triangle-exclamation"></i>
                                                子題數須 ≥ 母題數
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    var single = grp[0];
                                    @* 單體題型：簡潔卡，與複合卡視覺份量明顯區分 *@
                                    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-3 flex flex-col justify-center">
                                        <div class="text-xs text-gray-500 text-center mb-1.5">@typeName</div>
                                        <div class="relative">
                                            <input type="number" min="0" @bind="single.Count" placeholder="0"
                                                disabled="@IsCompositionPhaseEnded"
                                                class="w-full pl-1 pr-6 py-1.5 bg-white border border-gray-300 rounded text-sm text-center font-bold text-slate-main focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed" />
                                            <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400 pointer-events-none">@single.Unit</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    @if (IsCompositionPhaseEnded)
                    {
                        <p class="text-xs text-terracotta mt-2 font-bold flex items-center gap-1">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            命題階段於 @CompositionPhaseEndDisplay 結束，題數需求不可再修改。
                        </p>
                    }
                </div>

                <!-- 指派人員（來源：教師管理系統人才庫） -->
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <label class="block text-sm font-bold text-gray-700">指派人員 (命審題教師/委員列表)</label>
                    </div>
                    <!-- 搜尋框（debounce 250ms） -->
                    <div class="mb-2">
                        <DebouncedSearchInput @bind-Value="personSearchKeyword"
                                              Placeholder="搜尋姓名或編號..."
                                              CssClass="w-full pl-9 pr-3 py-1.5 text-sm border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-morandi" />
                    </div>
                    <!-- 人員列表容器 -->
                    <div class="border border-gray-300 rounded h-56 overflow-y-auto custom-scroll bg-white divide-y divide-gray-100 @(IsCompositionPhaseEnded ? "opacity-60 cursor-not-allowed" : "")"
                         title="@(IsCompositionPhaseEnded ? "命題階段已結束，已進入審題流程，無法再變更指派人員與身份" : null)">
                        @{ var filteredPersons = GetFilteredPersons(); }
                        @if (filteredPersons.Count == 0)
                        {
                            <div class="flex flex-col items-center justify-center h-full text-gray-400">
                                <i class="fa-solid fa-users-slash text-3xl mb-2 text-gray-300"></i>
                                <p class="text-sm font-medium">尚無人員資料</p>
                                <p class="text-xs mt-1">請先至「教師管理系統」新增教師名單</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var person in filteredPersons)
                            {
                                <div class="flex items-start gap-3 p-3 hover:bg-gray-50 transition-colors">
                                    <label class="flex items-center gap-3 mt-1 @(IsCompositionPhaseEnded ? "cursor-not-allowed" : "cursor-pointer")">
                                        <input type="checkbox" checked="@person.IsSelected"
                                            @key="@($"chk-{person.UserId}-{person.CheckboxKey}")"
                                            disabled="@IsCompositionPhaseEnded"
                                            @onchange="() => TogglePersonSelection(person)"
                                            class="w-4 h-4 text-morandi rounded border-gray-300 focus:ring-morandi mt-0.5 cursor-pointer disabled:cursor-not-allowed" />
                                        <div class="flex flex-col w-20">
                                            <span class="text-sm font-bold text-gray-700">@person.Name 老師</span>
                                            <span class="text-xs text-gray-500">@person.Identifier</span>
                                        </div>
                                    </label>
                                    <div class="flex-grow flex flex-col gap-1.5">
                                        @{
                                            var roleSlots = GetRoleSlots(person);
                                        }
                                        @for (var slotIndex = 0; slotIndex < roleSlots.Count; slotIndex++)
                                        {
                                            var idx = slotIndex;
                                            var currentRoleId = roleSlots[idx];
                                            var isFirst = idx == 0;
                                            var isLast = idx == roleSlots.Count - 1;
                                            // + 鈕掛在第一格，啟用條件改為「最後一格已選好身份」且還沒達上限
                                            var canAddMore = !IsCompositionPhaseEnded
                                                && person.IsSelected
                                                && roleSlots.Count < projectRoles.Count
                                                && roleSlots[roleSlots.Count - 1] > 0;

                                            <div class="flex items-center gap-1.5">
                                                <select value="@currentRoleId" disabled="@(IsCompositionPhaseEnded || !person.IsSelected)"
                                                    @key="@($"role-{person.UserId}-{idx}-{person.RoleSlotKey}")"
                                                    @onchange="(e) => OnRoleSlotChanged(person, idx, e)"
                                                    class="flex-grow text-xs border border-gray-300 rounded px-2 py-1.5 focus:ring-morandi focus:border-morandi bg-white disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed">
                                                    <option value="0">@(isFirst ? "請選派主要身份..." : "請選派附加身份...")</option>
                                                    @{
                                                        var propositionRoleId = GetPropositionTeacherRoleId();
                                                    }
                                                    @foreach (var role in projectRoles)
                                                    {
                                                        // 命題階段已結束時隱藏「命題教師」選項，但保留已選為命題教師者（避免下拉顯示空白）
                                                        var hidePropositionDuringLock = IsCompositionPhaseEnded
                                                                                         && propositionRoleId.HasValue
                                                                                         && role.Id == propositionRoleId.Value
                                                                                         && role.Id != currentRoleId;
                                                        if (hidePropositionDuringLock) { continue; }

                                                        // 排除已被同人選走的身份（但保留自己目前選的，避免顯示空白）
                                                        if (role.Id == currentRoleId || !person.SelectedRoleIds.Contains(role.Id))
                                                        {
                                                            // @key 鎖位避免 Blazor diff 就地改寫 value 屬性導致 <select> 顯示錯位
                                                            <option value="@role.Id" @key="role.Id">@role.Name</option>
                                                        }
                                                    }
                                                </select>
                                                @if (isFirst)
                                                {
                                                    <button type="button" title="新增附加身份"
                                                        disabled="@(!canAddMore)"
                                                        @onclick="() => AddRoleSlot(person)"
                                                        class="flex-shrink-0 w-7 h-7 rounded bg-sage text-white text-xs hover:bg-[#7b9c81] transition-colors disabled:bg-gray-200 disabled:text-gray-400 disabled:cursor-not-allowed cursor-pointer flex items-center justify-center">
                                                        <i class="fa-solid fa-plus"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="button" title="移除此身份"
                                                        disabled="@IsCompositionPhaseEnded"
                                                        @onclick="() => RemoveRoleSlot(person, idx)"
                                                        class="flex-shrink-0 w-7 h-7 rounded text-red-500 text-xs hover:bg-red-50 transition-colors cursor-pointer disabled:text-gray-300 disabled:hover:bg-transparent disabled:cursor-not-allowed flex items-center justify-center">
                                                        <i class="fa-solid fa-xmark"></i>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <p class="text-xs text-gray-400 mt-1 flex justify-between">
                        <span>人員清單擷取自「教師管理系統」人才庫</span>
                        <span>可複選多重身份（如：命題教師 + 審題委員）</span>
                    </p>
                </div>
            </div>

            <!-- ═══ 區塊 4: 人員命題數量配置 ═══ -->
            <div class="space-y-4 pt-2 border-t border-gray-100 @(IsCompositionPhaseEnded ? "cursor-not-allowed" : "")"
                 title="@(IsCompositionPhaseEnded ? "命題階段已結束，配額不可再修改" : null)">
                <div class="flex justify-between items-center border-b border-morandi/30 pb-2">
                    <h3 class="text-base font-bold text-gray-800 flex items-center gap-2">
                        <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">4</span>
                        人員命題數量配置
                        @if (IsCompositionPhaseEnded)
                        {
                            <span class="inline-flex items-center gap-1 text-xs text-gray-500 font-medium ml-2">
                                <i class="fa-solid fa-lock text-gray-400"></i> 已鎖定（命題階段已結束）
                            </span>
                        }
                    </h3>
                    <button type="button" @onclick="HandleAutoDistribute"
                        disabled="@IsCompositionPhaseEnded"
                        class="text-xs bg-white border border-morandi text-morandi px-3 py-1 rounded hover:bg-blue-50 transition-colors font-bold flex items-center gap-1 shadow-sm cursor-pointer disabled:bg-gray-100 disabled:text-gray-400 disabled:border-gray-300 disabled:cursor-not-allowed">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> 依命題教師人數平均分配
                    </button>
                </div>

                <p class="text-xs text-gray-500 mb-2">
                    <i class="fa-solid fa-circle-info text-morandi mr-1"></i>
                    系統會自動帶入具備「命題教師」身分的人員。配額總數須與「專案需求題數 / 組數」相符。
                </p>

                <!-- 教師配額列表 -->
                <div class="space-y-3 max-h-96 overflow-y-auto custom-scroll pr-2 -mr-2">
                    @if (allocationTeachers.Count == 0)
                    {
                        <div class="text-sm text-center text-gray-400 py-4 bg-gray-50 rounded border border-gray-100">
                            請先由上方勾選「命題教師」以進行數量配置...
                        </div>
                    }
                    else
                    {
                        @for (int i = 0; i < allocationTeachers.Count; i++)
                        {
                            var idx = i;
                            var teacher = allocationTeachers[idx];
                            <div class="bg-white border border-gray-200 rounded p-3 flex flex-col md:flex-row gap-4 items-start md:items-center">
                                <div class="flex items-center gap-2 w-full md:w-32 flex-shrink-0">
                                    <div class="w-8 h-8 rounded-full bg-morandi text-white flex items-center justify-center font-bold text-xs">@(idx + 1)</div>
                                    <div class="font-bold text-sm text-slate-main truncate">@teacher.Name</div>
                                </div>
                                <div class="flex-grow grid @CompactGridCols gap-2 w-full">
                                    @for (int j = 0; j < questionTypes.Count; j++)
                                    {
                                        var qIdx = j;
                                        if (!IsTypeVisibleForLevel(questionTypes[qIdx])) { continue; }
                                        <div>
                                            <label class="block text-xs text-gray-500 mb-0.5 truncate" title="@questionTypes[qIdx].Label">@questionTypes[qIdx].Label</label>
                                            <div class="relative">
                                                <input type="number" min="0" value="@teacher.Quotas[qIdx]"
                                                    @onchange="(e) => OnQuotaChanged(idx, qIdx, e)"
                                                    disabled="@IsCompositionPhaseEnded"
                                                    class="w-full pl-1 pr-6 py-1 border border-gray-300 rounded text-xs text-center focus:ring-1 focus:ring-morandi focus:outline-none disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed" />
                                                <span class="absolute right-1.5 top-1/2 -translate-y-1/2 text-xs text-gray-400 pointer-events-none">@questionTypes[qIdx].Unit</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- 分配狀態檢核 -->
                <div class="bg-gray-50 rounded border border-gray-200 p-3 mt-4">
                    <div class="text-xs font-bold text-gray-500 mb-2 flex items-center justify-between">
                        <span>分配狀態檢核：(已分配 / 需分配)</span>
                        <span>@GetValidationMessage()</span>
                    </div>
                    <div class="grid @CompactGridCols gap-1">
                        @for (int i = 0; i < questionTypes.Count; i++)
                        {
                            var qt = questionTypes[i];
                            if (!IsTypeVisibleForLevel(qt)) { continue; }
                            var target = qt.Count ?? 0;
                            var allocated = GetAllocatedSum(i);
                            var isExact = allocated == target;
                            var bgColor = isExact
                                ? (target > 0 ? "bg-sage/10 border-sage/30" : "bg-gray-100 border-gray-200")
                                : "bg-terracotta/10 border-terracotta/50";
                            var textColor = isExact
                                ? (target > 0 ? "text-sage" : "text-gray-400")
                                : "text-terracotta";

                            <div class="flex flex-col items-center justify-center border rounded p-1 @bgColor">
                                <span class="text-xs text-gray-500 mb-0.5 whitespace-nowrap overflow-hidden text-ellipsis w-full text-center" title="@qt.Label">@qt.Label</span>
                                <span class="text-xs font-bold flex items-center gap-1 @textColor">
                                    @allocated / @target @qt.Unit
                                    @if (isExact && target > 0)
                                    {
                                        <i class="fa-solid fa-check text-xs"></i>
                                    }
                                    else if (!isExact && target > 0)
                                    {
                                        <i class="fa-solid fa-xmark text-xs"></i>
                                    }
                                </span>
                            </div>
                        }
                    </div>
                </div>
                @if (IsCompositionPhaseEnded)
                {
                    <p class="text-xs text-terracotta font-bold flex items-center gap-1">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        命題階段於 @CompositionPhaseEndDisplay 結束，配額不可再修改。
                    </p>
                }
            </div>

        </EditForm>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="CloseProjectModal"
            class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors focus:outline-none shadow-sm">
            取消
        </button>
        <button type="button" @onclick="SaveProject"
            class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors focus:outline-none shadow-sm flex items-center gap-2">
            <i class="fa-solid fa-floppy-disk"></i> @(isEditMode ? "儲存修改" : "儲存專案")
        </button>
    </FooterContent>
</CustomModal>

@* 編輯聘期 Modal（共用元件） *@
<EditAppointmentPeriodModal @bind-IsVisible="showEditPeriodModal"
                             UserId="editPeriodUserId"
                             ProjectId="editPeriodProjectId"
                             OnSaved="HandleEditPeriodSaved" />

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    /// <summary>
    /// 儲存/更新專案後，呼叫 JS Canvas 繪製該專案所有「未完成」聘書並上傳。
    /// 若無 pending（user 沒新增成員），靜默略過不彈視窗。
    /// </summary>
    private async Task DrawPendingAppointmentsAsync(int projectId)
    {
        try
        {
            var pending = await AppointmentService.GetPendingDraftsByProjectAsync(projectId);
            if (pending.Count == 0) return;
            await JS.InvokeVoidAsync("AppointmentCert.drawAndUpload", pending, "", false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "聘書繪製失敗 (projectId={ProjectId})", projectId);
        }
    }

    // ──── 編輯聘期 Modal 狀態 ────
    private bool showEditPeriodModal = false;
    private int? editPeriodUserId;
    private int? editPeriodProjectId;

    private void OpenEditPeriodModal(int userId, int projectId)
    {
        editPeriodUserId = userId;
        editPeriodProjectId = projectId;
        showEditPeriodModal = true;
    }

    /// <summary>編輯聘期儲存後：觸發 client 重畫對應 cert（FileName 已被 UpdateCustomPeriodsAsync 設為 NULL）。</summary>
    private async Task HandleEditPeriodSaved()
    {
        if (editPeriodProjectId is int pid)
        {
            await DrawPendingAppointmentsAsync(pid);
        }
    }

    private bool showProjectModal = false;
    private bool isEditMode = false;
    private int? editingProjectId;
    private string personSearchKeyword = "";

    // ──── 專案列表狀態 ────
    private List<ProjectListItem> allProjects = new();
    private string searchKeyword = "";
    private string currentFilter = "all";
    private int? selectedProjectId;
    private ProjectDetailDto? selectedDetail;

    // 篩選按鈕定義
    private static readonly (string Key, string Label)[] filterOptions =
    [
        ("all", "全部"),
        ("active", "進行中"),
        ("closed", "已結案")
    ];

    // --- 表單模型 ---
    private ProjectFormModel formModel = new();

    // --- 8 階段時程定義 ---
    private StageItem[] stages = [];

    // --- 題型目標清單（依 ProjectType 動態建立） ---
    private List<QuestionTypeTarget> questionTypes = BuildCwtQuestionTypes();

    /// <summary>CWT 模式：6 欄位（一般/閱讀母/閱讀子/長文/短文母/短文子），其他題型不獨立設目標。</summary>
    private static List<QuestionTypeTarget> BuildCwtQuestionTypes() =>
    [
        new() { Key = "single",         Label = "一般單選題",   QuestionTypeId = 1, Granularity = 0 },
        new() { Key = "readGroupMain",  Label = "閱讀題組母題", QuestionTypeId = 3, Granularity = 0 },
        new() { Key = "readGroupSub",   Label = "閱讀題組子題", QuestionTypeId = 3, Granularity = 1 },
        new() { Key = "longText",       Label = "長文題目",     QuestionTypeId = 4, Granularity = 0 },
        new() { Key = "shortGroupMain", Label = "短文題組母題", QuestionTypeId = 5, Granularity = 0 },
        new() { Key = "shortGroupSub",  Label = "短文題組子題", QuestionTypeId = 5, Granularity = 1 },
    ];

    /// <summary>
    /// LCT 模式：6 欄位 — 聽力題目（QuestionTypeId=6）依難度一~五各自獨立，
    /// 加上聽力題組（QuestionTypeId=7）整體一個欄位以「組」計（不分難度）。
    /// 聽力題組 Level 為 null，與 DB MT_ProjectTargets.Level (nullable) 對應。
    /// </summary>
    private static List<QuestionTypeTarget> BuildLctQuestionTypes() =>
    [
        new() { Key = "lct1",     Label = "難度一",   QuestionTypeId = 6, Granularity = 0, Level = 1 },
        new() { Key = "lct2",     Label = "難度二",   QuestionTypeId = 6, Granularity = 0, Level = 2 },
        new() { Key = "lct3",     Label = "難度三",   QuestionTypeId = 6, Granularity = 0, Level = 3 },
        new() { Key = "lct4",     Label = "難度四",   QuestionTypeId = 6, Granularity = 0, Level = 4 },
        new() { Key = "lct5",     Label = "難度五",   QuestionTypeId = 6, Granularity = 0, Level = 5 },
        new() { Key = "lctGroup", Label = "聽力題組", QuestionTypeId = 7, Granularity = 0, Level = null },
    ];

    // --- 可選身份 ---
    private List<RoleOption> projectRoles = new();

    // --- 人才庫（來源：教師管理系統，目前尚未建構 TeacherService，故為空） ---
    private List<PersonItem> talentPool = new();

    // --- 命題教師配額表（區塊 4：僅含被勾選且身分為「命題教師」的人員） ---
    private List<AllocationItem> allocationTeachers = new();

    /// <summary>
    /// 命題階段（stages[1]，PhaseCode=2）是否已結束。
    /// 編輯模式下命題階段結束日 < 今日，則鎖定題數需求 / 配額 / 命題教師新增。
    /// 新增模式永遠不鎖。
    /// </summary>
    private bool IsCompositionPhaseEnded
        => isEditMode
           && stages.Length > 1
           && stages[1].End is DateTime endDate
           && endDate < DateTime.Today;

    /// <summary>命題階段結束日的顯示文字（鎖定提示用）。</summary>
    private string CompositionPhaseEndDisplay
        => stages.Length > 1 && stages[1].End is DateTime endDate
            ? endDate.ToString("yyyy-MM-dd")
            : "—";

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
        await LoadTalentPoolAsync();
        await LoadProjectRolesAsync();
        ResetForm();
    }

    /// <summary>從資料庫載入全部專案列表</summary>
    private async Task LoadProjectsAsync()
    {
        try
        {
            allProjects = await ProjectService.GetProjectListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入專案列表失敗");
            allProjects = new();
        }
    }

    // ──── 列表篩選邏輯 ────

    /// <summary>依關鍵字與狀態篩選專案</summary>
    private async Task LoadTalentPoolAsync()
    {
        try
        {
            var members = await ProjectService.GetTalentPoolAsync();
            talentPool = members
                .Select(member => new PersonItem
                {
                    Id = member.Identifier,
                    UserId = member.UserId,
                    Name = member.Name,
                    Identifier = member.Identifier
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入教師管理系統失敗");
            talentPool = new();
        }
    }

    private List<ProjectListItem> GetFilteredProjects()
    {
        IEnumerable<ProjectListItem> result = allProjects;

        // 狀態篩選
        result = currentFilter switch
        {
            "active" => result.Where(p => p.EffectiveStatus == ProjectLifecycleStatus.Active),
            "closed" => result.Where(p => p.IsClosed),
            _ => result // "all" 包含所有狀態
        };

        // 關鍵字模糊比對（名稱 / 年度）
        if (!string.IsNullOrWhiteSpace(searchKeyword))
        {
            var kw = searchKeyword.Trim();
            var schoolDisplay = (string? s) => string.IsNullOrEmpty(s) ? "無 (自辦)" : s;
            result = result.Where(p =>
                p.Name.Contains(kw, StringComparison.OrdinalIgnoreCase) ||
                p.Year.ToString().Contains(kw) ||
                schoolDisplay(p.School).Contains(kw, StringComparison.OrdinalIgnoreCase));
        }

        // 排序：準備中 (0) → 進行中 (1) → 已結案 (2)；同狀態內依年度新→舊、Id 新→舊
        return result
            .OrderBy(p => (int)p.EffectiveStatus)
            .ThenByDescending(p => p.Year)
            .ThenByDescending(p => p.Id)
            .ToList();
    }

    /// <summary>選取左側列表的專案，並載入詳情</summary>
    private async Task SelectProject(int projectId)
    {
        selectedProjectId = projectId;
        try
        {
            selectedDetail = await ProjectService.GetProjectDetailAsync(projectId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入專案詳情失敗 (Id={ProjectId})", projectId);
            selectedDetail = null;
        }
    }

    /// <summary>依狀態碼取得對應狀態文字</summary>
    private static string GetProjectStatusText(byte status) => status switch
    {
        0 => "準備中",
        1 => "進行中",
        2 => "已結案",
        _ => "未知"
    };

    private void ResetForm()
    {
        isEditMode = false;
        editingProjectId = null;
        formModel = new();
        personSearchKeyword = "";
        // 新增模式預設 CWT；編輯模式由 ApplyProjectEditData 覆寫
        questionTypes = BuildCwtQuestionTypes();
        foreach (var p in talentPool) { p.IsSelected = false; p.SelectedRoleIds.Clear(); p.CreatedQuestionCount = 0; }
        allocationTeachers.Clear();
        InitStages();
    }

    /// <summary>
    /// 新增模式下切換 ProjectType：整份替換 questionTypes，清空 allocationTeachers（配額結構不同）。
    /// 編輯模式下 ProjectType 欄位已 disabled，此 handler 不會被觸發。
    /// </summary>
    private void OnProjectTypeChanged(ChangeEventArgs e)
    {
        if (!Enum.TryParse<ProjectType>(e.Value?.ToString(), out var pt)) return;
        formModel.ProjectType = pt;
        questionTypes = pt == ProjectType.Lct ? BuildLctQuestionTypes() : BuildCwtQuestionTypes();
        allocationTeachers.Clear(); // 配額 Quotas 長度需重建
        // ExamLevel 切換邏輯：CWT 預設初等 (0)；LCT 不使用此欄位 → 清為 null
        formModel.ExamLevel = pt == ProjectType.Cwt ? (byte)0 : (byte?)null;
    }

    /// <summary>
    /// 命題等級下拉變更（僅 CWT 模式可達；編輯模式 disabled 不觸發）。
    /// 變更後將不適用此等級的題型 Count + 教師 Quotas 歸零，避免隱形數字影響驗證與寫入。
    /// </summary>
    private void OnExamLevelChanged(ChangeEventArgs e)
    {
        if (byte.TryParse(e.Value?.ToString(), out var lv))
        {
            formModel.ExamLevel = lv;
            ZeroOutHiddenTypes();
        }
    }

    /// <summary>
    /// 判斷某題型是否應在當前 ExamLevel 下顯示。
    /// CWT 規則：
    ///   一般單選題 (TypeId=1)：僅 初等/中等/中高等 (0/1/2) 顯示。
    ///   短文題組母/子題 (TypeId=5)：僅 高等/優等 (3/4) 顯示。
    /// LCT 與其他 CWT 題型（閱讀題組 3 / 長文題目 4）皆無此限制。
    /// </summary>
    private bool IsTypeVisibleForLevel(QuestionTypeTarget qt)
    {
        if (formModel.ProjectType != ProjectType.Cwt) return true;
        var level = formModel.ExamLevel ?? 0;

        return qt.QuestionTypeId switch
        {
            1 => level <= 2, // 一般單選題：初等/中等/中高等
            5 => level >= 3, // 短文題組：高等/優等
            _ => true
        };
    }

    /// <summary>等級切換後，將不適用此等級的題型 Count + 教師 Quotas 歸零。</summary>
    private void ZeroOutHiddenTypes()
    {
        for (int i = 0; i < questionTypes.Count; i++)
        {
            if (IsTypeVisibleForLevel(questionTypes[i])) continue;

            questionTypes[i].Count = 0;
            foreach (var teacher in allocationTeachers)
            {
                if (i < teacher.Quotas.Length) teacher.Quotas[i] = 0;
            }
        }
    }

    /// <summary>目前畫面中可見的題型數量（4=初等/中等/中高等、5=高等/優等、6=LCT 或無過濾情境）。</summary>
    private int VisibleTypeCount => questionTypes.Count(IsTypeVisibleForLevel);

    /// <summary>
    /// 區塊 4 教師配額 + 分配狀態檢核 grid 欄位數（緊湊小框版型）：
    /// 4 個 → sm 4 欄；5 個 → sm 5 欄；其他 → sm 6 欄；mobile 一律 2 欄。
    /// </summary>
    private string CompactGridCols => VisibleTypeCount switch
    {
        <= 4 => "grid-cols-2 sm:grid-cols-4",
        5    => "grid-cols-2 sm:grid-cols-5",
        _    => "grid-cols-2 sm:grid-cols-6",
    };

    /// <summary>題型 Id → 顯示名稱（與 QuestionTypeCatalog 一致；此處 hard-coded 因為列表固定 7 項）。</summary>
    private static string GetTypeName(int questionTypeId) => questionTypeId switch
    {
        1 => "一般單選題",
        3 => "閱讀題組",
        4 => "長文題目",
        5 => "短文題組",
        6 => "聽力測驗",
        7 => "聽力題組",
        _ => "其他",
    };

