    // 預設各階段天數
    private static readonly int[] DefaultDays = [100, 30, 7, 7, 14, 14, 14, 14];

    // ──── 時程連動引擎 ────

    /// <summary>第一階段開始日變更時，自動推算後續所有階段</summary>
    private async Task OnStageStartChanged(int idx, ChangeEventArgs e)
    {
        if (!DateTimeOffset.TryParse(e.Value?.ToString(), out var dt)) return;
        var date = dt.Date;

        // 防呆：非首階段時，新開始日不可晚於現存結束日
        if (idx > 0 && stages[idx].End is DateTime existingEnd && date > existingEnd)
        {
            stages[idx].StartKey++; // 強制重建 input，將 UI 顯示還原為原值
            StateHasChanged(); // 立即重新渲染，讓 input 在警示彈出前先還原
            await ShowAlertAsync("warning", "日期設定錯誤", $"「{stages[idx].Name}」的開始日不可晚於結束日（{existingEnd:yyyy-MM-dd}）。");
            return;
        }

        stages[idx].Start = date;

        if (idx == 0)
        {
            // 自動帶入所屬年度（民國年 = 西元年 - 1911）
            formModel.Year = (date.Year - 1911).ToString();

            // 產學計畫區間的結束日自動設為所有階段結束後
            var cursor = date.AddDays(14); // 命題階段在產學開始後 14 天
            for (int i = 1; i < stages.Length; i++)
            {
                stages[i].Start = cursor;
                stages[i].End = cursor.AddDays(DefaultDays[i]);
                cursor = stages[i].End!.Value.AddDays(1);
            }
            // 產學計畫結束日 = 最後一個階段的結束日
            stages[0].End = stages[^1].End;
        }
    }

    /// <summary>結束日變更 → 下一階段的開始日自動推進為隔天</summary>
    private async Task OnStageEndChanged(int idx, ChangeEventArgs e)
    {
        if (!DateTimeOffset.TryParse(e.Value?.ToString(), out var dt)) return;
        var newEnd = dt.Date;

        // 防呆：新結束日不可早於現存開始日
        if (stages[idx].Start is DateTime existingStart && newEnd < existingStart)
        {
            stages[idx].EndKey++; // 強制重建 input，將 UI 顯示還原為原值
            StateHasChanged(); // 立即重新渲染，讓 input 在警示彈出前先還原
            await ShowAlertAsync("warning", "日期設定錯誤", $"「{stages[idx].Name}」的結束日不可早於開始日（{existingStart:yyyy-MM-dd}）。");
            return;
        }

        stages[idx].End = newEnd;

        if (idx + 1 < stages.Length)
        {
            stages[idx + 1].Start = newEnd.AddDays(1);
        }
    }

