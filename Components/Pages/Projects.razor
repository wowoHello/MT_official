    // --- 表單模型 ---
    private ProjectFormModel formModel = new();

    // --- 8 階段時程定義 ---
    private StageItem[] stages = [];

    // --- 7 種題型 ---
    private List<QuestionTypeTarget> questionTypes = new()
    {
        new() { Key = "single",      Label = "一般單選題" },
        new() { Key = "select",      Label = "精選單選題" },
        new() { Key = "readGroup",   Label = "閱讀題組" },
        new() { Key = "longText",    Label = "長文題目" },
        new() { Key = "shortGroup",  Label = "短文題組" },
        new() { Key = "listen",      Label = "聽力測驗" },
        new() { Key = "listenGroup", Label = "聽力題組" },
    };

    // --- 可選身份 ---
    private static readonly string[] availableRoles = ["命題教師", "互審教師", "專審委員", "總召(專員)", "專家學者"];

    // --- 人才庫（來源：教師管理系統，目前尚未建構 TeacherService，故為空） ---
    private List<PersonItem> talentPool = new();

