    private async Task HandleDeleteProject()
    {
        if (selectedDetail == null)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("swalInterop.confirm", new
        {
            title = "確認移除專案？",
            text = $"移除後，專案「{selectedDetail.Name}」將自列表隱藏，相關資料仍會保留。",
            icon = "warning",
            showCancelButton = true,
            confirmButtonColor = "#ef4444",
            cancelButtonColor = "#6B8EAD",
            confirmButtonText = "確認移除",
            cancelButtonText = "取消"
        });

        if (!confirmed)
        {
            return;
        }

        try
        {
            var userId = await GetCurrentUserIdAsync();
            if (userId is null)
            {
                return;
            }

            await ProjectService.SoftDeleteProjectAsync(selectedDetail.Id, userId.Value);
            await ShowAlertAsync("success", "已移除", "專案已自列表隱藏，相關資料仍保留。");

            selectedDetail = null;
            selectedProjectId = null;
            await LoadProjectsAsync();
        }
        catch (Exception ex)
        {
            await ShowAlertAsync("error", "刪除失敗", $"錯誤：{ex.Message}");
        }
    }

    private async Task LoadProjectRolesAsync()
    {
        try
        {
            projectRoles = await ProjectService.GetProjectRoleOptionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入專案角色清單失敗");
            projectRoles = new();
        }
    }

    private async Task OpenEditProjectModalAsync()
    {
        if (selectedDetail is null)
        {
            return;
        }

        try
        {
            var editData = await ProjectService.GetProjectEditAsync(selectedDetail.Id);
            if (editData is null)
            {
                await ShowAlertAsync("error", "載入失敗", "找不到要編輯的專案資料。");
                return;
            }

            ApplyProjectEditData(editData);
            isEditMode = true;
            editingProjectId = editData.Id;
            showProjectModal = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入專案編輯資料失敗 (Id={ProjectId})", selectedDetail.Id);
            await ShowAlertAsync("error", "載入失敗", $"無法載入編輯資料：{ex.Message}");
        }
    }

    private async Task SaveProject()
    {
        if (string.IsNullOrWhiteSpace(formModel.Year) || string.IsNullOrWhiteSpace(formModel.Name))
        {
            await ShowAlertAsync("warning", "驗證未通過", "「專案年度」與「專案名稱」為必填項目");
            return;
        }

        if (stages[0].Start == null || stages[0].End == null)
        {
            await ShowAlertAsync("warning", "驗證未通過", "請設定產學計畫區間的起訖日期");
            return;
        }

        // 防呆：題組類（閱讀=3、短文=5）的子題數必須 ≥ 母題數，否則資料無法成組。
        // ZeroOutHiddenTypes 已把不適用等級的題型歸零，這裡 0 ≥ 0 自然通過。
        foreach (var groupTypeId in new[] { 3, 5 })
        {
            var master = questionTypes.FirstOrDefault(qt => qt.QuestionTypeId == groupTypeId && qt.Granularity == 0);
            var sub = questionTypes.FirstOrDefault(qt => qt.QuestionTypeId == groupTypeId && qt.Granularity == 1);
            if (master is null || sub is null) continue;
            var masterCount = master.Count ?? 0;
            var subCount = sub.Count ?? 0;
            if (subCount < masterCount)
            {
                await ShowAlertAsync("warning", "驗證未通過",
                    $"「{GetTypeName(groupTypeId)}」的子題數 ({subCount}) 不可少於母題數 ({masterCount})。");
                return;
            }
        }

        for (var i = 0; i < questionTypes.Count; i++)
        {
            var target = questionTypes[i].Count ?? 0;
            if (target > 0 && GetAllocatedSum(i) != target)
            {
                await ShowAlertAsync("warning", "驗證未通過", "題型數量的分配不符合專案需求題數，請重新配置");
                return;
            }
        }

        var currentUserId = await GetCurrentUserIdAsync();
        if (currentUserId is null)
        {
            return;
        }

        try
        {
            var req = BuildProjectRequest(currentUserId.Value);

            if (isEditMode && editingProjectId.HasValue)
            {
                var updateReq = new UpdateProjectRequest
                {
                    ProjectId = editingProjectId.Value,
                    Year = req.Year,
                    Name = req.Name,
                    School = req.School,
                    UpdatedBy = currentUserId.Value,
                    ProjectType = formModel.ProjectType,
                    ExamLevel = req.ExamLevel,
                    Phases = req.Phases,
                    Targets = req.Targets,
                    MemberAllocations = req.MemberAllocations
                };

                await ProjectService.UpdateProjectAsync(updateReq);
                showProjectModal = false;
                await DrawPendingAppointmentsAsync(updateReq.ProjectId);
                await ShowAlertAsync("success", "修改成功", "專案設定已更新。");
                await LoadProjectsAsync();
                await SelectProject(updateReq.ProjectId);
            }
            else
            {
                var newProjectId = await ProjectService.CreateProjectAsync(req);
                showProjectModal = false;
                await DrawPendingAppointmentsAsync(newProjectId);
                await ShowAlertAsync("success", "新增成功", "專案與所有設定已寫入資料庫！");
                await LoadProjectsAsync();
            }
        }
        catch (Exception ex)
        {
            var actionName = isEditMode ? "修改" : "新增";
            await ShowAlertAsync("error", "系統錯誤", $"{actionName}專案失敗：{ex.Message}");
        }
    }

    private CreateProjectRequest BuildProjectRequest(int currentUserId)
    {
        var req = new CreateProjectRequest
        {
            Year = formModel.Year.Trim(),
            Name = formModel.Name.Trim(),
            School = string.IsNullOrWhiteSpace(formModel.School) ? null : formModel.School.Trim(),
            CreatedBy = currentUserId,
            ProjectType = formModel.ProjectType,
            // LCT 模式由 ProjectService 端轉 NULL；此處原樣帶過
            ExamLevel = formModel.ProjectType == ProjectType.Cwt ? formModel.ExamLevel : null
        };

        for (var i = 0; i < stages.Length; i++)
        {
            if (stages[i].Start.HasValue && stages[i].End.HasValue)
            {
                req.Phases.Add(new ProjectPhaseDto
                {
                    PhaseCode = i + 1,
                    Name = stages[i].Name,
                    StartDate = stages[i].Start!.Value,
                    EndDate = stages[i].End!.Value
                });
            }
        }

        foreach (var qt in questionTypes)
        {
            var count = qt.Count ?? 0;
            if (count > 0)
            {
                req.Targets.Add(new ProjectTargetDto
                {
                    QuestionTypeId = qt.QuestionTypeId,
                    Granularity = qt.Granularity,
                    Level = qt.Level,
                    TargetCount = count
                });
            }
        }

        var propositionRoleId = GetPropositionTeacherRoleId();

        foreach (var person in talentPool.Where(x => x.IsSelected && x.UserId > 0))
        {
            var allocDto = new ProjectMemberAllocationDto
            {
                UserId = person.UserId,
                RoleIds = person.SelectedRoleIds.Where(id => id > 0).ToList()
            };

            if (propositionRoleId.HasValue && person.SelectedRoleIds.Contains(propositionRoleId.Value))
            {
                var allocation = allocationTeachers.FirstOrDefault(a => a.UserId == person.UserId);
                if (allocation != null)
                {
                    for (var i = 0; i < questionTypes.Count; i++)
                    {
                        if (allocation.Quotas[i] > 0)
                        {
                            allocDto.Quotas.Add(new ProjectMemberQuotaDto
                            {
                                QuestionTypeId = questionTypes[i].QuestionTypeId,
                                Granularity = questionTypes[i].Granularity,
                                Level = questionTypes[i].Level,
                                QuotaCount = allocation.Quotas[i]
                            });
                        }
                    }
                }
            }

            req.MemberAllocations.Add(allocDto);
        }

        return req;
    }

    private void ApplyProjectEditData(ProjectEditDto project)
    {
        ResetForm();

        formModel.Year = project.Year.ToString();
        formModel.Name = project.Name;
        formModel.School = project.School ?? string.Empty;
        formModel.ProjectType = project.ProjectType;
        // CWT 統一等級回填；LCT 模式為 NULL（與 DB 一致），UI 端 if 條件不顯示等級下拉
        formModel.ExamLevel = project.ExamLevel;

        // 依 ProjectType 初始化對應題型清單（編輯模式下 ProjectType dropdown 為 disabled）
        questionTypes = project.ProjectType == ProjectType.Lct
            ? BuildLctQuestionTypes()
            : BuildCwtQuestionTypes();

        foreach (var phase in project.Phases)
        {
            var phaseIndex = phase.PhaseCode - 1;
            if (phaseIndex < 0 || phaseIndex >= stages.Length)
            {
                continue;
            }

            stages[phaseIndex].Start = phase.StartDate;
            stages[phaseIndex].End = phase.EndDate;
        }

        // 以 (QuestionTypeId, Granularity, Level) 三元組比對回填目標題數
        foreach (var target in project.Targets)
        {
            var qt = questionTypes.FirstOrDefault(q =>
                q.QuestionTypeId == target.QuestionTypeId &&
                q.Granularity == target.Granularity &&
                q.Level == target.Level);
            if (qt is not null)
            {
                qt.Count = target.TargetCount;
            }
        }

        var memberAllocations = project.MemberAllocations.ToDictionary(allocation => allocation.UserId);

        foreach (var person in talentPool)
        {
            if (memberAllocations.TryGetValue(person.UserId, out var allocation))
            {
                person.IsSelected = true;
                person.SelectedRoleIds = allocation.RoleIds.Where(id => id > 0).Distinct().ToList();
                person.CreatedQuestionCount = allocation.CreatedQuestionCount;
            }
            else
            {
                person.IsSelected = false;
                person.SelectedRoleIds.Clear();
                person.CreatedQuestionCount = 0;
            }
        }

        RebuildAllocationTeachers();

        var propositionRoleId = GetPropositionTeacherRoleId();
        foreach (var allocation in project.MemberAllocations.Where(a => propositionRoleId.HasValue && a.RoleIds.Contains(propositionRoleId.Value)))
        {
            var teacher = allocationTeachers.FirstOrDefault(item => item.UserId == allocation.UserId);
            if (teacher is null)
            {
                continue;
            }

            Array.Fill(teacher.Quotas, 0);
            // 以 (QuestionTypeId, Granularity, Level) 三元組找到 questionTypes 的索引，再填 Quotas[index]
            foreach (var quota in allocation.Quotas)
            {
                var qtIndex = questionTypes.FindIndex(q =>
                    q.QuestionTypeId == quota.QuestionTypeId &&
                    q.Granularity == quota.Granularity &&
                    q.Level == quota.Level);
                if (qtIndex >= 0 && qtIndex < teacher.Quotas.Length)
                {
                    teacher.Quotas[qtIndex] = quota.QuotaCount;
                }
            }
        }
    }

    private async Task<int?> GetCurrentUserIdAsync()
    {
        var authState = await AuthState;
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userIdStr, out var userId) && userId > 0)
        {
            return userId;
        }

        await ShowAlertAsync("error", "登入狀態已失效", "請重新登入後再操作。");
        return null;
    }

    private Task ShowAlertAsync(string icon, string title, string text)
    {
        return JS.InvokeVoidAsync("swalInterop.fire", new
        {
            icon,
            title,
            text,
            confirmButtonColor = "#6B8EAD"
        }).AsTask();
    }

