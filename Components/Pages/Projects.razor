                                        <i class="fa-solid fa-check text-[9px]"></i>
                                    }
                                    else if (!isExact && target > 0)
                                    {
                                        <i class="fa-solid fa-xmark text-[9px]"></i>
                                    }
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </EditForm>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="() => showProjectModal = false"
