    /// <summary>依狀態碼取得對應 Badge 文字與樣式</summary>
    private static (string Text, string CssClass) GetStatusBadge(byte status) => status switch
    {
        0 => ("準備中", "text-[10px] font-bold px-2 py-0.5 rounded bg-amber-100 text-amber-700 whitespace-nowrap"),
        1 => ("進行中", "text-[10px] font-bold px-2 py-0.5 rounded bg-blue-100 text-blue-700 whitespace-nowrap"),
        2 => ("已結案", "text-[10px] font-bold px-2 py-0.5 rounded bg-gray-200 text-gray-600 whitespace-nowrap"),
        _ => ("未知",   "text-[10px] font-bold px-2 py-0.5 rounded bg-gray-100 text-gray-400 whitespace-nowrap")
    };

    private void ResetForm()
    {
        formModel = new();
        personSearchKeyword = "";
        foreach (var qt in questionTypes) qt.Count = null;
        foreach (var p in talentPool) { p.IsSelected = false; p.SelectedRole = ""; }
        allocationTeachers.Clear();
        InitStages();
    }

    /// <summary>初始化 8 階段時程（空白日期）</summary>
    private void InitStages()
    {
        stages =
        [
            new() { Name = "產學計畫區間", Hint = "［預設約100天］" },
            new() { Name = "命題階段",     Hint = "［預設30天］［倒數5天提醒］" },
            new() { Name = "交互審題",     Hint = "［命題階段後7天］" },
            new() { Name = "互審修題",     Hint = "［交互審題後7天］［倒數5天提醒］" },
            new() { Name = "專家審題",     Hint = "［互審修題後14天］" },
            new() { Name = "專審修題",     Hint = "［專家審題後14天］［倒數5天提醒］" },
            new() { Name = "總召審題",     Hint = "［專審修題後14天］" },
            new() { Name = "總召修題",     Hint = "［總召審題後14天］［倒數5天提醒］" },
        ];
    }

    // 預設各階段天數
    private static readonly int[] DefaultDays = [100, 30, 7, 7, 14, 14, 14, 14];

    // ──── 時程連動引擎 ────

    /// <summary>第一階段開始日變更時，自動推算後續所有階段</summary>
    private void OnStageStartChanged(int idx, ChangeEventArgs e)
    {
        if (!DateTimeOffset.TryParse(e.Value?.ToString(), out var dt)) return;
        var date = dt.Date;
        stages[idx].Start = date;

        if (idx == 0)
        {
            // 自動帶入所屬年度（民國年 = 西元年 - 1911）
            formModel.Year = (date.Year - 1911).ToString();

            // 產學計畫區間的結束日自動設為所有階段結束後
            var cursor = date.AddDays(14); // 命題階段在產學開始後 14 天
            for (int i = 1; i < stages.Length; i++)
            {
                stages[i].Start = cursor;
                stages[i].End = cursor.AddDays(DefaultDays[i]);
                cursor = stages[i].End!.Value.AddDays(1);
            }
            // 產學計畫結束日 = 最後一個階段的結束日
            stages[0].End = stages[^1].End;
        }
    }

    /// <summary>結束日變更 → 下一階段的開始日自動推進為隔天</summary>
    private void OnStageEndChanged(int idx, ChangeEventArgs e)
    {
        if (!DateTimeOffset.TryParse(e.Value?.ToString(), out var dt)) return;
        stages[idx].End = dt.Date;

        if (idx + 1 < stages.Length)
        {
            stages[idx + 1].Start = dt.Date.AddDays(1);
        }
    }

    // ──── 人員指派 ────

    /// <summary>依搜尋關鍵字過濾人員列表</summary>
    private List<PersonItem> GetFilteredPersons()
    {
        if (string.IsNullOrWhiteSpace(personSearchKeyword)) return talentPool;
        var kw = personSearchKeyword.Trim().ToLower();
        return talentPool.Where(p => p.Name.ToLower().Contains(kw) || p.Identifier.ToLower().Contains(kw)).ToList();
    }

    /// <summary>勾選/取消勾選人員 → 同步更新配額表</summary>
    private void TogglePersonSelection(PersonItem person)
    {
        person.IsSelected = !person.IsSelected;

        if (!person.IsSelected)
        {
            person.SelectedRole = "";
        }

        RebuildAllocationTeachers();
    }

    /// <summary>重建「命題教師」配額列表（保留已填入的配額數值）</summary>
    private void RebuildAllocationTeachers()
    {
        var newList = new List<AllocationItem>();

        foreach (var p in talentPool.Where(p => p.IsSelected && p.SelectedRole == "命題教師"))
        {
            var existing = allocationTeachers.FirstOrDefault(a => a.UserId == p.UserId);
            if (existing != null)
            {
                newList.Add(existing); // 保留舊配額
            }
            else
            {
                newList.Add(new AllocationItem
                {
                    Id = p.Id,
                    UserId = p.UserId,
                    Name = p.Name,
                    Identifier = p.Identifier,
                    Quotas = new int[questionTypes.Count]
                });
            }
        }

        allocationTeachers = newList;
    }

    // ──── 配額引擎 ────

    /// <summary>配額數值變更</summary>
    private void OnQuotaChanged(int teacherIdx, int qtIdx, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            allocationTeachers[teacherIdx].Quotas[qtIdx] = Math.Max(0, val);
        else
            allocationTeachers[teacherIdx].Quotas[qtIdx] = 0;
    }

    /// <summary>平均分配配額給所有命題教師</summary>
    private void HandleAutoDistribute()
    {
        // 重建確保名單最新
        RebuildAllocationTeachers();

        if (allocationTeachers.Count == 0) return;

        var count = allocationTeachers.Count;

        for (int q = 0; q < questionTypes.Count; q++)
        {
            var target = questionTypes[q].Count ?? 0;
            var baseQuota = target / count;
            var remainder = target % count;

            for (int t = 0; t < count; t++)
            {
                allocationTeachers[t].Quotas[q] = baseQuota + (t < remainder ? 1 : 0);
            }
        }
    }

    /// <summary>計算某題型的已分配總和</summary>
    private int GetAllocatedSum(int qtIdx)
    {
        return allocationTeachers.Sum(t => t.Quotas[qtIdx]);
    }

    /// <summary>驗證訊息</summary>
    private MarkupString GetValidationMessage()
    {
        if (allocationTeachers.Count == 0)
            return new("<span class=\"text-gray-400\">尚未分配</span>");

        for (int i = 0; i < questionTypes.Count; i++)
        {
            var target = questionTypes[i].Count ?? 0;
            if (target > 0 && GetAllocatedSum(i) != target)
                return new("<span class=\"text-terracotta bg-terracotta/10 px-2 py-0.5 rounded font-bold\"><i class=\"fa-solid fa-triangle-exclamation\"></i> 檢查未通過，數量不符</span>");
        }

        return new("<span class=\"text-sage bg-sage/10 px-2 py-0.5 rounded font-bold\"><i class=\"fa-solid fa-circle-check\"></i> 數量驗證正確</span>");
    }

    // ──── Modal 控制 ────

    private void OpenNewProjectModal()
    {
        ResetForm();
        showProjectModal = true;
    }

