    /// <summary>依搜尋關鍵字過濾人員列表</summary>
    private List<PersonItem> GetFilteredPersons()
    {
        if (string.IsNullOrWhiteSpace(personSearchKeyword)) return talentPool;
        var kw = personSearchKeyword.Trim().ToLower();
        return talentPool.Where(p => p.Name.ToLower().Contains(kw) || p.Identifier.ToLower().Contains(kw)).ToList();
    }

    /// <summary>勾選/取消勾選人員 → 同步更新配額表</summary>
    private async Task TogglePersonSelection(PersonItem person)
    {
        // 防呆：編輯模式下，已有命題紀錄者禁止取消勾選
        if (isEditMode && person.IsSelected && person.CreatedQuestionCount > 0)
        {
            person.CheckboxKey++; // 強制重建 checkbox，將 UI 顯示還原為勾選狀態
            StateHasChanged();    // 立即重新渲染，讓 checkbox 在警示彈出前先還原
            await ShowAlertAsync(
                "warning",
                "無法移除指派人員",
                $"「{person.Name}」老師在此專案已產出 {person.CreatedQuestionCount} 題，無法移除。如需調整，請聯繫該名教師處理或於梯次結案後再行調整。");
            return;
        }

        person.IsSelected = !person.IsSelected;

        if (!person.IsSelected)
        {
            person.SelectedRoleIds.Clear();
        }

        RebuildAllocationTeachers();
    }

    /// <summary>取得人員身份下拉的渲染清單：至少一筆（即使為 0）</summary>
    private static List<int> GetRoleSlots(PersonItem person)
    {
        return person.SelectedRoleIds.Count == 0 ? new List<int> { 0 } : person.SelectedRoleIds;
    }

    /// <summary>下拉變更時更新對應 slot 的 RoleId</summary>
    private async Task OnRoleSlotChanged(PersonItem person, int index, ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var newRoleId)) newRoleId = 0;

        // 模擬：先計算「若套用」後的最終 SelectedRoleIds，再決定是否核准
        var simulated = new List<int>(person.SelectedRoleIds);
        while (simulated.Count <= index)
        {
            simulated.Add(0);
        }
        simulated[index] = newRoleId;
        while (simulated.Count > 1 && simulated[^1] == 0)
        {
            simulated.RemoveAt(simulated.Count - 1);
        }

        // 防呆：編輯模式下，已有命題紀錄者不可移除「命題教師」身份
        if (await BlockIfRemovingPropositionRoleAsync(person, simulated))
        {
            return;
        }

        person.SelectedRoleIds = simulated;
        RebuildAllocationTeachers();
    }

    /// <summary>新增一個附加身份空 slot</summary>
    private void AddRoleSlot(PersonItem person)
    {
        if (!person.IsSelected) return;
        if (person.SelectedRoleIds.Count == 0) person.SelectedRoleIds.Add(0);
        if (person.SelectedRoleIds.Count >= projectRoles.Count) return;

        person.SelectedRoleIds.Add(0);
    }

    /// <summary>移除指定索引的身份</summary>
    private async Task RemoveRoleSlot(PersonItem person, int index)
    {
        if (index < 0 || index >= person.SelectedRoleIds.Count) return;

        // 模擬移除後的清單，供防呆檢查
        var simulated = new List<int>(person.SelectedRoleIds);
        simulated.RemoveAt(index);

        if (await BlockIfRemovingPropositionRoleAsync(person, simulated))
        {
            return;
        }

        person.SelectedRoleIds.RemoveAt(index);
        RebuildAllocationTeachers();
    }

    /// <summary>編輯模式下，若該人員已有命題紀錄但變更後將失去「命題教師」身份，則阻擋並彈警示。</summary>
    private async Task<bool> BlockIfRemovingPropositionRoleAsync(PersonItem person, List<int> simulatedRoleIds)
    {
        if (!isEditMode || person.CreatedQuestionCount <= 0) return false;

        var propositionRoleId = GetPropositionTeacherRoleId();
        if (!propositionRoleId.HasValue) return false;

        // 原本就沒有命題教師 → 不需保護
        if (!person.SelectedRoleIds.Contains(propositionRoleId.Value)) return false;

        // 變更後仍包含命題教師 → 放行
        if (simulatedRoleIds.Contains(propositionRoleId.Value)) return false;

        person.RoleSlotKey++; // 強制重建 select 還原顯示值
        StateHasChanged();
        await ShowAlertAsync(
            "warning",
            "無法變更身份",
            $"「{person.Name}」老師在此專案已產出 {person.CreatedQuestionCount} 題，無法移除「命題教師」身份。如需調整，請聯繫該名教師處理或於梯次結案後再行調整。");
        return true;
    }

    /// <summary>重建「命題教師」配額列表（保留已填入的配額數值）</summary>
    private void RebuildAllocationTeachers()
    {
        var newList = new List<AllocationItem>();

        var propositionRoleId = GetPropositionTeacherRoleId();
        foreach (var p in talentPool.Where(p => p.IsSelected && propositionRoleId.HasValue && p.SelectedRoleIds.Contains(propositionRoleId.Value)))
        {
            var existing = allocationTeachers.FirstOrDefault(a => a.UserId == p.UserId);
            if (existing != null)
            {
                newList.Add(existing); // 保留舊配額
            }
            else
            {
                newList.Add(new AllocationItem
                {
                    Id = p.Id,
                    UserId = p.UserId,
                    Name = p.Name,
                    Identifier = p.Identifier,
                    Quotas = new int[questionTypes.Count]
                });
            }
        }

        allocationTeachers = newList;
    }

    // ──── 配額引擎 ────

    /// <summary>配額數值變更</summary>
    private void OnQuotaChanged(int teacherIdx, int qtIdx, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
            allocationTeachers[teacherIdx].Quotas[qtIdx] = Math.Max(0, val);
        else
            allocationTeachers[teacherIdx].Quotas[qtIdx] = 0;
    }

    /// <summary>平均分配配額給所有命題教師</summary>
    private void HandleAutoDistribute()
    {
        // 重建確保名單最新
        RebuildAllocationTeachers();

        if (allocationTeachers.Count == 0) return;

        var count = allocationTeachers.Count;

        for (int q = 0; q < questionTypes.Count; q++)
        {
            var target = questionTypes[q].Count ?? 0;
            var baseQuota = target / count;
            var remainder = target % count;

            for (int t = 0; t < count; t++)
            {
                allocationTeachers[t].Quotas[q] = baseQuota + (t < remainder ? 1 : 0);
            }
        }
    }

    /// <summary>計算某題型的已分配總和</summary>
    private int GetAllocatedSum(int qtIdx)
    {
        return allocationTeachers.Sum(t => t.Quotas[qtIdx]);
    }

    /// <summary>驗證訊息</summary>
    private MarkupString GetValidationMessage()
    {
        if (allocationTeachers.Count == 0)
            return new("<span class=\"text-gray-400\">尚未分配</span>");

        for (int i = 0; i < questionTypes.Count; i++)
        {
            var target = questionTypes[i].Count ?? 0;
            if (target > 0 && GetAllocatedSum(i) != target)
                return new("<span class=\"text-terracotta bg-terracotta/10 px-2 py-0.5 rounded font-bold\"><i class=\"fa-solid fa-triangle-exclamation\"></i> 檢查未通過，數量不符</span>");
        }

        return new("<span class=\"text-sage bg-sage/10 px-2 py-0.5 rounded font-bold\"><i class=\"fa-solid fa-circle-check\"></i> 數量驗證正確</span>");
    }

