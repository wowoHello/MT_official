                </div>

                <!-- 分配狀態檢核 -->
                <div class="bg-gray-50 rounded border border-gray-200 p-3 mt-4">
                    <div class="text-[11px] font-bold text-gray-500 mb-2 flex items-center justify-between">
                        <span>分配狀態檢核：(已分配 / 需分配)</span>
                        <span>@GetValidationMessage()</span>
                    </div>
                    <div class="grid grid-cols-4 sm:grid-cols-7 gap-1">
                        @for (int i = 0; i < questionTypes.Count; i++)
                        {
                            var qt = questionTypes[i];
                            var target = qt.Count ?? 0;
                            var allocated = GetAllocatedSum(i);
                            var isExact = allocated == target;
                            var bgColor = isExact
                                ? (target > 0 ? "bg-sage/10 border-sage/30" : "bg-gray-100 border-gray-200")
                                : "bg-terracotta/10 border-terracotta/50";
                            var textColor = isExact
                                ? (target > 0 ? "text-sage" : "text-gray-400")
