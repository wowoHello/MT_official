                                            class="w-4 h-4 text-morandi rounded border-gray-300 focus:ring-morandi mt-0.5 cursor-pointer" />
                                        <div class="flex flex-col w-20">
                                            <span class="text-sm font-bold text-gray-700">@person.Name</span>
                                            <span class="text-[10px] text-gray-500">@person.Identifier</span>
                                        </div>
                                    </label>
                                    <div class="flex-grow">
                                        <select @bind="person.SelectedRole" disabled="@(!person.IsSelected)"
