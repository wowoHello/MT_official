@* ====================================================================== *@
@*  Login — 登入頁面                                                       *@
@*  路由：/ | 使用 LoginLayout（無 Navbar）                                *@
@*  功能：帳號密碼登入、圖形驗證碼、記住帳號、忘記密碼 Modal + 寄信重設     *@
@* ====================================================================== *@
@page "/login"
@attribute [AllowAnonymous]
@layout LoginLayout
@inject NavigationManager Navigation
@inject ICaptchaService CaptchaService
@inject ProtectedLocalStorage LocalStorage
@inject IWebHostEnvironment Env
@inject IAuthService AuthService

<PageTitle>CWT 命題工作平臺 - 登入</PageTitle>

<div class="h-screen flex items-center justify-center relative overflow-hidden bg-[var(--color-oatmeal)]">

    <!-- Background Decoration / Illustration Area -->
    <div class="absolute inset-0 z-0 flex md:flex-row flex-col">
        <!-- Left Side Image -->
        <div class="hidden md:block w-3/5 h-full relative">
            <img src="img/login-bg.png" alt="Knowledge Background"
                class="w-full h-full object-cover opacity-90">
            <!-- Overlay Gradient -->
            <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[var(--color-oatmeal)]"></div>
        </div>
        <!-- Right Side Space -->
        <div class="w-full md:w-2/5 h-full bg-[var(--color-oatmeal)]"></div>
    </div>

    <!-- Main Content Container -->
    <div class="container mx-auto px-4 py-4 z-10 flex md:justify-end justify-center items-center h-full overflow-y-auto">
        <!-- Login Card -->
        <div class="glass-card w-full max-w-md p-6 sm:py-6 sm:px-8 rounded-2xl shadow-xl md:mr-[10%] xl:mr-[15%]">

            <!-- Logo & Title -->
            <div class="text-center mb-4">
                <div class="w-12 h-12 bg-[var(--color-morandi)]/10 rounded-full flex items-center justify-center mx-auto mb-2">
                    <img src="img/pencil.png" alt="CWT Logo" class="w-8 h-8 object-contain">
                </div>
                <h1 tabindex="-1" class="text-xl font-bold text-slate-main mb-1 focus:outline-none">
                  CWT 命題工作平臺
                </h1>
                <p class="text-sm text-gray-500">歡迎回來，請登入您的帳號</p>
            </div>

            <!-- Dev Mode Indicator -->
            @if (IsDev)
            {
                <div class="mb-4 p-2.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-lg text-xs flex items-center gap-2">
                    <i class="fa-solid fa-flask"></i>
                    <span><strong>開發模式</strong>：帳密與驗證碼已自動填入，直接按登入即可。</span>
                </div>
            }

            <!-- Error Alert -->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mb-3 p-2 bg-red-50 text-[var(--color-terracotta)] border border-red-200 rounded-lg text-sm flex items-center gap-2">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@errorMessage</span>
                </div>
            }

            <!-- Login Form -->
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm" class="space-y-3">
                <!-- Account -->
                <div>
                    <label for="username" class="block text-sm font-medium mb-1">帳號</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-regular fa-user"></i>
                        </span>
                        <InputText id="username" @bind-Value="loginModel.Username" disabled="@isLoading"
                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all"
                            placeholder="請輸入帳號" />
                    </div>
                </div>

                <!-- Password -->
                <div>
                    <label for="password" class="block text-sm font-medium mb-1">密碼</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <InputText type="@(showPassword ? "text" : "password")" id="password" @bind-Value="loginModel.Password" disabled="@isLoading"
                            class="w-full pl-10 pr-10 py-2.5 rounded-lg border border-gray-300 bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all"
                            placeholder="請輸入密碼" />
                        <button type="button" @onclick="TogglePasswordVisibility"
                            class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-600 focus:outline-none cursor-pointer">
                            <i class="fa-regular @(showPassword ? "fa-eye" : "fa-eye-slash")"></i>
                        </button>
                    </div>
                    <!-- Remember Me & Forgot Password -->
                    <div class="flex items-center justify-between mt-2">
                        <label class="flex items-center gap-2 cursor-pointer group">
                            <div class="relative flex items-center justify-center">
                                <InputCheckbox @bind-Value="loginModel.RememberMe" class="peer sr-only" />
                                <div class="w-4 h-4 border border-gray-300 rounded flex items-center justify-center transition-colors peer-checked:bg-[var(--color-morandi)] peer-checked:border-[var(--color-morandi)] group-hover:border-[var(--color-morandi)]">
                                    <i class="fa-solid fa-check text-white text-[10px] opacity-0 peer-checked:opacity-100 transition-opacity"></i>
                                </div>
                            </div>
                            <span class="text-sm text-gray-600 group-hover:text-gray-800 transition-colors">記住登入狀態 (90天)</span>
                        </label>
                        <button type="button" @onclick="OpenForgotPwdModal"
                            class="text-sm text-[var(--color-morandi)] hover:text-blue-700 hover:underline transition-colors focus:outline-none cursor-pointer">忘記密碼？</button>
                    </div>
                </div>

                <!-- Captcha -->
                <div>
                    <label for="captcha" class="block text-sm font-medium mb-1">驗證碼</label>
                    <div class="flex gap-3">
                        <InputText id="captcha" @bind-Value="loginModel.CaptchaInput" disabled="@isLoading"
                            class="w-1/2 px-4 py-2.5 rounded-lg border border-gray-300 bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent transition-all uppercase"
                            placeholder="輸入圖形碼" autocomplete="off" />
                        <div class="w-1/2 flex items-center gap-2">
                            <img src="@captchaImage" @onclick="RefreshCaptcha"
                                class="rounded border border-gray-200 cursor-pointer bg-white h-[42px] w-[140px]" title="點擊重新產生" />
                            <button type="button" @onclick="RefreshCaptcha"
                                class="text-gray-400 hover:text-[var(--color-morandi)] focus:outline-none p-2 rounded-full hover:bg-gray-100 transition-colors cursor-pointer"
                                title="重新產生">
                                <i class="fa-solid fa-rotate-right"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Security Notice -->
                <div class="bg-blue-50/70 border border-blue-100 rounded-lg p-2.5 text-xs text-blue-800 flex items-start gap-2">
                    <i class="fa-solid fa-shield-halved mt-0.5 text-[var(--color-morandi)]"></i>
                    <div>
                        <strong class="block mb-0.5 text-[var(--color-morandi)]">資安提示</strong>
                        <ul class="list-disc pl-4 space-y-0.5 opacity-80">
                            <li>請勿將帳號密碼交給他人使用。</li>
                            <li>登入後若需離開座位，請確實登出系統。</li>
                            <li>建議定期更換密碼以確保帳號安全。</li>
                        </ul>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" disabled="@isLoading"
                    class="w-full py-3 bg-[var(--color-morandi)] hover:bg-[#5b7a95] text-white rounded-lg font-medium transition-all shadow-md flex justify-center items-center gap-2 mt-2 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[var(--color-morandi)] disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer">
                    <span>@(isLoading ? "登入中..." : "登入系統")</span>
                    @if (isLoading)
                    {
                        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    }
                    else
                    {
                        <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    }
                </button>
            </EditForm>

            <div class="mt-4 text-center text-xs text-gray-400">
                &copy; @DateTime.Now.Year 全民中文檢定 CWT. All rights reserved.
            </div>
        </div>
    </div>

    <!-- Forgot Password Modal -->
    @if (showForgotPwdModal)
    {
        <div class="fixed inset-0 z-[100] flex items-center justify-center">
            <!-- Backdrop -->
            <div class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity" @onclick="CloseForgotPwdModal"></div>
            <!-- Modal Content -->
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 relative z-10 transform transition-all duration-300"
                style="animation: modalIn 0.3s ease-out;">
                <div class="p-6 border-b border-gray-100 flex justify-between items-center">
                    <h2 class="text-lg font-bold text-[var(--color-slate-main)] flex items-center gap-2">
                        <i class="fa-solid fa-key text-[var(--color-morandi)]"></i> 忘記密碼 / 重設密碼
                    </h2>
                    <button type="button" @onclick="CloseForgotPwdModal"
                        class="text-gray-400 hover:text-gray-600 focus:outline-none w-8 h-8 rounded-full hover:bg-gray-100 flex items-center justify-center transition-colors cursor-pointer">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <div class="p-6">
                    <!-- Request Reset Link -->
                    <p class="text-sm text-gray-600 mb-4">請輸入您註冊的電子信箱，我們將發送密碼重設連結給您。</p>
                    <div class="mb-4 relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-regular fa-envelope"></i>
                        </span>
                        <input type="email" @bind="resetEmail"
                            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-transparent"
                            placeholder="example@school.edu.tw">
                    </div>
                    <button type="button" @onclick="SendResetLink" disabled="@isSendingReset"
                        class="w-full py-2.5 bg-[var(--color-sage)] hover:bg-[#7b9c81] text-white rounded-lg font-medium transition-all shadow-sm flex justify-center items-center gap-2 focus:outline-none disabled:opacity-60 cursor-pointer">
                        @if (isSendingReset)
                        {
                            <i class="fa-solid fa-spinner fa-spin"></i>
                            <span>驗證發送中...</span>
                        }
                        else
                        {
                            <span>發送重設連結</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

</div>
@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    // --- 表單模型 ---
    private LoginFormModel loginModel = new();

    // --- UI 控制 ---
    private string errorMessage = "";
    private bool isLoading = false;
    private bool showPassword = false;

    // --- 驗證碼 ---
    private string generatedCaptcha = "";
    private string captchaImage = "";

    // --- 忘記密碼 Modal ---
    private bool showForgotPwdModal = false;
    private string resetEmail = "";
    private bool isSendingReset = false;

    private bool IsDev => Env.IsDevelopment();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/");
            return;
        }

        GenerateNewCaptcha();

        if (IsDev)
        {
            loginModel.Username = "jay";
            loginModel.Password = "01024304";
            loginModel.CaptchaInput = generatedCaptcha;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var result = await LocalStorage.GetAsync<string>("cwt_remembered_account");
                if (result.Success && !string.IsNullOrEmpty(result.Value))
                {
                    loginModel.Username = result.Value;
                    loginModel.RememberMe = true;
                    StateHasChanged();
                }
            }
            catch
            {
                // 忽略 Pre-rendering 期間的錯誤
            }
        }
    }

    private void TogglePasswordVisibility() => showPassword = !showPassword;

    private void GenerateNewCaptcha()
    {
        var result = CaptchaService.GenerateCaptcha();
        generatedCaptcha = result.Text;
        captchaImage = result.ImageBase64;
    }

    private void RefreshCaptcha()
    {
        GenerateNewCaptcha();
        loginModel.CaptchaInput = IsDev ? generatedCaptcha : "";
    }

    /// <summary>處理登入流程（正式 DB 驗證）</summary>
    private async Task HandleLogin()
    {
        errorMessage = "";

        // 基本驗證
        if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
        {
            errorMessage = "請輸入完整的帳號密碼。";
            return;
        }

        // 驗證碼比對
        if (!string.Equals(loginModel.CaptchaInput?.Trim(), generatedCaptcha, StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "驗證碼錯誤，請重新輸入。";
            loginModel.CaptchaInput = "";
            GenerateNewCaptcha();
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            // 呼叫 AuthService 驗證帳密（DI 注入，伺服器端直接查 DB）
            var (success, message, user) = await AuthService.ValidateLoginAsync(
                loginModel.Username.Trim(), loginModel.Password);

            if (!success || user is null)
            {
                errorMessage = message;
                loginModel.CaptchaInput = "";
                GenerateNewCaptcha();
                isLoading = false;

                // 記錄失敗日誌
                await AuthService.LogLoginAttemptAsync(null, loginModel.Username, false, message, null, null);
                return;
            }

            // 登入成功 — 記錄日誌 + 更新最後登入時間
            await AuthService.LogLoginAttemptAsync(user.Id, user.Username, true, null, null, null);
            await AuthService.UpdateLastLoginAsync(user.Id);

            // 處理「記住帳號」
            if (loginModel.RememberMe)
                await LocalStorage.SetAsync("cwt_remembered_account", loginModel.Username);
            else
                await LocalStorage.DeleteAsync("cwt_remembered_account");

            // 暫存登入資料，取得一次性 key，導航至 HTTP 端點完成 Cookie 寫入
            var loginKey = AuthService.PrepareSignIn(user, loginModel.RememberMe);
            Navigation.NavigateTo($"/auth/login?key={loginKey}", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = IsDev
                ? $"[DEV] {ex.GetType().Name}: {ex.Message}"
                : "系統登入發生例外錯誤，請稍後再試。";
            isLoading = false;
        }
    }

    // --- 忘記密碼相關方法 ---

    private void OpenForgotPwdModal()
    {
        resetEmail = "";
        showForgotPwdModal = true;
    }

    private void CloseForgotPwdModal()
    {
        showForgotPwdModal = false;
    }

    /// <summary>發送重設連結 (TODO: 待 EmailService 建構完成後啟用)</summary>
    private async Task SendResetLink()
    {
        if (string.IsNullOrWhiteSpace(resetEmail))
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "error",
                title = "錯誤",
                text = "請輸入電子信箱",
                confirmButtonColor = "#6B8EAD"
            });
            return;
        }

        isSendingReset = true;
        StateHasChanged();

        try
        {
            await Task.Delay(800);
            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "info",
                title = "功能尚未啟用",
                text = "寄信功能尚在建置中，待所有頁面完成後將正式啟用。",
                confirmButtonColor = "#6B8EAD"
            });
        }
        finally
        {
            isSendingReset = false;
            StateHasChanged();
        }
    }

    // --- 表單模型類別 ---
    private sealed class LoginFormModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string CaptchaInput { get; set; } = "";
        public bool RememberMe { get; set; } = false;
    }
}
