@* ====================================================================== *@
@*  Login — 登入頁面                                                       *@
@*  路由：/ | 使用 LoginLayout（無 Navbar）                                *@
@*  功能：帳號密碼登入、圖形驗證碼、記住登入狀態、忘記密碼 Modal + 寄信重設 *@
@* ====================================================================== *@
@page "/login"
@attribute [AllowAnonymous]
@layout LoginLayout
@inject NavigationManager Navigation
@inject ICaptchaService CaptchaService
@inject IWebHostEnvironment Env
@inject IAuthService AuthService
@inject IPasswordResetService ResetService

<PageTitle>CWT 命題工作平臺</PageTitle>

<div class="h-screen flex items-center justify-center relative overflow-hidden bg-[var(--color-oatmeal)]">

    <!-- Background Decoration / Illustration Area -->
    <div class="absolute inset-0 z-0 flex md:flex-row flex-col">
        <!-- Left Side Image -->
        <div class="hidden md:block w-3/5 h-full relative">
            <img src="img/login-bg.png" alt="Knowledge Background"
                class="w-full h-full object-cover opacity-90">
            <!-- Overlay Gradient -->
            <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[var(--color-oatmeal)]"></div>
        </div>
        <!-- Right Side Space -->
        <div class="w-full md:w-2/5 h-full bg-[var(--color-oatmeal)]"></div>
    </div>

    <!-- Main Content Container -->
    <div class="container mx-auto px-4 py-4 z-10 flex md:justify-end justify-center items-center h-full overflow-y-auto">
        <!-- Login Card -->
        <div class="glass-card w-full max-w-md p-6 sm:py-6 sm:px-8 rounded-2xl shadow-xl md:mr-[10%] xl:mr-[15%]">

            <!-- Logo & Title -->
            <div class="text-center mb-4">
                <div class="w-12 h-12 bg-[var(--color-morandi)]/10 rounded-full flex items-center justify-center mx-auto mb-2">
                    <img src="img/pencil.png" alt="CWT Logo" class="w-8 h-8 object-contain">
                </div>
                <h1 tabindex="-1" class="text-xl font-bold text-slate-main mb-1 focus:outline-none">
                  CWT 命題工作平臺
                </h1>
                <p class="text-sm text-gray-500">歡迎回來，請登入您的帳號</p>
            </div>

            <!-- Dev Mode Indicator -->
            @if (IsDev)
            {
                <div class="mb-4 p-2.5 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-lg text-xs flex items-center gap-2">
                    <i class="fa-solid fa-flask"></i>
                    <span><strong>開發模式</strong>：帳密與驗證碼已自動填入，直接按登入即可。</span>
                </div>
            }

            <!-- Error Alert -->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mb-3 p-2 bg-red-50 text-[var(--color-terracotta)] border border-red-200 rounded-lg text-sm flex items-center gap-2">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@errorMessage</span>
                </div>
            }

            <!-- Login Form -->
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm" class="space-y-3">
                <!-- Account or Email -->
                <div>
                    <label for="username" class="block text-sm font-medium mb-1">帳號或信箱</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-regular fa-user"></i>
                        </span>
                        <InputText id="username" @bind-Value="loginModel.Username" disabled="@isLoading"
                            @bind-Value:after="() => ClearFieldError(nameof(loginModel.Username))"
                            class="@BuildLoginInputClass(nameof(loginModel.Username), true)"
                            placeholder="請輸入帳號或信箱" />
                    </div>
                </div>

                <!-- Password -->
                <div>
                    <label for="password" class="block text-sm font-medium mb-1">密碼</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                            <i class="fa-solid fa-lock"></i>
                        </span>
                        <InputText type="@(showPassword ? "text" : "password")" id="password" @bind-Value="loginModel.Password" disabled="@isLoading"
                            @bind-Value:after="() => ClearFieldError(nameof(loginModel.Password))"
                            class="@BuildLoginInputClass(nameof(loginModel.Password), true, "pr-10")"
                            placeholder="請輸入密碼" />
                        <button type="button" @onclick="TogglePasswordVisibility"
                            aria-label="切換密碼顯示"
                            class="absolute inset-y-0 right-2 my-1.5 px-2 flex items-center text-gray-400 hover:text-gray-600 rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-morandi)] focus-visible:bg-[var(--color-morandi)]/5 transition-colors cursor-pointer">
                            <i class="fa-regular @(showPassword ? "fa-eye" : "fa-eye-slash")"></i>
                        </button>
                    </div>
                    <!-- Remember Me & Forgot Password -->
                    <div class="flex items-center justify-between mt-2">
                        <label class="flex items-center gap-2 cursor-pointer group rounded-md px-1 py-0.5 has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-[var(--color-morandi)] has-[:focus-visible]:ring-offset-2 transition-shadow">
                            <div class="relative flex items-center justify-center">
                                <InputCheckbox @bind-Value="loginModel.RememberMe" class="peer sr-only" />
                                <div class="w-4 h-4 border border-gray-300 rounded flex items-center justify-center transition-colors peer-checked:bg-[var(--color-morandi)] peer-checked:border-[var(--color-morandi)] group-hover:border-[var(--color-morandi)] peer-focus-visible:border-[var(--color-morandi)]">
                                    <i class="fa-solid fa-check text-white text-xs opacity-0 peer-checked:opacity-100 transition-opacity"></i>
                                </div>
                            </div>
                            <span class="text-sm text-gray-600 group-hover:text-gray-800 transition-colors">記住登入狀態</span>
                        </label>
                        <button type="button" @onclick="OpenForgotPwdModal"
                            class="text-sm text-[var(--color-morandi)] hover:text-blue-700 hover:underline transition-all rounded-md px-1.5 py-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-morandi)] focus-visible:ring-offset-2 focus-visible:bg-[var(--color-morandi)]/5 cursor-pointer">忘記密碼？</button>
                    </div>
                </div>

                <!-- Captcha -->
                <div>
                    <label for="captcha" class="block text-sm font-medium mb-1">驗證碼</label>
                    <div class="flex gap-3">
                        <InputText id="captcha" @bind-Value="loginModel.CaptchaInput" disabled="@isLoading"
                            @bind-Value:after="() => ClearFieldError(nameof(loginModel.CaptchaInput))"
                            class="@BuildLoginInputClass(nameof(loginModel.CaptchaInput), false, "uppercase", false)"
                            placeholder="輸入圖形碼" autocomplete="off" />
                        <div class="w-1/2 flex items-center">
                            <img src="@captchaImage" @onclick="RefreshCaptcha"
                                class="rounded border border-gray-200 cursor-pointer bg-white h-[42px] w-[140px]" title="點擊重新產生" />
                        </div>
                    </div>
                </div>

                <!-- Security Notice -->
                <div class="bg-blue-50/70 border border-blue-100 rounded-lg p-2.5 text-xs text-blue-800 flex items-start gap-2">
                    <i class="fa-solid fa-shield-halved mt-0.5 text-[var(--color-morandi)]"></i>
                    <div>
                        <strong class="block mb-0.5 text-[var(--color-morandi)]">資安提示</strong>
                        <ul class="list-disc pl-4 space-y-0.5 opacity-80">
                            <li>請勿將帳號密碼交給他人使用。</li>
                            <li>登入後若需離開座位，請確實登出系統。</li>
                            <li>建議定期更換密碼以確保帳號安全。</li>
                        </ul>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" disabled="@isLoading"
                    class="w-full py-3 bg-[var(--color-morandi)] hover:bg-[#5b7a95] text-white rounded-lg font-medium transition-all shadow-md flex justify-center items-center gap-2 mt-2 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[var(--color-morandi)] disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer">
                    <span>@(isLoading ? "登入中..." : "登入系統")</span>
                    @if (isLoading)
                    {
                        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    }
                    else
                    {
                        <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    }
                </button>
            </EditForm>

            <div class="mt-4 text-center text-xs text-gray-400">
                &copy; @DateTime.Now.Year 全民中文檢定 CWT. All rights reserved.
            </div>
        </div>
    </div>

    <!-- Forgot Password Modal -->
    @if (showForgotPwdModal)
    {
        <div class="fixed inset-0 z-[100] flex items-center justify-center">
            <!-- Backdrop -->
            <div class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity" @onclick="CloseForgotPwdModal"></div>
            <!-- Modal Content -->
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 relative z-10 transform transition-all duration-300"
                style="animation: modalIn 0.3s ease-out;">
                <div class="p-6 border-b border-gray-100 flex justify-between items-center">
                    <h2 class="text-lg font-bold text-[var(--color-slate-main)] flex items-center gap-2">
                        <i class="fa-solid fa-key text-[var(--color-morandi)]"></i> 忘記密碼 / 重設密碼
                    </h2>
                    <button type="button" @onclick="CloseForgotPwdModal"
                        class="text-gray-400 hover:text-gray-600 focus:outline-none w-8 h-8 rounded-full hover:bg-gray-100 flex items-center justify-center transition-colors cursor-pointer">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <div class="p-6">
                    @if (!resetLinkSent)
                    {
                        <p class="text-sm text-gray-600 mb-4">請輸入您註冊的電子信箱，我們將發送密碼重設連結給您。</p>
                        <div class="mb-4 relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                                <i class="fa-regular fa-envelope"></i>
                            </span>
                            <input type="email" @bind="resetEmail"
                                class="login-input w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[var(--color-morandi)] focus:border-[var(--color-morandi)] transition-all"
                                placeholder="example@school.edu.tw">
                        </div>
                        <button type="button" @onclick="SendResetLink" disabled="@isSendingReset"
                            class="w-full py-2.5 bg-[var(--color-sage)] hover:bg-[#7b9c81] text-white rounded-lg font-medium transition-all shadow-sm flex justify-center items-center gap-2 focus:outline-none disabled:opacity-60 cursor-pointer">
                            @if (isSendingReset)
                            {
                                <i class="fa-solid fa-spinner fa-spin"></i>
                                <span>驗證發送中...</span>
                            }
                            else
                            {
                                <span>發送重設連結</span>
                            }
                        </button>
                    }
                    else
                    {
                        <div class="text-center">
                            <div class="w-14 h-14 bg-emerald-50 rounded-full flex items-center justify-center mx-auto mb-3">
                                <i class="fa-regular fa-envelope-open text-emerald-600 text-xl"></i>
                            </div>
                            <h3 class="text-base font-bold text-slate-main mb-2">請查收您的信箱</h3>
                            <p class="text-sm text-gray-600 mb-2">我們已將密碼重設連結發送至</p>
                            <p class="text-sm font-semibold text-[var(--color-morandi)] break-all mb-4">@resetEmailSentTo</p>

                            <div class="rounded-lg border border-blue-100 bg-blue-50/80 text-left p-3 mb-4 text-sm text-blue-900">
                                <p class="mb-1">如果您在幾分鐘內沒有收到郵件，請先檢查垃圾郵件資料夾。</p>
                                <p class="opacity-80">若連結失效，可在下方重新發送。</p>
                            </div>

                            <div class="space-y-3">
                                <button type="button" @onclick="SendResetLink" disabled="@IsResetResendDisabled"
                                    class="w-full py-2.5 bg-[var(--color-sage)] hover:bg-[#7b9c81] text-white rounded-lg font-medium transition-all shadow-sm flex justify-center items-center gap-2 focus:outline-none disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer">
                                    @if (isSendingReset)
                                    {
                                        <i class="fa-solid fa-spinner fa-spin"></i>
                                        <span>發送中...</span>
                                    }
                                    else if (resetResendCountdown > 0)
                                    {
                                        <span>@resetResendCountdown 秒後可重新發送</span>
                                    }
                                    else
                                    {
                                        <span>重新發送連結</span>
                                    }
                                </button>

                                <button type="button" @onclick="CloseForgotPwdModal"
                                    class="w-full py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg font-medium transition-all shadow-sm focus:outline-none cursor-pointer">
                                    返回登入頁
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

</div>
@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    // --- 表單模型 ---
    private LoginFormModel loginModel = new();

    // --- UI 控制 ---
    private string errorMessage = "";
    private bool isLoading = false;
    private bool showPassword = false;

    // --- 驗證碼 ---
    private string generatedCaptcha = "";
    private string captchaImage = "";

    // --- 忘記密碼 Modal ---
    private bool showForgotPwdModal = false;
    private string resetEmail = "";
    private string resetEmailSentTo = "";
    private bool isSendingReset = false;
    private bool resetLinkSent = false;
    private int resetResendCountdown = 0;
    private CancellationTokenSource? resetResendCountdownCts;
    private string? browserUserAgent;
    private readonly HashSet<string> fieldErrors = [];

    private bool IsResetResendDisabled => isSendingReset || resetResendCountdown > 0;

    private bool IsDev => Env.IsDevelopment();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo(string.Empty);
            return;
        }

        GenerateNewCaptcha();

        if (IsDev)
        {
            loginModel.Username = "jay";
            loginModel.Password = "01024304";
            loginModel.CaptchaInput = generatedCaptcha;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                browserUserAgent = await JS.InvokeAsync<string>("loginInterop.getUserAgent");
            }
            catch
            {
                // 忽略 Pre-rendering 期間的錯誤
            }
        }
    }

    private void TogglePasswordVisibility() => showPassword = !showPassword;

    private string BuildLoginInputClass(string fieldName, bool includeLeftIconPadding, string? extraClasses = null, bool fullWidth = true)
    {
        var classes = new List<string>
        {
            "login-input",
            "py-2.5",
            "rounded-lg",
            "border",
            "bg-white/50",
            "focus:bg-white",
            "focus:outline-none",
            "focus:ring-2",
            "focus:ring-[var(--color-morandi)]",
            "focus:ring-offset-2",
            "focus:ring-offset-white",
            "focus:border-[var(--color-morandi)]",
            "transition-all"
        };

        if (fullWidth)
        {
            classes.Add("w-full");
        }

        classes.Add(includeLeftIconPadding ? "pl-10" : "px-4");
        classes.Add(fieldErrors.Contains(fieldName) ? "border-red-400" : "border-gray-300");

        if (!string.IsNullOrWhiteSpace(extraClasses))
        {
            classes.Add(extraClasses);
        }

        return string.Join(" ", classes);
    }

    private void SetFieldError(params string[] fieldNames)
    {
        fieldErrors.Clear();

        foreach (var fieldName in fieldNames.Where(static name => !string.IsNullOrWhiteSpace(name)))
        {
            fieldErrors.Add(fieldName);
        }
    }

    private void ClearFieldError(string fieldName)
    {
        if (fieldErrors.Remove(fieldName))
        {
            StateHasChanged();
        }
    }

    private void GenerateNewCaptcha()
    {
        var result = CaptchaService.GenerateCaptcha();
        generatedCaptcha = result.Text;
        captchaImage = result.ImageBase64;
    }

    private void RefreshCaptcha()
    {
        GenerateNewCaptcha();
        loginModel.CaptchaInput = IsDev ? generatedCaptcha : "";
        ClearFieldError(nameof(loginModel.CaptchaInput));
    }

    /// <summary>處理登入流程（正式 DB 驗證）</summary>
    private async Task HandleLogin()
    {
        errorMessage = "";
        fieldErrors.Clear();

        // 基本驗證
        if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
        {
            errorMessage = "請輸入完整的帳號密碼。";
            SetFieldError(
                string.IsNullOrWhiteSpace(loginModel.Username) ? nameof(loginModel.Username) : string.Empty,
                string.IsNullOrWhiteSpace(loginModel.Password) ? nameof(loginModel.Password) : string.Empty);
            return;
        }

        // 驗證碼比對
        if (!string.Equals(loginModel.CaptchaInput?.Trim(), generatedCaptcha, StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "驗證碼錯誤，請重新輸入。";
            SetFieldError(nameof(loginModel.CaptchaInput));
            await AuthService.LogLoginAttemptAsync(
                null,
                loginModel.Username.Trim(),
                false,
                "驗證碼錯誤。",
                null,
                browserUserAgent);
            loginModel.CaptchaInput = "";
            GenerateNewCaptcha();
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            // 呼叫 AuthService 驗證帳密（DI 注入，伺服器端直接查 DB）
            var (success, message, user) = await AuthService.ValidateLoginAsync(
                loginModel.Username.Trim(), loginModel.Password, browserUserAgent);

            if (!success || user is null)
            {
                errorMessage = message;
                SetFieldError(nameof(loginModel.Username), nameof(loginModel.Password));
                loginModel.CaptchaInput = "";
                GenerateNewCaptcha();
                isLoading = false;
                return;
            }

            // 暫存登入資料，取得一次性 key，導航至 HTTP 端點完成 Cookie 寫入
            var loginKey = AuthService.PrepareSignIn(user, loginModel.RememberMe);
            Navigation.NavigateTo($"auth/login?key={loginKey}", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = IsDev
                ? $"[DEV] {ex.GetType().Name}: {ex.Message}"
                : "系統登入發生例外錯誤，請稍後再試。";
            isLoading = false;
        }
    }

    // --- 忘記密碼相關方法 ---

    private void OpenForgotPwdModal()
    {
        ResetForgotPasswordModalState(clearEmail: true);
        showForgotPwdModal = true;
    }

    private void CloseForgotPwdModal()
    {
        ResetForgotPasswordModalState(clearEmail: false);
        showForgotPwdModal = false;
    }

    /// <summary>發送密碼重設連結</summary>
    private async Task SendResetLink()
    {
        if (string.IsNullOrWhiteSpace(resetEmail))
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "error",
                title = "錯誤",
                text = "請輸入電子信箱",
                confirmButtonColor = "#6B8EAD"
            });
            return;
        }

        try
        {
            _ = new System.Net.Mail.MailAddress(resetEmail.Trim());
        }
        catch
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "error",
                title = "錯誤",
                text = "請輸入有效的電子信箱格式",
                confirmButtonColor = "#6B8EAD"
            });
            return;
        }

        isSendingReset = true;
        StateHasChanged();

        try
        {
            var (success, message) = await ResetService.RequestPasswordResetAsync(resetEmail.Trim(), Navigation.BaseUri);
            if (!success)
            {
                await JS.InvokeVoidAsync("swalInterop.fire", new
                {
                    icon = "error",
                    title = "發送失敗",
                    text = message,
                    confirmButtonColor = "#6B8EAD"
                });
                return;
            }

            resetEmailSentTo = resetEmail.Trim();
            resetLinkSent = true;
            _ = StartResetResendCountdownAsync();
        }
        catch (InvalidOperationException ex)
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "error",
                title = "系統設定未完成",
                text = ex.Message,
                confirmButtonColor = "#6B8EAD"
            });
        }
        catch
        {
            await JS.InvokeVoidAsync("swalInterop.fire", new
            {
                icon = "error",
                title = "發送失敗",
                text = "系統忙碌中，暫時無法發送密碼重設信，請稍後再試。",
                confirmButtonColor = "#6B8EAD"
            });
        }
        finally
        {
            isSendingReset = false;
            StateHasChanged();
        }
    }

    private void ResetForgotPasswordModalState(bool clearEmail)
    {
        resetResendCountdownCts?.Cancel();
        resetResendCountdownCts?.Dispose();
        resetResendCountdownCts = null;

        resetLinkSent = false;
        resetResendCountdown = 0;
        resetEmailSentTo = "";

        if (clearEmail)
        {
            resetEmail = "";
        }
    }

    private async Task StartResetResendCountdownAsync()
    {
        resetResendCountdownCts?.Cancel();
        resetResendCountdownCts?.Dispose();

        resetResendCountdownCts = new CancellationTokenSource();
        var cancellationToken = resetResendCountdownCts.Token;
        resetResendCountdown = 60;
        StateHasChanged();

        try
        {
            while (resetResendCountdown > 0 && !cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(1000, cancellationToken);
                resetResendCountdown--;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
            // Modal 關閉或重新發送時取消倒數，屬正常流程。
        }
    }

    // --- 表單模型類別 ---
    private sealed class LoginFormModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string CaptchaInput { get; set; } = "";
        public bool RememberMe { get; set; } = false;
    }
}
