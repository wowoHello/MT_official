            await Task.WhenAll(chartTasks);
    }

    /// <summary>
    /// 依達成率決定堆疊條的顏色：
    ///   未設定目標 → 灰；0-29% → 赤陶警示；30-69% → amber；70-99% → sage；100%+ → 深綠達標
    /// </summary>
    private static string ResolveBarColor(int produced, int target)
    {
        if (target <= 0 || produced == 0) return "#E5E7EB";
        var ratio = (double)produced / target;
        return ratio >= 1.0 ? "#5C8A6A"
             : ratio >= 0.7 ? "#8EAB94"
             : ratio >= 0.3 ? "#F59E0B"
             :                "#D98A6C";
    }

