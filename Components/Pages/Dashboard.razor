@* ====================================================================== *@
@*  Dashboard — 命題儀表板                                                  *@
@*  路由：/dashboard                                                       *@
@*  功能：統計卡片（目標題數、採用、審修、退回）、題型缺口圖表、緊急待辦     *@
@* ====================================================================== *@
@page "/dashboard"
@inject IDashboardService DashboardService
@inject ILogger<Dashboard> Logger
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="flex-grow w-full mx-auto flex flex-col">
    <!-- Breadcrumb & Header -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 bg-white/50 backdrop-blur border-b border-gray-200 flex-shrink-0">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <!-- Breadcrumb -->
                <nav class="flex text-sm text-gray-500 mb-2 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <NavLink href="" Match="NavLinkMatch.All" class="inline-flex items-center hover:text-[var(--color-morandi)] transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-[var(--color-slate-main)]">命題儀表板</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-chart-pie text-[var(--color-morandi)]"></i> 命題儀表板
                </h1>
                <p class="text-sm text-gray-500 mt-1">監控目前梯次的題目產出達成率、題型缺口與逾期狀態。資料會隨梯次切換動態更新。</p>
            </div>

            <!-- Quick Actions -->
            <div class="flex gap-2">
                <NavLink href="projects" class="px-4 py-2 bg-white border border-gray-200 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 hover:text-[var(--color-morandi)] hover:-translate-y-0.5 hover:shadow-md cursor-pointer active:scale-95 transition-all duration-200 shadow-sm focus:outline-none flex items-center">
                    <i class="fa-solid fa-gear mr-1"></i> 專案設定
                </NavLink>
                <NavLink href="overview" class="px-4 py-2 bg-[var(--color-morandi)] text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] hover:-translate-y-0.5 hover:shadow-md cursor-pointer active:scale-95 transition-all duration-200 shadow-sm focus:outline-none flex items-center">
                    <i class="fa-solid fa-list-check mr-1"></i> 試題總覽
                </NavLink>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="flex-grow p-4 sm:p-6 lg:p-8">

        <!-- 4 KPI Cards：統一結構 Header → Main → Divider → Footer（mt-auto 推底） -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

            @* ── 卡片 1：總目標題數（morandi 灰藍） ── *@
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all border-l-[3px] border-l-[var(--color-morandi)] p-5 flex flex-col min-h-[200px]">
                <!-- Header -->
                <div class="flex items-center gap-2.5 mb-2">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 text-[var(--color-morandi)] flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-bullseye text-sm"></i>
                    </div>
                    <p class="text-sm font-semibold text-gray-600">總目標題數</p>
                </div>
                <!-- Main -->
                <div class="flex items-baseline gap-1.5 mb-3">
                    <h3 class="text-4xl font-black text-[var(--color-morandi)] tabular-nums leading-none">
                        @(isLoading ? "…" : kpi.TotalTarget.ToString())
                    </h3>
                    <span class="text-sm text-gray-400">題</span>
                </div>
                <!-- Footer：永遠顯示題型明細（即使全為 0 也顯示列表） -->
                <div class="mt-auto pt-3 border-t border-gray-100">
                    @if (isLoading)
                    {
                        <div class="text-xs text-gray-300">載入中…</div>
                    }
                    else
                    {
                        <div class="grid grid-cols-2 gap-x-3 gap-y-1 text-xs">
                            @foreach (var t in kpi.TargetBreakdown)
                            {
                                <div class="flex justify-between gap-2">
                                    <span class="text-gray-500 truncate">@t.TypeName</span>
                                    <span class="font-semibold text-[var(--color-slate-main)] tabular-nums shrink-0">@t.TargetCount</span>
                                </div>
                            }
                            @if (!kpi.TargetBreakdown.Any())
                            {
                                <span class="col-span-2 text-gray-400">請先設定各題型目標數量</span>
                            }
                        </div>
                    }
                </div>
            </div>

            @* ── 卡片 2：已納入題庫（採用）（sage 鼠尾草綠） ── *@
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all border-l-[3px] border-l-[var(--color-sage)] p-5 flex flex-col min-h-[200px]">
                <!-- Header -->
                <div class="flex items-center gap-2.5 mb-2">
                    <div class="w-8 h-8 rounded-lg bg-green-50 text-[var(--color-sage)] flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-check-double text-sm"></i>
                    </div>
                    <p class="text-sm font-semibold text-gray-600">已納入題庫（採用）</p>
                </div>
                <!-- Main -->
                <div class="flex items-baseline gap-1.5 mb-3">
                    <h3 class="text-4xl font-black text-[var(--color-sage)] tabular-nums leading-none">
                        @(isLoading ? "…" : kpi.AdoptedCount.ToString())
                    </h3>
                    <span class="text-sm text-gray-400">題</span>
                </div>
                <!-- Footer：永遠顯示進度條，0% 也呈現結構 -->
                <div class="mt-auto pt-3 border-t border-gray-100">
                    @if (isLoading)
                    {
                        <div class="text-xs text-gray-300">載入中…</div>
                    }
                    else
                    {
                        <div class="flex justify-between items-center text-xs mb-1.5">
                            <span class="text-gray-500">採用率</span>
                            <span class="font-bold text-[var(--color-sage)] tabular-nums">@kpi.AdoptedPercent%</span>
                        </div>
                        <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                            <div class="h-full bg-[var(--color-sage)] rounded-full transition-all duration-500" style="width:@(kpi.AdoptedPercent)%"></div>
                        </div>
                        <div class="text-xs text-gray-400 mt-1.5 tabular-nums">@kpi.AdoptedCount / @kpi.TotalTarget 已採用</div>
                    }
                </div>
            </div>

            @* ── 卡片 3：各階段審題（amber-600）── *@
            @* 依當前 PhaseCode 對應 ReviewStage，顯示審題完成度（已完成/總數） *@
            @* 非審題階段顯示「未啟動」替代區塊；Footer 顯示真正當前階段名稱 *@
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all border-l-[3px] border-l-amber-500 p-5 flex flex-col min-h-[200px]">
                <!-- Header：圖示 + 標題 + 右上角階段 Pill Badge -->
                <div class="flex items-center gap-2.5 mb-2">
                    <div class="w-8 h-8 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center shrink-0">
                        <i class="fa-solid @(isLoading ? "fa-spinner fa-spin-pulse" : "fa-clipboard-check") text-sm"></i>
                    </div>
                    <p class="text-sm font-semibold text-gray-600">各階段審題</p>
                    @if (!isLoading)
                    {
                        <span class="ml-auto px-2.5 py-0.5 text-xs font-medium rounded-full border tabular-nums @ReviewPhasePillClass(kpi.CurrentReviewPhase)">
                            @ReviewPhaseLabel(kpi.CurrentReviewPhase)
                        </span>
                    }
                </div>
                <!-- Main：審題階段顯示 XX/OO 題；非審題階段顯示「未啟動」替代區 -->
                <div class="mb-3 min-h-[44px]">
                    @if (isLoading)
                    {
                        <div class="flex items-baseline gap-1.5">
                            <h3 class="text-4xl font-black text-amber-600 tabular-nums leading-none">…</h3>
                        </div>
                    }
                    else if (kpi.CurrentReviewPhase == MT.Models.ReviewPhaseLabel.Closed)
                    {
                        @* 已結案：用印章感的封存卡（實線邊框 + 完成圖示，與「未啟動」虛線狀態做出區隔） *@
                        <div class="flex items-center gap-2.5 px-3 py-2 bg-stone-100 rounded-lg border border-stone-300">
                            <div class="w-9 h-9 rounded-md bg-white border border-stone-300 flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-circle-check text-stone-500 text-base"></i>
                            </div>
                            <div class="min-w-0">
                                <p class="text-sm font-semibold text-stone-700 truncate">本梯次已結案</p>
                                <p class="text-xs text-stone-500 mt-0.5 truncate tabular-nums">
                                    @if (kpi.ClosedAt.HasValue)
                                    {
                                        <span>結案於 @kpi.ClosedAt.Value.ToString("yyyy-MM-dd")</span>
                                    }
                                    else
                                    {
                                        <span>所有審題進度已凍結</span>
                                    }
                                </p>
                            </div>
                        </div>
                    }
                    else if (kpi.CurrentReviewPhase == MT.Models.ReviewPhaseLabel.None)
                    {
                        @* 非審題階段：虛線卡 + 月亮圖示 *@
                        <div class="flex items-center gap-2.5 px-3 py-2 bg-stone-50 rounded-lg border border-dashed border-stone-200">
                            <i class="fa-solid fa-moon text-stone-400 text-base shrink-0"></i>
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-stone-600 truncate">本階段審題未啟動</p>
                                <p class="text-xs text-stone-400 mt-0.5 truncate">目前處於 @kpi.PhaseStatusText</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @* 審題階段：XX/OO 題 *@
                        <h3 class="flex items-baseline gap-1 leading-none">
                            <span class="text-4xl font-black text-amber-600 tabular-nums">@kpi.ReviewedCount</span>
                            <span class="text-2xl text-gray-300 mx-0.5">/</span>
                            <span class="text-2xl font-bold text-gray-400 tabular-nums">@kpi.ReviewTotalCount</span>
                            <span class="text-sm text-gray-400 ml-1">題</span>
                        </h3>
                    }
                </div>
                <!-- Footer：依 PhaseStatusType 顯示真正當前階段 -->
                <div class="mt-auto pt-3 border-t border-gray-100">
                    @if (isLoading)
                    {
                        <div class="text-xs text-gray-300">載入中…</div>
                    }
                    else
                    {
                        @switch (kpi.PhaseStatusType)
                        {
                            case PhaseStatusType.InPhase:
                                <div class="flex items-center gap-2 text-xs">
                                    <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse shrink-0"></span>
                                    <span class="font-semibold text-amber-700 truncate">@kpi.PhaseStatusText</span>
                                    @if (kpi.PhaseDaysRemaining.HasValue)
                                    {
                                        @if (kpi.PhaseDaysRemaining.Value >= 0)
                                        {
                                            <span class="ml-auto text-gray-500 tabular-nums shrink-0">剩 @kpi.PhaseDaysRemaining 天</span>
                                        }
                                        else
                                        {
                                            <span class="ml-auto text-[var(--color-terracotta)] tabular-nums shrink-0">逾期 @Math.Abs(kpi.PhaseDaysRemaining.Value) 天</span>
                                        }
                                    }
                                </div>
                                break;
                            case PhaseStatusType.BetweenPhases:
                                <div class="flex items-center gap-2 text-xs text-amber-600">
                                    <i class="fa-solid fa-hourglass-half shrink-0"></i>
                                    <span>@kpi.PhaseStatusText</span>
                                </div>
                                break;
                            default:
                                <div class="flex items-center gap-2 text-xs text-gray-400">
                                    <i class="fa-solid fa-circle-info shrink-0"></i>
                                    <span>@kpi.PhaseStatusText</span>
                                </div>
                                break;
                        }
                    }
                </div>
            </div>

            @* ── 卡片 4：退回修題（terracotta 赤陶色） ── *@
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-all border-l-[3px] border-l-[var(--color-terracotta)] p-5 flex flex-col min-h-[200px]">
                <!-- Header -->
                <div class="flex items-center gap-2.5 mb-2">
                    <div class="w-8 h-8 rounded-lg bg-red-50 text-[var(--color-terracotta)] flex items-center justify-center shrink-0">
                        <i class="fa-solid fa-triangle-exclamation text-sm"></i>
                    </div>
                    <p class="text-sm font-semibold text-gray-600">退回修題</p>
                </div>
                <!-- Main -->
                <div class="flex items-baseline gap-1.5 mb-3">
                    <h3 class="text-4xl font-black text-[var(--color-terracotta)] tabular-nums leading-none">
                        @(isLoading ? "…" : kpi.ReturnEditCount.ToString())
                    </h3>
                    <span class="text-sm text-gray-400">題</span>
                </div>
                <!-- Footer：3 等分 grid，即使全為 0 也完整顯示欄位 -->
                <div class="mt-auto pt-3 border-t border-gray-100">
                    @if (isLoading)
                    {
                        <div class="text-xs text-gray-300">載入中…</div>
                    }
                    else
                    {
                        <div class="grid grid-cols-3 gap-2 text-center">
                            <div>
                                <div class="text-base font-bold text-[var(--color-terracotta)] tabular-nums">@kpi.PeerEditCount</div>
                                <div class="text-xs text-gray-500 mt-0.5">互審修題</div>
                            </div>
                            <div class="border-x border-gray-100">
                                <div class="text-base font-bold text-[var(--color-terracotta)] tabular-nums">@kpi.ExpertEditCount</div>
                                <div class="text-xs text-gray-500 mt-0.5">專審修題</div>
                            </div>
                            <div>
                                <div class="text-base font-bold text-[var(--color-terracotta)] tabular-nums">@kpi.FinalEditCount</div>
                                <div class="text-xs text-gray-500 mt-0.5">總審修題</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- Charts Row -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
            <!-- Chart 1：題型缺口達成率（Horizontal Bar + Goals） -->
            <div class="bg-white rounded-xl shadow-sm p-6 lg:col-span-1 flex flex-col h-[350px] overflow-hidden">
                <h3 class="text-lg font-bold text-slate-main mb-1">題型缺口達成率</h3>
                <p class="text-xs text-gray-500 mb-2">展示目前各題型「已產出」與「目標」比例。</p>
                <div class="flex-grow min-h-0">
                    @if (isLoading)
                    {
                        <EmptyState IconClass="fa-spinner" Message="載入中…" Compact="true" CssClass="h-full" />
                    }
                    else if (!kpi.AchievementByType.Any(x => x.Target > 0 || x.Produced > 0))
                    {
                        <EmptyState IconClass="fa-chart-pie" Message="尚無數據" SubMessage="請先設定各題型目標數量" Compact="true" CssClass="h-full" />
                    }
                    else
                    {
                        <div id="chart-achievement" class="h-full"></div>
                    }
                </div>
            </div>

            <!-- Chart 2：依題型狀態分佈（Vertical Stacked Bar） -->
            <div class="bg-white rounded-xl shadow-sm p-6 lg:col-span-2 flex flex-col h-[350px] overflow-hidden">
                <h3 class="text-lg font-bold text-slate-main mb-1">依題型狀態分佈表</h3>
                <p class="text-xs text-gray-500 mb-2">依當前階段動態呈現：草稿、階段進行中、階段完成、採用、不採用。</p>
                <div class="flex-grow min-h-0">
                    @if (isLoading)
                    {
                        <EmptyState IconClass="fa-spinner" Message="載入中…" Compact="true" CssClass="h-full" />
                    }
                    else if (!kpi.StatusByType.Any(x => x.Drafts > 0 || x.InProgress > 0 || x.DoneStage > 0 || x.Adopted > 0 || x.Rejected > 0))
                    {
                        <EmptyState IconClass="fa-chart-column" Message="尚無數據" SubMessage="新增題目後將自動產生統計" Compact="true" CssClass="h-full" />
                    }
                    else
                    {
                        <div id="chart-status" class="h-full"></div>
                    }
                </div>
            </div>
        </div>

        <!-- Bottom Row: Alerts & Audits -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 pb-12">
            <!-- Urgent Tasks -->
            @{
                // 拆分階段倒數（Header 右側顯示，純資訊）與教師待辦（清單，可點開 Modal）
                var phaseAlert    = kpi.UrgentItems.FirstOrDefault(x => x.Source == UrgentSourceType.PhaseDeadline);
                var teacherItems  = kpi.UrgentItems.Where(x => x.Source == UrgentSourceType.TeacherShortage).ToList();
            }
            <div class="bg-white rounded-xl shadow-sm border border-red-100 flex flex-col overflow-hidden">
                <div class="bg-red-50 px-5 py-3 border-b border-red-100 flex justify-between items-center gap-3 shrink-0">
                    <h3 class="font-bold text-terracotta text-sm flex items-center gap-2 shrink-0">
                        <i class="fa-solid fa-triangle-exclamation"></i> 逾期與緊急待辦
                        @if (!isLoading && teacherItems.Count > 0)
                        {
                            <span class="ml-1 px-2 py-0.5 rounded-full bg-white/80 text-xs font-semibold text-terracotta tabular-nums border border-red-200">
                                @teacherItems.Count
                            </span>
                        }
                    </h3>
                    @* 階段倒數提醒：純資訊單行顯示在 header 右側（一階段一次，不可點） *@
                    @if (!isLoading && phaseAlert is not null)
                    {
                        <span class="text-xs font-semibold tabular-nums truncate flex items-center gap-1.5 @PhaseAlertTextClass(phaseAlert.Severity)"
                              title="@phaseAlert.Title @phaseAlert.Subtitle">
                            <i class="fa-solid @IconFor(phaseAlert) text-xs"></i>
                            <span class="truncate">@phaseAlert.Title</span>
                        </span>
                    }
                </div>
                @if (isLoading)
                {
                    <div class="p-4 h-full">
                        <EmptyState CssClass="py-8 h-full" IconClass="fa-spinner" Message="載入中…" Compact="true" />
                    </div>
                }
                else if (teacherItems.Count == 0)
                {
                    <div class="p-4 h-full">
                        <EmptyState CssClass="py-8 h-full" IconClass="fa-circle-check" Message="目前沒有教師進度落後"
                                    SubMessage="所有教師命題進度皆在正常範圍" Compact="true" />
                    </div>
                }
                else
                {
                    @* 警示清單最大高度 = 5 筆（單筆 ~58px），超過則啟用捲動，與 LOG 卡片對齊 *@
                    <ul class="max-h-[290px] overflow-y-auto divide-y divide-stone-100">
                        @foreach (var item in teacherItems)
                        {
                            <li>
                                @* 教師落後：點擊開啟 Modal 顯示詳情 *@
                                <button @onclick="() => OpenDetail(item)"
                                        class="w-full px-5 py-3 flex items-center gap-3 text-left
                                               cursor-pointer transition-colors duration-200
                                               @SeverityBgClass(item.Severity)
                                               @SeverityHoverClass(item.Severity)">
                                    <span class="w-2.5 h-2.5 rounded-full @SeverityDotClass(item.Severity) shrink-0"></span>
                                    <i class="fa-solid @IconFor(item) text-base text-slate-500 shrink-0"></i>
                                    <div class="flex-1 min-w-0">
                                        <div class="text-sm font-medium text-slate-main truncate">@item.Title</div>
                                        <div class="text-xs text-slate-500 mt-0.5">@item.Subtitle</div>
                                    </div>
                                    <i class="fa-solid fa-chevron-right text-xs text-slate-400 shrink-0 transition-all duration-200"></i>
                                </button>
                            </li>
                        }
                    </ul>
                }
            </div>

            <!-- Audit Logs -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 flex flex-col overflow-hidden">
                <!-- Header：標題 + 筆數 badge + 含全站事件 Toggle -->
                <div class="bg-gray-50 px-5 py-3 border-b border-gray-200 flex justify-between items-center gap-3 shrink-0">
                    <h3 class="font-bold text-gray-700 text-sm flex items-center gap-2 shrink-0">
                        <i class="fa-solid fa-list-ul text-gray-400"></i> 最新稽核歷程 (LOG)
                        @if (logPage is not null && logPage.TotalCount > 0)
                        {
                            <span class="ml-1 px-2 py-0.5 rounded-full bg-white text-xs font-semibold text-gray-700 tabular-nums border border-gray-200">
                                @logPage.TotalCount
                            </span>
                        }
                    </h3>
                    @* iOS-style Toggle：含全站事件 *@
                    <label class="flex items-center gap-2 cursor-pointer select-none shrink-0"
                           title="含登入/登出、教師管理、全站公告等跨梯次事件">
                        <span class="text-xs text-gray-600">含全站事件</span>
                        <span class="relative inline-block w-9 h-5 transition-colors duration-200 rounded-full
                                     @(includeGlobalLogs ? "bg-[var(--color-morandi)]" : "bg-stone-300")">
                            <input type="checkbox" class="sr-only peer"
                                   checked="@includeGlobalLogs"
                                   @onchange="ToggleIncludeGlobalAsync" />
                            <span class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow transition-transform duration-200
                                         @(includeGlobalLogs ? "translate-x-4" : "")"></span>
                        </span>
                    </label>
                </div>

                <!-- Filter Chips（單選） -->
                <div class="px-3 py-2 border-b border-gray-100 flex items-center gap-1.5 overflow-x-auto bg-white shrink-0">
                    @foreach (var f in LogFilters)
                    {
                        var active = activeLogFilter == f.Filter;
                        <button @onclick="() => ChangeLogFilterAsync(f.Filter)"
                                class="px-2.5 py-1 rounded-full text-xs font-medium tabular-nums shrink-0
                                       cursor-pointer transition-all duration-150 border
                                       @(active
                                            ? "bg-[var(--color-slate-main)] text-white border-[var(--color-slate-main)]"
                                            : "bg-white text-gray-600 border-gray-200 hover:bg-gray-50 hover:border-gray-300")">
                            @f.Label
                        </button>
                    }
                </div>

                <!-- Body -->
                @if (logPage is null && isLoadingLogs)
                {
                    <div class="flex-grow flex items-center justify-center p-4">
                        <EmptyState CssClass="py-8" IconClass="fa-spinner" Message="載入中…" Compact="true" />
                    </div>
                }
                else if (logPage is not null && logPage.Logs.Count == 0)
                {
                    <div class="flex-grow flex items-center justify-center p-4">
                        <EmptyState CssClass="py-8" IconClass="fa-clipboard-user"
                                    Message="目前沒有近期紀錄"
                                    SubMessage="@(activeLogFilter == LogTypeFilter.All ? "梯次中的增刪改動作將顯示於此" : "請切換其他篩選或開啟「含全站事件」")"
                                    Compact="true" />
                    </div>
                }
                else if (logPage is not null)
                {
                    @* 列表最大高度 = 5 筆（單筆 ~56px：icon 36px + py-2.5 20px），超過則啟用捲動 *@
                    <ul class="max-h-[290px] overflow-y-auto divide-y divide-stone-100">
                        @foreach (var log in logPage.Logs)
                        {
                            <li class="px-4 py-2.5 flex items-center gap-3 hover:bg-stone-50 cursor-pointer transition-colors duration-150">
                                @* 動作圖示 *@
                                <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 text-xs @LogIconBgClass(log.Action)">
                                    <i class="fa-solid @LogIconClass(log.Action)"></i>
                                </span>
                                @* 主要描述文字 *@
                                <div class="flex-1 min-w-0">
                                    @if (log.Action == 3 || log.Action == 4)
                                    {
                                        <div class="text-sm text-[var(--color-slate-main)] truncate"
                                             title="@log.UserName @ActionVerb(log.Action)系統">
                                            <span class="font-semibold">@log.UserName</span>
                                            <span class="text-gray-500"> @ActionVerb(log.Action)系統</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-sm text-[var(--color-slate-main)] truncate"
                                             title="@log.UserName @ActionVerb(log.Action)了 @TargetTypeLabel(log.TargetType)「@log.TargetName」">
                                            <span class="font-semibold">@log.UserName</span>
                                            <span class="text-gray-500"> @ActionVerb(log.Action)了 @TargetTypeLabel(log.TargetType)</span>
                                            <span class="font-medium">「@log.TargetName」</span>
                                        </div>
                                    }
                                </div>
                                @* 時間標記 *@
                                <time class="text-xs text-gray-400 shrink-0 tabular-nums"
                                      title="@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")">
                                    @FormatRelativeTime(log.CreatedAt)
                                </time>
                            </li>
                        }
                    </ul>

                    @* 載入更多 *@
                    @if (logPage.HasMore)
                    {
                        <button @onclick="LoadMoreLogsAsync"
                                disabled="@isLoadingLogs"
                                class="border-t border-gray-100 px-5 py-2.5 text-xs text-gray-500 hover:bg-stone-50 hover:text-[var(--color-slate-main)] cursor-pointer transition-colors duration-150 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed shrink-0">
                            @if (isLoadingLogs)
                            {
                                <i class="fa-solid fa-spinner fa-spin-pulse"></i>
                                <span>載入中…</span>
                            }
                            else
                            {
                                <i class="fa-solid fa-chevron-down"></i>
                                <span class="tabular-nums">載入更早 @Math.Min(LogPageSize, logPage.TotalCount - logPage.Logs.Count) 筆</span>
                            }
                        </button>
                    }
                }
            </div>
        </div>
    </div>
</div>

@* ── 教師詳情 Modal（TeacherShortage 列點擊觸發） ── *@
@if (selectedDetailItem is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4"
         @onclick="CloseDetail">
        @* Backdrop *@
        <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm
                    animate-[fadeIn_200ms_ease-out]"></div>

        @* Modal Content *@
        <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg
                    max-h-[85vh] overflow-hidden flex flex-col
                    animate-[scaleIn_200ms_ease-out]"
             @onclick:stopPropagation="true">

            @* Header *@
            <header class="px-6 py-4 border-b border-stone-200 flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl bg-rose-100 flex items-center justify-center flex-shrink-0">
                    <i class="fa-solid fa-user-clock text-[var(--color-terracotta)] text-lg"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <h2 class="text-xl font-semibold text-[var(--color-slate-main)] truncate">
                        @ExtractTeacherName(selectedDetailItem.Title)
                    </h2>
                    <p class="text-sm text-slate-500 mt-0.5">@selectedDetailItem.Subtitle</p>
                </div>
                <button @onclick="CloseDetail"
                        class="w-8 h-8 rounded-lg cursor-pointer hover:bg-stone-100 flex items-center justify-center transition-colors flex-shrink-0">
                    <i class="fa-solid fa-xmark text-slate-500"></i>
                </button>
            </header>

            @* Body（可捲動） *@
            <div class="flex-1 overflow-y-auto px-6 py-5 space-y-5">
                @{
                    var details = selectedDetailItem.TeacherDetails ?? new();
                    var totalAssigned = details.Sum(d => d.Assigned);
                    var totalProduced = details.Sum(d => d.Produced);
                    var totalAch = totalAssigned > 0 ? (decimal)totalProduced / totalAssigned : 0m;
                }

                @* 總配額進度卡 *@
                <div class="bg-stone-50 rounded-xl p-4 border border-stone-100">
                    <div class="flex items-baseline justify-between mb-2">
                        <span class="text-sm text-slate-500">總配額達成</span>
                        <span class="text-base font-semibold tabular-nums @AchClass(totalAch)">
                            @totalProduced / @totalAssigned 題（@($"{totalAch:P0}")）
                        </span>
                    </div>
                    <div class="h-2 bg-stone-200 rounded-full overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-500 @AchBarClass(totalAch)"
                             style="width:@($"{Math.Min(totalAch, 1m) * 100:F0}%")"></div>
                    </div>
                </div>

                @* 各題型進度明細 *@
                <div>
                    <h3 class="text-xs font-bold text-[var(--color-morandi)] uppercase tracking-wider mb-3">各題型進度</h3>
                    <div class="space-y-3">
                        @foreach (var d in details)
                        {
                            <div>
                                <div class="flex items-baseline justify-between mb-1.5">
                                    <span class="text-sm font-medium text-[var(--color-slate-main)]">@d.TypeName</span>
                                    <span class="text-xs tabular-nums @AchClass(d.Achievement)">
                                        @d.Produced / @d.Assigned（@($"{d.Achievement:P0}")）
                                    </span>
                                </div>
                                <div class="h-2 bg-stone-100 rounded-full overflow-hidden">
                                    <div class="h-full rounded-full @AchBarClass(d.Achievement)"
                                         style="width:@($"{Math.Min(d.Achievement, 1m) * 100:F0}%")"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Footer *@
            <footer class="px-6 py-3 border-t border-stone-200 bg-stone-50 flex items-center justify-between gap-3">
                <button @onclick="CloseDetail"
                        class="px-4 py-2 text-sm font-medium text-slate-600
                               bg-white border border-stone-300 rounded-lg cursor-pointer
                               hover:bg-stone-100 hover:border-stone-400 hover:text-slate-main
                               active:scale-[0.97] transition-all duration-200">
                    關閉
                </button>
                <a href="@selectedDetailItem.TargetUrl"
                   class="px-4 py-2 text-sm font-medium text-white
                          bg-[var(--color-morandi)] rounded-lg cursor-pointer
                          hover:bg-[var(--color-slate-main)] hover:shadow-md
                          active:scale-[0.97] transition-all duration-200
                          flex items-center gap-2">
                    前往命題總覽
                    <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-0.5"></i>
                </a>
            </footer>
        </div>
    </div>
}

@code {
    [CascadingParameter(Name = "CurrentProject")] private ProjectSwitcherItem? CurrentProject { get; set; }

    private DashboardKpiDto kpi = new();
    private bool isLoading;
    private int? previousProjectId;

    // 旗標：資料載入完成後觸發圖表渲染（在 OnAfterRenderAsync 中偵測）
    private bool chartsNeedRender;

    // 逾期待辦 Modal：儲存目前開啟的教師詳情項目（null = 關閉）
    private DashboardUrgentItem? selectedDetailItem;

    // ── LOG 區塊狀態 ────────────────────────────────────────────────
    private const int LogPageSize = 50;
    private const string LogPrefKey = "cwt-dashboard-log-include-global";

    private AuditLogPage? logPage;
    private bool isLoadingLogs;
    private bool includeGlobalLogs;          // Toggle：含全站事件
    private LogTypeFilter activeLogFilter = LogTypeFilter.All;
    private bool logPrefLoaded;              // localStorage 是否已讀取（避免 firstRender 重複）

    /// <summary>Filter Chip 設定清單（顯示順序與本地化標籤）。</summary>
    private static readonly (LogTypeFilter Filter, string Label)[] LogFilters =
    {
        (LogTypeFilter.All,          "全部"),
        (LogTypeFilter.Question,     "試題"),
        (LogTypeFilter.Announcement, "公告"),
        (LogTypeFilter.Role,         "角色"),
        (LogTypeFilter.Teacher,      "教師"),
        (LogTypeFilter.Review,       "審題"),
        (LogTypeFilter.Login,        "登入"),
    };

    protected override async Task OnParametersSetAsync()
    {
        // 梯次切換偵測（同 Teachers.razor 模式）
        var newProjectId = CurrentProject?.Id;
        if (newProjectId != previousProjectId)
        {
            previousProjectId = newProjectId;
            await LoadKpiAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 首次渲染後從 localStorage 讀取 toggle 偏好（OnInitializedAsync 階段 JSInterop 不可用）
        if (firstRender && !logPrefLoaded)
        {
            logPrefLoaded = true;
            try
            {
                var stored = await JS.InvokeAsync<string>("localStorage.getItem", LogPrefKey);
                includeGlobalLogs = stored == "1";
            }
            catch
            {
                // localStorage 讀取失敗（隱私模式等），維持預設關閉
            }
            await LoadLogsAsync(reset: true);
        }

        // 每次 StateHasChanged 後若旗標為 true，就執行圖表渲染
        if (chartsNeedRender)
        {
            chartsNeedRender = false;
            await RenderChartsAsync();
        }
    }

    private async Task LoadKpiAsync()
    {
        if (CurrentProject is null)
        {
            kpi = new DashboardKpiDto();
            chartsNeedRender = false;
            selectedDetailItem = null;
            logPage = null;
            return;
        }

        isLoading = true;
        selectedDetailItem = null;
        StateHasChanged();

        try
        {
            kpi = await DashboardService.GetKpiAsync(CurrentProject.Id);
            chartsNeedRender = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入 Dashboard KPI 失敗，ProjectId={ProjectId}", CurrentProject.Id);
            kpi = new DashboardKpiDto();
            chartsNeedRender = false;
        }
        finally
        {
            isLoading = false;
        }

        // KPI 載完後若已讀過 toggle 偏好，重新載入 LOG（梯次切換時觸發）
        if (logPrefLoaded)
        {
            await LoadLogsAsync(reset: true);
        }
    }

    // ── LOG 載入流程 ────────────────────────────────────────────────

    /// <summary>載入或重載稽核歷程（reset=true 從頭；false 為追加分頁）。</summary>
    private async Task LoadLogsAsync(bool reset)
    {
        if (CurrentProject is null)
        {
            logPage = new AuditLogPage();
            return;
        }

        isLoadingLogs = true;
        StateHasChanged();

        try
        {
            var skip = reset ? 0 : (logPage?.Logs.Count ?? 0);
            var page = await DashboardService.GetAuditLogsAsync(new AuditLogQuery
            {
                ProjectId     = CurrentProject.Id,
                IncludeGlobal = includeGlobalLogs,
                TypeFilter    = activeLogFilter,
                Skip          = skip,
                Take          = LogPageSize
            });

            if (reset || logPage is null)
            {
                logPage = page;
            }
            else
            {
                // 追加：合併資料、保留新的 TotalCount/HasMore
                logPage.Logs.AddRange(page.Logs);
                logPage.TotalCount = page.TotalCount;
                logPage.HasMore    = page.HasMore;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入 LOG 失敗，ProjectId={ProjectId}", CurrentProject.Id);
            logPage = new AuditLogPage();
        }
        finally
        {
            isLoadingLogs = false;
        }
    }

    /// <summary>切換「含全站事件」Toggle，存 localStorage 並重載。</summary>
    private async Task ToggleIncludeGlobalAsync(ChangeEventArgs e)
    {
        includeGlobalLogs = e.Value is bool b && b;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", LogPrefKey, includeGlobalLogs ? "1" : "0");
        }
        catch
        {
            // localStorage 寫入失敗時忽略，仍以本次 session 狀態為準
        }
        await LoadLogsAsync(reset: true);
    }

    /// <summary>切換 Filter Chip，重新載入 LOG。</summary>
    private async Task ChangeLogFilterAsync(LogTypeFilter filter)
    {
        if (activeLogFilter == filter) return;
        activeLogFilter = filter;
        await LoadLogsAsync(reset: true);
    }

    /// <summary>載入更早 50 筆。</summary>
    private async Task LoadMoreLogsAsync() => await LoadLogsAsync(reset: false);

    /// <summary>
    /// 依 kpi 資料組裝 ApexCharts options 並透過 JS Interop 渲染兩張圖表。
    /// 無資料時 DOM 元素不存在，JS 端會安全跳過。
    /// </summary>
    private async Task RenderChartsAsync()
    {
        // ── 圖表 1：題型缺口達成率（100% 堆疊水平條） ──
        // formatter 函式無法 JSON 化，改由 JS 端的 renderAchievement 方法處理
        if (kpi.AchievementByType.Any(x => x.Target > 0 || x.Produced > 0))
        {
            var achievementItems = kpi.AchievementByType.Select(item => new
            {
                typeName  = item.TypeName,
                produced  = item.Produced,
                target    = item.Target,
                fillColor = ResolveBarColor(item.Produced, item.Target)
            }).ToArray();

            await JS.InvokeVoidAsync("apexInterop.renderAchievement", "chart-achievement", achievementItems);
        }

        // ── 圖表 2：依題型狀態分佈（Vertical Stacked Bar） ──
        if (kpi.StatusByType.Any(x => x.Drafts > 0 || x.InProgress > 0 || x.DoneStage > 0 || x.Adopted > 0 || x.Rejected > 0))
        {
            var categories = kpi.StatusByType.Select(x => x.TypeName).ToArray();

            var chart2Options = new
            {
                chart = new
                {
                    type = "bar",
                    height = "100%",
                    stacked = true,
                    toolbar = new { show = false },
                    fontFamily = "Noto Sans TC, sans-serif"
                },
                plotOptions = new
                {
                    bar = new
                    {
                        horizontal = false,
                        columnWidth = "55%",
                        borderRadius = 4,
                        borderRadiusApplication = "end"
                    }
                },
                series = new object[]
                {
                    new { name = "命題草稿",   data = kpi.StatusByType.Select(x => x.Drafts).ToArray() },
                    new { name = "階段進行中", data = kpi.StatusByType.Select(x => x.InProgress).ToArray() },
                    new { name = "階段完成",   data = kpi.StatusByType.Select(x => x.DoneStage).ToArray() },
                    new { name = "已採用",     data = kpi.StatusByType.Select(x => x.Adopted).ToArray() },
                    new { name = "不採用",     data = kpi.StatusByType.Select(x => x.Rejected).ToArray() }
                },
                // 色彩語意：草稿=中性灰、進行中=暖色琥珀（注意力）、完成=莫蘭迪藍、採用=鼠尾草綠、不採用=深紅
                colors = new[] { "#9CA3AF", "#F59E0B", "#6B8EAD", "#8EAB94", "#991B1B" },
                xaxis = new
                {
                    categories,
                    labels = new { style = new { colors = "#374151", fontSize = "12px" } }
                },
                yaxis = new
                {
                    title = new { text = "題目數量", style = new { fontSize = "12px", color = "#6B7280" } },
                    labels = new { style = new { colors = "#374151", fontSize = "12px" } }
                },
                legend = new
                {
                    position = "bottom",
                    horizontalAlign = "center",
                    fontSize = "12px",
                    labels = new { colors = "#374151" }
                },
                grid = new { borderColor = "#F3F4F6" },
                dataLabels = new { enabled = false },
                tooltip = new { shared = true, intersect = false }
            };

            await JS.InvokeVoidAsync("apexInterop.render", "chart-status", chart2Options);
        }
    }

    /// <summary>
    /// 依達成率決定堆疊條的顏色：
    ///   未設定目標 → 灰；0-29% → 赤陶警示；30-69% → amber；70-99% → sage；100%+ → 深綠達標
    /// </summary>
    private static string ResolveBarColor(int produced, int target)
    {
        if (target <= 0 || produced == 0) return "#E5E7EB";
        var ratio = (double)produced / target;
        return ratio >= 1.0 ? "#5C8A6A"
             : ratio >= 0.7 ? "#8EAB94"
             : ratio >= 0.3 ? "#F59E0B"
             :                "#D98A6C";
    }

    // ─── 逾期待辦輔助方法 ───────────────────────────────────────────

    /// <summary>開啟教師詳情 Modal（僅 TeacherShortage 且有明細資料時）。</summary>
    private void OpenDetail(DashboardUrgentItem item)
    {
        if (item.Source == UrgentSourceType.TeacherShortage && item.TeacherDetails is { Count: > 0 })
            selectedDetailItem = item;
    }

    /// <summary>關閉教師詳情 Modal。</summary>
    private void CloseDetail() => selectedDetailItem = null;

    /// <summary>從「{教師名} 命題進度落後」格式的 Title 中萃取教師名稱。</summary>
    private static string ExtractTeacherName(string title)
    {
        var idx = title.LastIndexOf(' ');
        return idx > 0 ? title[..idx] : title;
    }

    /// <summary>依進度達成率回傳進度條背景色 class。</summary>
    private static string AchBarClass(decimal achievement)
    {
        if (achievement >= 1.0m) return "bg-[var(--color-sage)]";
        if (achievement >= 0.7m) return "bg-[var(--color-morandi)]";
        if (achievement >= 0.3m) return "bg-amber-500";
        return "bg-[var(--color-terracotta)]";
    }

    /// <summary>依 item.TargetUrl 跳轉對應頁面（PhaseDeadline 列點擊用）。</summary>
    [Inject] private NavigationManager Nav { get; set; } = default!;
    private void NavigateToUrgent(DashboardUrgentItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.TargetUrl))
            Nav.NavigateTo(item.TargetUrl);
    }

    /// <summary>依嚴重度回傳背景底色 Tailwind class。</summary>
    private static string SeverityBgClass(UrgentSeverity s) => s switch
    {
        UrgentSeverity.Critical => "bg-rose-50",
        UrgentSeverity.Warning  => "bg-amber-50",
        _                       => "bg-stone-50"
    };

    /// <summary>依嚴重度回傳 hover 背景色 Tailwind class。</summary>
    private static string SeverityHoverClass(UrgentSeverity s) => s switch
    {
        UrgentSeverity.Critical => "hover:bg-rose-100",
        UrgentSeverity.Warning  => "hover:bg-amber-100",
        _                       => "hover:bg-stone-100"
    };

    /// <summary>依嚴重度回傳圓點顏色 Tailwind class。</summary>
    private static string SeverityDotClass(UrgentSeverity s) => s switch
    {
        UrgentSeverity.Critical => "bg-terracotta",
        UrgentSeverity.Warning  => "bg-amber-500",
        _                       => "bg-morandi"
    };

    /// <summary>Header 右側階段倒數文字顏色 class（依嚴重度，與莫蘭迪色系對齊）。</summary>
    private static string PhaseAlertTextClass(UrgentSeverity s) => s switch
    {
        UrgentSeverity.Critical => "text-terracotta",
        UrgentSeverity.Warning  => "text-amber-700",
        _                       => "text-slate-500"
    };

    /// <summary>依 source 與嚴重度回傳 Font Awesome icon class（不含 fa-solid 前綴）。</summary>
    private static string IconFor(DashboardUrgentItem item)
    {
        if (item.Source == UrgentSourceType.TeacherShortage)
            return item.Severity == UrgentSeverity.Critical ? "fa-user-xmark" : "fa-user-clock";
        return item.Severity switch
        {
            UrgentSeverity.Critical => "fa-circle-exclamation",
            UrgentSeverity.Warning  => "fa-hourglass-half",
            _                       => "fa-clock"
        };
    }

    /// <summary>依教師達成率回傳文字顏色 class。</summary>
    private static string AchClass(decimal ach) =>
          ach >= 1.0m ? "text-sage"
        : ach >= 0.7m ? "text-slate-500"
        : ach >= 0.3m ? "text-amber-700"
        :               "text-terracotta";

    // ─── 稽核歷程 Helper 方法 ────────────────────────────────────────

    /// <summary>依 Action 碼回傳中文動詞（建立/修改/刪除/登入/登出）。</summary>
    private static string ActionVerb(byte action) => action switch
    {
        0 => "建立",
        1 => "修改",
        2 => "刪除",
        3 => "登入",
        4 => "登出",
        _ => "操作"
    };

    /// <summary>依 TargetType 碼回傳目標類型標籤。</summary>
    private static string TargetTypeLabel(byte type) => type switch
    {
        0 => "使用者",
        1 => "角色",
        2 => "梯次",
        3 => "試題",
        4 => "公告",
        5 => "教師",
        6 => "審題",
        _ => "資料"
    };

    /// <summary>依 Action 碼回傳圖示背景 + 文字顏色 class。</summary>
    private static string LogIconBgClass(byte action) => action switch
    {
        0 => "bg-emerald-50 text-[var(--color-sage)]",
        1 => "bg-blue-50 text-[var(--color-morandi)]",
        2 => "bg-rose-50 text-[var(--color-terracotta)]",
        3 => "bg-indigo-50 text-indigo-600",     // 登入：迎入暖意
        4 => "bg-stone-100 text-stone-500",       // 登出：離開中性
        _ => "bg-stone-100 text-slate-500"
    };

    /// <summary>依 Action 碼回傳 Font Awesome icon class（含前綴）。</summary>
    private static string LogIconClass(byte action) => action switch
    {
        0 => "fa-plus",
        1 => "fa-pen",
        2 => "fa-trash",
        3 => "fa-arrow-right-to-bracket",   // 登入箭頭進入
        4 => "fa-arrow-right-from-bracket", // 登出箭頭離開
        _ => "fa-circle-info"
    };

    /// <summary>
    /// 回傳相對時間字串（剛剛 / N 分鐘前 / N 小時前 / N 天前 / MM/dd HH:mm）。
    /// </summary>
    private static string FormatRelativeTime(DateTime time)
    {
        var diff = DateTime.Now - time;
        if (diff.TotalSeconds < 60) return "剛剛";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} 分鐘前";
        if (diff.TotalHours   < 24) return $"{(int)diff.TotalHours} 小時前";
        if (diff.TotalDays    <  7) return $"{(int)diff.TotalDays} 天前";
        return time.ToString("MM/dd HH:mm");
    }

    // ─── 卡片 3 Pill Badge Helper ────────────────────────────────────

    /// <summary>依當前審題階段回傳 Pill Badge 文字。</summary>
    private static string ReviewPhaseLabel(MT.Models.ReviewPhaseLabel phase) => phase switch
    {
        MT.Models.ReviewPhaseLabel.Peer   => "互審階段",
        MT.Models.ReviewPhaseLabel.Expert => "專審階段",
        MT.Models.ReviewPhaseLabel.Final  => "總召審題",
        MT.Models.ReviewPhaseLabel.Closed => "已結案",
        _                                  => "非審題階段"
    };

    /// <summary>
    /// 依當前審題階段回傳 Pill Badge 顏色 class（border + bg + text）。
    /// 配色貼近莫蘭迪色系，避免高飽和度刺激年長使用者視覺。
    /// </summary>
    private static string ReviewPhasePillClass(MT.Models.ReviewPhaseLabel phase) => phase switch
    {
        MT.Models.ReviewPhaseLabel.Peer   => "bg-blue-50 text-[var(--color-morandi)] border-blue-200",
        MT.Models.ReviewPhaseLabel.Expert => "bg-violet-50 text-violet-700 border-violet-200",
        MT.Models.ReviewPhaseLabel.Final  => "bg-amber-50 text-amber-700 border-amber-200",
        MT.Models.ReviewPhaseLabel.Closed => "bg-stone-200 text-stone-700 border-stone-300",
        _                                  => "bg-stone-100 text-stone-500 border-stone-200"
    };

    /// <summary>
    /// 頁面卸載時銷毀所有圖表實例，釋放 JS 端記憶體。
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("apexInterop.destroy", "chart-achievement");
            await JS.InvokeVoidAsync("apexInterop.destroy", "chart-status");
        }
        catch
        {
            // 頁面已卸載時 JS Runtime 可能不可用，安全忽略
        }
    }
}
