@* ====================================================================== *@
@*  Overview — 命題總覽（唯讀）                                             *@
@*  路由：/overview                                                        *@
@*  功能：當前梯次全部試題一覽、7 階段狀態軌跡、詳情面板（題目內容）         *@
@*  邏輯分層：UI / 事件處理 → Pages；資料組裝 → Services/OverviewService    *@
@* ====================================================================== *@
@page "/overview"
@inject IOverviewService OverviewService
@inject IPhaseTransitionCoordinator PhaseCoordinator
@inject NavigationManager Nav

<div tabindex="-1" @onkeydown="HandleKeyDown" @onkeydown:stopPropagation="false" class="contents">
<div class="flex-grow flex flex-col w-full mx-auto">

    <!-- Header -->
    <div class="sticky top-16 z-30 px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/95 backdrop-blur-md border-b border-gray-200 shadow-sm">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1">
                        <li class="inline-flex items-center">
                            <NavLink href="" Match="NavLinkMatch.All" class="inline-flex items-center hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-slate-main">命題總覽</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-layer-group text-[var(--color-morandi)]"></i> 當前梯次：命題總覽
                </h1>
                    <p class="text-sm text-gray-500 mt-1">全梯次試題列表、題目內容與審題全局結果檢視。</p>
            </div>
        </div>
    </div>

    <!-- Body -->
    <div class="flex flex-col p-4 sm:p-6 lg:p-8 pb-12">

        <!-- Statistics -->
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4 mb-6 shrink-0">
            @StatCard("總題數", TotalQuestions(), "fa-hashtag", "text-morandi", "text-slate-main")
            @StatCard("命題進行中", SumCounts([QuestionStatus.Draft, QuestionStatus.Completed]), "fa-pen", "text-sage", "text-slate-main")
            @StatCard("已採用", SumCounts([QuestionStatus.Adopted, QuestionStatus.Archived]), "fa-circle-check", "text-sage", "text-sage")
            @StatCard("待修編", result.PendingRevisionCount, "fa-rotate-left", "text-terracotta", "text-terracotta")
            @* 各審查環節：依當前梯次 PhaseCode 動態計算對應審題階段「待審 + 已給意見」總和。
               後端事實 — 互審期間題目實際停在 Status=2 (Submitted) 不會升到 PeerReviewing(3)；
               專審/總審涵蓋 EnsurePhaseTransitionAsync 各 case 的所有 fromStatuses（避免邊界殘留漏算）。
               非當前階段的格子灰掉並顯示 0，提示使用者「現在不在這個審題階段」。 *@
            @{
                var peerBucket = ReviewBucket(3);
                var expBucket  = ReviewBucket(5);
                var finBucket  = ReviewBucket(7);
            }
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 col-span-2 md:col-span-4 lg:col-span-1 border-l-4 border-l-morandi">
                <div class="text-gray-500 text-xs font-bold mb-1">各審查環節</div>
                <div class="text-sm font-bold text-slate-main flex gap-2 w-full justify-between items-end mt-2">
                    <div class="text-center w-1/3">
                        <span class="block text-gray-400 text-xs">互審</span>
                        <span class="text-lg @(peerBucket < 0 ? "text-gray-300" : "text-morandi font-bold")">@(peerBucket < 0 ? 0 : peerBucket)</span>
                    </div>
                    <div class="text-center w-1/3">
                        <span class="block text-gray-400 text-xs">專審</span>
                        <span class="text-lg @(expBucket < 0 ? "text-gray-300" : "text-morandi font-bold")">@(expBucket < 0 ? 0 : expBucket)</span>
                    </div>
                    <div class="text-center w-1/3">
                        <span class="block text-gray-400 text-xs">總審</span>
                        <span class="text-lg @(finBucket < 0 ? "text-gray-300" : "text-morandi font-bold")">@(finBucket < 0 ? 0 : finBucket)</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main panel -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 flex flex-col relative overflow-hidden">

            <!-- Filters -->
            <div class="rounded-t-xl p-4 border-b border-gray-100 bg-gray-50 flex flex-col md:flex-row gap-3 items-start md:items-center justify-between shrink-0">
                <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                    <div class="w-full md:w-64">
                        <DebouncedSearchInput Value="@(filter.Keyword ?? "")" ValueChanged="OnKeywordChanged"
                            Placeholder="搜尋題號 / 題幹 / 命題教師..." />
                    </div>
                    <select value="@queryTypeId" @onchange="OnTypeFilterChanged"
                        class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="">所有題型</option>
                        @* 「有才顯示」：只列梯次內實際存在的題型（由 OverviewService.TypeIdCounts 計算，忽略 filter）；
                           隱藏的精選單選題（HiddenTypeIds）+ CWT/LCT 模式過濾由 GetVisibleTypeIdToKeyForProject 一併處理。 *@
                        @foreach (var (id, key) in QuestionConstants.GetVisibleTypeIdToKeyForProject(
                            CurrentProject?.ProjectType ?? ProjectType.Cwt,
                            CurrentProject?.ExamLevel))
                        {
                            if (!result.TypeIdCounts.ContainsKey(id)) continue;
                            <option value="@id">@QuestionConstants.TypeLabels.GetValueOrDefault(key, key)</option>
                        }
                    </select>
                    @* 狀態篩選：選項與列表「當前狀態」Badge 文字 100% 對齊（見 OverviewStatusKey + ResolveDisplayStatus）。
                       不直接拿 QuestionStatus.Labels：原 13 個 byte label 多數會被 ResolveDisplayStatus 重寫成「待審 / 已給意見 / OO 完成 / 修題已送出 / 未完成命題」等 Overview 專用 Badge，
                       直接列出來會出現「使用者選了某 label 但列表沒有對應 Badge」的對不齊。
                       動態渲染：只列梯次實際存在的 key（result.StatusKeyCounts 由 OverviewService 忽略所有 filter 後計算），
                       整個 optgroup 內全空時整組省略，避免使用者選了卻篩到 0 筆。 *@
                    <select value="@queryStatus" @onchange="OnStatusFilterChanged"
                        class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="">所有狀態</option>
                        @foreach (var (groupLabel, options) in OverviewStatusKey.Groups)
                        {
                            var visibleOptions = options.Where(o => result.StatusKeyCounts.ContainsKey(o.Key)).ToArray();
                            if (visibleOptions.Length == 0) continue;
                            <optgroup label="@groupLabel">
                                @foreach (var (key, label) in visibleOptions)
                                {
                                    <option value="@key">@label</option>
                                }
                            </optgroup>
                        }
                    </select>
                    @* 命題教師篩選：下拉只列此專案有命題紀錄的老師（含已刪題目者） *@
                    <select value="@queryCreatorId" @onchange="OnCreatorFilterChanged"
                        class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="">所有命題教師</option>
                        @foreach (var c in creatorOptions)
                        {
                            <option value="@c.Id">@c.DisplayName（@c.QuestionCount）</option>
                        }
                    </select>
                </div>
                <div class="text-sm text-gray-500 font-medium">
                    共 <span class="text-morandi font-bold">@result.TotalCount</span> 題
                </div>
            </div>

            @* 水平捲動容器：包住 Header + List，narrow 時整塊一起橫向捲動，
               header 與 row 的 min-w-[1080px] 才能真正撐開不被父層 overflow-hidden 壓扁 *@
            @if (isLoading)
            {
                <div class="p-8 text-center text-gray-400 text-sm flex-grow">
                    <i class="fa-solid fa-spinner fa-spin mr-2"></i> 載入中…
                </div>
            }
            else if (result.Items.Count == 0)
            {
                <div class="flex-grow p-4">
                    <EmptyState IconClass="fa-folder-open" Message="目前尚無題目" SubMessage="當前梯次沒有任何題目可檢視。" />
                </div>
            }
            else
            {
                @* 單層 overflow-auto 同時管橫向 + 縱向，避免巢狀雙 overflow 導致內層被擠扁；
                   header 用 sticky top-0 保持在頂部，narrow 時整體水平捲動，header 與 row 對齊 *@
                <div>
                    <div class="min-w-[1080px]">
                        <!-- Table Header -->
                        <div class="grid grid-cols-12 gap-4 px-6 py-3 border-b border-gray-200 bg-white text-xs font-bold text-gray-500 uppercase tracking-wider shadow-sm">
                            <div class="col-span-2">題號</div>
                            <div class="col-span-1">命題教師</div>
                            <div class="col-span-1">題型</div>
                            <div class="col-span-1">等級/難度</div>
                            <div class="col-span-6 min-w-[480px] text-center">三審狀態軌跡（7 階段）</div>
                            <div class="col-span-1 text-center">當前狀態</div>
                        </div>

                    @* 題組類拆列：建立「母題 Status 索引」供子題列在母題=結案不採用(11) 時 fallback 強制顯示 *@
                    @{
                        var parentStatusById = result.Items
                            .Where(i => i.SubQuestionId is null)
                            .GroupBy(i => i.Id)
                            .ToDictionary(g => g.Key, g => g.First().Status);
                    }
                    @foreach (var item in result.Items)
                    {
                        var isSubRow = item.SubQuestionId.HasValue;
                        @* allResponded：在進入 markup 前先算好，供 stepper 與右側狀態 Badge 共用，避免重複查 dict
                           母題、子題各自獨立計算 — key 用 (Id, SubQuestionId) tuple *@
                        var allResponded = result.AllReviewersResponded.GetValueOrDefault((item.Id, item.SubQuestionId));
                        <div @onclick="() => OpenDetailAsync(item.Id, item.SubQuestionId)"
                            class="grid grid-cols-12 gap-4 px-6 py-4 border-b border-gray-100 relative hover:z-10 hover:bg-blue-50/40 hover:shadow-[inset_4px_0_0_var(--color-morandi),0_6px_16px_-4px_rgba(0,0,0,0.18)] transition-all items-center cursor-pointer group">
                            <div class="col-span-2 flex flex-col">
                                <span class="font-bold text-slate-main text-sm group-hover:text-morandi transition-colors inline-flex items-center gap-1">
                                    @if (isSubRow)
                                    {
                                        @* 子題列：縮排 + 樹枝符號（沿用 Reviews.razor 的視覺語彙） *@
                                        <span class="inline-flex items-center text-xs text-gray-400 mr-1" aria-hidden="true">
                                            <i class="fa-solid fa-turn-up rotate-90"></i>
                                        </span>
                                    }
                                    @* 子題列：題號後加 -NN（兩位數零填）；SubSortOrder 是 DB 1-based，直接用不要 +1 *@
                                    <span>@(isSubRow ? $"{item.QuestionCode}-{(item.SubSortOrder ?? 1):00}" : item.QuestionCode)</span>
                                </span>
                                <span class="text-xs text-gray-400 mt-0.5">@item.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                                @if (!isSubRow && item.SubQuestionCount > 0)
                                {
                                    <span class="inline-flex items-center self-start mt-1 px-1.5 py-0.5 bg-morandi/10 text-morandi rounded text-xs font-bold border border-morandi/20">
                                        @item.SubQuestionCount 子題
                                    </span>
                                }
                                @* 子題列題號已加 -NN 後綴（見上方），不再顯示額外「第 N 子題」徽章 *@
                            </div>
                            <!-- 命題教師 -->
                            <div class="col-span-1 flex items-center gap-1.5 text-sm text-slate-main min-w-0">
                                <i class="fa-regular fa-user text-morandi shrink-0"></i>
                                <span class="font-medium truncate" title="@item.CreatorName">
                                    @(string.IsNullOrWhiteSpace(item.CreatorName) ? "—" : item.CreatorName)
                                </span>
                            </div>
                            <div class="col-span-1">
                                <span class="inline-block px-2 py-1 bg-gray-100 text-gray-600 rounded text-xs font-bold border border-gray-200">
                                    @QuestionConstants.TypeLabels.GetValueOrDefault(item.TypeKey, "未知")
                                </span>
                            </div>
                            <div class="col-span-1 flex flex-col items-start gap-1">
                                @if (item.Level is not null)
                                {
                                    <span class="inline-block px-1.5 py-0.5 bg-blue-50 text-morandi rounded text-xs font-bold border border-blue-100">@OverviewService.LevelLabel(item.TypeKey, item.Level, CurrentProject?.ProjectType ?? ProjectType.Cwt)</span>
                                }
                                @if (item.Difficulty is byte df)
                                {
                                    <span class="inline-block px-1.5 py-0.5 bg-orange-50 text-terracotta rounded text-xs font-bold border border-orange-100">@QuestionConstants.DifficultyLabels.GetValueOrDefault(df, "")</span>
                                }
                            </div>
                            @* col-span-6 在 min-w-[1080px] 容器內理應 ~510px，但實際上 fr 配置會被內容多寡擠壓，
                               直接給 min-w-[480px] 鎖住 stepper 所需空間，確保 7 顆球與連線不被壓縮 *@
                            <div class="col-span-6 min-w-[480px]">
                                <PhaseProgressStepper Status="item.Status"
                                                      CurrentPhaseCode="result.CurrentPhaseCode"
                                                      HasRepliedThisStage="item.HasRepliedThisStage"
                                                      AllReviewersResponded="allResponded" />
                            </div>
                            <div class="col-span-1 flex flex-col items-center gap-1.5">
                                @if (item.IsDeleted)
                                {
                                    <StatusBadge StatusText="命題刪除" BadgeType="danger" Compact="true" />
                                    <button @onclick:stopPropagation="true"
                                            @onclick="() => RestoreAsync(item.Id, item.QuestionCode)"
                                            title="復原此題"
                                            class="text-xs text-sage hover:text-emerald-700 font-bold cursor-pointer focus:outline-none">
                                        <i class="fa-solid fa-rotate-left mr-0.5"></i> 復原
                                    </button>
                                }
                                else
                                {
                                    @* 當前狀態 Badge：依「題目 Status × 梯次 PhaseCode × 本人是否送出修題 × 全體審題者是否已給意見」四維度判定。
                                       母題結案淘汰例外：父母題 Status=11（結案不採用）時，子題列強制 fallback 為「結案不採用」
                                       allResponded 已於 foreach 頂端算好，與 stepper 共用 *@
                                    byte? parentStatusForFallback = isSubRow && parentStatusById.TryGetValue(item.Id, out var ps) ? ps : null;
                                    var display = ResolveDisplayStatus(item.Status, result.CurrentPhaseCode, item.HasRepliedThisStage, allResponded, parentStatusForFallback);
                                    @if (display.IsAwaitingNext)
                                    {
                                        @* 「OO 完成」等待下一階段：用莫蘭迪藍 inline badge，與綠色「修題已送出 / 完成」做語意區隔 *@
                                        <span class="inline-flex items-center px-2 py-0.5 bg-morandi/10 text-morandi rounded text-xs font-bold whitespace-nowrap border border-morandi/20">
                                            <i class="fa-solid fa-circle-check text-xs mr-1"></i>@display.Text
                                        </span>
                                    }
                                    else
                                    {
                                        <StatusBadge StatusText="@display.Text" BadgeType="@display.BadgeType" Compact="true" />
                                    }
                                }
                            </div>
                        </div>
                    }
                    </div>
                </div>

                <Pagination CurrentPage="@filter.Page" TotalPages="@result.PageCount" IsLoading="@isLoading" OnPageChanged="GoToPageAsync" />
            }
        </div>
    </div>
</div>

<!-- 詳情 Slide-over -->
<CustomModal @bind-IsVisible="showDetailModal" Type="CustomModal.ModalType.SlideOver" Title="@CurrentModalTitle" MaxWidth="max-w-3xl">
    <ChildContent>
        @if (detailItem is null || detailData is null)
        {
            <div class="p-8 text-center text-gray-400 text-sm">
                <i class="fa-solid fa-spinner fa-spin mr-2"></i> 載入中…
            </div>
        }
        else
        {
            <!-- 上半：題目內容（複用 QuestionPreviews 元件） -->
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-6">
                <div class="flex justify-between items-start border-b border-gray-100 pb-4 mb-4">
                    <div>
                        <div class="text-xs text-gray-400 mb-1">題號</div>
                        @* 子題聚焦模式：顯示 母題碼-子題序號（-01/-02/-03）；母題模式顯示原碼 *@
                        <div class="text-base font-mono font-bold text-slate-main">@FormattedDetailCode</div>
                    </div>
                    <div class="text-right">
                        <div class="text-xs text-gray-400 mb-1">題型 / 等級 / 難易度</div>
                        <div class="text-sm font-bold text-gray-800">
                            <span>@QuestionConstants.TypeLabels.GetValueOrDefault(detailItem.TypeKey, "")</span>
                            @if (detailItem.Level is not null)
                            {
                                <span> / <span class="text-morandi">@OverviewService.LevelLabel(detailItem.TypeKey, detailItem.Level, CurrentProject?.ProjectType ?? ProjectType.Cwt)</span></span>
                            }
                            @if (detailItem.Difficulty is byte d)
                            {
                                <span> / <span class="text-terracotta">@QuestionConstants.DifficultyLabels.GetValueOrDefault(d, "")</span></span>
                            }
                        </div>
                    </div>
                </div>

                <h3 class="text-xs font-bold text-morandi uppercase tracking-wider mb-2">題目內容</h3>
                @* 不掛粗粒度 data-annot-target —— PreviewXxx 元件內部已備齊細粒度容器
                   （stem / optionA-D / article / subStem.{idx} / subOption*.{idx} 等），
                   hover 時直接傳 annotation 真實 fieldKey + AnchorStart/End，由 annotation.js 在對應容器內精準定位螢光筆 *@
                <div class="bg-gray-50 rounded-lg p-4 border border-gray-100">
                    @RenderPreview()
                </div>
            </div>

            <!-- 中段：劃記評語卡片（hover 卡片觸發上方螢光筆） -->
            @if (detailAnnotations.Count > 0)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
                    <div class="px-5 py-3 border-b border-gray-100 bg-amber-50/40 flex items-center gap-2">
                        <i class="fa-solid fa-highlighter text-amber-500"></i>
                        <h3 class="text-sm font-bold text-slate-main">劃記評語</h3>
                        <span class="text-xs text-gray-400 ml-auto">滑鼠移到卡片查看對應位置・共 @detailAnnotations.Count 筆</span>
                    </div>
                    <div class="p-4">
                        @* GetAnnotationsForUnitAsync 已用 (QuestionId, SubQuestionId) NULL-safe 比對，
                           回傳全部是同一單元的劃記 → 不再分組，直接依 Stage 升冪排序展開卡片 *@
                        <div class="space-y-2">
                            @foreach (var card in detailAnnotations.OrderBy(a => a.Stage).ThenBy(a => a.CreatedAt))
                            {
                                        var stageCss = card.Stage switch
                                        {
                                            1 => "bg-morandi/15 text-morandi border-morandi/30",      // 互審
                                            2 => "bg-terracotta/15 text-terracotta border-terracotta/30", // 專審
                                            3 => "bg-red-50 text-red-700 border-red-200",            // 總審
                                            _ => "bg-gray-100 text-gray-500 border-gray-300"
                                        };
                                        var isPinned = pinnedAnnotationId == card.AnnotationId;
                                        var pinCss = isPinned
                                            ? "border-amber-400 bg-amber-50 ring-2 ring-amber-200 shadow-md"
                                            : "border-gray-200 hover:border-amber-300 hover:bg-amber-50/30 hover:shadow-md";
                                        <div @onmouseenter="() => OnAnnotationHoverAsync(card)"
                                             @onmouseleave="OnAnnotationLeaveAsync"
                                             @onclick="() => OnAnnotationClickAsync(card)"
                                             class="border rounded-lg p-3 transition-all cursor-pointer @pinCss">
                                            <div class="flex flex-wrap items-center gap-2 mb-2">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold border bg-gray-100 text-gray-600 border-gray-200">
                                                    @card.FieldLabel
                                                </span>
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold border @stageCss">
                                                    @card.StageLabel
                                                </span>
                                                @if (isPinned)
                                                {
                                                    @* 釘選徽章：提示使用者「再次點按可取消」 *@
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-bold border bg-amber-100 text-amber-700 border-amber-300">
                                                        <i class="fa-solid fa-thumbtack text-xs"></i> 已釘選（再點取消）
                                                    </span>
                                                }
                                                <span class="text-xs text-gray-400 ml-auto">@card.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(card.SelectedText))
                                            {
                                                <div class="text-xs text-gray-500 mb-1">劃記原文：</div>
                                                <div class="bg-amber-100 text-gray-800 px-2 py-1 rounded text-sm mb-2 font-serif break-words">
                                                    @card.SelectedText
                                                </div>
                                            }
                                            <div class="text-xs text-gray-500 mb-1">評語：</div>
                                            <div class="text-sm text-slate-main mb-2 whitespace-pre-wrap break-words">@card.Comment</div>

                                            <div class="flex flex-wrap items-center gap-2 pt-2 border-t border-dashed border-gray-200 text-xs">
                                                <span class="text-gray-500">建立人：<span class="font-bold text-slate-main">@(string.IsNullOrWhiteSpace(card.CreatorName) ? "—" : card.CreatorName)</span></span>
                                                @{
                                                    var (respText, respCss, respIcon) = card.ResponseState switch
                                                    {
                                                        1 => ("命題者確認修改", "bg-sage/15 text-sage border-sage/30",         "fa-check"),
                                                        2 => ("命題者不修改", "bg-red-50 text-red-700 border-red-200",       "fa-xmark"),
                                                        _ => ("命題者未回應",     "bg-amber-50 text-amber-700 border-amber-200", "fa-hourglass-half")
                                                    };
                                                }
                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded border text-xs font-bold @respCss">
                                                    <i class="fa-solid @respIcon"></i> @respText
                                                </span>
                                                @if (card.ResponseState == 2 && !string.IsNullOrWhiteSpace(card.NoChangeReason))
                                                {
                                                    <span class="text-gray-500">不修改理由：<span class="text-slate-main">@card.NoChangeReason</span></span>
                                                }
                                            </div>
                                        </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- 下半：審題意見歷程（管理員視角，不匿名） -->
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-5 py-3 border-b border-gray-100 bg-morandi/5 flex items-center gap-2">
                    <i class="fa-solid fa-clipboard-list text-morandi"></i>
                    <h3 class="text-sm font-bold text-slate-main">審題意見歷程</h3>
                    <span class="text-xs text-gray-400 ml-auto">管理員視角・顯示真實姓名</span>
                </div>
                <ReviewHistoryTimeline Entries="detailHistory" ShowActorName="true" ShowUnitBadge="true" />
            </div>
        }
    </ChildContent>
</CustomModal>
</div>

@code {
    [CascadingParameter(Name = "CurrentProject")]
    private ProjectSwitcherItem? CurrentProject { get; set; }

    /// <summary>從 query string 接收 Dashboard 的教師篩選跳轉（/overview?creatorId=X）。</summary>
    [SupplyParameterFromQuery]
    public int? CreatorId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    private OverviewFilter filter = new();
    private OverviewListResult result = new();
    /// <summary>
    /// 預設 true：避免 CascadingParameter CurrentProject 尚未送達 / OnParametersSetAsync 內前置 await 期間，
    /// UI 因 result.Items.Count==0 閃現「目前尚無題目」(修補 A)。
    /// </summary>
    private bool isLoading = true;

    // razor 端 dropdown 用字串值，事件觸發時轉成 byte/int 寫進 filter
    private string queryTypeId    = "";
    private string queryStatus    = "";
    private string queryCreatorId = "";

    // 命題教師下拉選項（依專案載入；切換梯次時重抓）
    private List<OverviewCreatorOption> creatorOptions = [];

    private bool showDetailModal;
    private QuestionListItem? detailItem;
    private QuestionFormData? detailData;
    private List<ReviewHistoryEntry> detailHistory = new();

    /// <summary>當前 SlideOver 聚焦的子題單元 Id；NULL = 母題單元（傳給 GetAnnotationsForUnitAsync 用）</summary>
    private int? detailSubQuestionId;

    /// <summary>當前單元的劃記評語卡片清單（hover 卡片時觸發螢光筆）</summary>
    private List<OverviewAnnotationCard> detailAnnotations = new();

    /// <summary>annotation.js 是否已 init（避免重複 init）</summary>
    private bool annotJsInited;

    /// <summary>
    /// 被「點按釘選」的劃記 Id（null = 無釘選）。互動模式：
    ///   hover 卡片        → 螢光筆短暫亮起；
    ///   leave 卡片        → 若無 pinned 則熄滅、若有 pinned 則切回該 pinned；
    ///   click 卡片        → 釘選 + 渲染 + scroll 錨點；
    ///   click 已釘選卡片  → 取消釘選 + 熄滅。
    /// 切換子題單元 / 重新開啟 SlideOver 時 reset。
    /// </summary>
    private int? pinnedAnnotationId;

    // 已載入的 ProjectId 守門 —— 避免父層重渲染時重跑 LoadAsync 導致列表骨架閃爍
    private int? loadedProjectId;

    protected override async Task OnParametersSetAsync()
    {
        if (CurrentProject is null) return;
        if (loadedProjectId == CurrentProject.Id) return;   // 同專案重派 → 不重載
        loadedProjectId = CurrentProject.Id;

        // 修補 A：立刻把 isLoading 提升並 render 一次，避免「creator 載入 + LoadAsync」期間
        // result.Items.Count==0 觸發「目前尚無題目」空狀態閃現
        isLoading = true;
        StateHasChanged();

        // 修補 B：刪掉 razor 端的 PhaseCoordinator.EnsureAsync —— OverviewService.LoadAsync 內已有
        // 60 秒去重的呼叫，這裡再跑一次純贅餘（多一個序列 round-trip）

        // 修補 C：並行載入教師選項 + 主列表
        //  - 先「樂觀地」依 query string CreatorId 設 filter，並行兩個 Task
        //  - 完成後再驗證 CreatorId 是否真存在於 options；若不存在則清空 + 重 Load（罕見路徑）
        if (CreatorId.HasValue)
        {
            queryCreatorId   = CreatorId.Value.ToString();
            filter.CreatorId = CreatorId.Value;
        }
        else
        {
            queryCreatorId   = "";
            filter.CreatorId = null;
        }

        var creatorTask = OverviewService.GetCreatorOptionsAsync(CurrentProject.Id);
        var loadTask    = LoadAsync();
        await Task.WhenAll(creatorTask, loadTask);
        creatorOptions = creatorTask.Result;

        // CreatorId 樂觀套用後的後驗證：若該教師不在 options 內（例如 Dashboard 跳轉帶到舊資料），清空篩選重 Load
        if (CreatorId.HasValue && !creatorOptions.Any(o => o.Id == CreatorId.Value))
        {
            queryCreatorId   = "";
            filter.CreatorId = null;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        if (CurrentProject is null) return;
        isLoading = true;
        // 立刻 render「載入中…」狀態（被 GoToPage / 篩選變更等 caller 觸發時也保證 UI 同步）
        StateHasChanged();
        try
        {
            result = await OverviewService.LoadAsync(CurrentProject.Id, filter);

            // 守門：當前選中的 StatusKey 已不在動態下拉選項中（例如資料變動或切到無此狀態的梯次），
            // 自動清空為「所有狀態」並重新載入；避免 UI 顯示「所有狀態」但底層仍持有失效篩選。
            if (!string.IsNullOrEmpty(queryStatus) && !result.StatusKeyCounts.ContainsKey(queryStatus))
            {
                queryStatus      = "";
                filter.StatusKey = null;
                filter.Page      = 1;
                result = await OverviewService.LoadAsync(CurrentProject.Id, filter);
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OnKeywordChanged(string? keyword)
    {
        filter.Keyword = keyword;
        filter.Page = 1;
        await LoadAsync();
    }

    private async Task OnTypeFilterChanged(ChangeEventArgs e)
    {
        queryTypeId = e.Value?.ToString() ?? "";
        filter.QuestionTypeId = int.TryParse(queryTypeId, out var t) ? t : null;
        filter.Page = 1;
        await LoadAsync();
    }

    private async Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        queryStatus = e.Value?.ToString() ?? "";
        filter.StatusKey = string.IsNullOrWhiteSpace(queryStatus) ? null : queryStatus;
        filter.Page = 1;
        await LoadAsync();
    }

    private async Task OnCreatorFilterChanged(ChangeEventArgs e)
    {
        queryCreatorId = e.Value?.ToString() ?? "";
        filter.CreatorId = int.TryParse(queryCreatorId, out var cid) ? cid : null;
        filter.Page = 1;
        await LoadAsync();
    }

    private async Task GoToPageAsync(int page)
    {
        if (page < 1 || page > result.PageCount || page == filter.Page) return;
        filter.Page = page;
        await LoadAsync();
    }

    private async Task OpenDetailAsync(int questionId, int? subQuestionId = null)
    {
        // 對於題組類拆列：可能同一 questionId 同時有母題列與多筆子題列，先精準對位
        detailItem = result.Items.FirstOrDefault(x => x.Id == questionId && x.SubQuestionId == subQuestionId)
                  ?? result.Items.FirstOrDefault(x => x.Id == questionId);
        detailSubQuestionId = subQuestionId;
        detailData          = null;
        detailHistory       = new();
        detailAnnotations   = new();
        pinnedAnnotationId  = null;
        @* modalTitle / 題號顯示已改為 computed property（CurrentModalTitle / FormattedDetailCode），會在 detailData 載入後自動套用子題編號 *@
        showDetailModal = true;
        // 進入新單元時先清掉舊高亮 + 清空 snapshot，避免殘留（clearAll 同時清 DOM 與 snapshot）
        try { await JS.InvokeVoidAsync("annotation.clearAll"); } catch { }
        StateHasChanged();

        // 並行載入題目詳情、審題歷程、劃記評語
        var dataTask        = OverviewService.GetDetailAsync(questionId);
        // 單元視角：母題列只看母題歷程、子題列只看該子題歷程（不混合，避免管理員誤判）
        var historyTask     = OverviewService.GetReviewHistoryAsync(questionId, subQuestionId);
        var annotationsTask = OverviewService.GetAnnotationsForUnitAsync(questionId, subQuestionId);
        await Task.WhenAll(dataTask, historyTask, annotationsTask);
        detailData        = dataTask.Result;
        detailHistory     = historyTask.Result;
        detailAnnotations = annotationsTask.Result;
        StateHasChanged();
    }

    /// <summary>
    /// 詳情 SlideOver 開啟時初始化 annotation.js（純唯讀模式，不需要 .NET 回呼）。
    /// 關閉時呼叫 dispose。切換不同單元（detailItem/detailSubQuestionId 變更）時，OpenDetailAsync 內已先 clearHighlights。
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (showDetailModal && !annotJsInited)
        {
            try
            {
                // 純唯讀：dotnetRef 傳 null（annotation.js init 已支援），不彈加註浮層按鈕
                await JS.InvokeVoidAsync("annotation.init", null, new { readOnly = true });
                annotJsInited = true;
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"[Overview] annotation.init failed: {ex.Message}");
            }
        }
        else if (!showDetailModal && annotJsInited)
        {
            try { await JS.InvokeVoidAsync("annotation.dispose"); } catch { }
            annotJsInited = false;
        }
    }

    /// <summary>
    /// hover 進入卡片 → 渲染對應螢光筆（短暫）。若已是 pinned 卡片則略過（避免重複 render）。
    /// 不 scroll：scroll 只在 click 釘選時做（避免使用者只是滑過畫面就跳動）。
    /// </summary>
    private async Task OnAnnotationHoverAsync(OverviewAnnotationCard card)
    {
        if (!annotJsInited) return;
        if (pinnedAnnotationId == card.AnnotationId) return;
        await RenderHighlightAsync(card, scrollTo: false);
    }

    /// <summary>
    /// 離開卡片 → 若無 pinned 則 clearAll；若有 pinned 則切回 pinned 的螢光筆。
    /// </summary>
    private async Task OnAnnotationLeaveAsync()
    {
        if (!annotJsInited) return;
        if (pinnedAnnotationId is null)
        {
            try { await JS.InvokeVoidAsync("annotation.clearAll"); }
            catch (Exception ex) { Console.Error.WriteLine($"[Overview] clearAll failed: {ex.Message}"); }
            return;
        }
        // 回到 pinned 狀態
        var pinned = detailAnnotations.FirstOrDefault(c => c.AnnotationId == pinnedAnnotationId.Value);
        if (pinned is not null)
        {
            await RenderHighlightAsync(pinned, scrollTo: false);
        }
        else
        {
            // pinned 卡片不在當前 list（理論不應發生）→ 清掉狀態
            pinnedAnnotationId = null;
            try { await JS.InvokeVoidAsync("annotation.clearAll"); } catch { }
        }
    }

    /// <summary>
    /// 點按卡片：
    ///   未釘選 → 釘選 + render + scroll 錨點過去
    ///   已釘選同一張 → 取消釘選 + clearAll
    /// 點不同卡片自動換 pinned。
    /// </summary>
    private async Task OnAnnotationClickAsync(OverviewAnnotationCard card)
    {
        if (!annotJsInited) return;
        if (pinnedAnnotationId == card.AnnotationId)
        {
            pinnedAnnotationId = null;
            try { await JS.InvokeVoidAsync("annotation.clearAll"); }
            catch (Exception ex) { Console.Error.WriteLine($"[Overview] clearAll failed: {ex.Message}"); }
            return;
        }
        pinnedAnnotationId = card.AnnotationId;
        await RenderHighlightAsync(card, scrollTo: true);
    }

    /// <summary>共用：把 annotation 物件丟給 JS render，並選擇是否 scroll 到該位置。</summary>
    private async Task RenderHighlightAsync(OverviewAnnotationCard card, bool scrollTo)
    {
        var payload = new[]
        {
            new
            {
                id            = card.AnnotationId,
                fieldKey      = card.FieldKey,
                anchorStart   = card.AnchorStart,
                anchorEnd     = card.AnchorEnd,
                selectedText  = card.SelectedText,
                comment       = card.Comment,
                responseState = card.ResponseState
            }
        };
        try
        {
            await JS.InvokeVoidAsync("annotation.renderHighlights", (object)payload);
            if (scrollTo)
                await JS.InvokeVoidAsync("annotation.scrollToAnnotation", card.AnnotationId);
        }
        catch (Exception ex) { Console.Error.WriteLine($"[Overview] highlight failed: {ex.Message}"); }
    }

    /// <summary>ESC 鍵關閉詳情 SlideOver（補 CustomModal 未支援的鍵盤關閉行為，避免動到共用元件）。</summary>
    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (showDetailModal && e.Key == "Escape")
        {
            showDetailModal = false;
        }
    }

    private async Task RestoreAsync(int questionId, string questionCode)
    {
        var auth = await AuthState;
        var claim = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(claim, out var uid)) return;

        var confirm = await JS.InvokeAsync<SwalResult>("Swal.fire", new
        {
            icon = "question",
            title = $"確定復原 {questionCode}？",
            text = "題目將回到原本的狀態（IsDeleted = 0）",
            showCancelButton = true,
            confirmButtonText = "確定復原",
            cancelButtonText = "取消",
            confirmButtonColor = "#8EAB94",
            cancelButtonColor  = "#6B8EAD"
        });

        if (!confirm.IsConfirmed) return;

        var ok = await OverviewService.RestoreAsync(questionId, uid);
        if (ok)
        {
            await ShowToastAsync("success", "已復原");
            await LoadAsync();
        }
        else
        {
            await ShowToastAsync("error", "復原失敗，題目可能已不在刪除狀態");
        }
    }

    private record SwalResult(bool IsConfirmed, bool IsDenied, bool IsDismissed);

    private ValueTask ShowToastAsync(string icon, string title) =>
        JS.InvokeVoidAsync("Swal.fire", new
        {
            icon,
            title,
            toast = true,
            position = "top-end",
            showConfirmButton = false,
            timer = 2000
        });

    private int CountOf(byte status) => result.StatusCounts.GetValueOrDefault(status, 0);
    private int SumCounts(byte[] statuses) => statuses.Sum(s => result.StatusCounts.GetValueOrDefault(s, 0));
    private int TotalQuestions() => result.StatusCounts.Values.Sum();

    /// <summary>
    /// 「各審查環節」三格的階段感知計數：當前梯次 PhaseCode 對應該格時才計算總和，否則回 -1（UI 灰掉顯示 0）。
    /// 涵蓋的 status 範圍與 EnsurePhaseTransitionAsync 各 case 的 fromStatuses 對齊，
    /// 確保「coordinator 60 秒去重期內未跑」「邊界殘留」等情境不會少算。
    ///   3 互審：Submitted(2) + PeerReviewing(3) — 後端實際事實是題目仍停在 2，不會升到 3
    ///   5 專審：Submitted(2) + PeerReviewing(3) + PeerEditing(4) + ExpertReviewing(5)
    ///   7 總審：上述 + ExpertEditing(6) + FinalReviewing(7)
    /// 與 ResolveDisplayStatus R2 規則的「待審 / 已給意見」範圍一致，避免列表與卡片數字不對盤。
    /// </summary>
    private int ReviewBucket(byte targetPhase)
    {
        if (result.CurrentPhaseCode != targetPhase) return -1;
        return targetPhase switch
        {
            3 => SumCounts([QuestionStatus.Submitted,
                            QuestionStatus.PeerReviewing]),
            5 => SumCounts([QuestionStatus.Submitted,
                            QuestionStatus.PeerReviewing,
                            QuestionStatus.PeerEditing,
                            QuestionStatus.ExpertReviewing]),
            7 => SumCounts([QuestionStatus.Submitted,
                            QuestionStatus.PeerReviewing,
                            QuestionStatus.PeerEditing,
                            QuestionStatus.ExpertReviewing,
                            QuestionStatus.ExpertEditing,
                            QuestionStatus.FinalReviewing]),
            _ => 0
        };
    }

    /// <summary>
    /// 解析「當前狀態」Badge 的顯示內容：依「題目 Status × 梯次 PhaseCode × 本人是否送出修題 × 全體審題者是否已給意見」四維度判定。
    /// 規則優先順序（命中即回）：
    ///  R1. 草稿落隊：題目 Status=Draft 且梯次已進入交互審題（PhaseCode ≥ 3） → 「未完成命題」（danger 紅）。
    ///  A.  題目 Status ∈ {4,6,8} 但梯次 PhaseCode 尚未推進到對應修題階段 → 「OO 完成」（莫蘭迪藍）。
    ///  B.  梯次已到修題階段，且本人已於本階段送出修題說明 → 「修題已送出」（綠）。
    ///  R2. 審題階段語意修正：梯次 PhaseCode ∈ {3,5,7} 且 Status ∈ {2,3,5,7}（待審/審題鎖定中），
    ///        依「全體審題者是否皆已給意見」切換成「已給意見」（success 綠）或「待審」（warning 橘）。
    ///        取代命題視角的「已送審」「互審中」「專審中」「總審中」label，避免管理員誤讀。
    ///  C.  其他狀態（含修題進行中尚未送出）→ 沿用 QuestionStatus.Labels 對應文字。
    /// </summary>
    private static (string Text, string BadgeType, bool IsAwaitingNext) ResolveDisplayStatus(
        byte status, byte? currentPhaseCode, bool hasRepliedThisStage, bool allReviewersResponded,
        byte? parentStatusForFallback = null)
    {
        // 母題結案淘汰例外：父母題 Status=11（結案不採用）時，子題列強制顯示「結案不採用」
        // 此 fallback 不改子題實際 Status，只覆寫顯示文字；對母題列 parentStatusForFallback 永遠為 null，不受影響
        if (parentStatusForFallback == QuestionStatus.ClosedNotAdopted)
            return ("結案不採用", "default", false);

        // 規則 R1：草稿題目 + 梯次已進入交互審題後 → 已永久落隊（命題教師沒命完）
        // PhaseCode 3 = 交互審題；PhaseCode ≥ 3 涵蓋之後所有階段（互修/專審/專修/總審/總修）
        if (status == QuestionStatus.Draft && currentPhaseCode is byte pcDraft && pcDraft >= 3)
            return ("未完成命題", "danger", false);

        // 規則 A：「該審完成等待中」——題目已被審題人決策進入修題狀態，但梯次仍在前一審階段
        if (status == QuestionStatus.PeerEditing   && (currentPhaseCode is null || currentPhaseCode < QuestionStatus.PeerEditing))
            return ("互審完成", "info", true);
        if (status == QuestionStatus.ExpertEditing && (currentPhaseCode is null || currentPhaseCode < QuestionStatus.ExpertEditing))
            return ("專審完成", "info", true);
        if (status == QuestionStatus.FinalEditing  && (currentPhaseCode is null || currentPhaseCode < QuestionStatus.FinalEditing))
            return ("總審完成", "info", true);

        // 規則 B：梯次已到對應修題階段、且本人已送出修題說明 → 綠色「修題已送出」
        var inEditing = status is QuestionStatus.PeerEditing
                                or QuestionStatus.ExpertEditing
                                or QuestionStatus.FinalEditing;
        if (inEditing && hasRepliedThisStage)
            return ("修題已送出", "success", false);

        // 規則 R2：梯次處於審題階段（互審/專審/總審），改以「待審 / 已給意見」呈現審題進度
        // 不管題目 Status 是 Submitted(2)、PeerReviewing(3)、ExpertReviewing(5) 或 FinalReviewing(7)，
        // 從 Overview 視角都是「待審」（鎖定等待審題人決策），與命題端的「已送審」用詞區隔
        if (currentPhaseCode is byte pcReview && (pcReview == 3 || pcReview == 5 || pcReview == 7)
            && status is QuestionStatus.Submitted
                       or QuestionStatus.PeerReviewing
                       or QuestionStatus.ExpertReviewing
                       or QuestionStatus.FinalReviewing)
        {
            return allReviewersResponded
                ? ("已給意見", "success", false)
                : ("待審",     "warning", false);
        }

        // 規則 C：其餘狀態沿用 QuestionStatus.Labels（StatusBadge 內部會推斷色系）
        return (QuestionStatus.Labels.GetValueOrDefault(status, "未知"), "default", false);
    }

    private RenderFragment StatCard(string title, int value, string icon, string iconColor, string valueColor) => __builder =>
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="text-2xl font-bold @valueColor">@value</div>
        </div>
    };

    /// <summary>
    /// 詳情預覽：依題型挑對應 PreviewXxx 元件。
    /// 題組類（ReadGroup / ShortGroup / ListenGroup）做 master/sub 切換：
    ///   - 母題模式（detailSubQuestionId is null）：顯示文章/語音 + 子題索引卡，子題不全部展開（避免畫面雜亂）
    ///   - 子題聚焦模式：顯示文章/語音作上下文 + 單一子題 + 返回母題按鈕
    /// 非題組類沿用整題渲染。
    /// </summary>
    private RenderFragment RenderPreview() => __builder =>
    {
        if (detailData is null || detailItem is null) return;

        var typeLabel  = QuestionConstants.TypeLabels.GetValueOrDefault(detailItem.TypeKey, "");
        var levelLabel = OverviewService.LevelLabel(detailItem.TypeKey, detailItem.Level, CurrentProject?.ProjectType ?? ProjectType.Cwt);
        var diffLabel  = detailItem.Difficulty is byte d ? QuestionConstants.DifficultyLabels.GetValueOrDefault(d, "") : "";
        var tags       = OverviewService.BuildPreviewTags(detailData);

        switch (detailItem.TypeKey)
        {
            case QuestionTypeCodes.Single:
            case QuestionTypeCodes.Select:
                <PreviewSingle QuestionType="@typeLabel" Level="@levelLabel" Difficulty="@diffLabel" Tags="@tags"
                    Stem="@detailData.Stem" Options="@detailData.Options" Answer="@detailData.Answer" Images="@detailData.Images"
                    HideOptionAnswerMarker="true" />
                @RenderAnalysisSection
                break;
            case QuestionTypeCodes.LongText:
                <PreviewLongText Level="@levelLabel" Difficulty="@diffLabel" Tags="@tags"
                    Stem="@detailData.Stem" Passage="@detailData.ArticleContent" Images="@detailData.Images" />
                @RenderAnalysisSection
                break;
            case QuestionTypeCodes.Listen:
                <PreviewListen Level="@levelLabel" Difficulty="@diffLabel" Tags="@tags"
                    AudioFileName="@detailData.AudioUrl" Stem="@detailData.Stem"
                    Content="@detailData.ArticleContent"
                    Options="@detailData.Options" Answer="@detailData.Answer"
                    Images="@detailData.Images"
                    HideOptionAnswerMarker="true" />
                @RenderAnalysisSection
                break;

            case QuestionTypeCodes.ReadGroup:
                if (detailSubQuestionId is null)
                {
                    @* 母題模式：傳空 SubQuestions list，PreviewReadGroup 只渲染文章不展開子題 *@
                    <PreviewReadGroup Level="@levelLabel" Difficulty="@diffLabel" Tags="@tags"
                        Passage="@detailData.ArticleContent" Images="@detailData.Images"
                        SubQuestions="@(new List<PreviewReadGroup.SubQuestionData>())"
                        HideOptionAnswerMarker="true" />
                    @RenderSubIndexCards(detailData.ReadSubQuestions.Select(s => (s.Id, s.Stem)).ToList())
                }
                else
                {
                    var focusIdx = detailData.ReadSubQuestions.FindIndex(s => s.Id == detailSubQuestionId);
                    @RenderBackButton
                    if (focusIdx >= 0)
                    {
                        var focus = detailData.ReadSubQuestions[focusIdx];
                        <PreviewReadGroup Level="@levelLabel" Difficulty="@diffLabel" Tags="@tags"
                            Passage="@detailData.ArticleContent" Images="@detailData.Images"
                            StartIndex="@focusIdx"
                            SubQuestions="@(new List<PreviewReadGroup.SubQuestionData> {
                                new PreviewReadGroup.SubQuestionData {
                                    Stem = focus.Stem, Options = focus.Options, Answer = focus.Answer,
                                    Dimension = QuestionConstants.DecodeSubCoreAbility(focus.CoreAbility, QuestionTypeCodes.ReadGroup),
                                    Indicator = QuestionConstants.DecodeSubIndicator(focus.Indicator, QuestionTypeCodes.ReadGroup)
                                }
                            })"
                            HideOptionAnswerMarker="true" />
                        @RenderSubAnalysisSection(focus.Analysis, focusIdx)
                    }
                    else
                    {
                        <div class="bg-white rounded-xl border border-dashed border-terracotta/30 p-6 text-center text-sm text-terracotta font-sans">
                            <i class="fa-solid fa-circle-exclamation mr-1"></i>找不到該子題（可能已被刪除）
                        </div>
                    }
                }
                break;

            case QuestionTypeCodes.ShortGroup:
                if (detailSubQuestionId is null)
                {
                    <PreviewShortGroup Level="@levelLabel" Difficulty="@diffLabel" Tags="@tags"
                        Passage="@detailData.ArticleContent" Images="@detailData.Images"
                        SubQuestions="@(new List<PreviewShortGroup.SubQuestionData>())" />
                    @RenderSubIndexCards(detailData.ShortSubQuestions.Select(s => (s.Id, s.Stem)).ToList())
                }
                else
                {
                    var focusIdx = detailData.ShortSubQuestions.FindIndex(s => s.Id == detailSubQuestionId);
                    @RenderBackButton
                    if (focusIdx >= 0)
                    {
                        var focus = detailData.ShortSubQuestions[focusIdx];
                        <PreviewShortGroup Level="@levelLabel" Difficulty="@diffLabel" Tags="@tags"
                            Passage="@detailData.ArticleContent" Images="@detailData.Images"
                            StartIndex="@focusIdx"
                            SubQuestions="@(new List<PreviewShortGroup.SubQuestionData> {
                                new PreviewShortGroup.SubQuestionData {
                                    Stem      = focus.Stem,
                                    Dimension = QuestionConstants.DecodeSubCoreAbility(focus.CoreAbility, QuestionTypeCodes.ShortGroup),
                                    Indicator = QuestionConstants.DecodeSubIndicator(focus.Indicator, QuestionTypeCodes.ShortGroup)
                                }
                            })" />
                        @RenderSubAnalysisSection(focus.Analysis, focusIdx)
                    }
                    else
                    {
                        <div class="bg-white rounded-xl border border-dashed border-terracotta/30 p-6 text-center text-sm text-terracotta font-sans">
                            <i class="fa-solid fa-circle-exclamation mr-1"></i>找不到該子題（可能已被刪除）
                        </div>
                    }
                }
                break;

            case QuestionTypeCodes.ListenGroup:
                if (detailSubQuestionId is null)
                {
                    <PreviewListenGroup Tags="@tags" AudioFileName="@detailData.AudioUrl"
                        Passage="@detailData.ArticleContent" Images="@detailData.Images"
                        SubQuestions="@(new List<PreviewListenGroup.SubQuestionData>())"
                        HideOptionAnswerMarker="true" />
                    @RenderSubIndexCards(detailData.ListenGroupSubQuestions.Select(s => (s.Id, s.Stem)).ToList())
                }
                else
                {
                    var focusIdx = detailData.ListenGroupSubQuestions.FindIndex(s => s.Id == detailSubQuestionId);
                    @RenderBackButton
                    if (focusIdx >= 0)
                    {
                        var focus = detailData.ListenGroupSubQuestions[focusIdx];
                        <PreviewListenGroup Tags="@tags" AudioFileName="@detailData.AudioUrl"
                            Passage="@detailData.ArticleContent" Images="@detailData.Images"
                            StartIndex="@focusIdx"
                            SubQuestions="@(new List<PreviewListenGroup.SubQuestionData> {
                                new PreviewListenGroup.SubQuestionData {
                                    Level           = QuestionConstants.ListenLevelLabels.GetValueOrDefault(focus.FixedDifficulty, ""),
                                    CoreAbility     = QuestionConstants.DecodeSubCoreAbility(focus.CoreAbility, QuestionTypeCodes.ListenGroup),
                                    DetailIndicator = QuestionConstants.DecodeSubIndicator(focus.DetailIndicator, QuestionTypeCodes.ListenGroup),
                                    Stem = focus.Stem, Options = focus.Options, Answer = focus.Answer
                                }
                            })"
                            HideOptionAnswerMarker="true" />
                        @RenderSubAnalysisSection(focus.Analysis, focusIdx)
                    }
                    else
                    {
                        <div class="bg-white rounded-xl border border-dashed border-terracotta/30 p-6 text-center text-sm text-terracotta font-sans">
                            <i class="fa-solid fa-circle-exclamation mr-1"></i>找不到該子題（可能已被刪除）
                        </div>
                    }
                }
                break;
        }
    };

    /// <summary>「返回母題」按鈕（子題聚焦模式頂部）— 切回母題模式並隱藏該子題的劃記。</summary>
    private RenderFragment RenderBackButton => __builder =>
    {
        <div class="mb-3">
            <button type="button" @onclick="@(() => SwitchSubUnitAsync(null))"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs font-bold text-slate-main hover:border-morandi hover:text-morandi transition focus:outline-none cursor-pointer">
                <i class="fa-solid fa-chevron-left"></i> 返回母題
            </button>
        </div>
    };

    /// <summary>
    /// 子題索引卡清單（母題模式專用）：點擊任一卡片切換到對應子題聚焦模式。
    /// 與 ReviewQuestionDisplay.RenderSubIndexCard 視覺語彙一致（左側題號膠囊 + 右側摘要 + 箭頭）。
    /// </summary>
    private RenderFragment RenderSubIndexCards(List<(int Id, string Stem)> subs) => __builder =>
    {
        if (subs.Count == 0)
        {
            <div class="mt-4 bg-white rounded-xl border border-dashed border-gray-300 p-6 text-center text-sm text-gray-400 italic font-sans">
                尚未新增子題
            </div>
            return;
        }
        <div class="mt-4 space-y-2">
            <p class="text-xs font-bold text-morandi mb-2 uppercase tracking-wider">
                <i class="fa-solid fa-list-ol mr-1"></i> 子題清單（點擊檢視）
            </p>
            @for (var i = 0; i < subs.Count; i++)
            {
                var idx = i;
                var sub = subs[idx];
                var snippet = SnippetOfHtml(sub.Stem);
                <button type="button" @onclick="@(() => SwitchSubUnitAsync(sub.Id))"
                        class="w-full text-left bg-white rounded-lg shadow-sm border border-gray-200 hover:border-morandi hover:shadow-md transition group flex items-stretch overflow-hidden focus:outline-none cursor-pointer">
                    <div class="w-12 flex-shrink-0 bg-gradient-to-b from-morandi/15 to-morandi/5 border-r border-morandi/15 flex flex-col items-center justify-center py-2 font-serif">
                        <span class="text-xs text-morandi/70 font-bold tracking-wider font-sans">第</span>
                        <span class="text-lg font-black text-morandi leading-none my-0.5">@(idx + 1)</span>
                        <span class="text-xs text-morandi/70 font-bold tracking-wider font-sans">題</span>
                    </div>
                    <div class="flex-1 min-w-0 px-3 py-2 flex items-center gap-2">
                        <div class="flex-1 min-w-0">
                            <div class="text-xs text-gray-400 mb-0.5 font-sans">點此進入子題</div>
                            <div class="text-sm text-gray-700 truncate" title="@snippet">
                                @(string.IsNullOrEmpty(snippet) ? "（尚未填寫題幹）" : snippet)
                            </div>
                        </div>
                        <i class="fa-solid fa-arrow-right text-gray-300 group-hover:text-morandi group-hover:translate-x-0.5 transition"></i>
                    </div>
                </button>
            }
        </div>
    };

    /// <summary>HTML 字串擷取前 N 字（去標籤）— 子題索引卡摘要用。</summary>
    private static string SnippetOfHtml(string? html, int max = 80)
    {
        if (string.IsNullOrWhiteSpace(html)) return "";
        var text = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return text.Length <= max ? text : text[..max] + "…";
    }

    /// <summary>判斷 HTML 字串是否有實質內容（去標籤後非空，或包含圖片）。</summary>
    private static bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }

    /// <summary>
    /// 非題組類 / 題組類母題模式的「審題輔助資訊」摺疊區（試題解析 / 批閱說明）。
    /// 視覺與 ReviewQuestionDisplay.RenderAnalysisSection 對齊（amber 配色、details 預設展開）。
    /// data-annot-target 用 "analysis" / "gradingNote"，對齊審題端劃記容器命名。
    /// </summary>
    private RenderFragment RenderAnalysisSection => __builder =>
    {
        if (detailData is null || detailItem is null) return;

        var isLongText = detailItem.TypeKey == QuestionTypeCodes.LongText;
        var content    = isLongText ? detailData.GradingNote : detailData.Analysis;
        var icon       = isLongText ? "fa-list-check" : "fa-lightbulb";
        var fieldKey   = isLongText ? "gradingNote" : "analysis";

        if (!HasContent(content)) return;

        <details open class="group mt-4 overflow-hidden rounded-2xl border border-stone-200/80 bg-white shadow-md">
            <summary class="flex cursor-pointer list-none select-none items-center gap-3 bg-morandi/10 px-5 py-3.5 transition-colors hover:bg-morandi/20">
                <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-morandi/10 ring-1 ring-inset ring-morandi/20">
                    <i class="fa-solid fa-lock text-sm text-morandi/80"></i>
                </span>
                <div class="flex flex-col leading-tight">
                    <span class="text-sm font-bold text-slate-700">審題參考資訊（題旨說明與解題詮釋）</span>
                </div>
                <i class="fa-solid fa-chevron-down ml-auto text-sm text-slate-400 transition-transform duration-200 group-open:rotate-180"></i>
            </summary>
            <div class="border-t border-stone-200/80 px-5 pb-5 pt-4">                
                <div class="rounded-xl border border-stone-200/70 bg-white px-4 py-3.5 shadow-sm">
                    <div class="prose max-w-none font-serif text-base leading-loose text-slate-700" data-annot-target="@fieldKey">
                        @((MarkupString)content!)
                    </div>
                </div>
            </div>
        </details>
    };

    /// <summary>
    /// 題組類子題聚焦模式的「子題試題解析」摺疊區。
    /// data-annot-target 用 "subAnalysis.{idx}"，對齊審題端劃記容器命名。
    /// </summary>
    private RenderFragment RenderSubAnalysisSection(string? content, int subIdx) => __builder =>
    {
        if (!HasContent(content)) return;
        var fieldKey = $"subAnalysis.{subIdx}";
        <details open class="group mt-4 overflow-hidden rounded-2xl border border-stone-200/80 bg-white shadow-md">
            <summary class="flex cursor-pointer list-none select-none items-center gap-3 bg-morandi/10 px-5 py-3.5 transition-colors hover:bg-morandi/20">
                <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-morandi/10 ring-1 ring-inset ring-morandi/20">
                    <i class="fa-solid fa-lock text-sm text-morandi/80"></i>
                </span>
                <div class="flex flex-col leading-tight">
                    <span class="text-sm font-bold text-slate-700">審題參考資訊（子題題旨說明與解題詮釋）</span>
                </div>
                <i class="fa-solid fa-chevron-down ml-auto text-sm text-slate-400 transition-transform duration-200 group-open:rotate-180"></i>
            </summary>
            <div class="border-t border-stone-200/80 px-5 pb-5 pt-4">                
                <div class="rounded-xl border border-stone-200/70 bg-white px-4 py-3.5 shadow-sm">
                    <div class="prose max-w-none font-serif text-base leading-loose text-slate-700" data-annot-target="@fieldKey">
                        @((MarkupString)content!)
                    </div>
                </div>
            </div>
        </details>
    };

    /// <summary>
    /// 取得當前聚焦子題在母題子題列表中的順序號（1-based）。
    /// 用 list index + 1，與 DB MT_SubQuestions.SortOrder 對齊（list 由 Service 端依 SortOrder 排序載入）。
    /// 母題模式 / detailData 尚未載入時回 null。
    /// </summary>
    private int? GetFocusSubNumber()
    {
        if (detailData is null || detailItem is null || detailSubQuestionId is null) return null;
        var idx = detailItem.TypeKey switch
        {
            QuestionTypeCodes.ReadGroup   => detailData.ReadSubQuestions.FindIndex(s => s.Id == detailSubQuestionId),
            QuestionTypeCodes.ShortGroup  => detailData.ShortSubQuestions.FindIndex(s => s.Id == detailSubQuestionId),
            QuestionTypeCodes.ListenGroup => detailData.ListenGroupSubQuestions.FindIndex(s => s.Id == detailSubQuestionId),
            _ => -1
        };
        return idx >= 0 ? idx + 1 : null;
    }

    /// <summary>SlideOver 內題號 div / Title 共用：母題模式回原碼、子題模式回「母題碼-NN」。</summary>
    private string FormattedDetailCode
    {
        get
        {
            var baseCode = detailItem?.QuestionCode ?? "";
            if (string.IsNullOrEmpty(baseCode)) return "";
            return GetFocusSubNumber() is int n ? $"{baseCode}-{n:00}" : baseCode;
        }
    }

    /// <summary>SlideOver Title：computed，自動套用子題編號（- detailData 尚未載入時退回母題碼）。</summary>
    private string CurrentModalTitle
        => detailItem is null ? "試題詳情" : $"試題詳情 — {FormattedDetailCode}";

    /// <summary>
    /// SlideOver 內切換子題單元（不關閉 Modal）：
    ///   subId=null  → 切回母題模式（顯示文章/語音 + 子題索引卡）
    ///   subId≠null  → 切到該子題聚焦模式（顯示文章/語音作上下文 + 單一子題）
    /// 同時重抓對應單元的劃記評語清單與審題意見歷程；清空螢光筆（含 snapshot），避免殘留。
    /// </summary>
    private async Task SwitchSubUnitAsync(int? subId)
    {
        if (detailItem is null) return;
        detailSubQuestionId = subId;
        @* modalTitle / 題號 div 走 computed property，本方法不再手動賦值 *@

        detailAnnotations = new();
        detailHistory     = new();
        pinnedAnnotationId = null;
        try { await JS.InvokeVoidAsync("annotation.clearAll"); } catch { }
        StateHasChanged();

        // 並行重抓單元層級的劃記評語與審題歷程，與 OpenDetailAsync 同步策略
        var annotationsTask = OverviewService.GetAnnotationsForUnitAsync(detailItem.Id, subId);
        var historyTask     = OverviewService.GetReviewHistoryAsync(detailItem.Id, subId);
        await Task.WhenAll(annotationsTask, historyTask);
        detailAnnotations = annotationsTask.Result;
        detailHistory     = historyTask.Result;
        StateHasChanged();
    }
}
