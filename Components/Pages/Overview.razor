@* ====================================================================== *@
@*  Overview — 命題總覽                                                     *@
@*  路由：/overview                                                        *@
@*  功能：當前梯次全部試題一覽，含統計卡片、篩選列、三審狀態軌跡、詳情面板   *@
@* ====================================================================== *@
@page "/overview"

<div class="flex-grow flex flex-col w-full mx-auto h-[calc(100vh-4rem)] overflow-hidden">
    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <NavLink href="" Match="NavLinkMatch.All" class="inline-flex items-center hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-slate-main">命題總覽</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-layer-group text-morandi"></i> 當前梯次：命題總覽
                </h1>
            </div>
            <div class="flex gap-2">
                <button class="px-4 py-2 bg-white border border-gray-300 rounded text-sm font-medium hover:bg-gray-50 text-gray-700 transition-colors shadow-sm">
                    <i class="fa-solid fa-file-export mr-1"></i> 匯出報表
                </button>
            </div>
        </div>
    </div>

    <!-- Dashboard Body -->
    <div class="flex-grow flex flex-col overflow-y-auto custom-scroll p-4 sm:p-6 lg:p-8 relative">
        <!-- Statistics Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4 mb-6 shrink-0">
            @StatCard("總題數", "0", "fa-hashtag", "text-morandi", "text-slate-main")
            @StatCard("命題進行中", "0", "fa-pen", "text-sage", "text-slate-main")
            @StatCard("已採用", "0", "fa-circle-check", "text-sage", "text-sage")
            @StatCard("待修編 (退回)", "0", "fa-rotate-left", "text-terracotta", "text-terracotta")
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 col-span-2 md:col-span-4 lg:col-span-1 border-l-4 border-l-morandi">
                <div class="text-gray-500 text-xs font-bold mb-1">各審查環節卡關中</div>
                <div class="text-sm font-bold text-slate-main flex gap-2 w-full justify-between items-end mt-2">
                    <div class="text-center w-1/3"><span class="block text-gray-400 text-[10px]">待審</span><span class="text-lg text-blue-600">0</span></div>
                    <div class="text-center w-1/3"><span class="block text-gray-400 text-[10px]">互審中</span><span class="text-lg">0</span></div>
                    <div class="text-center w-1/3"><span class="block text-gray-400 text-[10px]">專審中</span><span class="text-lg">0</span></div>
                </div>
            </div>
        </div>

        <!-- Main Panel: Filters & List -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 flex flex-col flex-grow overflow-hidden relative min-h-[400px]">
            <!-- Filters Bar -->
            <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col md:flex-row gap-3 items-center justify-between shrink-0">
                <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                    <div class="relative w-full md:w-64">
                        <i class="fa-solid fa-magnifying-glass left-3 top-2.5 absolute text-gray-400"></i>
                        <input type="text" class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white" placeholder="搜尋題號或教師姓名...">
                    </div>
                    <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white">
                        <option value="all">所有題型</option>
                    </select>
                    <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white">
                        <option value="all">所有等級</option>
                    </select>
                    <select class="w-full md:w-auto px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white">
                        <option value="all">所有狀態</option>
                    </select>
                </div>
                <div class="text-sm text-gray-500 font-medium">
                    共 <span class="text-morandi font-bold">0</span> 題
                </div>
            </div>

            <!-- Table Header -->
            <div class="grid grid-cols-12 gap-4 px-6 py-3 border-b border-gray-200 bg-white text-xs font-bold text-gray-500 uppercase tracking-wider shrink-0 shadow-sm">
                <div class="col-span-2">題號 / 作者</div>
                <div class="col-span-2 lg:col-span-1">題型</div>
                <div class="col-span-2 lg:col-span-1">等級/難度</div>
                <div class="col-span-5 lg:col-span-7 hidden lg:block text-center">三審狀態軌跡</div>
                <div class="col-span-1 text-center">當前狀態</div>
            </div>

            <!-- Empty List Content -->
            <div class="flex-grow p-4">
                <EmptyState IconClass="fa-folder-open" Message="目前尚無題目" SubMessage="當前專案梯次沒有任何送出的題目可以檢視。" />
            </div>
        </div>
    </div>
</div>

<CustomModal @bind-IsVisible="showDetailModal" Type="CustomModal.ModalType.SlideOver" Title="@modalTitle">
    <ChildContent>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-6">
            <h3 class="text-xs font-bold text-morandi uppercase tracking-wider mb-2">題幹內容</h3>
            <div class="text-base text-gray-800 p-4 bg-gray-50 rounded-lg min-h-[100px] border border-gray-100">
                <!-- Data goes here -->
            </div>
        </div>
    </ChildContent>
</CustomModal>

@code {
    private bool showDetailModal = false;
    private string modalTitle = "試題詳情";

    private RenderFragment StatCard(string title, string value, string icon, string iconColor, string valueColor) => __builder =>
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                @title <i class="fa-solid @icon @iconColor opacity-50"></i>
            </div>
            <div class="text-2xl font-bold @valueColor">@value</div>
        </div>
    };
}
