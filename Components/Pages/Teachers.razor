@* ====================================================================== *@
@*  Teachers — 教師人才庫管理                                               *@
@*  路由：/teachers                                                        *@
@*  功能：統計卡片、左右分割佈局（左側列表搜尋＋篩選、右側詳情四分頁）       *@
@*        SlideOver 新增/編輯教師表單（基本資料、任教背景、帳號設定）         *@
@*        加入梯次 Modal（選擇專案＋勾選角色）                              *@
@* ====================================================================== *@
@page "/teachers"
@inject ITeacherService TeacherService
@inject IAppointmentService AppointmentService
@inject ILogger<Teachers> Logger
@inject NavigationManager NavigationManager

<div class="flex-grow flex flex-col w-full mx-auto h-[calc(100vh-4rem)] overflow-hidden">

    @* ── Breadcrumb & Header ── *@
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-2 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <NavLink href="" Match="NavLinkMatch.All" class="inline-flex items-center hover:text-[var(--color-morandi)] transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </NavLink>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-[var(--color-slate-main)]">教師管理系統</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-chalkboard-user text-[var(--color-morandi)]"></i> 教師管理系統 (人才庫)
                </h1>
                <p class="text-sm text-gray-500 mt-1">教師人才庫、跨梯次命審歷程與帳號管理。</p>
            </div>
            <div class="flex gap-2">
                <button type="button" @onclick="OpenImportSlideOver"
                    class="cursor-pointer px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-file-import"></i> 批次匯入
                </button>
                <button type="button" @onclick="HandleExport"
                    class="cursor-pointer px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-file-export"></i> 匯出名單
                </button>
                <button type="button" @onclick="OpenNewTeacher"
                    class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-user-plus"></i> 新增教師
                </button>
            </div>
        </div>
    </div>

    @* ── Statistics Cards ── *@
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                    人才庫總數 <i class="fa-solid fa-users text-morandi opacity-50"></i>
                </div>
                <div class="text-2xl font-bold text-slate-main">@stats.Total</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                    帳號啟用中 <i class="fa-solid fa-circle-check text-sage opacity-50"></i>
                </div>
                <div class="text-2xl font-bold text-sage">@stats.Active</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                    帳號停用中 <i class="fa-solid fa-circle-xmark text-terracotta opacity-50"></i>
                </div>
                <div class="text-2xl font-bold text-terracotta">@stats.Inactive</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                    本梯次參與教師 <i class="fa-solid fa-user-check text-morandi opacity-50"></i>
                </div>
                <div class="text-2xl font-bold text-morandi">@stats.CurrentProject</div>
            </div>
        </div>
    </div>

    @* ── Split Layout ── *@
    <div class="flex-grow flex overflow-hidden px-4 sm:px-6 lg:px-8 pb-4">
        <div class="flex-grow flex overflow-hidden bg-white rounded-xl shadow-sm border border-gray-200">

            @* ── Left Panel: Teacher List ── *@
            <div class="w-full lg:w-[380px] xl:w-[420px] border-r border-gray-200 flex flex-col z-10 flex-shrink-0">
                <!-- 搜尋 + 篩選 -->
                <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col gap-3 flex-shrink-0">
                    <DebouncedSearchInput @bind-Value="searchKeyword"
                                          Placeholder="搜尋姓名、編號、學校或信箱..." />
                    <div class="flex gap-2">
                        @foreach (var (key, label) in new[] { ("all", "全部"), ("active", "啟用中"), ("inactive", "停用中") })
                        {
                            var k = key;
                            <button @onclick="() => listFilter = k"
                                class="@(listFilter == k ? "bg-morandi text-white" : "border border-gray-200 text-gray-500 hover:bg-gray-100") flex-1 py-1 text-xs font-bold rounded cursor-pointer transition-colors focus:outline-none">
                                @label
                            </button>
                        }
                    </div>
                </div>

                <!-- 列表 -->
                <div class="flex-grow overflow-y-auto custom-scroll">
                    @if (isLoadingList)
                    {
                        <div class="flex items-center justify-center h-full text-gray-400">
                            <i class="fa-solid fa-spinner fa-spin mr-2"></i> 載入中...
                        </div>
                    }
                    else if (!FilteredTeachers.Any())
                    {
                        <EmptyState IconClass="fa-users-slash" Message="目前尚無教師" SubMessage="點擊右上角「新增教師」來建立人才庫。" Compact="true" CssClass="h-full !my-0" />
                    }
                    else
                    {
                        @foreach (var teacher in FilteredTeachers)
                        {
                            var isSelected = selectedTeacherId == teacher.Id;
                            <div @onclick="() => SelectTeacher(teacher.Id)" @key="teacher.Id"
                                class="@(isSelected ? "bg-blue-50/70 border-l-[3px] border-l-morandi" : "border-l-[3px] border-l-transparent hover:bg-gray-50") cursor-pointer p-4 border-b border-gray-100 transition-colors">
                                <div class="flex items-start gap-3">
                                    <!-- 狀態圓點 + 頭像 -->
                                    <div class="relative flex-shrink-0">
                                        <div class="w-10 h-10 rounded-full bg-morandi/15 text-morandi flex items-center justify-center font-bold text-sm">
                                            @(teacher.DisplayName.Length > 0 ? teacher.DisplayName[0] : '?')
                                        </div>
                                        <span class="absolute -top-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-white @(teacher.Status == 1 ? "bg-sage" : "bg-terracotta")"></span>
                                    </div>
                                    <!-- 資訊 -->
                                    <div class="flex-grow min-w-0">
                                        <div class="flex items-center gap-2">
                                            <span class="font-bold text-sm text-slate-main truncate">@teacher.DisplayName</span>
                                            <span class="text-xs text-gray-400 font-mono">@teacher.TeacherCode</span>
                                        </div>
                                        <div class="text-xs text-gray-500 mt-0.5 truncate">@teacher.School</div>
                                        <!-- 角色 Badge（依 Category 配色：內部紫 / 外部琥珀） -->
                                        <div class="flex flex-wrap gap-1 mt-1.5">
                                            @if (teacher.ProjectRoles.Count > 0)
                                            {
                                                @foreach (var role in teacher.ProjectRoles)
                                                {
                                                    <StatusBadge StatusText="@role.Name" IsInternal="@(role.Category == 0)" Compact="true" ShowIcon="false" />
                                                }
                                            }
                                            else
                                            {
                                                <span class="px-1.5 py-0.5 text-xs font-bold rounded bg-gray-100 text-gray-400">未參與此梯次</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            @* ── Right Panel: Teacher Details ── *@
            @* 整個右側為單一捲動容器：頂部資訊卡與 Tab 列會一起隨內容滾動，不再 sticky *@
            <div class="hidden lg:flex flex-col flex-grow bg-oatmeal overflow-y-auto custom-scroll">
                @if (selectedDetail is null)
                {
                    <div class="flex-grow flex flex-col items-center justify-center text-gray-400 p-8">
                        <i class="fa-solid fa-user-graduate text-6xl mb-4 text-gray-300"></i>
                        <p class="text-lg font-medium">請由左側列表選擇教師，或新增一位教師。</p>
                    </div>
                }
                else
                {
                    <!-- 頂部資訊卡片（Prototype 風格） -->
                    <div class="p-6 bg-white border-b border-gray-200 flex-shrink-0">
                        <div class="flex items-center gap-6">
                            <!-- 大頭像 -->
                            <div class="w-[72px] h-[72px] rounded-full bg-morandi/15 text-morandi flex items-center justify-center font-bold text-2xl flex-shrink-0 border-2 border-morandi/20">
                                @(selectedDetail.DisplayName.Length > 0 ? selectedDetail.DisplayName[0] : '?')
                            </div>
                            <!-- 資訊 -->
                            <div class="flex-grow min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <h2 class="text-xl font-bold text-slate-main">@selectedDetail.DisplayName</h2>
                                    <span class="@(selectedDetail.Status == 1 ? "bg-sage/15 text-sage" : "bg-terracotta/15 text-terracotta") text-xs font-bold px-2.5 py-0.5 rounded-full">
                                        @(selectedDetail.Status == 1 ? "啟用中" : "停用中")
                                    </span>
                                </div>
                                <div class="text-sm text-gray-500 font-mono mb-0.5">
                                    ID: @selectedDetail.TeacherCode
                                </div>
                                @if (!string.IsNullOrEmpty(selectedDetail.Email))
                                {
                                    <div class="text-sm text-gray-500">
                                        <i class="fa-solid fa-envelope mr-1.5 text-gray-400"></i>@selectedDetail.Email
                                    </div>
                                }
                            </div>
                            <!-- 操作按鈕（垂直堆疊） -->
                            <div class="flex flex-col gap-2 flex-shrink-0">
                                <button @onclick="OpenEditTeacher" disabled="@isActionBusy"
                                    class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors focus:outline-none shadow-sm disabled:opacity-50 flex items-center gap-1.5 justify-center">
                                    <i class="fa-solid fa-pen-to-square"></i> 編輯資料
                                </button>
                                <button @onclick="HandleToggleStatus" disabled="@isActionBusy"
                                    class="cursor-pointer px-4 py-2 rounded-lg text-sm font-medium transition-colors focus:outline-none shadow-sm disabled:opacity-50 flex items-center gap-1.5 justify-center @(selectedDetail.Status == 1 ? "bg-terracotta text-white hover:bg-[#c77a5e]" : "bg-sage text-white hover:bg-[#7b9c81]")">
                                    <i class="fa-solid @(selectedDetail.Status == 1 ? "fa-user-slash" : "fa-user-check")"></i>
                                    @(selectedDetail.Status == 1 ? "停用帳號" : "啟用帳號")
                                </button>
                                <button @onclick="HandleResetPassword" disabled="@isActionBusy"
                                    class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors focus:outline-none shadow-sm disabled:opacity-50 flex items-center gap-1.5 justify-center">
                                    <i class="fa-solid fa-key"></i> 重設密碼
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Tab 按鈕（Prototype 風格） -->
                    <div class="px-6 pt-4 flex-shrink-0">
                        <div class="flex gap-1 border-b border-gray-200">
                            @foreach (var (key, label, icon) in new[] {
                                ("info", "基本資料", "fa-address-card"),
                                ("compose", "命題歷程", "fa-clock-rotate-left"),
                                ("review", "審題歷程", "fa-clipboard-check"),
                                ("projects", "參與專案", "fa-folder-tree")
                            })
                            {
                                var k = key;
                                <button @onclick="() => SwitchDetailTabAsync(k)"
                                    class="@(detailTab == k ? "border-b-2 border-morandi text-morandi" : "text-gray-400 hover:text-gray-600") px-4 py-3 text-sm font-bold transition-colors focus:outline-none cursor-pointer flex items-center gap-2">
                                    <i class="fa-solid @icon"></i> @label
                                </button>
                            }
                        </div>
                    </div>

                    <!-- Tab 內容（與上方資訊卡共用外層捲軸） -->
                    <div class="p-6">
                        @* ── Tab: 基本資料 ── *@
                        @if (detailTab == "info")
                        {
                            <div class="space-y-6">
                                <!-- 個人資料 -->
                                <div>
                                    <h3 class="text-sm font-bold text-gray-800 mb-3 flex items-center gap-2">
                                        <i class="fa-solid fa-id-card text-morandi"></i> 個人資料
                                    </h3>
                                    <div class="grid grid-cols-2 gap-x-8 gap-y-3 bg-white p-4 rounded-lg border border-gray-100">
                                        @InfoRow("姓名", selectedDetail.DisplayName)
                                        @InfoRow("性別", selectedDetail.GenderText)
                                        @InfoRow("電子信箱", selectedDetail.Email ?? "未設定")
                                        @InfoRow("聯絡電話", selectedDetail.Phone ?? "未設定")
                                        @InfoRow("身分證字號", selectedDetail.MaskedIdNumber)
                                        @InfoRow("帳號建立日", selectedDetail.CreatedAt.ToString("yyyy-MM-dd"))
                                        @InfoRow("首次登入", selectedDetail.IsFirstLogin ? "尚未登入" : "已完成")
                                        @InfoRow("最後登入", selectedDetail.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "從未登入")
                                    </div>
                                </div>
                                <!-- 任教背景 -->
                                <div>
                                    <h3 class="text-sm font-bold text-gray-800 mb-3 flex items-center gap-2">
                                        <i class="fa-solid fa-graduation-cap text-morandi"></i> 任教背景
                                    </h3>
                                    <div class="grid grid-cols-2 gap-x-8 gap-y-3 bg-white p-4 rounded-lg border border-gray-100">
                                        @InfoRow("任教學校", selectedDetail.School)
                                        @InfoRow("系所 / 科別", selectedDetail.Department ?? "未設定")
                                        @InfoRow("職稱", selectedDetail.Title ?? "未設定")
                                        @InfoRow("專長領域", selectedDetail.Expertise ?? "未設定")
                                        @InfoRow("教學年資", selectedDetail.TeachingYears.HasValue ? $"{selectedDetail.TeachingYears} 年" : "未設定")
                                        @InfoRow("最高學歷", selectedDetail.EducationText)
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(selectedDetail.Note))
                                {
                                    <div>
                                        <h3 class="text-sm font-bold text-gray-800 mb-3 flex items-center gap-2">
                                            <i class="fa-solid fa-note-sticky text-morandi"></i> 備註
                                        </h3>
                                        <div class="bg-white p-4 rounded-lg border border-gray-100 text-sm text-gray-700 whitespace-pre-wrap">@selectedDetail.Note</div>
                                    </div>
                                }
                            </div>
                        }

                        @* ── Tab: 命題歷程 ── *@
                        else if (detailTab == "compose")
                        {
                            <!-- 統計卡片 -->
                            <div class="grid grid-cols-4 gap-3 mb-4">
                                <div class="bg-white p-3 rounded-lg border border-gray-100 text-center">
                                    <div class="text-xs text-gray-500 font-bold">累計產出</div>
                                    <div class="text-xl font-bold text-slate-main mt-1">@composeStats.TotalCount</div>
                                </div>
                                <div class="bg-white p-3 rounded-lg border border-gray-100 text-center">
                                    <div class="text-xs text-gray-500 font-bold">已採用</div>
                                    <div class="text-xl font-bold text-sage mt-1">@composeStats.AdoptedCount</div>
                                </div>
                                <div class="bg-white p-3 rounded-lg border border-gray-100 text-center">
                                    <div class="text-xs text-gray-500 font-bold">不採用</div>
                                    <div class="text-xl font-bold text-terracotta mt-1">@composeStats.RejectedCount</div>
                                </div>
                                <div class="bg-white p-3 rounded-lg border border-gray-100 text-center">
                                    <div class="text-xs text-gray-500 font-bold">審查中</div>
                                    <div class="text-xl font-bold text-morandi mt-1">@composeStats.ReviewingCount</div>
                                </div>
                            </div>
                            <!-- 篩選 + 列表 -->
                            <div class="bg-white rounded-lg border border-gray-100">
                                <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
                                    <span class="font-bold text-sm text-gray-800">
                                        跨專案命題歷程
                                        @if (composeResult.TotalCount > 0)
                                        {
                                            <span class="ml-2 text-xs font-normal text-gray-500">共 <span class="text-morandi font-bold">@composeResult.TotalCount</span> 筆</span>
                                        }
                                    </span>
                                    <select @bind="composeFilterProjectId" @bind:after="OnComposeFilterChangedAsync"
                                        class="text-sm border border-gray-300 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-morandi cursor-pointer bg-white">
                                        <option value="">全部專案</option>
                                        @foreach (var p in projectFilterOptions)
                                        {
                                            <option value="@p.Id">@p.Name</option>
                                        }
                                    </select>
                                </div>
                                @if (composeResult.Items.Count == 0)
                                {
                                    <div class="p-4">
                                        <EmptyState IconClass="fa-clock-rotate-left" Message="尚無命題歷程"
                                            SubMessage="此教師在所選篩選條件下尚未產出任何題目。" Compact="true" />
                                    </div>
                                }
                                else
                                {
                                    @foreach (var item in composeResult.Items)
                                    {
                                        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-50 last:border-b-0 hover:bg-gray-50/50">
                                            <div class="flex items-center gap-3">
                                                <span class="text-sm font-mono text-morandi font-bold">@item.QuestionCode</span>
                                                <span class="text-sm text-gray-700 font-bold">@item.TypeName</span>
                                                <span class="text-xs text-gray-400">@item.LevelText</span>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <span class="text-xs text-gray-500">@item.ProjectName</span>
                                                <span class="px-2 py-0.5 text-xs font-bold rounded @GetQuestionStatusBadge(item.Status)">@GetQuestionStatusText(item.Status)</span>
                                            </div>
                                        </div>
                                    }
                                    <Pagination CurrentPage="@composePage"
                                                TotalPages="@composeResult.PageCount"
                                                IsLoading="@isLoadingCompose"
                                                OnPageChanged="OnComposePageChangedAsync" />
                                }
                            </div>
                        }

                        @* ── Tab: 審題歷程 ── *@
                        else if (detailTab == "review")
                        {
                            <!-- 統計卡片 -->
                            <div class="grid grid-cols-3 gap-3 mb-4">
                                <div class="bg-white p-3 rounded-lg border border-gray-100 text-center">
                                    <div class="text-xs text-gray-500 font-bold">審題總數</div>
                                    <div class="text-xl font-bold text-slate-main mt-1">@reviewStats.TotalCount</div>
                                </div>
                                <div class="bg-white p-3 rounded-lg border border-gray-100 text-center">
                                    <div class="text-xs text-gray-500 font-bold">待審中</div>
                                    <div class="text-xl font-bold text-morandi mt-1">@reviewStats.PendingCount</div>
                                </div>
                                <div class="bg-white p-3 rounded-lg border border-gray-100 text-center">
                                    <div class="text-xs text-gray-500 font-bold">已完成</div>
                                    <div class="text-xl font-bold text-sage mt-1">@reviewStats.CompletedCount</div>
                                </div>                                
                            </div>
                            <!-- 篩選 + 列表 -->
                            <div class="bg-white rounded-lg border border-gray-100">
                                <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
                                    <span class="font-bold text-sm text-gray-800">
                                        跨專案審題歷程
                                        @if (reviewResult.TotalCount > 0)
                                        {
                                            <span class="ml-2 text-xs font-normal text-gray-500">共 <span class="text-morandi font-bold">@reviewResult.TotalCount</span> 筆</span>
                                        }
                                    </span>
                                    <select @bind="reviewFilterProjectId" @bind:after="OnReviewFilterChangedAsync"
                                        class="text-sm border border-gray-300 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-morandi cursor-pointer bg-white">
                                        <option value="">全部專案</option>
                                        @foreach (var p in projectFilterOptions)
                                        {
                                            <option value="@p.Id">@p.Name</option>
                                        }
                                    </select>
                                </div>
                                @if (reviewResult.Items.Count == 0)
                                {
                                    <div class="p-4">
                                        <EmptyState IconClass="fa-clipboard-check" Message="尚無審題歷程"
                                            SubMessage="此教師在所選篩選條件下尚未進行任何審題任務。" Compact="true" />
                                    </div>
                                }
                                else
                                {
                                    @foreach (var item in reviewResult.Items)
                                    {
                                        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-50 last:border-b-0 hover:bg-gray-50/50">
                                            <div class="flex items-center gap-3">
                                                <span class="text-sm font-mono text-morandi font-bold">@item.QuestionCode</span>
                                                <span class="text-sm text-gray-700 font-bold">@item.TypeName</span>
                                                <span class="text-xs text-gray-400">@item.LevelText</span>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <span class="text-xs text-gray-500">@item.ProjectName</span>
                                                <span class="px-2 py-0.5 text-xs font-bold rounded @GetStageBadgeClass(item)">@item.StageText</span>
                                                @* 本次決策 Badge：永遠顯示當次 assignment 的決策 *@
                                                <span class="px-2 py-0.5 text-xs font-bold rounded @GetThisDecisionBadgeClass(item)">@item.ThisDecisionText</span>
                                                @* 最終結果 Badge：僅結案後顯示，未結案顯示 — *@
                                                <span class="px-2 py-0.5 text-xs font-bold rounded @GetFinalResultBadgeClass(item)">@item.FinalResultText</span>
                                            </div>
                                        </div>
                                    }
                                    <Pagination CurrentPage="@reviewPage"
                                                TotalPages="@reviewResult.PageCount"
                                                IsLoading="@isLoadingReview"
                                                OnPageChanged="OnReviewPageChangedAsync" />
                                }
                            </div>
                        }

                        @* ── Tab: 參與專案 ── *@
                        else if (detailTab == "projects")
                        {
                            <div class="flex items-center justify-between mb-4">
                                <p class="text-sm text-gray-600">
                                    此教師已參與的命題專案（梯次），可從此處將教師加入新的梯次。
                                </p>
                                <button @onclick="OpenAssignModal" disabled="@isActionBusy"
                                    class="cursor-pointer px-4 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors focus:outline-none shadow-sm disabled:opacity-50 flex items-center gap-2 flex-shrink-0">
                                    <i class="fa-solid fa-folder-plus"></i> 加入梯次
                                </button>
                            </div>
                            @if (teacherProjects.Count == 0)
                            {
                                <EmptyState IconClass="fa-folder-open" Message="尚未參與任何梯次"
                                    SubMessage="點擊右上角「加入梯次」按鈕，將此教師指派至命題專案。" Compact="true" />
                            }
                            else
                            {
                                <div class="space-y-3">
                                    @foreach (var project in teacherProjects)
                                    {
                                        var statusBadgeClass = project.EffectiveStatus switch
                                        {
                                            ProjectLifecycleStatus.Active => "bg-blue-100 text-blue-700",
                                            ProjectLifecycleStatus.Closed => "bg-gray-200 text-gray-600",
                                            _ => "bg-amber-100 text-amber-700"
                                        };
                                        var statusLabel = project.EffectiveStatus switch
                                        {
                                            ProjectLifecycleStatus.Active => "進行中",
                                            ProjectLifecycleStatus.Closed => "已結案",
                                            _ => "準備中"
                                        };
                                        <div class="bg-white rounded-lg border border-gray-200 p-5 hover:shadow-md transition-shadow">
                                            <!-- 頂部列：狀態標籤 + 專案編號 + 移除按鈕 -->
                                            <div class="flex items-center justify-between mb-2">
                                                <div class="flex items-center gap-2">
                                                    <span class="px-2.5 py-1 text-xs font-bold rounded @statusBadgeClass">@statusLabel</span>
                                                    <span class="text-xs text-gray-400 font-mono">@project.ProjectCode</span>
                                                </div>
                                                @if (project.EffectiveStatus != ProjectLifecycleStatus.Closed)
                                                {
                                                    <button @onclick="() => HandleRemoveFromProject(project.ProjectId, project.ProjectName)" disabled="@isActionBusy"
                                                        class="cursor-pointer text-xs text-terracotta hover:text-red-700 transition-colors focus:outline-none disabled:opacity-50">
                                                        <i class="fa-solid fa-xmark mr-0.5"></i> 移除
                                                    </button>
                                                }
                                            </div>
                                            <!-- 專案名稱 -->
                                            <h4 class="text-base font-bold text-slate-main mb-3">
                                                @project.ProjectYear 年度 @project.ProjectName
                                            </h4>
                                            <!-- 角色（如有）：內部紫 / 外部琥珀 -->
                                            @if (project.Roles.Count > 0)
                                            {
                                                <div class="flex flex-wrap gap-1 mb-3">
                                                    @foreach (var role in project.Roles)
                                                    {
                                                        <StatusBadge StatusText="@role.Name" IsInternal="@(role.Category == 0)" Compact="true" ShowIcon="false" />
                                                    }
                                                </div>
                                            }
                                            <!-- 統計列 + 下載聘書 -->
                                            <div class="flex items-center justify-between gap-3 text-sm text-gray-600">
                                                <div class="flex items-center gap-5">
                                                    <span class="flex items-center gap-1.5">
                                                        <i class="fa-solid fa-pen-to-square text-morandi"></i>
                                                        命題 <span class="font-bold text-slate-main">@project.QuestionCount</span> 題
                                                    </span>
                                                    <span class="flex items-center gap-1.5">
                                                        <i class="fa-solid fa-circle-check text-sage"></i>
                                                        採用 <span class="font-bold text-slate-main">@project.AdoptedCount</span> 題
                                                    </span>
                                                    @if (project.QuestionCount > 0)
                                                    {
                                                        <span class="flex items-center gap-1.5">
                                                            <i class="fa-solid fa-chart-line text-terracotta"></i>
                                                            採用率 <span class="font-bold text-slate-main">@project.AdoptionRateText</span>
                                                        </span>
                                                    }
                                                </div>
                                                @if (project.HasDownloadableCerts)
                                                {
                                                    <div class="flex items-center gap-2 flex-wrap justify-end">
                                                        <button type="button" @onclick="() => OpenEditPeriodModal(selectedDetail!.UserId, project.ProjectId)"
                                                            title="編輯此教師在本梯次的聘期（儲存後自動重產聘書）"
                                                            class="cursor-pointer flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-slate-main border border-slate-main/30 rounded-lg hover:bg-slate-main/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-main/40 transition-colors whitespace-nowrap">
                                                            <i class="fa-solid fa-pen-to-square"></i> 編輯聘期
                                                        </button>
                                                        <a href="@($"api/appointment-cert/download/{project.ProjectId}/user/{selectedDetail!.UserId}")"
                                                           target="_blank"
                                                           rel="noopener"
                                                           title="下載此教師在本梯次的聘書（1 份直下 jpg、多份打包 zip）"
                                                           class="cursor-pointer flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold text-morandi border border-morandi/30 rounded-lg hover:bg-morandi/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-morandi/40 transition-colors whitespace-nowrap no-underline">
                                                            <i class="fa-solid fa-award"></i> 下載聘書
                                                        </a>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════════════════ *@
@*  SlideOver：新增 / 編輯教師                                           *@
@* ══════════════════════════════════════════════════════════════════════ *@
<CustomModal @bind-IsVisible="showTeacherModal" Type="CustomModal.ModalType.SlideOver"
    Title="@panelTitle" HeaderIcon="fa-solid fa-chalkboard-user" MaxWidth="max-w-2xl" CloseOnBackdropClick="true">
    <ChildContent>
        <EditForm Model="formModel" OnValidSubmit="HandleSaveTeacher" FormName="teacherForm">
            <div class="space-y-8">
                <!-- 聘書相關欄位提醒：跨區塊提示，避免使用者忽略職稱必填 -->
                <div class="px-4 py-3 bg-morandi/10 border border-morandi/30 rounded-lg flex items-start gap-2.5 text-sm text-morandi">
                    <i class="fa-solid fa-award mt-0.5 flex-shrink-0 text-base"></i>
                    <span class="leading-relaxed">
                        <span class="font-bold">教師姓名</span>、
                        <span class="font-bold">任教學校</span>、
                        <span class="font-bold">職稱</span>
                        會用於產聘書，請務必正確填寫。
                    </span>
                </div>

                <!-- 區塊 1: 基本資料 -->
                <div class="space-y-4">
                    <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                        <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">1</span>
                        基本資料
                    </h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">教師姓名 <span class="text-red-500">*</span></label>
                            <InputText @bind-Value="formModel.DisplayName" placeholder="如: 王小明"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">性別</label>
                            <InputSelect @bind-Value="formModel.Gender"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                                <option value="0">請選擇</option>
                                <option value="1">男</option>
                                <option value="2">女</option>
                            </InputSelect>
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-medium mb-1 text-gray-700">電子信箱 (帳號) <span class="text-red-500">*</span></label>
                            <InputText @bind-Value="formModel.Email" placeholder="name@school.edu.tw"
                                disabled="@isEditMode"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm disabled:bg-gray-100 disabled:cursor-not-allowed" />
                            @if (isEditMode)
                            {
                                <p class="text-xs text-gray-400 mt-1"><i class="fa-solid fa-circle-info mr-0.5"></i> 帳號建立後信箱不可修改。</p>
                            }
                            else
                            {
                                <p class="text-xs text-gray-400 mt-1"><i class="fa-solid fa-circle-info mr-0.5"></i> 此信箱即為登入帳號，預設密碼為 <span class="font-bold font-mono">CSF@01024304</span>，首次登入系統將強制修改密碼。</p>
                            }
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">聯絡電話</label>
                            <InputText @bind-Value="formModel.Phone" placeholder="0912-345-678"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">身分證字號</label>
                            <InputText @bind-Value="formModel.IdNumber" placeholder="A123456789"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm" />
                        </div>
                    </div>
                </div>

                <!-- 區塊 2: 任教背景 -->
                <div class="space-y-4 pt-2">
                    <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                        <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">2</span>
                        任教背景
                    </h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="col-span-2">
                            <label class="block text-sm font-medium mb-1 text-gray-700">任教學校 <span class="text-red-500">*</span></label>
                            <InputText @bind-Value="formModel.School" placeholder="如: 國立臺灣師範大學"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">系所 / 科別</label>
                            <InputText @bind-Value="formModel.Department" placeholder="如: 國文學系"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">職稱 <span class="text-red-500">*</span></label>
                            <InputText @bind-Value="formModel.Title" placeholder="如：教授、副教授、助理教授"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm" />
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-medium mb-1 text-gray-700">專長領域</label>
                            <InputText @bind-Value="formModel.Expertise" placeholder="如: 古典文學、現代文學、語言學"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">教學年資</label>
                            <InputNumber @bind-Value="formModel.TeachingYears" placeholder="如: 10" min="0"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">最高學歷</label>
                            <InputSelect @bind-Value="formModel.Education"
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                                <option value="">請選擇</option>
                                <option value="4">博士</option>
                                <option value="3">碩士</option>
                                <option value="2">學士</option>
                                <option value="1">專科</option>
                                <option value="0">其它</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <!-- 區塊 3: 帳號設定 -->
                <div class="space-y-4 pt-2">
                    <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                        <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">3</span>
                        帳號設定
                    </h3>
                    <div class="space-y-4">
                        <div class="bg-blue-50/50 p-4 rounded-lg border border-blue-100">
                            <p class="text-xs text-morandi font-medium">
                                <i class="fa-solid fa-lightbulb mr-1"></i>
                                @if (isEditMode)
                                {
                                    <span>此教師帳號已建立，登入帳號為電子信箱。</span>
                                }
                                else
                                {
                                    <span>系統將自動以教師信箱作為登入帳號，預設密碼為 <span class="font-bold font-mono">CSF@01024304</span>。教師首次登入時，系統會強制要求變更密碼。</span>
                                }
                            </p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">帳號狀態</label>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="accountStatus" value="1" checked="@(formModel.Status == 1)" @onchange="() => formModel.Status = 1" class="text-morandi focus:ring-morandi">
                                    <span class="text-sm">啟用</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="accountStatus" value="0" checked="@(formModel.Status == 0)" @onchange="() => formModel.Status = 0" class="text-morandi focus:ring-morandi">
                                    <span class="text-sm">停用</span>
                                </label>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1 text-gray-700">備註</label>
                            <InputTextArea @bind-Value="formModel.Note" rows="3" placeholder="如：特殊專長說明、合作注意事項..."
                                class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm resize-none" />
                        </div>
                    </div>
                </div>
            </div>
        </EditForm>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="() => showTeacherModal = false"
            class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors focus:outline-none shadow-sm">
            取消
        </button>
        <button type="button" @onclick="HandleSaveTeacher" disabled="@isSaving"
            class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors focus:outline-none shadow-sm flex items-center gap-2 disabled:opacity-50">
            @if (isSaving)
            {
                <i class="fa-solid fa-spinner fa-spin"></i>
            }
            else
            {
                <i class="fa-solid fa-floppy-disk"></i>
            }
            <span>儲存教師</span>
        </button>
    </FooterContent>
</CustomModal>

@* ══════════════════════════════════════════════════════════════════════ *@
@*  Modal：加入梯次                                                     *@
@* ══════════════════════════════════════════════════════════════════════ *@
<CustomModal @bind-IsVisible="showAssignModal" Type="CustomModal.ModalType.Center" Title="加入梯次">
    <ChildContent>
        <div class="space-y-5">
            <div>
                <label class="block text-sm font-medium mb-1 text-gray-700">選擇梯次 <span class="text-red-500">*</span></label>
                <select @bind="assignProjectId"
                    class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                    <option value="0">請選擇梯次</option>
                    @foreach (var p in availableProjects)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium mb-2 text-gray-700">指派角色 <span class="text-red-500">*</span></label>
                <div class="space-y-2">
                    @foreach (var role in externalRoleOptions)
                    {
                        var roleId = role.Id;
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" checked="@assignRoleIds.Contains(roleId)"
                                @onchange="e => ToggleAssignRole(roleId, (bool)(e.Value ?? false))"
                                class="rounded text-morandi focus:ring-morandi">
                            <span class="text-sm">@role.Name</span>
                        </label>
                    }
                </div>
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="() => showAssignModal = false"
            class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors focus:outline-none shadow-sm">
            取消
        </button>
        <button type="button" @onclick="HandleAssignProject" disabled="@isSaving"
            class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors focus:outline-none shadow-sm flex items-center gap-2 disabled:opacity-50">
            @if (isSaving) { <i class="fa-solid fa-spinner fa-spin"></i> }
            <span>確認加入</span>
        </button>
    </FooterContent>
</CustomModal>

@* 編輯聘期 Modal（共用元件） *@
<EditAppointmentPeriodModal @bind-IsVisible="showEditPeriodModal"
                             UserId="editPeriodUserId"
                             ProjectId="editPeriodProjectId"
                             OnSaved="HandleEditPeriodSaved" />

@* ══════════════════════════════════════════════════════════════════════ *@
@*  SlideOver：批次匯入教師                                              *@
@* ══════════════════════════════════════════════════════════════════════ *@
@if (showImportSlideOver)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        @* ── Backdrop ── *@
        <div class="absolute inset-0 bg-black/50" @onclick="CloseImportSlideOver"></div>

        @* ── 主面板（置中、圓角、scale-in 動畫）── *@
        <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] flex flex-col overflow-hidden animate-modal-in">

            @* ── Header（固定，不滾動）── *@
            <div class="shrink-0 px-6 py-4 border-b border-gray-200 flex items-center justify-between bg-white">
                <div class="flex items-center gap-3">
                    <i class="fa-solid fa-file-import text-morandi text-lg"></i>
                    <h3 class="text-lg font-bold text-slate-main focus:outline-none">批次匯入教師</h3>
                    @if (importStep == "preview" && importRows is not null)
                    {
                        <span class="text-xs text-gray-500 font-medium bg-gray-100 px-2 py-0.5 rounded-full">
                            共 @importRows.Count 列
                        </span>
                    }
                </div>
                <button type="button" @onclick="CloseImportSlideOver"
                    class="cursor-pointer p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors focus:outline-none">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>

            @* ── 主要內容區（可捲動）── *@
            <div class="flex-1 overflow-y-auto">

                @* ===== Step A：上傳區 ===== *@
                @if (importStep == "upload")
                {
                    <div class="p-6 space-y-6">

                        @* 說明提示 *@
                        <div class="bg-morandi/10 border border-morandi/30 rounded-lg px-4 py-3 flex items-start gap-2.5 text-sm text-morandi">
                            <i class="fa-solid fa-circle-info mt-0.5 flex-shrink-0"></i>
                            <span class="leading-relaxed">
                                請先<strong>下載公版範本</strong>，依欄位填妥教師資料後，再上傳 xlsx 檔案。
                                必填欄位：姓名、電子信箱（帳號）、任教學校、職稱、帳號狀態。
                            </span>
                        </div>

                        @* 下載公版範本連結 *@
                        <div class="flex items-center gap-2">
                            <a href="@($"{NavigationManager.BaseUri}temp/教師資料匯入_公版.xlsx")"
                               download="教師資料匯入_公版.xlsx"
                               class="inline-flex items-center gap-2 px-4 py-2 bg-morandi/10 border border-morandi/30 text-morandi text-sm font-medium rounded-lg hover:bg-morandi/20 transition-colors focus:outline-none">
                                <i class="fa-solid fa-download"></i> 下載公版範本
                            </a>
                            <span class="text-xs text-gray-400">填妥後再上傳</span>
                        </div>

                        @* 錯誤 Banner *@
                        @if (importErrorBanner is not null)
                        {
                            <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 flex items-center gap-2.5 text-sm text-red-700">
                                <i class="fa-solid fa-circle-exclamation flex-shrink-0"></i>
                                <span>@importErrorBanner</span>
                            </div>
                        }

                        @* 上傳拖曳區（InputFile 包在大方框內，純 CSS hover 反饋）*@
                        <div class="relative border-2 border-dashed border-gray-300 rounded-xl bg-gray-50 hover:border-morandi hover:bg-morandi/5 transition-colors group">
                            <label class="flex flex-col items-center justify-center py-12 px-6 cursor-pointer text-center">
                                @if (isParsingFile)
                                {
                                    @* 解析中狀態 *@
                                    <i class="fa-solid fa-spinner fa-spin text-4xl text-morandi mb-4"></i>
                                    <p class="text-base font-medium text-morandi">解析中，請稍候...</p>
                                    <p class="text-sm text-gray-400 mt-1">正在讀取 Excel 並驗證資料</p>
                                }
                                else
                                {
                                    <i class="fa-solid fa-cloud-arrow-up text-4xl text-gray-300 group-hover:text-morandi mb-4 transition-colors"></i>
                                    <p class="text-base font-medium text-gray-600 group-hover:text-morandi transition-colors">
                                        拖曳 Excel 至此，或點擊選擇檔案
                                    </p>
                                    <p class="text-sm text-gray-400 mt-1">僅支援 .xlsx 格式，最大 5MB</p>
                                }
                                @* InputFile 透明覆蓋整個 label 讓整區可點擊 *@
                                <InputFile OnChange="HandleFileSelectedAsync"
                                           accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                                           class="absolute inset-0 opacity-0 w-full h-full cursor-pointer"
                                           disabled="@isParsingFile" />
                            </label>
                        </div>

                    </div>
                }

                @* ===== Step B：預覽表格 ===== *@
                else if (importStep == "preview" && importRows is not null)
                {
                    @* 即時統計：在 Razor 方法中計算（避免 lambda 在 markup 中多次呼叫）*@
                    var totalCount = importRows.Count;
                    var errorCount = importRows.Count(r => r.Status == BatchImportRowStatus.Error);
                    var warnCount  = importRows.Count(r => r.Status == BatchImportRowStatus.Warning);
                    var validCount = importRows.Count(r => r.Status != BatchImportRowStatus.Error && r.IsSelected);

                    <div class="p-6 space-y-4">

                        @* 操作列：標題 + 重新上傳 *@
                        <div class="flex items-center justify-between">
                            <h3 class="text-sm font-bold text-gray-700 flex items-center gap-2">
                                <i class="fa-solid fa-clipboard-check text-morandi"></i> 驗證結果
                            </h3>
                            <button type="button" @onclick='() => { importStep = "upload"; importRows = null; importErrorBanner = null; }'
                                class="cursor-pointer text-sm text-morandi hover:underline focus:outline-none flex items-center gap-1.5">
                                <i class="fa-solid fa-arrow-rotate-left"></i> 重新上傳
                            </button>
                        </div>

                        @* 預覽表格 *@
                        <div class="overflow-x-auto rounded-lg border border-gray-200">
                            <table class="min-w-full text-xs">
                                <thead class="bg-gray-50 border-b border-gray-200 text-left">
                                    <tr>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 whitespace-nowrap">#</th>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 whitespace-nowrap">姓名</th>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 whitespace-nowrap">性別</th>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 whitespace-nowrap min-w-[160px]">電子信箱</th>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 whitespace-nowrap">學校</th>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 whitespace-nowrap">職稱</th>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 whitespace-nowrap">帳號狀態</th>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 min-w-[180px]">驗證結果</th>
                                        <th class="px-3 py-2.5 font-bold text-gray-600 text-center">勾選</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @foreach (var (row, idx) in importRows.Select((r, i) => (r, i)))
                                    {
                                        @* 三色列 CSS：紅色=Error / 橘色=Warning / 綠色=Valid *@
                                        var rowCss = row.Status switch
                                        {
                                            BatchImportRowStatus.Error   => "bg-red-50",
                                            BatchImportRowStatus.Warning => "bg-orange-50",
                                            _                            => "bg-green-50/30"
                                        };
                                        var msgCss = row.Status switch
                                        {
                                            BatchImportRowStatus.Error   => "text-red-700",
                                            BatchImportRowStatus.Warning => "text-orange-600",
                                            _                            => "text-sage"
                                        };
                                        var genderText = row.Data.Gender switch { 1 => "男", 2 => "女", _ => "—" };
                                        var statusText = row.Data.Status == 1 ? "啟用" : "停用";

                                        <tr class="@rowCss">
                                            <td class="px-3 py-2 text-gray-400 font-mono">@(idx + 1)</td>
                                            <td class="px-3 py-2 font-medium text-gray-800 whitespace-nowrap">@(row.Data.DisplayName ?? "—")</td>
                                            <td class="px-3 py-2 text-gray-500">@genderText</td>
                                            <td class="px-3 py-2 text-gray-600 font-mono text-xs break-all">@(row.Data.Email ?? "—")</td>
                                            <td class="px-3 py-2 text-gray-500 whitespace-nowrap">@(row.Data.School ?? "—")</td>
                                            <td class="px-3 py-2 text-gray-500 whitespace-nowrap">@(row.Data.Title ?? "—")</td>
                                            <td class="px-3 py-2 whitespace-nowrap">
                                                <span class="@(row.Data.Status == 1 ? "text-sage" : "text-terracotta") font-medium">@statusText</span>
                                            </td>
                                            <td class="px-3 py-2 @msgCss leading-snug">
                                                @if (row.Status == BatchImportRowStatus.Valid)
                                                {
                                                    <span class="font-medium">OK</span>
                                                }
                                                else if (row.Status == BatchImportRowStatus.Error)
                                                {
                                                    <span>@string.Join("；", row.Errors)</span>
                                                }
                                                else
                                                {
                                                    <span>@string.Join("；", row.Warnings)</span>
                                                }
                                            </td>
                                            <td class="px-3 py-2 text-center">
                                                @if (row.Status == BatchImportRowStatus.Error)
                                                {
                                                    @* 錯誤列：禁用 checkbox，顯示叉叉 *@
                                                    <i class="fa-solid fa-xmark text-red-400"></i>
                                                }
                                                else
                                                {
                                                    <input type="checkbox" @bind="row.IsSelected"
                                                        class="w-4 h-4 accent-[var(--color-morandi)] cursor-pointer" />
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                }

                @* ===== Step C：匯入結果摘要 ===== *@
                else if (importStep == "result" && importResults is not null)
                {
                    var successCount = importResults.Count(r => r.IsSuccess);
                    var failureCount = importResults.Count(r => !r.IsSuccess);
                    var failures = importResults.Where(r => !r.IsSuccess).ToList();

                    <div class="p-6 space-y-4">

                        @* 摘要圓形徽章 *@
                        <div class="flex flex-col items-center justify-center py-8">
                            <div class="w-16 h-16 rounded-full bg-sage/15 flex items-center justify-center mb-4">
                                <i class="fa-solid fa-check-circle text-3xl" style="color: var(--color-sage);"></i>
                            </div>
                            <h4 class="text-xl font-bold text-slate-main mb-4">匯入完成</h4>
                            <div class="flex items-center gap-8 text-sm">
                                <div class="flex flex-col items-center gap-1">
                                    <span class="text-2xl font-bold" style="color: var(--color-sage);">@successCount</span>
                                    <span class="text-gray-500">成功匯入</span>
                                </div>
                                <div class="w-px h-10 bg-gray-200"></div>
                                <div class="flex flex-col items-center gap-1">
                                    <span class="text-2xl font-bold @(failureCount > 0 ? "text-red-600" : "text-gray-400")">@failureCount</span>
                                    <span class="text-gray-500">匯入失敗</span>
                                </div>
                            </div>
                        </div>

                        @* 失敗明細表格（只在有失敗列時顯示）*@
                        @if (failureCount > 0)
                        {
                            <div>
                                <h5 class="text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
                                    <i class="fa-solid fa-triangle-exclamation text-red-500"></i> 失敗明細
                                </h5>
                                <div class="border border-red-200 rounded-lg overflow-hidden">
                                    <table class="w-full text-sm">
                                        <thead class="bg-red-50 text-left">
                                            <tr>
                                                <th class="px-3 py-2 font-bold text-gray-600 w-24">Excel 列號</th>
                                                <th class="px-3 py-2 font-bold text-gray-600">錯誤原因</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-red-100">
                                            @foreach (var f in failures)
                                            {
                                                <tr class="bg-red-50/60">
                                                    <td class="px-3 py-2 text-gray-500 font-mono">第 @f.RowNumber 列</td>
                                                    <td class="px-3 py-2 text-red-700">@f.ErrorMessage</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }

                    </div>
                }

            </div>

            @* ── Footer（固定，不滾動）：Step B / Step C 各自的 Footer ── *@
            @if (importStep == "preview" && importRows is not null)
            {
                var footerValid = importRows.Count(r => r.Status != BatchImportRowStatus.Error && r.IsSelected);
                var footerError = importRows.Count(r => r.Status == BatchImportRowStatus.Error);
                var footerWarn  = importRows.Count(r => r.Status == BatchImportRowStatus.Warning);
                <div class="shrink-0 px-6 py-4 border-t border-gray-200 bg-gray-50 flex items-center justify-between gap-3">
                    @* 統計列 *@
                    <div class="flex flex-wrap gap-3 text-sm">
                        <span class="text-gray-500">共 <strong class="text-slate-main">@importRows.Count</strong> 列</span>
                        <span class="text-sage font-medium">可匯入 <strong>@footerValid</strong> 筆</span>
                        @if (footerError > 0)
                        {
                            <span class="text-red-600 font-medium">錯誤 <strong>@footerError</strong> 筆（不可匯入）</span>
                        }
                        @if (footerWarn > 0)
                        {
                            <span class="text-orange-500 font-medium">警告 <strong>@footerWarn</strong> 筆（DB Email 已存在）</span>
                        }
                    </div>
                    @* 按鈕組 *@
                    <div class="flex items-center gap-3 shrink-0">
                        <button type="button" @onclick="CloseImportSlideOver"
                            disabled="@isImporting"
                            class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors focus:outline-none shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
                            取消
                        </button>
                        <button type="button" @onclick="ConfirmImportAsync"
                            disabled="@(footerValid == 0 || isImporting)"
                            class="cursor-pointer px-5 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors focus:outline-none shadow-sm disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-2">
                            @if (isImporting)
                            {
                                <i class="fa-solid fa-circle-notch fa-spin"></i>
                                <span>匯入中...</span>
                            }
                            else
                            {
                                <i class="fa-solid fa-upload"></i>
                                <span>確認匯入 @footerValid 筆</span>
                            }
                        </button>
                    </div>
                </div>
            }
            else if (importStep == "result")
            {
                <div class="shrink-0 px-6 py-4 border-t border-gray-200 bg-gray-50 flex items-center justify-end">
                    <button type="button" @onclick="FinishImportAsync"
                        class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-bold hover:bg-[#5b7a95] transition-colors focus:outline-none shadow-sm">
                        完成
                    </button>
                </div>
            }

        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════════════ *@
@*  @code                                                               *@
@* ══════════════════════════════════════════════════════════════════════ *@
@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    [CascadingParameter(Name = "CurrentProject")] private ProjectSwitcherItem? CurrentProject { get; set; }

    /// <summary>
    /// 加入梯次後即時繪製該專案所有「未完成」聘書並上傳。
    /// 無 pending 時靜默略過。
    /// </summary>
    private async Task DrawPendingAppointmentsAsync(int projectId)
    {
        try
        {
            var pending = await AppointmentService.GetPendingDraftsByProjectAsync(projectId);
            if (pending.Count == 0) return;
            await JS.InvokeVoidAsync("AppointmentCert.drawAndUpload", pending, "", false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "聘書繪製失敗 (projectId={ProjectId})", projectId);
        }
    }

    // ──── 編輯聘期 Modal 狀態 ────
    private bool showEditPeriodModal = false;
    private int? editPeriodUserId;
    private int? editPeriodProjectId;

    private void OpenEditPeriodModal(int userId, int projectId)
    {
        editPeriodUserId = userId;
        editPeriodProjectId = projectId;
        showEditPeriodModal = true;
    }

    /// <summary>編輯聘期儲存後：觸發 client 重畫對應 cert（FileName 已被 UpdateCustomPeriodsAsync 設為 NULL）。</summary>
    private async Task HandleEditPeriodSaved()
    {
        if (editPeriodProjectId is int pid)
        {
            await DrawPendingAppointmentsAsync(pid);
            // 重畫完成後可能需要更新「HasDownloadableCerts」狀態（暫時保留下次重載觸發即可）
            if (selectedDetail is not null)
            {
                await SelectTeacher(selectedDetail.Id);
            }
        }
    }

    // ──── 列表狀態 ────
    private List<TeacherListItem> allTeachers = [];
    private TeacherStatsDto stats = new();
    private bool isLoadingList = true;
    private string searchKeyword = "";
    private string listFilter = "all";

    // ──── 詳情狀態 ────
    private int? selectedTeacherId;
    private TeacherDetailDto? selectedDetail;
    private string detailTab = "info";
    private bool isActionBusy = false;

    // ──── 命題歷程 ────
    private const int HistoryPageSize = 10;
    private TeacherComposeStats composeStats = new();
    private TeacherComposeHistoryResult composeResult = new() { PageSize = HistoryPageSize };
    private string composeFilterProjectId = "";
    private int composePage = 1;
    private bool isLoadingCompose = false;

    // ──── 審題歷程 ────
    private TeacherReviewStats reviewStats = new();
    private TeacherReviewHistoryResult reviewResult = new() { PageSize = HistoryPageSize };
    private string reviewFilterProjectId = "";
    private int reviewPage = 1;
    private bool isLoadingReview = false;

    // ──── 參與專案 ────
    private List<TeacherProjectItem> teacherProjects = [];
    private List<ProjectDropdownItem> projectFilterOptions = [];

    // ──── Lazy Load 旗標（換教師時 reset；Tab 首次切入後設 true）────
    private bool composeHistoryLoaded = false;
    private bool reviewHistoryLoaded = false;
    private bool projectsLoaded = false;

    // ──── SlideOver ────
    private bool showTeacherModal = false;
    private string panelTitle = "新增教師";
    private TeacherFormModel formModel = new();
    private bool isEditMode = false;
    private int? editingTeacherId;
    private bool isSaving = false;

    // ──── 批次匯入 SlideOver ────
    private bool showImportSlideOver = false;
    private List<BatchImportRow>? importRows;               // ParseExcelAsync 解析後的列資料
    private List<BatchImportRowResult>? importResults;      // ImportTeachersAsync 回傳結果
    private bool isParsingFile = false;
    private bool isImporting = false;                       // 匯入中防重複提交
    private string importStep = "upload";                   // "upload" | "preview" | "result"
    private string? importErrorBanner;                      // 前端攔截的格式/大小/解析層級錯誤

    // ──── 加入梯次 Modal ────
    private bool showAssignModal = false;
    private List<ProjectDropdownItem> availableProjects = [];
    private List<RoleOption> externalRoleOptions = [];
    private int assignProjectId = 0;
    private HashSet<int> assignRoleIds = [];

    // ──── 上次梯次 Id（偵測切換）────
    private int? previousProjectId;

    private IEnumerable<TeacherListItem> FilteredTeachers =>
        allTeachers
            .Where(t => listFilter == "all"
                        || (listFilter == "active" && t.Status == 1)
                        || (listFilter == "inactive" && t.Status != 1))
            .Where(t => string.IsNullOrWhiteSpace(searchKeyword)
                        || t.DisplayName.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase)
                        || t.TeacherCode.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase)
                        || t.School.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase)
                        || (t.Email?.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadListAsync();
        externalRoleOptions = await TeacherService.GetExternalRoleOptionsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        var newProjectId = CurrentProject?.Id;
        if (newProjectId != previousProjectId)
        {
            previousProjectId = newProjectId;
            await LoadListAsync();
            // 若已有選取的教師，重新載入詳情（角色 Badge 可能變）
            if (selectedTeacherId.HasValue)
                await SelectTeacher(selectedTeacherId.Value);
        }
    }

    private async Task LoadListAsync()
    {
        // 僅首次載入顯示 Loading，後續刷新直接替換清單（避免閃爍）
        var isFirstLoad = allTeachers.Count == 0;
        try
        {
            if (isFirstLoad) isLoadingList = true;
            allTeachers = await TeacherService.GetTeacherListAsync(CurrentProject?.Id);
            stats = await TeacherService.GetTeacherStatsAsync(CurrentProject?.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入教師清單失敗");
        }
        finally
        {
            isLoadingList = false;
        }
    }

    private async Task SelectTeacher(int teacherId)
    {
        selectedTeacherId = teacherId;
        // 切換教師時預設回「基本資料」Tab，並 reset 所有 Lazy Load 旗標
        detailTab = "info";
        composeHistoryLoaded = false;
        reviewHistoryLoaded = false;
        projectsLoaded = false;
        // 清空前一位教師的快取資料，避免短暫顯示舊資料
        composeResult = new() { PageSize = HistoryPageSize };
        reviewResult = new() { PageSize = HistoryPageSize };
        composeStats = new();
        reviewStats = new();
        composeFilterProjectId = "";
        reviewFilterProjectId = "";
        composePage = 1;
        reviewPage = 1;

        try
        {
            selectedDetail = await TeacherService.GetTeacherDetailAsync(teacherId);

            if (selectedDetail is not null)
            {
                // 參與專案資料：由 Tab 切換時 Lazy Load
                teacherProjects = [];
                projectFilterOptions = [];

                // Lazy Load：只有當前 Tab 對應的資料才立即載入
                if (detailTab == "compose")
                {
                    await LoadComposeHistoryAsync();
                    composeHistoryLoaded = true;
                }
                else if (detailTab == "review")
                {
                    await LoadReviewHistoryAsync();
                    reviewHistoryLoaded = true;
                }
                else if (detailTab == "projects")
                {
                    await LoadProjectsTabAsync();
                    projectsLoaded = true;
                }
                // detailTab == "info"（預設）：不查任何歷程 DB
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "載入教師詳情失敗");
        }
    }

    /// <summary>Tab 切換 handler：切換到目標 Tab，並在首次切入時 Lazy Load 對應資料。</summary>
    private async Task SwitchDetailTabAsync(string tab)
    {
        detailTab = tab;

        if (selectedDetail is null) return;

        if (tab == "compose" && !composeHistoryLoaded)
        {
            await LoadComposeHistoryAsync();
            composeHistoryLoaded = true;
        }
        else if (tab == "review" && !reviewHistoryLoaded)
        {
            await LoadReviewHistoryAsync();
            reviewHistoryLoaded = true;
        }
        else if (tab == "projects" && !projectsLoaded)
        {
            await LoadProjectsTabAsync();
            projectsLoaded = true;
        }
        // info Tab 或已載入過的 Tab：直接顯示快取，不查 DB
    }

    /// <summary>載入參與專案清單（含專案下拉選項），供 Lazy Load 使用。</summary>
    private async Task LoadProjectsTabAsync()
    {
        if (selectedDetail is null) return;
        teacherProjects = await TeacherService.GetTeacherProjectsAsync(selectedDetail.UserId);
        projectFilterOptions = teacherProjects
            .Select(p => new ProjectDropdownItem { Id = p.ProjectId, Name = p.ProjectName })
            .ToList();
    }

    // ──── 命題歷程載入 ────
    private async Task LoadComposeHistoryAsync()
    {
        if (selectedDetail is null) return;
        isLoadingCompose = true;
        try
        {
            var projectId = string.IsNullOrEmpty(composeFilterProjectId) ? (int?)null : int.Parse(composeFilterProjectId);
            composeStats = await TeacherService.GetTeacherComposeStatsAsync(selectedDetail.UserId, projectId);
            composeResult = await TeacherService.GetTeacherComposeHistoryAsync(selectedDetail.UserId, projectId, composePage, HistoryPageSize);
        }
        finally
        {
            isLoadingCompose = false;
        }
    }

    // 切換梯次篩選時重設為第 1 頁
    private async Task OnComposeFilterChangedAsync()
    {
        composePage = 1;
        await LoadComposeHistoryAsync();
    }

    // 分頁器回呼
    private async Task OnComposePageChangedAsync(int page)
    {
        if (page < 1 || page > composeResult.PageCount || page == composePage) return;
        composePage = page;
        await LoadComposeHistoryAsync();
    }

    // ──── 審題歷程載入 ────
    private async Task LoadReviewHistoryAsync()
    {
        if (selectedDetail is null) return;
        isLoadingReview = true;
        try
        {
            var projectId = string.IsNullOrEmpty(reviewFilterProjectId) ? (int?)null : int.Parse(reviewFilterProjectId);
            reviewStats = await TeacherService.GetTeacherReviewStatsAsync(selectedDetail.UserId, projectId);
            reviewResult = await TeacherService.GetTeacherReviewHistoryAsync(selectedDetail.UserId, projectId, reviewPage, HistoryPageSize);
        }
        finally
        {
            isLoadingReview = false;
        }
    }

    // 切換梯次篩選時重設為第 1 頁
    private async Task OnReviewFilterChangedAsync()
    {
        reviewPage = 1;
        await LoadReviewHistoryAsync();
    }

    // 分頁器回呼
    private async Task OnReviewPageChangedAsync(int page)
    {
        if (page < 1 || page > reviewResult.PageCount || page == reviewPage) return;
        reviewPage = page;
        await LoadReviewHistoryAsync();
    }

    // ──── 新增教師 ────
    private void OpenNewTeacher()
    {
        panelTitle = "新增教師";
