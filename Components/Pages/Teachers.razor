@* ====================================================================== *@
@*  Teachers — 教師人才庫管理                                               *@
@*  路由：/teachers                                                        *@
@*  功能：統計卡片、左右分割佈局（左側列表搜尋＋篩選、右側詳情三分頁）       *@
@*        SlideOver 新增/編輯教師表單（基本資料、任教背景、帳號設定）         *@
@* ====================================================================== *@
@page "/teachers"
@using MT.Components.Shared

<div class="flex-grow flex flex-col w-full max-w-[1920px] mx-auto h-[calc(100vh-4rem)] overflow-hidden">

    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <a href="/home" class="inline-flex items-center hover:text-morandi transition-colors focus:outline-none">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </a>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-slate-main">教師管理系統</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 tabindex="-1" class="text-2xl font-bold flex items-center gap-2 focus:outline-none">
                    <i class="fa-solid fa-chalkboard-user text-morandi"></i> 教師管理系統 (人才庫)
                </h1>
            </div>
            <div class="flex gap-2">
                <button type="button"
                    class="cursor-pointer px-4 py-2.5 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-file-export"></i> 匯出名單
                </button>
                <button type="button" @onclick="OpenNewTeacher"
                    class="cursor-pointer px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] transition-all shadow-sm focus:outline-none flex items-center gap-2">
                    <i class="fa-solid fa-user-plus"></i> 新增教師
                </button>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                    人才庫總數 <i class="fa-solid fa-users text-morandi opacity-50"></i>
                </div>
                <div class="text-2xl font-bold text-slate-main">0</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                    帳號啟用中 <i class="fa-solid fa-circle-check text-sage opacity-50"></i>
                </div>
                <div class="text-2xl font-bold text-sage">0</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                    帳號停用中 <i class="fa-solid fa-circle-xmark text-terracotta opacity-50"></i>
                </div>
                <div class="text-2xl font-bold text-terracotta">0</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 transition duration-200 hover:shadow-md">
                <div class="text-gray-500 text-xs font-bold mb-1 flex items-center justify-between">
                    本梯次參與教師 <i class="fa-solid fa-user-check text-morandi opacity-50"></i>
                </div>
                <div class="text-2xl font-bold text-morandi">0</div>
            </div>
        </div>
    </div>

    <!-- Split Layout (Left List, Right Detail) -->
    <div class="flex-grow flex overflow-hidden px-4 sm:px-6 lg:px-8 pb-4">
        <div class="flex-grow flex overflow-hidden bg-white rounded-xl shadow-sm border border-gray-200">

            <!-- Left Panel: Teacher List -->
            <div class="w-full lg:w-[380px] xl:w-[420px] border-r border-gray-200 flex flex-col z-10 flex-shrink-0">
                <!-- Filters -->
                <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col gap-3 flex-shrink-0">
                    <div class="relative">
                        <i class="fa-solid fa-magnifying-glass left-3 top-2.5 absolute text-gray-400"></i>
                        <input type="text" class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi" placeholder="搜尋姓名、編號、學校或信箱...">
                    </div>
                    <div class="flex gap-2">
                        <button @onclick='() => listFilter = "all"'
                            class="@(listFilter == "all" ? "bg-morandi text-white" : "border border-gray-200 text-gray-500 hover:bg-gray-100") flex-1 py-1 text-xs font-bold rounded cursor-pointer transition-colors focus:outline-none">
                            全部
                        </button>
                        <button @onclick='() => listFilter = "active"'
                            class="@(listFilter == "active" ? "bg-morandi text-white" : "border border-gray-200 text-gray-500 hover:bg-gray-100") flex-1 py-1 text-xs font-bold rounded cursor-pointer transition-colors focus:outline-none">
                            啟用中
                        </button>
                        <button @onclick='() => listFilter = "inactive"'
                            class="@(listFilter == "inactive" ? "bg-morandi text-white" : "border border-gray-200 text-gray-500 hover:bg-gray-100") flex-1 py-1 text-xs font-bold rounded cursor-pointer transition-colors focus:outline-none">
                            停用中
                        </button>
                    </div>
                </div>
                <!-- List -->
                <div class="flex-grow overflow-y-auto custom-scroll p-4">
                    <EmptyState IconClass="fa-users-slash" Message="目前尚無教師" SubMessage="點擊右上角「新增教師」來建立人才庫。" Compact="true" />
                </div>
            </div>

            <!-- Right Panel: Teacher Details -->
            <div class="hidden lg:flex flex-col flex-grow bg-oatmeal overflow-hidden">
                <!-- Fallback empty state -->
                <div class="flex-grow flex flex-col items-center justify-center text-gray-400 p-8">
                    <i class="fa-solid fa-user-graduate text-6xl mb-4 text-gray-300"></i>
                    <p class="text-lg font-medium">請由左側列表選擇教師，或新增一位教師。</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SlideOver：新增 / 編輯教師 -->
<CustomModal @bind-IsVisible="showTeacherModal" Type="CustomModal.ModalType.SlideOver" Title="@panelTitle" CloseOnBackdropClick="false">
    <ChildContent>
        <form class="space-y-8" @onsubmit:preventDefault>

            <!-- 區塊 1: 基本資料 -->
            <div class="space-y-4">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">1</span>
                    基本資料
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">教師姓名 <span class="text-red-500">*</span></label>
                        <input type="text" placeholder="如: 王小明" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">性別</label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            <option value="male">男</option>
                            <option value="female">女</option>
                        </select>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">電子信箱 (帳號) <span class="text-red-500">*</span></label>
                        <input type="email" placeholder="name@school.edu.tw" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                        <p class="text-[10px] text-gray-400 mt-1">
                            <i class="fa-solid fa-circle-info mr-0.5"></i> 此信箱即為登入帳號，預設密碼為 Cwt2026!，首次登入系統將強制修改密碼。
                        </p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">聯絡電話</label>
                        <input type="tel" placeholder="0912-345-678" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">身分證字號</label>
                        <input type="text" placeholder="A123456789" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                </div>
            </div>

            <!-- 區塊 2: 任教背景 -->
            <div class="space-y-4 pt-2">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">2</span>
                    任教背景
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">任教學校 <span class="text-red-500">*</span></label>
                        <input type="text" placeholder="如: 國立臺灣師範大學" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">系所 / 科別</label>
                        <input type="text" placeholder="如: 國文學系" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">職稱</label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            <option value="教授">教授</option>
                            <option value="副教授">副教授</option>
                            <option value="助理教授">助理教授</option>
                            <option value="講師">講師</option>
                            <option value="教師">教師</option>
                            <option value="兼任教師">兼任教師</option>
                        </select>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-sm font-medium mb-1 text-gray-700">專長領域</label>
                        <input type="text" placeholder="如: 古典文學、現代文學、語言學" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">教學年資</label>
                        <input type="number" placeholder="如: 10" min="0" class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">最高學歷</label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            <option value="博士">博士</option>
                            <option value="碩士">碩士</option>
                            <option value="學士">學士</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- 區塊 3: 帳號設定 -->
            <div class="space-y-4 pt-2">
                <h3 class="text-base font-bold text-gray-800 border-b border-morandi/30 pb-2 flex items-center gap-2">
                    <span class="bg-morandi text-white w-5 h-5 rounded-full flex items-center justify-center text-xs">3</span>
                    帳號設定
                </h3>
                <div class="space-y-4">
                    <div class="bg-blue-50/50 p-4 rounded-lg border border-blue-100">
                        <p class="text-xs text-morandi font-medium">
                            <i class="fa-solid fa-lightbulb mr-1"></i>
                            系統將自動以教師信箱作為登入帳號，預設密碼為 <span class="font-bold font-mono">Cwt2026!</span>。教師首次登入時，系統會強制要求變更密碼。
                        </p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">帳號狀態</label>
                        <div class="flex gap-4">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="accountStatus" value="active" checked class="text-morandi focus:ring-morandi">
                                <span class="text-sm">啟用</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="accountStatus" value="inactive" class="text-morandi focus:ring-morandi">
                                <span class="text-sm">停用</span>
                            </label>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1 text-gray-700">備註</label>
                        <textarea rows="3" placeholder="如：特殊專長說明、合作注意事項..."
                            class="w-full px-3 py-2 border border-gray-300 rounded focus:ring-1 focus:ring-morandi focus:border-morandi focus:outline-none text-sm resize-none"></textarea>
                    </div>
                </div>
            </div>
        </form>
    </ChildContent>
    <FooterContent>
        <button type="button" @onclick="() => showTeacherModal = false"
            class="cursor-pointer px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-100 transition-colors focus:outline-none shadow-sm">
            取消
        </button>
        <button type="button"
            class="cursor-pointer px-6 py-2 bg-morandi text-white rounded-lg text-sm font-medium hover:bg-[#5b7a95] transition-colors focus:outline-none shadow-sm flex items-center gap-2">
            <i class="fa-solid fa-floppy-disk"></i> 儲存教師
        </button>
    </FooterContent>
</CustomModal>

@code {
    private bool showTeacherModal = false;
    private string panelTitle = "新增教師";
    private string listFilter = "all";

    private void OpenNewTeacher()
    {
        panelTitle = "新增教師";
        showTeacherModal = true;
    }
}
