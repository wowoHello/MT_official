@page "/teachers"
@using MT.Components.Shared

<div class="flex-grow flex flex-col w-full max-w-[1920px] mx-auto h-[calc(100vh-4rem)] overflow-hidden">
    <!-- Breadcrumb & Header Row -->
    <div class="px-4 sm:px-6 lg:px-8 py-4 flex-shrink-0 bg-white/50 backdrop-blur border-b border-gray-200">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <nav class="flex text-sm text-gray-500 mb-1 font-medium" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-2">
                        <li class="inline-flex items-center">
                            <a href="/home" class="inline-flex items-center hover:text-morandi transition-colors">
                                <i class="fa-solid fa-house mr-1"></i> 首頁
                            </a>
                        </li>
                        <li>
                            <div class="flex items-center">
                                <i class="fa-solid fa-chevron-right text-xs mx-1"></i>
                                <span class="text-slate-main">教師管理系統</span>
                            </div>
                        </li>
                    </ol>
                </nav>
                <h1 class="text-2xl font-bold flex items-center gap-2">
                    <i class="fa-solid fa-chalkboard-user text-morandi"></i> 教師人才庫
                </h1>
            </div>
            <button type="button" @onclick="() => showTeacherModal = true" class="px-5 py-2.5 bg-sage text-white rounded-lg text-sm font-medium hover:bg-[#7b9c81] shadow-sm flex items-center gap-2">
                <i class="fa-solid fa-user-plus"></i> 新增教師
            </button>
        </div>
    </div>

    <!-- Split Layout (Left List, Right Detail) -->
    <div class="flex-grow flex overflow-hidden">
        <!-- Left Panel: List -->
        <div class="w-full lg:w-1/3 xl:w-1/4 bg-white border-r border-gray-200 flex flex-col z-10 flex-shrink-0">
            <div class="p-4 border-b border-gray-100 bg-gray-50 flex flex-col gap-3 shrink-0">
                <div class="relative">
                    <i class="fa-solid fa-magnifying-glass left-3 top-2.5 absolute text-gray-400"></i>
                    <input type="text" class="w-full pl-9 pr-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi" placeholder="搜尋姓名 / 編號 / 信箱...">
                </div>
            </div>
            <div class="flex-grow overflow-y-auto custom-scroll p-4">
                <EmptyState IconClass="fa-users-slash" Message="目前尚無教師" SubMessage="點擊右上角「新增教師」來建立人才庫。" />
            </div>
        </div>

        <!-- Right Panel: Details -->
        <div class="hidden lg:flex flex-col w-full lg:w-2/3 xl:w-3/4 bg-[var(--color-oatmeal)] overflow-hidden">
             <!-- Fallback empty state -->
            <div class="flex-grow flex flex-col items-center justify-center text-gray-400 p-8">
                <i class="fa-solid fa-address-card text-6xl mb-4 text-gray-300"></i>
                <p class="text-lg font-medium">請由左側列表選擇教師以查看詳情。</p>
            </div>
        </div>
    </div>
</div>

<CustomModal @bind-IsVisible="showTeacherModal" Type="CustomModal.ModalType.SlideOver" Title="新增教師檔案" CloseOnBackdropClick="false">
    <ChildContent>
        <form class="space-y-6">
            <div class="bg-blue-50/50 p-4 rounded border border-blue-100 mb-4">
                <h3 class="font-bold text-morandi text-sm flex items-center gap-2 mb-2">
                    <i class="fa-solid fa-id-card"></i> 基本資料
                </h3>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-gray-700 mb-1">姓名 <span class="text-red-500">*</span></label>
                        <input type="text" class="w-full text-sm border-gray-300 rounded px-2 py-1 focus:ring-1">
                    </div>
                </div>
            </div>
            <!-- Backend handles saving logic -->
        </form>
    </ChildContent>
</CustomModal>

@code {
    private bool showTeacherModal = false;
}
