    {
        <div class="flex flex-col">
            <span class="text-xs text-gray-400 font-bold">@label</span>
            <span class="text-sm text-slate-main">@value</span>
        </div>
    };


    /// <summary>結案後階段 Badge 改為中性灰；進行中依審題階段配色。</summary>
    private static string GetStageBadgeClass(TeacherReviewItem item) =>
        item.ProjectClosedAt != null
            ? "bg-gray-100 text-gray-600"
            : item.ReviewStage switch
            {
                1 => "bg-blue-50 text-blue-700",
                2 => "bg-purple-50 text-purple-700",
                3 => "bg-amber-50 text-amber-700",
                _ => "bg-gray-100 text-gray-500"
            };

    /// <summary>本次決策 Badge 配色：通過=鼠尾草綠、修正=橘黃、退回=赤陶、未決=灰。永遠顯示當次 assignment 決策。</summary>
    private static string GetThisDecisionBadgeClass(TeacherReviewItem item) => item.Decision switch
    {
        1 => "bg-sage/15 text-sage",
        2 => "bg-yellow-50 text-yellow-700",
        3 => "bg-terracotta/15 text-terracotta",
        _ => "bg-gray-100 text-gray-500"
    };

    /// <summary>最終結果 Badge 配色：採用=鼠尾草綠、不採用=赤陶、未結案=灰（顯示 —）。</summary>
    private static string GetFinalResultBadgeClass(TeacherReviewItem item) =>
        item.ProjectClosedAt == null
            ? "bg-gray-100 text-gray-400"
            : (item.FinalQuestionStatus == 12 ? "bg-sage/15 text-sage" : "bg-terracotta/15 text-terracotta");

    /// <remarks>已棄用，請改用 GetThisDecisionBadgeClass / GetFinalResultBadgeClass。</remarks>
    [Obsolete("請改用 GetThisDecisionBadgeClass / GetFinalResultBadgeClass")]
    private static string GetDecisionBadgeClass(TeacherReviewItem item) =>
        item.ProjectClosedAt != null
            ? (item.FinalQuestionStatus == 12 ? "bg-sage/15 text-sage" : "bg-terracotta/15 text-terracotta")
            : item.Decision switch
            {
                1 => "bg-sage/15 text-sage",
                2 => "bg-yellow-50 text-yellow-700",
                3 => "bg-terracotta/15 text-terracotta",
                _ => "bg-gray-100 text-gray-500"
            };

    private static string GetQuestionStatusBadge(int status) => status switch
    {
        0 => "bg-gray-100 text-gray-500",            // 草稿
        1 => "bg-blue-50 text-blue-700",             // 完成
        2 => "bg-sage/15 text-sage",                 // 送審
        3 or 5 or 7 => "bg-blue-50 text-blue-600",   // 審查中（互/專/總審）
        4 or 6 or 8 => "bg-amber-50 text-amber-700", // 修題中（互/專/總修）
        9 or 12 => "bg-sage/15 text-sage",           // 採用 / 結案入庫
        10 or 11 => "bg-gray-100 text-gray-500",     // 不採用 / 結案未採用
        _ => "bg-morandi/15 text-morandi"
    };

    private static string GetQuestionStatusText(int status) => status switch
    {
        0 => "草稿",
        1 => "完成",
        2 => "送審",
        3 => "互審中",
        4 => "互修中",
        5 => "專審中",
        6 => "專修中",
        7 => "總審中",
        8 => "總修中",
        9 => "採用",
        10 => "不採用",
        11 => "結案未採用",
        12 => "結案入庫",
        _ => $"狀態{status}"
    };
}
