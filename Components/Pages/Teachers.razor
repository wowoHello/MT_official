    // ──── 加入梯次 ────
    private async Task OpenAssignModal()
    {
        if (selectedDetail is null) return;

        // 防呆：停用帳號不可加入梯次
        if (selectedDetail.Status != 1)
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "warning",
                title = "此帳號目前為停用帳號",
                text = "請先啟用帳號後再加入梯次。",
                confirmButtonColor = "#6B8EAD",
            });
            return;
        }

        availableProjects = await TeacherService.GetAvailableProjectsAsync(selectedDetail.UserId);
        assignProjectId = 0;
        assignRoleIds = [];
        showAssignModal = true;
    }

    private void ToggleAssignRole(int roleId, bool isChecked)
    {
        if (isChecked) assignRoleIds.Add(roleId);
        else assignRoleIds.Remove(roleId);
    }

    private async Task HandleAssignProject()
    {
        if (assignProjectId <= 0)
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請選擇梯次", confirmButtonColor = "#6B8EAD" });
            return;
        }
        if (assignRoleIds.Count == 0)
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請至少選擇一個角色", confirmButtonColor = "#6B8EAD" });
            return;
        }

        isSaving = true;
        try
        {
            var authState = await AuthState;
            var operatorId = int.Parse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);

            await TeacherService.AssignToProjectAsync(new AssignProjectRequest
            {
                TeacherUserId = selectedDetail!.UserId,
                ProjectId = assignProjectId,
                RoleIds = assignRoleIds.ToList(),
            }, operatorId);

            // 立即關閉視窗並以非同步方式播放 SweetAlert，不阻塞後續資料刷新
            showAssignModal = false;
            _ = JS.InvokeVoidAsync("Swal.fire", new { icon = "success", title = "已加入梯次", toast = true, position = "top-end", showConfirmButton = false, timer = 1500 });
            StateHasChanged();

            await LoadListAsync();
            await SelectTeacher(selectedDetail.Id);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "error", title = "加入失敗", text = ex.Message, confirmButtonColor = "#6B8EAD" });
        }
        finally
        {
            isSaving = false;
        }
    }

    // ──── 移除梯次 ────
