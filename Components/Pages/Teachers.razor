    // ──── 儲存教師 ────
    private async Task HandleSaveTeacher()
    {
        if (string.IsNullOrWhiteSpace(formModel.DisplayName))
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請填寫教師姓名", confirmButtonColor = "#6B8EAD" });
            return;
        }
        if (!isEditMode && string.IsNullOrWhiteSpace(formModel.Email))
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請填寫電子信箱", confirmButtonColor = "#6B8EAD" });
            return;
        }
        if (string.IsNullOrWhiteSpace(formModel.School))
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請填寫任教學校", confirmButtonColor = "#6B8EAD" });
            return;
        }
        if (string.IsNullOrWhiteSpace(formModel.Title))
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "warning", title = "請選擇職稱", confirmButtonColor = "#6B8EAD" });
            return;
        }

        isSaving = true;
        try
        {
            // 表單正規化：與 Roles.SaveAccount 一致，避免複製貼上帶到前後空白導致 Email 比對 miss
            formModel.DisplayName = formModel.DisplayName.Trim();
            formModel.Email       = formModel.Email?.Trim() ?? "";
            formModel.School      = formModel.School.Trim();
            formModel.Phone       = formModel.Phone?.Trim();
            formModel.IdNumber    = formModel.IdNumber?.Trim();
            formModel.Department  = formModel.Department?.Trim();
            formModel.Title       = formModel.Title?.Trim();
            formModel.Expertise   = formModel.Expertise?.Trim();
            formModel.Note        = formModel.Note?.Trim();

            var authState = await AuthState;
            var operatorId = int.Parse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);

            CreateTeacherResult? createResult = null;
            if (isEditMode && editingTeacherId.HasValue)
            {
                await TeacherService.UpdateTeacherAsync(new UpdateTeacherRequest
                {
                    TeacherId = editingTeacherId.Value,
                    DisplayName = formModel.DisplayName,
                    Gender = formModel.Gender,
                    Phone = formModel.Phone,
                    IdNumber = formModel.IdNumber,
                    School = formModel.School,
                    Department = formModel.Department,
                    Title = formModel.Title,
                    Expertise = formModel.Expertise,
                    TeachingYears = formModel.TeachingYears,
                    Education = formModel.Education,
                    Status = formModel.Status,
                    Note = formModel.Note,
                }, operatorId);
            }
            else
            {
                createResult = await TeacherService.CreateTeacherAsync(new CreateTeacherRequest
                {
                    DisplayName = formModel.DisplayName,
                    Email = formModel.Email,
                    Gender = formModel.Gender,
                    Phone = formModel.Phone,
                    IdNumber = formModel.IdNumber,
                    School = formModel.School,
                    Department = formModel.Department,
                    Title = formModel.Title,
                    Expertise = formModel.Expertise,
                    TeachingYears = formModel.TeachingYears,
                    Education = formModel.Education,
                    Status = formModel.Status,
                    Note = formModel.Note,
                }, operatorId);
                editingTeacherId = createResult.TeacherId;
            }

            // 立即關閉視窗並以非同步方式播放 SweetAlert，不阻塞後續資料刷新
            showTeacherModal = false;

            if (createResult is { ReusedExistingUser: true })
            {
                // 沿用既有帳號 — 用 info 提示說明，避免使用者誤以為新建了帳號
                _ = JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "info",
                    title = "已沿用既有帳號",
                    html = $"此信箱已是系統使用者 <b>{createResult.ExistingDisplayName}</b>（帳號：{createResult.ExistingUsername}），<br/>已將其加入教師人才庫，登入帳號與密碼維持原狀。",
                    confirmButtonColor = "#6B8EAD"
                });
            }
            else
            {
                _ = JS.InvokeVoidAsync("Swal.fire", new { icon = "success", title = "儲存成功", toast = true, position = "top-end", showConfirmButton = false, timer = 1500 });
            }
            StateHasChanged();

            await LoadListAsync();
            if (editingTeacherId.HasValue)
                await SelectTeacher(editingTeacherId.Value);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "儲存教師失敗");
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "error", title = "儲存失敗", text = ex.Message, confirmButtonColor = "#6B8EAD" });
        }
        finally
        {
            isSaving = false;
        }
    }

