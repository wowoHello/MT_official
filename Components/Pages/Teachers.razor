    /// <summary>關閉批次匯入 Slide-over 並清除所有匯入狀態。</summary>
    private void CloseImportSlideOver()
    {
        showImportSlideOver = false;
        importStep = "upload";
        importRows = null;
        importResults = null;
        importErrorBanner = null;
        isImporting = false;
    }

    /// <summary>使用者選擇 xlsx 檔案後：前端攔截 → 呼叫 ParseExcelAsync → 切換到 preview step。</summary>
    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs e)
    {
        importErrorBanner = null;
        var file = e.File;
        if (file is null) return;

        // 前端攔截 1：格式驗證
        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            importErrorBanner = "僅支援 .xlsx 格式，請下載公版範本填寫後上傳";
            return;
        }
        // 前端攔截 2：大小上限 5MB
        if (file.Size > 5_000_000)
        {
            importErrorBanner = "檔案超過 5MB 上限";
            return;
        }

        isParsingFile = true;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var (rows, parseError) = await TeacherService.ParseExcelAsync(ms);
            if (parseError is not null)
            {
                importErrorBanner = parseError;
                return;
            }
            importRows = rows;
            importStep = "preview";
        }
        catch (Exception ex)
        {
            importErrorBanner = $"解析失敗：{ex.Message}";
            Logger.LogError(ex, "批次匯入解析 Excel 失敗");
        }
        finally
        {
            isParsingFile = false;
        }
    }

    /// <summary>確認匯入：SweetAlert 二次確認 → 呼叫 ImportTeachersAsync → 切換 Step C 顯示結果。</summary>
    private async Task ConfirmImportAsync()
    {
        if (importRows is null) return;

        // 計算真正可匯入筆數（勾選中且非 Error）
        var eligible = importRows.Where(r => r.IsSelected && r.Status != BatchImportRowStatus.Error).ToList();
        if (eligible.Count == 0) return;

        // SweetAlert 二次確認
        var confirmed = await JS.InvokeAsync<bool>("swalConfirm", new
        {
            title = "確認匯入",
            text = $"即將匯入 {eligible.Count} 筆教師資料，確定要繼續嗎？",
            icon = "question",
            showCancelButton = true,
            confirmButtonText = $"確定匯入 {eligible.Count} 筆",
            cancelButtonText = "取消",
            confirmButtonColor = "#6B8EAD",
        });
        if (!confirmed) return;

        isImporting = true;
        importErrorBanner = null;
        StateHasChanged();

        try
        {
            var authState = await AuthState;
            var operatorId = int.Parse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);

            importResults = await TeacherService.ImportTeachersAsync(importRows, operatorId);
            importStep = "result";
        }
        catch (Exception ex)
        {
            importErrorBanner = $"匯入過程發生錯誤：{ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }

