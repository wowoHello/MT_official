    // ──── UI 輔助方法 ────

    private static RenderFragment InfoRow(string label, string value) => __builder =>
    {
        <div class="flex flex-col">
            <span class="text-xs text-gray-400 font-bold">@label</span>
            <span class="text-sm text-slate-main">@value</span>
        </div>
    };


    private static string GetStageBadgeClass(int stage) => stage switch
    {
        1 => "bg-blue-50 text-blue-700",
        2 => "bg-purple-50 text-purple-700",
        3 => "bg-amber-50 text-amber-700",
        _ => "bg-gray-100 text-gray-500"
    };

    private static string GetDecisionBadgeClass(int? decision) => decision switch
    {
        1 => "bg-sage/15 text-sage",
        2 => "bg-yellow-50 text-yellow-700",
        3 => "bg-terracotta/15 text-terracotta",
        _ => "bg-gray-100 text-gray-500"
    };

    private static string GetQuestionStatusBadge(int status) => status switch
    {
        0 => "bg-gray-100 text-gray-500",          // 草稿
        1 => "bg-blue-50 text-blue-700",            // 完成
        2 => "bg-sage/15 text-sage",                // 送審
        3 or 5 or 7 => "bg-blue-50 text-blue-600",  // 審查中
        4 or 6 or 8 => "bg-amber-50 text-amber-700", // 修題中
        12 => "bg-sage/15 text-sage",               // 採用
        13 => "bg-gray-100 text-gray-500",          // 不採用
        _ => "bg-morandi/15 text-morandi"
    };

    private static string GetQuestionStatusText(int status) => status switch
    {
        0 => "草稿",
        1 => "完成",
        2 => "送審",
        3 => "互審中",
        4 => "互修中",
        5 => "專審中",
        6 => "專修中",
        7 => "總審中",
        8 => "總修中",
        12 => "採用",
        13 => "不採用",
        _ => $"狀態{status}"
    };
}
