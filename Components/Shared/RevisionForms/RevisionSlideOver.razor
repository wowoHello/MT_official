        3 => ("bg-morandi/15 text-morandi border-morandi/30",            "fa-lock",  "交互審題進行中"),
        4 => ("bg-terracotta/15 text-terracotta border-terracotta/30",   "fa-pen",   "互審修題"),
        5 => ("bg-morandi/15 text-morandi border-morandi/30",            "fa-lock",  "專家審題進行中"),
        6 => ("bg-terracotta/15 text-terracotta border-terracotta/30",   "fa-pen",   "專審修題"),
        7 => ("bg-morandi/15 text-morandi border-morandi/30",            "fa-lock",  "總召審題進行中"),
        8 => ("bg-red-50 text-red-700 border-red-200",                   "fa-crown", "總審修題"),
        _ => ("bg-gray-100 text-gray-500 border-gray-300",               "fa-circle","非修題期")
