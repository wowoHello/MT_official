    private static string GetPhaseName(byte phaseCode) => phaseCode switch
    {
        3 => "交互審題",
        4 => "互審修題",
        5 => "專家審題",
        6 => "專審修題",
        7 => "總召審題",
        8 => "總審修題",
        _ => "修題"
    };
