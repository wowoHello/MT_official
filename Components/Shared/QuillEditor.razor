@* ====================================================================== *@
@*  QuillEditor — Quill 富文本編輯器 Blazor 包裝元件                       *@
@*  底部滑入面板式設計、含中文標點快速插入、字數統計                         *@
@*  效能策略：Quill 實例常駐，首次展開才初始化，後續僅 CSS 顯隱             *@
@* ====================================================================== *@
@inject IJSRuntime JS
@implements IAsyncDisposable

<!-- 可編輯欄位（點擊觸發底部編輯器） -->
<div class="editable-field cursor-text border-[1.5px] border-gray-200 rounded-lg min-h-[100px] max-h-[200px] overflow-y-auto custom-scroll p-4 hover:border-blue-300 transition-all @(isOpen ? "border-morandi shadow-[0_0_0_3px_rgba(107,142,173,0.15)]" : "")"
     @onclick="OpenEditor">
    @if (string.IsNullOrEmpty(Value))
    {
        <p class="text-gray-400 text-sm">@Placeholder</p>
    }
    else
    {
        @((MarkupString)Value)
    }
</div>

<!-- 底部滑入式 Quill 面板（始終渲染，CSS 控制顯隱） -->
<!-- Backdrop -->
<div class="fixed inset-0 bg-slate-900/10 z-[150] transition-opacity duration-300 @(isOpen ? "opacity-100" : "opacity-0 pointer-events-none")"
     @onclick="CloseEditor"></div>

<!-- Editor Sheet -->
<div class="fixed inset-x-0 bottom-0 z-[150] transition-transform duration-300 ease-in-out @(isOpen ? "translate-y-0" : "translate-y-full")">
    <div class="bg-white border-t-2 border-morandi shadow-[0_-8px_30px_rgba(0,0,0,0.12)] h-[25vh] flex flex-col rounded-t-2xl overflow-visible">

        <!-- 標頭：欄位指示 + 中文標點 + 收起 -->
        <div class="flex items-center justify-between px-4 py-2 bg-gray-50 border-b border-gray-200 gap-2 flex-shrink-0">
            <div class="flex items-center gap-2 text-sm text-gray-600 min-w-0 flex-wrap">
                <i class="fa-solid fa-pen-to-square text-morandi"></i>
                <span class="text-gray-500">正在編輯：</span>
                <span class="font-bold text-slate-main truncate">@FieldLabel</span>
                <span class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-2.5 py-1 text-xs font-semibold text-amber-700">
                    字數：@wordCount
                </span>
                <label class="inline-flex items-center gap-1 cursor-pointer select-none flex-shrink-0">
                    <input type="checkbox" class="accent-morandi w-3.5 h-3.5 cursor-pointer" @bind="excludePunctuation" @bind:after="OnExcludeToggleChanged" />
                    <span class="text-xs text-gray-500">標點與空白不算</span>
                </label>
            </div>
            <div class="flex items-center gap-1 overflow-x-auto custom-scroll flex-shrink">
                <span class="text-[10px] text-gray-400 mr-1 flex-shrink-0">快速插入</span>
                @foreach (var p in punctuations)
                {
                    @* 改為純 JS onclick，繞過 Blazor Server SignalR 往返，點擊延遲降至 0ms *@
                    <button type="button"
                        onclick="QuillInterop.insertPunctuation('@containerId', '@p.Char', @(p.IsPair ? "true" : "false"))"
                        class="punct-btn px-2 py-0.5 text-sm text-gray-500 border border-gray-200 rounded bg-white hover:bg-morandi hover:text-white hover:border-morandi transition-all cursor-pointer flex-shrink-0">
                        @p.Char
                    </button>
                }
            </div>
            <button type="button" @onclick="CloseEditor"
                class="text-sm text-gray-400 hover:text-gray-600 font-medium transition-colors cursor-pointer flex items-center gap-1 flex-shrink-0 ml-2">
                <i class="fa-solid fa-chevron-down"></i> 收起
            </button>
        </div>

        <!-- Quill 編輯器容器 -->
        <div id="@containerId" class="quill-editor-container flex-grow min-h-0"></div>
    </div>
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string FieldLabel { get; set; } = "內容";
    [Parameter] public string Placeholder { get; set; } = "點擊此處開始編輯...";

    private string containerId = $"quill-{Guid.NewGuid():N}";
    private bool isOpen = false;
    private bool quillInitialized = false;
    private bool pendingShow = false;
    private int wordCount = 0;
    private bool excludePunctuation = false;
    private DotNetObjectReference<QuillEditor>? dotNetRef;

    private record PunctuationItem(string Char, bool IsPair);

    private static readonly PunctuationItem[] punctuations = [
        new("，", false), new("。", false), new("、", false),
        new("；", false), new("：", false),
        new("「」", true), new("『』", true), new("（）", true),
        new("！", false), new("？", false),
        new("——", false), new("……", false)
    ];

    private void OpenEditor()
    {
        isOpen = true;
        pendingShow = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (pendingShow)
        {
            pendingShow = false;
            dotNetRef ??= DotNetObjectReference.Create(this);
            // 單次 interop 呼叫：初始化（若首次）+ 填入內容 + 聚焦
            await JS.InvokeVoidAsync("QuillInterop.show", containerId, dotNetRef, Value ?? "", excludePunctuation);
            quillInitialized = true;
        }
    }

    private async Task CloseEditor()
    {
        if (quillInitialized)
        {
            try
            {
                var html = await JS.InvokeAsync<string>("QuillInterop.getHtml", containerId);
                if (html != Value)
                {
                    Value = html;
                    await ValueChanged.InvokeAsync(Value);
                }
            }
            catch (Exception ex) when (ex is TaskCanceledException || ex.GetType().Name == "JSDisconnectedException")
            {
            }
        }
        isOpen = false;
    }

    private async Task OnExcludeToggleChanged()
    {
        if (quillInitialized)
        {
            await JS.InvokeVoidAsync("QuillInterop.setExcludePunct", containerId, excludePunctuation);
        }
    }

    [JSInvokable]
    public void OnWordCountChanged(int count)
    {
        wordCount = count;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnContentChanged(string html)
    {
        if (html != Value)
        {
            Value = html;
            await InvokeAsync(async () =>
            {
                await ValueChanged.InvokeAsync(Value);
                StateHasChanged();
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (quillInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("QuillInterop.dispose", containerId);
            }
            catch (Exception ex) when (ex is TaskCanceledException || ex.GetType().Name == "JSDisconnectedException")
            {
            }
        }
        dotNetRef?.Dispose();
    }
}
