@* ====================================================================== *@
@*  StatusBadge — 狀態標籤元件                                             *@
@*  以圓角 pill 樣式顯示狀態文字與圖示，支援自動從中文文字推斷顏色類型      *@
@*  參數：StatusText、BadgeType（info/success/warning/danger/draft）        *@
@* ====================================================================== *@

<span class="@GetBadgeContainerClass()">
    @if (ShowIcon && !string.IsNullOrEmpty(GetIconClass()))
    {
        <i class="fa-solid @GetIconClass() text-xs mr-1"></i>
    }
    @StatusText
</span>

@code {
    [Parameter]
    public string StatusText { get; set; } = "";

    [Parameter]
    public string BadgeType { get; set; } = "default"; // info, success, warning, danger, draft, default

    [Parameter]
    public bool Compact { get; set; }

    [Parameter]
    public bool ShowIcon { get; set; } = true;

    /// <summary>
    /// 身分別模式開關：傳入時套用「內部紫 / 外部琥珀」雙色配色，
    /// 用於角色身分別標籤（命題教師、系統管理員...），與狀態標籤區分開。
    /// </summary>
    [Parameter]
    public bool? IsInternal { get; set; }

    /// <summary>
    /// 自動根據文字判斷顏色，若有指定 BadgeType 則優先使用
    /// </summary>
    private string GetBadgeContainerClass()
    {
        var baseClass = Compact
            ? "inline-flex items-center px-2 py-0.5 rounded text-xs font-bold whitespace-nowrap"
            : "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border";

        return $"{baseClass} {GetBadgeToneClass()}";
    }

    private string GetBadgeToneClass()
    {
        // 身分別模式：依內部/外部直接套雙色
        if (IsInternal is bool isInternal)
        {
            return (isInternal, Compact) switch
            {
                (true, true)   => "bg-purple-100 text-purple-700",
                (true, false)  => "bg-purple-50 text-purple-700 border-purple-200",
                (false, true)  => "bg-amber-100 text-amber-700",
                (false, false) => "bg-amber-50 text-amber-700 border-amber-200",
            };
        }

        var type = BadgeType != "default" ? BadgeType : InferTypeFromStatus();

        return (type, Compact) switch
        {
            ("success", true) => "bg-emerald-100 text-emerald-700",
            ("success", false) => "bg-emerald-50 text-emerald-700 border-emerald-200",
            ("warning", true) => "bg-amber-100 text-amber-700",
            ("warning", false) => "bg-amber-50 text-amber-700 border-amber-200",
            ("danger", true) => "bg-terracotta/10 text-terracotta",
            ("danger", false) => "bg-terracotta/10 text-terracotta border-terracotta/20",
            ("info", true) => "bg-blue-100 text-blue-700",
            ("info", false) => "bg-blue-50 text-morandi border-blue-200",
            ("closed", true) => "bg-gray-200 text-gray-600",
            ("closed", false) => "bg-gray-100 text-gray-600 border-gray-200",
            ("draft", true) => "bg-gray-100 text-gray-500",
            ("draft", false) => "bg-gray-100 text-gray-500 border-gray-200",
            (_, true) => "bg-gray-100 text-gray-500",
            _ => "bg-gray-50 text-gray-600 border-gray-200"
        };
    }

    private string InferTypeFromStatus()
    {
        if (string.IsNullOrEmpty(StatusText)) return "default";

        var text = StatusText.Trim();
        if (text.Contains("完成") || text.Contains("採用") || text.Contains("啟用") || text.Contains("已發佈"))
            return "success";
        if (text.Contains("進行中") || text.Contains("送審") || text.Contains("鎖定") || text.Contains("審查中") || text.Contains("未發佈"))
            return "info";
        if (text.Contains("退回") || text.Contains("修題") || text.Contains("待審"))
            return "warning";
        if (text.Contains("不採用") || text.Contains("停用") || text.Contains("失敗") || text.Contains("異常") || text.Contains("已下架"))
            return "danger";
        if (text.Contains("結案"))
            return "closed";
        if (text.Contains("草稿") || text.Contains("準備中") || text.Contains("關閉"))
            return "draft";

        return "default";
    }

    private string GetIconClass()
    {
        var type = BadgeType != "default" ? BadgeType : InferTypeFromStatus();
        return type switch
        {
            "success" => "fa-circle-check",
            "warning" => "fa-triangle-exclamation",
            "danger" => "fa-circle-xmark",
            "info" => "fa-circle-info",
            "closed" => "fa-box-archive",
            "draft" => "fa-pen-ruler",
            _ => "fa-circle-dot"
        };
    }
}
