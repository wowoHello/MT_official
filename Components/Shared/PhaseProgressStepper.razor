@* ====================================================================== *@
@*  PhaseProgressStepper — 7 階段命審進度燈號                              *@
@*  傳入 QuestionStatus byte，自動推導當前階段與燈色                        *@
@*  階段：1 命題 / 2 互審 / 3 互修 / 4 專審 / 5 專修 / 6 總審 / 7 總修       *@
@*  結構：兩層（球+線 / labels）對齊，避免單層 mb 補償計算誤差               *@
@* ====================================================================== *@

@{
    var (stage, tone) = ResolveStage(Status, CurrentPhaseCode, HasRepliedThisStage);
    var lamps = new string[7];
    for (var i = 0; i < 7; i++) lamps[i] = GetLampTone(i + 1, stage, tone);
}

<div class="w-full max-w-[480px] mx-auto px-1">
    <!-- 第一層：球與連線（垂直居中） -->
    <div class="flex items-center">
        @for (var i = 1; i <= 7; i++)
        {
            var lamp = lamps[i - 1];
            <div class="w-8 h-8 rounded-full border-2 flex items-center justify-center text-xs flex-shrink-0 @LampClass(lamp)">
                @if (lamp == "gray")
                {
                    <span class="font-bold opacity-60">@i</span>
                }
                else
                {
                    <i class="fa-solid @LampIcon(lamp)"></i>
                }
            </div>
            @if (i < 7)
            {
                <div class="flex-1 h-1 @LineClass(i, stage, tone)"></div>
            }
        }
    </div>

    <!-- 第二層：階段名稱（每顆球正下方對齊） -->
    <div class="flex items-center mt-1">
        @for (var i = 1; i <= 7; i++)
        {
            var lamp = lamps[i - 1];
            var labelCss = lamp switch
            {
                "gray"        => "text-gray-300",                     // 未完成：明顯較淡
                "green"       => "text-sage font-extrabold",          // 已完成：sage 強調
                "awaitNext"   => "text-morandi font-extrabold",       // 該審完成等待中：morandi 強調，與 sage 綠區隔
                "blue"        => "text-morandi font-extrabold",       // 進行中：morandi 強調
                "red"         => "text-terracotta font-extrabold",    // 修題中：terracotta 強調
                "rejectedRed" => "text-morandi-red font-extrabold",   // 不採用：莫蘭迪紅強調，與 terracotta 區隔
                _             => "text-gray-700"
            };
            <div class="w-8 text-center text-xs font-bold flex-shrink-0 @labelCss">
                @StageNames[i - 1]
            </div>
            @if (i < 7)
            {
                <div class="flex-1"></div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public byte Status { get; set; }

    /// <summary>
    /// 梯次當前 PhaseCode（2-8 對應命題階段~總審修題；null = 不傳或未在任何進行中階段）。
    /// 用於「梯次階段感知」：題目 Status 已進入修題狀態（4/6/8），但梯次尚未推進到對應修題階段時，
    /// 改顯示為「該審完成等待中」（morandi 藍 ✓）而非紅色筆。
    /// 預設 null —— 不傳此參數時完全沿用舊行為，Reviews 等其他頁面零影響。
    /// </summary>
    [Parameter] public byte? CurrentPhaseCode { get; set; }

    /// <summary>
    /// 當前修題階段（4/6/8）內，本人是否已送出修題說明。
    /// true 時搭配「Status == CurrentPhaseCode == 修題狀態」三條件成立 →
    ///   對應修題球（3/5/7）由 red（terracotta ✏）改為 awaitNext（morandi ✓），語意：「我這題已修完，等下一階段審題人接手」。
    /// 預設 false —— 不傳此參數時完全沿用舊行為（紅色筆），Reviews / CwtList 等其他頁面零影響。
    /// </summary>
    [Parameter] public bool HasRepliedThisStage { get; set; } = false;

    private static readonly string[] StageNames = ["命題", "互審", "互修", "專審", "專修", "總審", "總修"];

    /// <summary>
    /// 將 14 種 QuestionStatus 對應到 7 階段燈號的 (當前階段, 當前階段燈色)。
    /// tone 特殊值：
    ///   "green"        → 全綠（採用）
    ///   "rejected"     → 卡關紅後續灰
    ///   "draftDone"    → 命題完成（Status == Completed）；第 1 顆命題球顯示 sage 綠 ✓，後續灰
    ///   "preDone"      → 該審完成、梯次未推進；倒數第 1 顆（stage-1）顯示莫蘭迪藍 ✓，更早顯示 sage 綠 ✓
    ///   "revisionSent" → 修題已送出（Status == PhaseCode == 修題階段 + HasRepliedThisStage = true）；
    ///                    當前修題球（stage 本身）顯示莫蘭迪藍 ✓，之前階段 sage 綠 ✓，之後灰
    /// </summary>
    private static (int Stage, string Tone) ResolveStage(byte status, byte? currentPhaseCode, bool hasRepliedThisStage)
    {
        // 規則 D：草稿落隊 —— 題目 Status=Draft，但梯次已進入交互審題（PhaseCode ≥ 3）
        // 命題教師沒命完，題目永久不參與後續審題流程，第 1 顆球顯示莫蘭迪紅 X、後續灰
        // 僅 Overview 會傳 currentPhaseCode；其他頁面不傳 → 此規則不觸發
        if (status == QuestionStatus.Draft && currentPhaseCode is byte pcDraft && pcDraft >= 3)
            return (1, "draftFailed");

        // 規則 A：題目已進入修題狀態，但梯次尚未推進到對應修題階段 → 「該審完成等待中」
        // 例：ExpertEditing(6) 但梯次 PhaseCode < 6（仍在專審 5 或更早）→ 視為專審完成等待專修開始
        if (status == QuestionStatus.PeerEditing   && (currentPhaseCode is null || currentPhaseCode < QuestionStatus.PeerEditing))
            return (3, "preDone");
        if (status == QuestionStatus.ExpertEditing && (currentPhaseCode is null || currentPhaseCode < QuestionStatus.ExpertEditing))
            return (5, "preDone");
        if (status == QuestionStatus.FinalEditing  && (currentPhaseCode is null || currentPhaseCode < QuestionStatus.FinalEditing))
            return (7, "preDone");

        // 規則 A.5：梯次 PhaseCode 與題目 Status 同步在修題階段，且本人已送出修題說明
        //          → 修題球本身轉為 awaitNext（莫蘭迪藍 ✓），語意：「我這題已修完，等下一階段審題人接手」
        //          互修(4) / 專修(6) / 總修(8) 三階段邏輯一致
        if (status == QuestionStatus.PeerEditing   && currentPhaseCode == QuestionStatus.PeerEditing   && hasRepliedThisStage)
            return (3, "revisionSent");
        if (status == QuestionStatus.ExpertEditing && currentPhaseCode == QuestionStatus.ExpertEditing && hasRepliedThisStage)
            return (5, "revisionSent");
        if (status == QuestionStatus.FinalEditing  && currentPhaseCode == QuestionStatus.FinalEditing  && hasRepliedThisStage)
            return (7, "revisionSent");

        // 規則 B / C：維持原有對應
        return status switch
        {
            QuestionStatus.Draft             => (1, "blue"),
            QuestionStatus.Completed         => (1, "draftDone"),
            QuestionStatus.Submitted         => (2, "blue"),
            QuestionStatus.PeerReviewing     => (2, "blue"),
            QuestionStatus.PeerEditing       => (3, "red"),
            QuestionStatus.ExpertReviewing   => (4, "blue"),
            QuestionStatus.ExpertEditing     => (5, "red"),
            QuestionStatus.FinalReviewing    => (6, "blue"),
            QuestionStatus.FinalEditing      => (7, "red"),
            QuestionStatus.Adopted           => (8, "green"),
            QuestionStatus.Rejected          => (7, "rejected"),
            QuestionStatus.ClosedNotAdopted  => (7, "rejected"),
            _                                => (1, "gray")
        };
    }

    private static string GetLampTone(int i, int stage, string tone)
    {
        if (tone == "green")    return "green";                       // 採用 → 全綠
        if (tone == "rejected") return i < stage ? "green" : i == stage ? "rejectedRed" : "gray";
        if (tone == "preDone")
        {
            // 倒數第 1 顆（剛完成的審題階段，stage-1）：莫蘭迪藍 ✓，與一般完成的 sage 綠 ✓ 區隔
            // 更早的階段：仍維持 sage 綠 ✓（已穩定完成）
            // 當前 stage 與之後：灰（修題階段尚未由梯次開放）
            if (i == stage - 1) return "awaitNext";
            if (i < stage - 1)  return "green";
            return "gray";
        }
        if (tone == "revisionSent")
        {
            // 修題已送出：當前修題球本身（i == stage）轉為 awaitNext（莫蘭迪藍 ✓），語意「等下一階段審題人接手」
            // 之前所有階段：sage 綠 ✓（已穩定完成）
            // 之後階段：灰（尚未開始）
            if (i == stage) return "awaitNext";
            if (i < stage)  return "green";
            return "gray";
        }
        if (tone == "draftDone")
        {
            // 命題完成：第 1 顆命題球本身轉為 sage 綠 ✓（已完成、等送審推進）
            // 後續所有階段：灰（梯次尚未推進到互審階段）
            if (i == stage) return "green";
            return "gray";
        }
        if (tone == "draftFailed")
        {
            // 草稿落隊：第 1 顆命題球轉為 rejectedRed（莫蘭迪紅 X），後續所有階段灰
            // 語意：命題教師沒命完，題目於梯次進入交互審題後永久落隊
            if (i == stage) return "rejectedRed";
            return "gray";
        }
        if (i < stage) return "green";
        if (i > stage) return "gray";
        return tone;
    }

    private static string LampClass(string tone) => tone switch
    {
        // 已完成：sage 實心 + 細陰影，視覺最重
        "green"       => "bg-sage border-sage text-white shadow-sm ring-2 ring-sage/20",
        // 該審完成等待中：莫蘭迪藍半填 + 同色描邊與 ✓，視覺上明顯有別於 sage 綠（強調「等下一階段推進」）
        "awaitNext"   => "bg-morandi/15 border-morandi text-morandi shadow-sm ring-2 ring-morandi/20",
        // 進行中：morandi 實心，與「修題中」terracotta 實心對稱，皆為純實心無外暈動畫，
        // 視覺重量一致，避免命題第 1 顆球的進行中樣式與後段修題（紅筆）格格不入
        "blue"        => "bg-morandi border-morandi text-white shadow-sm",
        // 修題中：terracotta 實心
        "red"         => "bg-terracotta border-terracotta text-white shadow-sm",
        // 不採用：莫蘭迪紅實心，與 terracotta（修題中）視覺區隔，搭配 X 圖示更貼合「終止」語意
        "rejectedRed" => "bg-morandi-red border-morandi-red text-white shadow-sm",
        // 未完成：白底虛線細邊框 + 淡灰字，明顯「尚未抵達」的 ghost 樣式
        _             => "bg-white border-dashed border-gray-300 text-gray-300"
    };

    private static string LampIcon(string tone) => tone switch
    {
        "green"       => "fa-check",
        "awaitNext"   => "fa-check",       // 同樣是 ✓，但顏色不同（莫蘭迪藍）以表達等待語意
        "blue"        => "fa-pen-to-square",   // 進行中（命題/互審/專審/總審）：靜態筆墨圖示，與修題的 fa-pen 同字根但有方框，明顯為「正在處理」而非旋轉等待
        "red"         => "fa-pen",
        "rejectedRed" => "fa-xmark",       // 不採用：用 X 替代鉛筆，明確表達「最終駁回」而非「修題中」
        _             => "fa-circle"
    };

    /// <summary>連線著色：左燈為基準（同色，不打折）。</summary>
    private static string LineClass(int leftIdx, int stage, string tone)
    {
        if (tone == "green") return "bg-sage";
        var leftLamp = GetLampTone(leftIdx, stage, tone);
        return leftLamp switch
        {
            "green"       => "bg-sage",
            "awaitNext"   => "bg-morandi/40",   // 銜接「該審完成等待中」燈：莫蘭迪藍系，與 sage 區隔
            "blue"        => "bg-morandi",
            "red"         => "bg-terracotta",
            "rejectedRed" => "bg-morandi-red",
            _             => "bg-gray-300"
        };
    }
}
