@* ====================================================================== *@
@*  EmptyState — 空狀態佔位元件                                            *@
@*  當列表或區塊無資料時顯示圖示、訊息文字，可選配操作按鈕                  *@
@*  參數：IconClass、Message、SubMessage、ShowAction、ActionText、Compact   *@
@* ====================================================================== *@

<div class="flex flex-col items-center justify-center text-center w-full bg-white/50 rounded-2xl border border-dashed border-gray-200 @(Compact ? "p-6 my-2" : "h-full p-12 min-h-[300px]") @CssClass">
    <div class="@(Compact ? "w-14 h-14 mb-3" : "w-20 h-20 mb-4") bg-gray-50 rounded-full flex items-center justify-center border border-gray-100 shadow-sm">
        <i class="fa-solid @IconClass @(Compact ? "text-2xl" : "text-3xl") text-gray-400"></i>
    </div>
    <h3 class="@(Compact ? "text-base" : "text-xl") font-bold text-gray-500 mb-2">@Message</h3>
    @if (!string.IsNullOrEmpty(SubMessage))
    {
        <p class="text-gray-400 text-sm max-w-md mb-6">@SubMessage</p>
    }
    
    @if (ShowAction && !string.IsNullOrEmpty(ActionText))
    {
        <button type="button" @onclick="OnActionClick"
                class="px-6 py-2.5 bg-morandi text-white font-medium rounded-lg shadow-sm hover:bg-slate-main transition-all flex items-center gap-2 transform hover:-translate-y-0.5">
            @if (!string.IsNullOrEmpty(ActionIcon))
            {
                <i class="fa-solid @ActionIcon"></i>
            }
            @ActionText
        </button>
    }
</div>

@code {
    [Parameter]
    public string IconClass { get; set; } = "fa-folder-open";

    [Parameter]
    public string Message { get; set; } = "目前尚無資料";

    [Parameter]
    public string SubMessage { get; set; } = "";

    [Parameter]
    public bool ShowAction { get; set; } = false;

    [Parameter]
    public string ActionText { get; set; } = "";

    [Parameter]
    public string ActionIcon { get; set; } = "fa-plus";

    [Parameter]
    public EventCallback OnActionClick { get; set; }

    /// <summary>緊湊模式：縮小 padding 與圖示，移除 min-height，適用於固定高度容器內</summary>
    [Parameter]
    public bool Compact { get; set; } = false;

    /// <summary>自訂額外的 CSS 類別，例如用於控制高度或間距</summary>
    [Parameter]
    public string CssClass { get; set; } = "";
}
