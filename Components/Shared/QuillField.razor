@* ====================================================================== *@
@*  QuillField — 輕量富文本欄位入口                                        *@
@*  只負責顯示預覽與通知共用 QuillHost，不再各自建立完整編輯器面板          *@
@* ====================================================================== *@

<div class="editable-field cursor-text border-[1.5px] border-gray-200 rounded-lg min-h-[100px] max-h-[200px] overflow-y-auto custom-scroll p-4 hover:border-blue-300 transition-all"
     @onclick="OpenEditor">
    @if (string.IsNullOrEmpty(Value))
    {
        <p class="text-gray-400 text-sm">@Placeholder</p>
    }
    else
    {
        @((MarkupString)Value)
    }
</div>

@code {
    [CascadingParameter] private SharedQuillEditorContext? EditorContext { get; set; }

    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string FieldLabel { get; set; } = "內容";
    [Parameter] public string Placeholder { get; set; } = "點擊此處開始編輯...";

    private async Task OpenEditor()
    {
        if (EditorContext?.IsAvailable != true)
        {
            return;
        }

        await EditorContext.OpenAsync(new SharedQuillEditRequest
        {
            FieldLabel = FieldLabel,
            Placeholder = Placeholder,
            Value = Value ?? "",
            ValueChanged = async value => await ValueChanged.InvokeAsync(value)
        });
    }
}
