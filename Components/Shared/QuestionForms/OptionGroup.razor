@* ====================================================================== *@
@*  OptionGroup — ABCD 四選項共用元件                                     *@
@*  支援兩種佈局：vertical（垂直排列）、grid（2×2 格狀排列）              *@
@*  用於：Single、Listen、ReadGroup 子題、ListenGroup 子題               *@
@*                                                                       *@
@*  ※ 標題列已抽到外層 FormSectionCard；此元件僅渲染選項主體 + 警示提醒。 *@
@* ====================================================================== *@
@using MT.Components.Shared

@* 警示提醒 *@
<div class="mb-3 px-3 py-2 bg-amber-50 border border-amber-200 rounded-md text-sm text-amber-700 flex items-center gap-2">
    <i class="fa-solid fa-triangle-exclamation text-amber-500 flex-shrink-0"></i>
    請避免選項長短、語氣明顯差異，以免影響鑑別度。
</div>

<div class="@(Layout == OptionLayout.Grid ? "grid grid-cols-2 gap-3" : "space-y-3")">
    @for (int i = 0; i < 4; i++)
    {
        var idx = i;
        var optLabel = Labels[idx];
        <div class="flex items-start gap-@(Layout == OptionLayout.Grid ? "2" : "3") @(Layout == OptionLayout.Vertical ? "group" : "")">
            <label class="flex items-center gap-@(Layout == OptionLayout.Grid ? "1.5" : "2") mt-3 flex-shrink-0 @(IsFormReadOnly ? "cursor-not-allowed" : "cursor-pointer")">
                <input type="radio" name="@RadioName" value="@optLabel"
                    checked="@(Answer == optLabel)"
                    @onchange="() => OnAnswerSelect(optLabel)"
                    disabled="@IsFormReadOnly"
                    class="w-4 h-4 text-sage focus:ring-sage disabled:cursor-not-allowed disabled:opacity-50 @(IsFormReadOnly ? "" : "cursor-pointer")">
                <span class="w-@(Layout == OptionLayout.Grid ? "6" : "7") h-@(Layout == OptionLayout.Grid ? "6" : "7") rounded-full flex items-center justify-center text-xs font-bold @(Answer == optLabel ? "bg-sage text-white" : "bg-gray-100 text-gray-500" + (IsFormReadOnly ? "" : " group-hover:bg-gray-200")) transition-colors">
                    @optLabel
                </span>
            </label>
            <div class="flex-grow">
                <QuillField Value="@Options[idx]"
                    ValueChanged="v => OnOptionChange(idx, v)"
                    FieldLabel="@($"選項 ({optLabel})")"
                    Placeholder="@($"請輸入選項 ({optLabel}) 內容...")" />
                @if (EnableImages && OptionImages is not null && idx < OptionImages.Count)
                {
                    <QuestionImagesField Images="OptionImages[idx]"
                        ImagesChanged="updated => OnOptionImagesChanged(idx, updated)" />
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string[] Options { get; set; } = ["", "", "", ""];
    [Parameter] public EventCallback<string[]> OptionsChanged { get; set; }

    [Parameter] public string Answer { get; set; } = "";
    [Parameter] public EventCallback<string> AnswerChanged { get; set; }

    [Parameter] public string RadioName { get; set; } = Guid.NewGuid().ToString("N")[..8];
    [Parameter] public OptionLayout Layout { get; set; } = OptionLayout.Vertical;

    /// <summary>是否啟用每個選項下方的附圖欄位（預設關閉，未提供 OptionImages 的題型不受影響）。</summary>
    [Parameter] public bool EnableImages { get; set; }

    /// <summary>四個選項的附圖清單（長度必須 = 4），與 OptionImageChanged 搭配使用。</summary>
    [Parameter] public List<List<QuestionImage>>? OptionImages { get; set; }

    /// <summary>選項附圖變動：(選項索引 0~3, 該選項更新後的附圖清單)。</summary>
    [Parameter] public EventCallback<(int Index, List<QuestionImage> Updated)> OptionImageChanged { get; set; }

    /// <summary>從父層 QuestionForm Modal 接收唯讀狀態（沿著 cascading 鏈傳入）。</summary>
    [CascadingParameter(Name = "IsFormReadOnly")] private bool IsFormReadOnly { get; set; }

    private static readonly string[] Labels = ["A", "B", "C", "D"];

    private async Task OnAnswerSelect(string label)
    {
        if (IsFormReadOnly) return;
        Answer = label;
        await AnswerChanged.InvokeAsync(label);
    }

    private async Task OnOptionChange(int idx, string value)
    {
        if (IsFormReadOnly) return;
        Options[idx] = value;
        await OptionsChanged.InvokeAsync(Options);
    }

    private async Task OnOptionImagesChanged(int idx, List<QuestionImage> updated)
    {
        if (IsFormReadOnly) return;
        await OptionImageChanged.InvokeAsync((idx, updated));
    }

    public enum OptionLayout { Vertical, Grid }
}
