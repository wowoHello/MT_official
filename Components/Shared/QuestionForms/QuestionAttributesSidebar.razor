@* ====================================================================== *@
@*  QuestionAttributesSidebar — 命題表單左側屬性設定側欄                    *@
@*  共用欄位：題型、等級、難易度                                            *@
@*  依題型動態渲染專屬屬性欄位（主題/次類/文體/模式/音檔類型...）           *@
@*  所有 enum 對照與級聯映射皆來自 MT.Models.QuestionConstants              *@
@* ====================================================================== *@

<div class="p-4 space-y-4 flex-grow overflow-y-auto custom-scroll transition-opacity duration-200 @(IsCollapsed ? "opacity-0 invisible pointer-events-none" : "opacity-100 visible delay-100")">
    <div class="flex items-center justify-between gap-3">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider flex items-center gap-1.5">
            <i class="fa-solid fa-sliders"></i> 題目屬性
        </h3>
        <span class="text-xs text-gray-300 uppercase tracking-[0.18em]">共用欄位</span>
    </div>

    <!-- 題型選擇 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-1.5">題型 <span class="text-red-400">*</span></label>
        <select @bind="QuestionType" @bind:after="OnTypeChanged"
            disabled="@IsFormReadOnly"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
            @foreach (var pair in QuestionConstants.TypeLabels)
            {
                <option value="@pair.Key">@pair.Value</option>
            }
        </select>
    </div>

    <!-- 等級（聽力題組母題無等級） -->
    <div class="@(QuestionType == QuestionTypeCodes.ListenGroup ? "hidden" : "")">
        <label class="block text-sm font-bold text-gray-700 mb-1.5">等級 <span class="text-red-400">*</span></label>
        <select @bind="Level" @bind:after="OnLevelChanged"
            disabled="@IsFormReadOnly"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
            <option value="">請選擇等級</option>
            @if (QuestionConstants.TypeLevels.TryGetValue(QuestionType, out var allowed))
            {
                @foreach (var lv in allowed)
                {
                    <option value="@lv">@LevelLabel(lv)</option>
                }
            }
        </select>
    </div>

    <!-- 題型專屬屬性 -->
    <div class="space-y-4">
        @if (QuestionType is QuestionTypeCodes.Single or QuestionTypeCodes.Select)
        {
            <!-- 一般/精選單選題分類 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-tags text-morandi"></i>
                        @(QuestionType == QuestionTypeCodes.Single ? "一般單選題" : "精選單選題")分類
                    </span>
                    <span class="text-xs text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        適用等級：初～中高等
                    </span>
                </div>
                <!-- 主類 + 次類 並排 -->
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">主類 <span class="text-red-400">*</span></label>
                        <select @bind="Topic" @bind:after="OnTopicChanged"
                            disabled="@IsFormReadOnly"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                            <option value="">請選擇</option>
                            @foreach (var pair in QuestionConstants.TopicLabels)
                            {
                                <option value="@pair.Key">@pair.Value</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">次類 <span class="text-red-400">*</span></label>
                        <select @bind="Subtopic" @bind:after="() => SubtopicChanged.InvokeAsync(Subtopic)"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed @(Topic is null ? "bg-gray-50 text-gray-300" : "")"
                            disabled="@(IsFormReadOnly || Topic is null)">
                            <option value="">@(Topic is null ? "先選主類" : "請選擇")</option>
                            @if (Topic is not null && QuestionConstants.TopicSubtopicMap.TryGetValue(Topic.Value, out var subs))
                            {
                                @foreach (var sub in subs)
                                {
                                    <option value="@sub">@QuestionConstants.SubtopicLabels.GetValueOrDefault(sub, "")</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <p class="text-xs text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    先選擇「主類」，「次類」會根據主類自動篩選對應選項。
                </p>
            </div>
        }
        else if (QuestionType == QuestionTypeCodes.LongText)
        {
            <!-- 長文題目屬性 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-pen-fancy text-morandi"></i>
                        長文題目屬性
                    </span>
                    <span class="text-xs text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        適用等級：初～優級（不含高級）
                    </span>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">寫作模式 <span class="text-red-400">*</span></label>
                    <select @bind="WritingMode" @bind:after="() => WritingModeChanged.InvokeAsync(WritingMode)"
                        disabled="@IsFormReadOnly"
                        class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                        <option value="">請選擇</option>
                        @foreach (var pair in QuestionConstants.WritingModeLabels)
                        {
                            <option value="@pair.Key">@pair.Value</option>
                        }
                    </select>
                </div>
                <p class="text-xs text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    長文題目包含題目、文章內容與批閱說明。
                </p>
            </div>
        }
        else if (QuestionType == QuestionTypeCodes.ReadGroup)
        {
            <!-- 閱讀題組屬性 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-book-open text-morandi"></i>
                        閱讀題組屬性
                    </span>
                    <span class="text-xs text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        適用等級：初～優級
                    </span>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">文體 <span class="text-red-400">*</span></label>
                    <select @bind="Genre" @bind:after="() => GenreChanged.InvokeAsync(Genre)"
                        disabled="@IsFormReadOnly"
                        class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                        <option value="">請選擇文體</option>
                        @foreach (var pair in QuestionConstants.GenreLabels)
                        {
                            <option value="@pair.Key">@pair.Value</option>
                        }
                    </select>
                </div>
                <p class="text-xs text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    母題底下有複數子題，以子題代碼區分。
                </p>
            </div>
        }
        else if (QuestionType == QuestionTypeCodes.ShortGroup)
        {
            <!-- 短文題組屬性 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-file-lines text-morandi"></i>
                        短文題組屬性
                    </span>
                    <span class="text-xs text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        適用等級：初～優級
                    </span>
                </div>
                <!-- 固定屬性：主類 = 文意判讀(6) / 次類 = 篇章辨析(17) -->
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">主類</label>
                        <input type="text" value="文意判讀" disabled class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg bg-gray-100 text-gray-400">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">次類</label>
                        <input type="text" value="篇章辨析" disabled class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg bg-gray-100 text-gray-400">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">文體 <span class="text-red-400">*</span></label>
                    <select @bind="Genre" @bind:after="() => GenreChanged.InvokeAsync(Genre)"
                        disabled="@IsFormReadOnly"
                        class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                        <option value="">請選擇文體</option>
                        @foreach (var pair in QuestionConstants.GenreLabels)
                        {
                            <option value="@pair.Key">@pair.Value</option>
                        }
                    </select>
                </div>
                <p class="text-xs text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    主類/次類為固定值（文意判讀 / 篇章辨析），母題底下有複數子題。
                </p>
            </div>
        }
        else if (QuestionType == QuestionTypeCodes.Listen)
        {
            <!-- 聽力測驗屬性 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-headphones text-morandi"></i>
                        聽力測驗屬性
                    </span>
                    <span class="text-xs text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        難度一～五
                    </span>
                </div>

                <!-- 核心能力（依等級自動帶入；難度五由使用者選） -->
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">核心能力</label>
                    @if (Level is null || !QuestionConstants.ListenLevelCoreAbilityMap.TryGetValue(Level.Value, out var abilities))
                    {
                        <input type="text" value="請先選擇等級" disabled
                            class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg bg-gray-100 text-gray-300">
                    }
                    else if (abilities.Length > 1)
                    {
                        <select @bind="CoreAbility" @bind:after="OnCoreAbilityChanged"
                            disabled="@IsFormReadOnly"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                            <option value="">請選擇</option>
                            @foreach (var ab in abilities)
                            {
                                <option value="@ab">@QuestionConstants.CoreAbilityLabels.GetValueOrDefault(ab, "")</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input type="text" value="@QuestionConstants.CoreAbilityLabels.GetValueOrDefault(CoreAbility ?? 0, "")" disabled
                            class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg bg-gray-100 text-gray-500 font-medium">
                    }
                </div>

                <!-- 細目指標 -->
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">細目指標 <span class="text-red-400">*</span></label>
                    <select @bind="DetailIndicator" @bind:after="() => DetailIndicatorChanged.InvokeAsync(DetailIndicator)"
                        class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed @(CoreAbility is null ? "bg-gray-50 text-gray-300" : "")"
                        disabled="@(IsFormReadOnly || CoreAbility is null)">
                        <option value="">@(CoreAbility is null ? "先選等級" : "請選擇")</option>
                        @if (CoreAbility is not null && QuestionConstants.CoreAbilityIndicatorMap.TryGetValue(CoreAbility.Value, out var indicators))
                        {
                            @foreach (var ind in indicators)
                            {
                                <option value="@ind">@QuestionConstants.DetailIndicatorLabels.GetValueOrDefault(ind, "")</option>
                            }
                        }
                    </select>
                </div>

                <!-- 語音類型 + 素材分類 並排 -->
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">語音類型 <span class="text-red-400">*</span></label>
                        <select @bind="AudioType" @bind:after="() => AudioTypeChanged.InvokeAsync(AudioType)"
                            disabled="@IsFormReadOnly"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                            <option value="">請選擇</option>
                            @foreach (var pair in QuestionConstants.AudioTypeLabels)
                            {
                                <option value="@pair.Key">@pair.Value</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">素材分類 <span class="text-red-400">*</span></label>
                        <select @bind="Material" @bind:after="() => MaterialChanged.InvokeAsync(Material)"
                            disabled="@IsFormReadOnly"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                            <option value="">請選擇</option>
                            @foreach (var pair in QuestionConstants.MaterialLabels)
                            {
                                <option value="@pair.Key">@pair.Value</option>
                            }
                        </select>
                    </div>
                </div>

                <p class="text-xs text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    選擇等級後自動帶入核心能力，再依核心能力篩選細目指標。
                </p>
            </div>
        }
        else if (QuestionType == QuestionTypeCodes.ListenGroup)
        {
            <!-- 聽力題組屬性 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-headphones text-morandi"></i>
                        聽力題組屬性
                    </span>
                    <span class="text-xs text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        母題無難度
                    </span>
                </div>

                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">語音類型 <span class="text-red-400">*</span></label>
                        <select @bind="AudioType" @bind:after="() => AudioTypeChanged.InvokeAsync(AudioType)"
                            disabled="@IsFormReadOnly"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                            <option value="">請選擇</option>
                            @foreach (var pair in QuestionConstants.AudioTypeLabels)
                            {
                                <option value="@pair.Key">@pair.Value</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">素材分類 <span class="text-red-400">*</span></label>
                        <select @bind="Material" @bind:after="() => MaterialChanged.InvokeAsync(Material)"
                            disabled="@IsFormReadOnly"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                            <option value="">請選擇</option>
                            @foreach (var pair in QuestionConstants.MaterialLabels)
                            {
                                <option value="@pair.Key">@pair.Value</option>
                            }
                        </select>
                    </div>
                </div>

                <p class="text-xs text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    母題不區分難度，子題各自設定難度、核心能力與細目指標。
                </p>
            </div>
        }
    </div>

    <!-- 難易度（聽力題組母題無難易度） -->
    <div class="@(QuestionType == QuestionTypeCodes.ListenGroup ? "hidden" : "")">
        <label class="block text-sm font-bold text-gray-700 mb-1.5">難易度 <span class="text-red-400">*</span></label>
        <select @bind="Difficulty" @bind:after="() => DifficultyChanged.InvokeAsync(Difficulty)"
            disabled="@IsFormReadOnly"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
            <option value="">請選擇</option>
            @foreach (var pair in QuestionConstants.DifficultyLabels)
            {
                <option value="@pair.Key">@pair.Value</option>
            }
        </select>
    </div>

    <hr class="border-gray-100">
</div>

<!-- 底部提示 -->
<div class="px-4 py-3 border-t border-gray-100 bg-gray-50/50 text-xs text-gray-400 leading-snug flex-shrink-0 transition-opacity duration-200 @(IsCollapsed ? "opacity-0 invisible pointer-events-none" : "opacity-100 visible delay-100")">
    <i class="fa-solid fa-circle-info mr-1"></i>
    點右側欄位，就會滑出底部編輯器。
</div>

@code {
    [CascadingParameter(Name = "IsFormReadOnly")] private bool IsFormReadOnly { get; set; }

    [Parameter] public bool IsCollapsed { get; set; } = false;

    [Parameter] public string QuestionType { get; set; } = QuestionTypeCodes.Single;
    [Parameter] public EventCallback<string> QuestionTypeChanged { get; set; }

    [Parameter] public byte? Level { get; set; }
    [Parameter] public EventCallback<byte?> LevelChanged { get; set; }

    [Parameter] public byte? Difficulty { get; set; }
    [Parameter] public EventCallback<byte?> DifficultyChanged { get; set; }

    // 單選題 / 精選單選題 attributes
    [Parameter] public byte? Topic { get; set; }
    [Parameter] public EventCallback<byte?> TopicChanged { get; set; }
    [Parameter] public byte? Subtopic { get; set; }
    [Parameter] public EventCallback<byte?> SubtopicChanged { get; set; }

    // 長文題目
    [Parameter] public byte? WritingMode { get; set; }
    [Parameter] public EventCallback<byte?> WritingModeChanged { get; set; }

    // 閱讀題組 / 短文題組
    [Parameter] public byte? Genre { get; set; }
    [Parameter] public EventCallback<byte?> GenreChanged { get; set; }

    // 聽力
    [Parameter] public byte? AudioType { get; set; }
    [Parameter] public EventCallback<byte?> AudioTypeChanged { get; set; }
    [Parameter] public byte? Material { get; set; }
    [Parameter] public EventCallback<byte?> MaterialChanged { get; set; }
    [Parameter] public byte? CoreAbility { get; set; }
    [Parameter] public EventCallback<byte?> CoreAbilityChanged { get; set; }
    [Parameter] public byte? DetailIndicator { get; set; }
    [Parameter] public EventCallback<byte?> DetailIndicatorChanged { get; set; }

    private bool IsListenType => QuestionType is QuestionTypeCodes.Listen or QuestionTypeCodes.ListenGroup;

    private string LevelLabel(byte lv) => IsListenType
        ? QuestionConstants.ListenLevelLabels.GetValueOrDefault(lv, "")
        : QuestionConstants.GeneralLevelLabels.GetValueOrDefault(lv, "");

    private async Task OnTypeChanged()
    {
        await QuestionTypeChanged.InvokeAsync(QuestionType);
    }

    private async Task OnLevelChanged()
    {
        // 聽力題型：等級變更時自動帶入核心能力
        if (QuestionType == QuestionTypeCodes.Listen
            && Level is not null
            && QuestionConstants.ListenLevelCoreAbilityMap.TryGetValue(Level.Value, out var abilities))
        {
            // 只有一個核心能力時自動帶入，多個（難度四、五）讓使用者選
            CoreAbility = abilities.Length == 1 ? abilities[0] : null;
            DetailIndicator = null;
            await CoreAbilityChanged.InvokeAsync(CoreAbility);
            await DetailIndicatorChanged.InvokeAsync(DetailIndicator);
        }
        await LevelChanged.InvokeAsync(Level);
    }

    private async Task OnCoreAbilityChanged()
    {
        DetailIndicator = null;
        await CoreAbilityChanged.InvokeAsync(CoreAbility);
        await DetailIndicatorChanged.InvokeAsync(DetailIndicator);
    }

    private async Task OnTopicChanged()
    {
        // 若該主類只有一個次類，自動帶入
        if (Topic is not null
            && QuestionConstants.TopicSubtopicMap.TryGetValue(Topic.Value, out var subs)
            && subs.Length == 1)
        {
            Subtopic = subs[0];
        }
        else
        {
            Subtopic = null;
        }

        await TopicChanged.InvokeAsync(Topic);
        await SubtopicChanged.InvokeAsync(Subtopic);
    }
}
