@* ====================================================================== *@
@*  QuestionAttributesSidebar — 命題表單左側屬性設定側欄                    *@
@*  共用欄位：題型、等級、難易度                                            *@
@*  依題型動態渲染專屬屬性欄位（主題/次類/文體/模式/音檔類型...）           *@
@* ====================================================================== *@

<div class="p-4 space-y-4 flex-grow overflow-y-auto custom-scroll">
    <div class="flex items-center justify-between gap-3">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider flex items-center gap-1.5">
            <i class="fa-solid fa-sliders"></i> 題目屬性
        </h3>
        <span class="text-[11px] text-gray-300 uppercase tracking-[0.18em]">共用欄位</span>
    </div>

    <!-- 題型選擇 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-1.5">題型 <span class="text-red-400">*</span></label>
        <select @bind="QuestionType" @bind:after="OnTypeChanged"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
            <option value="single">一般單選題</option>
            <option value="select">精選單選題</option>
            <option value="readGroup">閱讀題組</option>
            <option value="longText">長文題目</option>
            <option value="shortGroup">短文題組</option>
            <option value="listen">聽力測驗</option>
            <option value="listenGroup">聽力題組</option>
        </select>
    </div>

    <!-- 等級（聽力題組母題無等級） -->
    <div class="@(QuestionType == "listenGroup" ? "hidden" : "")">
        <label class="block text-sm font-bold text-gray-700 mb-1.5">等級 <span class="text-red-400">*</span></label>
        <select @bind="Level" @bind:after="OnLevelChanged"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
            <option value="">請選擇等級</option>
            @if (IsListenType)
            {
                <option value="難度一">難度一</option>
                <option value="難度二">難度二</option>
                <option value="難度三">難度三</option>
                <option value="難度四">難度四</option>
                <option value="難度五">難度五</option>
            }
            else if (QuestionType is "single" or "select")
            {
                <option value="初等">初等</option>
                <option value="中等">中等</option>
                <option value="中高等">中高等</option>
            }
            else if (QuestionType == "longText")
            {
                <option value="初級">初級</option>
                <option value="中級">中級</option>
                <option value="中高級">中高級</option>
                <option value="優級">優級</option>
            }
            else
            {
                <option value="初級">初級</option>
                <option value="中級">中級</option>
                <option value="中高級">中高級</option>
                <option value="高級">高級</option>
                <option value="優級">優級</option>
            }
        </select>
    </div>

    <!-- 題型專屬屬性 -->
    <div class="space-y-4">
        @if (QuestionType is "single" or "select")
        {
            <!-- 一般/精選單選題分類 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-tags text-morandi"></i>
                        @(QuestionType == "single" ? "一般單選題" : "精選單選題")分類
                    </span>
                    <span class="text-[10px] text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        適用等級：初～中高等
                    </span>
                </div>
                <!-- 主題 + 次類 並排 -->
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">主類 <span class="text-red-400">*</span></label>
                        <select @bind="Topic" @bind:after="OnTopicChanged"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            @foreach (var t in SingleChoiceTopics)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">次類 <span class="text-red-400">*</span></label>
                        <select @bind="Subtopic"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer @(string.IsNullOrEmpty(Topic) ? "bg-gray-50 text-gray-300" : "")"
                            disabled="@(string.IsNullOrEmpty(Topic))">
                            <option value="">@(string.IsNullOrEmpty(Topic) ? "先選主類" : "請選擇")</option>
                            @if (!string.IsNullOrEmpty(Topic) && SingleChoiceCategoryMap.ContainsKey(Topic))
                            {
                                @foreach (var sub in SingleChoiceCategoryMap[Topic])
                                {
                                    <option value="@sub">@sub</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <p class="text-[10px] text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    先選擇「主類」，「次類」會根據主題自動篩選對應選項。
                </p>
            </div>
        }
        else if (QuestionType == "longText")
        {
            <!-- 長文題目屬性 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-pen-fancy text-morandi"></i>
                        長文題目屬性
                    </span>
                    <span class="text-[10px] text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        適用等級：初～優級（不含高級）
                    </span>
                </div>
                <!-- 寫作模式 -->
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">寫作模式 <span class="text-red-400">*</span></label>
                    <select @bind="WritingMode"
                        class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="">請選擇</option>
                        <option value="引導寫作">引導寫作</option>
                        <option value="資訊整合">資訊整合</option>
                    </select>
                </div>
                <p class="text-[10px] text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    長文題目包含題目、文章內容與批閱說明。
                </p>
            </div>
        }
        else if (QuestionType == "readGroup")
        {
            <!-- 閱讀題組分類 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-book-open text-morandi"></i>
                        閱讀題組屬性
                    </span>
                    <span class="text-[10px] text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        適用等級：初～優級
                    </span>
                </div>
                <!-- 文體 -->
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">文體 <span class="text-red-400">*</span></label>
                    <select @bind="Genre"
                        class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="">請選擇文體</option>
                        <option value="文言文">文言文</option>
                        <option value="應用文">應用文</option>
                        <option value="語體文">語體文</option>
                    </select>
                </div>
                <p class="text-[10px] text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    母題底下有複數子題，以子題代碼區分。
                </p>
            </div>
        }
        else if (QuestionType == "shortGroup")
        {
            <!-- 短文題組分類 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-file-lines text-morandi"></i>
                        短文題組屬性
                    </span>
                    <span class="text-[10px] text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        適用等級：初～優級
                    </span>
                </div>
                <!-- 固定屬性：主類 / 次類 -->
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">主類</label>
                        <input type="text" value="文義判讀" disabled class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg bg-gray-100 text-gray-400">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">次類</label>
                        <input type="text" value="篇章辨析" disabled class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg bg-gray-100 text-gray-400">
                    </div>
                </div>
                <!-- 文體 -->
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">文體 <span class="text-red-400">*</span></label>
                    <select @bind="Genre"
                        class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                        <option value="">請選擇文體</option>
                        <option value="文言文">文言文</option>
                        <option value="應用文">應用文</option>
                        <option value="語體文">語體文</option>
                    </select>
                </div>
                <p class="text-[10px] text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    主類/次類為固定值，母題底下有複數子題。
                </p>
            </div>
        }
        else if (QuestionType == "listen")
        {
            <!-- 聽力測驗屬性 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-headphones text-morandi"></i>
                        聽力測驗屬性
                    </span>
                    <span class="text-[10px] text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        難度一～五
                    </span>
                </div>

                <!-- 核心能力（依等級自動帶入） -->
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">核心能力</label>
                    @if (string.IsNullOrEmpty(Level) || !LevelCoreAbilityMap.ContainsKey(Level))
                    {
                        <input type="text" value="請先選擇等級" disabled
                            class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg bg-gray-100 text-gray-300">
                    }
                    else if (LevelCoreAbilityMap[Level].Length > 1)
                    {
                        <select @bind="CoreAbility" @bind:after="OnCoreAbilityChanged"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            @foreach (var ability in LevelCoreAbilityMap[Level])
                            {
                                <option value="@ability">@ability</option>
                            }
                        </select>
                    }
                    else
                    {
                        <input type="text" value="@CoreAbility" disabled
                            class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg bg-gray-100 text-gray-500 font-medium">
                    }
                </div>

                <!-- 細目指標 -->
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">細目指標 <span class="text-red-400">*</span></label>
                    <select @bind="DetailIndicator"
                        class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer @(string.IsNullOrEmpty(CoreAbility) ? "bg-gray-50 text-gray-300" : "")"
                        disabled="@(string.IsNullOrEmpty(CoreAbility))">
                        <option value="">@(string.IsNullOrEmpty(CoreAbility) ? "先選等級" : "請選擇")</option>
                        @if (!string.IsNullOrEmpty(CoreAbility) && CoreAbilityIndicatorMap.TryGetValue(GetIndicatorKey(CoreAbility), out var indicators))
                        {
                            @foreach (var ind in indicators)
                            {
                                <option value="@ind">@ind</option>
                            }
                        }
                    </select>
                </div>

                <!-- 語音類型 + 素材分類 並排 -->
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">語音類型 <span class="text-red-400">*</span></label>
                        <select @bind="AudioType"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            <option value="對話">對話</option>
                            <option value="情境">情境</option>
                            <option value="陳述">陳述</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">素材分類 <span class="text-red-400">*</span></label>
                        <select @bind="Material"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            <option value="生活">生活</option>
                            <option value="教育">教育</option>
                            <option value="職場">職場</option>
                            <option value="專業">專業</option>
                        </select>
                    </div>
                </div>

                <p class="text-[10px] text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    選擇等級後自動帶入核心能力，再依核心能力篩選細目指標。
                </p>
            </div>
        }
        else if (QuestionType == "listenGroup")
        {
            <!-- 聽力題組屬性 -->
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-3 space-y-3">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-bold text-gray-500 flex items-center gap-1.5">
                        <i class="fa-solid fa-headphones text-morandi"></i>
                        聽力題組屬性
                    </span>
                    <span class="text-[10px] text-gray-400 bg-white px-1.5 py-0.5 rounded border border-gray-100">
                        母題無難度
                    </span>
                </div>

                <!-- 語音類型 + 素材分類 並排 -->
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">語音類型 <span class="text-red-400">*</span></label>
                        <select @bind="AudioType"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            <option value="對話">對話</option>
                            <option value="情境">情境</option>
                            <option value="陳述">陳述</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">素材分類 <span class="text-red-400">*</span></label>
                        <select @bind="Material"
                            class="w-full px-2 py-1.5 text-xs border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                            <option value="">請選擇</option>
                            <option value="生活">生活</option>
                            <option value="教育">教育</option>
                            <option value="職場">職場</option>
                            <option value="專業">專業</option>
                        </select>
                    </div>
                </div>

                <p class="text-[10px] text-gray-400 leading-relaxed">
                    <i class="fa-solid fa-circle-info mr-0.5"></i>
                    母題不區分難度，子題各自設定難度、核心能力與細目指標。
                </p>
            </div>
        }
    </div>

    <!-- 難易度（聽力題組母題無難易度） -->
    <div class="@(QuestionType == "listenGroup" ? "hidden" : "")">
        <label class="block text-sm font-bold text-gray-700 mb-1.5">難易度 <span class="text-red-400">*</span></label>
        <select @bind="Difficulty"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
            <option value="">請選擇</option>
            <option value="easy">易</option>
            <option value="medium">中</option>
            <option value="hard">難</option>
        </select>
    </div>

    <hr class="border-gray-100">
</div>

<!-- 底部提示 -->
<div class="px-4 py-3 border-t border-gray-100 bg-gray-50/50 text-[11px] text-gray-400 leading-snug flex-shrink-0">
    <i class="fa-solid fa-circle-info mr-1"></i>
    點右側欄位，就會滑出底部編輯器。
</div>

@code {
    [Parameter] public string QuestionType { get; set; } = "single";
    [Parameter] public EventCallback<string> QuestionTypeChanged { get; set; }

    [Parameter] public string Level { get; set; } = "";
    [Parameter] public EventCallback<string> LevelChanged { get; set; }

    [Parameter] public string Difficulty { get; set; } = "";
    [Parameter] public EventCallback<string> DifficultyChanged { get; set; }

    // 單選題 / 精選單選題 attributes
    [Parameter] public string Topic { get; set; } = "";
    [Parameter] public EventCallback<string> TopicChanged { get; set; }
    [Parameter] public string Subtopic { get; set; } = "";
    [Parameter] public EventCallback<string> SubtopicChanged { get; set; }

    // 長文題目
    [Parameter] public string WritingMode { get; set; } = "";
    [Parameter] public EventCallback<string> WritingModeChanged { get; set; }

    // 閱讀題組 / 短文題組
    [Parameter] public string Genre { get; set; } = "";
    [Parameter] public EventCallback<string> GenreChanged { get; set; }

    // 聽力
    [Parameter] public string AudioType { get; set; } = "";
    [Parameter] public EventCallback<string> AudioTypeChanged { get; set; }
    [Parameter] public string Material { get; set; } = "";
    [Parameter] public EventCallback<string> MaterialChanged { get; set; }
    [Parameter] public string CoreAbility { get; set; } = "";
    [Parameter] public EventCallback<string> CoreAbilityChanged { get; set; }
    [Parameter] public string DetailIndicator { get; set; } = "";
    [Parameter] public EventCallback<string> DetailIndicatorChanged { get; set; }

    private bool IsListenType => QuestionType is "listen" or "listenGroup";

    private async Task OnTypeChanged()
    {
        await QuestionTypeChanged.InvokeAsync(QuestionType);
    }

    private async Task OnLevelChanged()
    {
        // 聽力題型：等級變更時自動帶入核心能力
        if (IsListenType && !string.IsNullOrEmpty(Level) && LevelCoreAbilityMap.TryGetValue(Level, out var abilities))
        {
            // 只有一個核心能力時自動帶入，多個（難度五）讓使用者選
            CoreAbility = abilities.Length == 1 ? abilities[0] : "";
            DetailIndicator = "";
            await CoreAbilityChanged.InvokeAsync(CoreAbility);
            await DetailIndicatorChanged.InvokeAsync(DetailIndicator);
        }
        await LevelChanged.InvokeAsync(Level);
    }

    private async Task OnCoreAbilityChanged()
    {
        DetailIndicator = "";
        await CoreAbilityChanged.InvokeAsync(CoreAbility);
        await DetailIndicatorChanged.InvokeAsync(DetailIndicator);
    }

    private async Task OnTopicChanged()
    {
        // 若該主題只有一個次類，自動帶入
        if (!string.IsNullOrEmpty(Topic) && SingleChoiceCategoryMap.TryGetValue(Topic, out var subs) && subs.Length == 1)
        {
            Subtopic = subs[0];
        }
        else
        {
            Subtopic = "";
        }

        await TopicChanged.InvokeAsync(Topic);
        await SubtopicChanged.InvokeAsync(Subtopic);
    }

    private static readonly string[] SingleChoiceTopics =
        ["文字", "語詞", "成語短語", "造句標點", "修辭技巧", "語文知識", "文意判讀"];

    private static readonly Dictionary<string, string[]> SingleChoiceCategoryMap = new()
    {
        ["文字"] = ["字音", "字型", "造字原則"],
        ["語詞"] = ["辭義辨識", "詞彙辨析", "詞性分辨", "語詞應用"],
        ["成語短語"] = ["短語辨識", "語詞使用", "文義取得"],
        ["造句標點"] = ["句義", "句法辨析", "標點符號"],
        ["修辭技巧"] = ["修辭類型", "語態變化"],
        ["語文知識"] = ["語文知識"],
        ["文意判讀"] = ["段義辨析"]
    };

    // === 聽力：等級 → 核心能力 ===
    private static readonly Dictionary<string, string[]> LevelCoreAbilityMap = new()
    {
        ["難度一"] = ["提取訊息"],
        ["難度二"] = ["理解訊息"],
        ["難度三"] = ["推斷訊息"],
        ["難度四"] = ["歸納分析訊息", "區辨詞語多義性"],
        ["難度五"] = ["統整、闡述或評鑑訊息", "思辨、推衍訊息"]
    };

    // === 聽力：核心能力 → 細目指標 ===
    private static readonly Dictionary<string, string[]> CoreAbilityIndicatorMap = new()
    {
        ["提取訊息"] = ["提取對話與訊息主旨", "回應訊息內容", "轉述訊息內容"],
        ["理解訊息"] = ["理解訊息意圖或細節", "理解說話者語氣或態度變化", "理解慣用語的意義"],
