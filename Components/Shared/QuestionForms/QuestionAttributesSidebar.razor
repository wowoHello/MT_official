@* ====================================================================== *@
@*  QuestionAttributesSidebar — 命題表單左側屬性設定側欄                    *@
@*  共用欄位：題型、等級、難易度                                            *@
@*  依題型動態渲染專屬屬性欄位（主題/次類/文體/模式/音檔類型...）           *@
@* ====================================================================== *@

<div class="p-4 space-y-4 flex-grow overflow-y-auto custom-scroll">
    <div class="flex items-center justify-between gap-3">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider flex items-center gap-1.5">
            <i class="fa-solid fa-sliders"></i> 題目屬性
        </h3>
        <span class="text-[11px] text-gray-300 uppercase tracking-[0.18em]">共用欄位</span>
    </div>

    <!-- 題型選擇 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-1.5">題型 <span class="text-red-400">*</span></label>
        <select @bind="QuestionType" @bind:after="OnTypeChanged"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
            <option value="single">一般單選題</option>
            <option value="select">精選單選題</option>
            <option value="readGroup">閱讀題組</option>
            <option value="longText">長文題目</option>
            <option value="shortGroup">短文題組</option>
            <option value="listen">聽力測驗</option>
            <option value="listenGroup">聽力題組</option>
        </select>
    </div>

    <!-- 等級 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-1.5">等級 <span class="text-red-400">*</span></label>
        <select @bind="Level"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
            <option value="">請選擇等級</option>
            @if (IsListenType)
            {
                <option value="難度一">難度一</option>
                <option value="難度二">難度二</option>
                <option value="難度三">難度三</option>
                <option value="難度四">難度四</option>
                <option value="難度五">難度五</option>
            }
            else
            {
                <option value="初級">初級</option>
                <option value="中級">中級</option>
                <option value="中高級">中高級</option>
                <option value="高級">高級</option>
                <option value="優級">優級</option>
            }
        </select>
    </div>

    <!-- 題型專屬屬性 -->
    <div class="space-y-4">
        @if (QuestionType is "single" or "select")
        {
            <!-- 主題 -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">主題 <span class="text-red-400">*</span></label>
                <select @bind="Topic" @bind:after="OnTopicChanged"
                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                    <option value="">請選擇主題</option>
                    @foreach (var t in SingleChoiceTopics)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <!-- 次類 -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">次類</label>
                <select @bind="Subtopic"
                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                    <option value="">請選擇次類</option>
                    @if (!string.IsNullOrEmpty(Topic) && SingleChoiceCategoryMap.ContainsKey(Topic))
                    {
                        @foreach (var sub in SingleChoiceCategoryMap[Topic])
                        {
                            <option value="@sub">@sub</option>
                        }
                    }
                </select>
            </div>
        }
        else if (QuestionType == "longText")
        {
            <!-- 寫作模式 -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">寫作模式 <span class="text-red-400">*</span></label>
                <select @bind="WritingMode"
                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                    <option value="">請選擇</option>
                    <option value="引導寫作">引導寫作</option>
                    <option value="資訊整合">資訊整合</option>
                </select>
            </div>
        }
        else if (QuestionType is "readGroup" or "shortGroup")
        {
            @if (QuestionType == "shortGroup")
            {
                <!-- 固定屬性：主類 / 次類 -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1.5">主類</label>
                    <input type="text" value="文義判讀" disabled class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 text-gray-400">
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1.5">次類</label>
                    <input type="text" value="篇章辨析" disabled class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg bg-gray-50 text-gray-400">
                </div>
            }
            <!-- 文體 -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">文體 <span class="text-red-400">*</span></label>
                <select @bind="Genre"
                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                    <option value="">請選擇文體</option>
                    <option value="文言文">文言文</option>
                    <option value="應用文">應用文</option>
                    <option value="語體文">語體文</option>
                </select>
            </div>
        }
        else if (QuestionType is "listen" or "listenGroup")
        {
            <!-- 音檔類型 -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">音檔類型 <span class="text-red-400">*</span></label>
                <select @bind="AudioType"
                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                    <option value="">請選擇</option>
                    <option value="對話">對話</option>
                    <option value="情境">情境</option>
                    <option value="陳述">陳述</option>
                </select>
            </div>
            <!-- 語料素材 -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">語料素材 <span class="text-red-400">*</span></label>
                <select @bind="Material"
                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                    <option value="">請選擇</option>
                    <option value="生活">生活</option>
                    <option value="教育">教育</option>
                    <option value="職場">職場</option>
                    <option value="專業">專業</option>
                </select>
            </div>
        }
    </div>

    <!-- 難易度 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-1.5">難易度 <span class="text-red-400">*</span></label>
        <select @bind="Difficulty"
            class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
            <option value="">請選擇</option>
            <option value="easy">易</option>
            <option value="medium">中</option>
            <option value="hard">難</option>
        </select>
    </div>

    <hr class="border-gray-100">
</div>

<!-- 底部提示 -->
<div class="px-4 py-3 border-t border-gray-100 bg-gray-50/50 text-[11px] text-gray-400 leading-snug flex-shrink-0">
    <i class="fa-solid fa-circle-info mr-1"></i>
    點右側欄位，就會滑出底部編輯器。
</div>

@code {
    [Parameter] public string QuestionType { get; set; } = "single";
    [Parameter] public EventCallback<string> QuestionTypeChanged { get; set; }

    [Parameter] public string Level { get; set; } = "";
    [Parameter] public EventCallback<string> LevelChanged { get; set; }

    [Parameter] public string Difficulty { get; set; } = "";
    [Parameter] public EventCallback<string> DifficultyChanged { get; set; }

    // 單選題 / 精選單選題 attributes
    [Parameter] public string Topic { get; set; } = "";
    [Parameter] public EventCallback<string> TopicChanged { get; set; }
    [Parameter] public string Subtopic { get; set; } = "";
    [Parameter] public EventCallback<string> SubtopicChanged { get; set; }

    // 長文題目
    [Parameter] public string WritingMode { get; set; } = "";
    [Parameter] public EventCallback<string> WritingModeChanged { get; set; }

    // 閱讀題組 / 短文題組
    [Parameter] public string Genre { get; set; } = "";
    [Parameter] public EventCallback<string> GenreChanged { get; set; }

    // 聽力
    [Parameter] public string AudioType { get; set; } = "";
    [Parameter] public EventCallback<string> AudioTypeChanged { get; set; }
    [Parameter] public string Material { get; set; } = "";
    [Parameter] public EventCallback<string> MaterialChanged { get; set; }

    private bool IsListenType => QuestionType is "listen" or "listenGroup";

    private async Task OnTypeChanged()
    {
        await QuestionTypeChanged.InvokeAsync(QuestionType);
    }

    private async Task OnTopicChanged()
    {
        Subtopic = "";
        await TopicChanged.InvokeAsync(Topic);
    }

    private static readonly string[] SingleChoiceTopics =
        ["字形", "字音", "字義", "詞語", "成語", "文法", "修辭", "文意", "閱讀", "國學常識", "文化認知"];

    private static readonly Dictionary<string, string[]> SingleChoiceCategoryMap = new()
    {
        ["字形"] = ["形近字辨識", "同音異字", "正確用字"],
        ["字音"] = ["多音字辨識", "破音字", "正確讀音"],
        ["字義"] = ["一字多義", "字義辨析", "古今字義"],
        ["詞語"] = ["詞義辨析", "近義詞", "詞語運用"],
        ["成語"] = ["成語釋義", "成語運用", "成語辨正"],
        ["文法"] = ["語法結構", "句型分析", "語病修正"],
        ["修辭"] = ["修辭辨識", "修辭運用", "修辭效果"],
        ["文意"] = ["主旨判讀", "文意推論", "文意理解"],
        ["閱讀"] = ["閱讀理解", "訊息擷取", "推論判斷"],
        ["國學常識"] = ["經典認識", "文學流變", "文體特徵"],
        ["文化認知"] = ["傳統文化", "文化比較", "現代應用"]
    };
}
