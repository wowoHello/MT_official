@* ====================================================================== *@
@*  QuestionFormShortGroup — 短文題組 命題表單                              *@
@*  結構：題目（Quill）+ 文章內容（Quill）+ N 個子題（題幹+主向度+指標+解析）*@
@*  屬性側欄：文體（文言文 / 應用文 / 語體文）                              *@
@*  固定屬性：主類 = 文義判讀、次類 = 篇章辨析                              *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-6 lg:p-8 pb-16 max-w-4xl mx-auto space-y-6 min-h-full">

    <!-- 題目 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-file-lines text-morandi"></i> 題目 <span class="text-red-400">*</span>
        </label>
        <QuillEditor @bind-Value="Stem" FieldLabel="題目" Placeholder="請輸入題目..." />
    </div>

    <!-- 文章內容 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-book-open text-sage"></i> 文章內容 <span class="text-red-400">*</span>
        </label>
        <p class="text-xs text-gray-400 mb-2"><i class="fa-solid fa-circle-info mr-1"></i>母題需要題目與文章內容，子題設定主向度及能力指標。</p>
        <QuillEditor @bind-Value="Passage" FieldLabel="文章內容" Placeholder="請輸入短文內容..." />
    </div>

    <!-- 子題列表（自由作答模式） -->
    <div>
        <div class="flex items-center justify-between mb-3">
            <label class="text-sm font-bold text-gray-700 flex items-center gap-2">
                <i class="fa-solid fa-list-check text-terracotta"></i> 子題 <span class="text-red-400">*</span>
                <span class="text-xs text-gray-400 font-normal">（共 @SubQuestions.Count 題）</span>
            </label>
            <button type="button" @onclick="AddSubQuestion"
                class="px-3 py-1 text-xs font-bold text-sage bg-sage/10 rounded-lg hover:bg-sage/20 transition-colors cursor-pointer">
                <i class="fa-solid fa-plus mr-1"></i> 新增子題
            </button>
        </div>

        <div class="space-y-4">
            @for (int i = 0; i < SubQuestions.Count; i++)
            {
                var idx = i;
                var sq = SubQuestions[idx];
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-main">第 @(idx + 1) 題</span>
                        @if (SubQuestions.Count > 1)
                        {
                            <button type="button" @onclick="() => RemoveSubQuestion(idx)"
                                class="text-xs text-red-400 hover:text-red-600 transition-colors cursor-pointer">
                                <i class="fa-solid fa-trash-can mr-0.5"></i> 刪除
                            </button>
                        }
                    </div>
                    <div class="p-4 space-y-4">
                        <!-- 子題題幹 -->
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">題幹</label>
                            <input type="text" @bind="sq.Stem" placeholder="請輸入子題題幹..."
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi">
                        </div>

                        <!-- 主向度 + 能力指標 -->
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">主向度</label>
                                <select @bind="sq.Dimension"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                    <option value="">請選擇</option>
                                    @foreach (var dim in DimensionOptions)
                                    {
                                        <option value="@dim">@dim</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">能力指標</label>
                                <select @bind="sq.Indicator"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                    <option value="">請選擇</option>
                                    @if (!string.IsNullOrEmpty(sq.Dimension) && DimensionIndicatorMap.ContainsKey(sq.Dimension))
                                    {
                                        @foreach (var ind in DimensionIndicatorMap[sq.Dimension])
                                        {
                                            <option value="@ind">@ind</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- 解析 -->
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">解析</label>
                            <textarea @bind="sq.Analysis" rows="2" placeholder="解析（選填）..."
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi resize-none"></textarea>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public List<SubQuestionFreeResponse> SubQuestions { get; set; } = [new()];
    [Parameter] public EventCallback<List<SubQuestionFreeResponse>> SubQuestionsChanged { get; set; }

    private static readonly string[] DimensionOptions = ["條列敘述", "分析推理", "歸納統整"];

    private static readonly Dictionary<string, string[]> DimensionIndicatorMap = new()
    {
        ["條列敘述"] = ["擷取明確訊息", "辨識文本細節", "掌握段落大意", "理解字詞語意", "判斷語句語意", "指出篇章主旨", "概覽全文要點", "分析內容觀點"],
        ["分析推理"] = ["分析文本架構", "推斷隱含意義", "辨析語氣語調", "評估立場觀點", "推論因果邏輯", "比較異同關係", "判斷修辭手法", "理解篇章脈絡"],
        ["歸納統整"] = ["統整跨段訊息", "歸納中心思想", "評鑑寫作技巧", "綜合比較分析", "整合多元觀點", "建構全面理解", "評述整體架構", "提出綜合判斷"]
    };

    private void AddSubQuestion()
    {
        SubQuestions.Add(new SubQuestionFreeResponse());
    }

    private void RemoveSubQuestion(int idx)
    {
        if (SubQuestions.Count > 1)
            SubQuestions.RemoveAt(idx);
    }

    public class SubQuestionFreeResponse
    {
        public string Stem { get; set; } = "";
        public string Dimension { get; set; } = "";
        public string Indicator { get; set; } = "";
        public string Analysis { get; set; } = "";
    }
}
