@* ====================================================================== *@
@*  QuestionFormShortGroup — 短文題組 命題表單                              *@
@*  結構：題目（Quill）+ 文章內容（Quill）+ N 個子題（題幹Quill+主向度+指標+解析Quill）*@
@*  屬性側欄：文體（文言文 / 應用文 / 語體文）                              *@
@*  固定屬性：主類 = 文義判讀、次類 = 篇章辨析                              *@
@* ====================================================================== *@
@using MT.Components.Shared
@inject IJSRuntime JS

<div class="p-6 lg:p-8 pb-16 max-w-4xl mx-auto space-y-6 min-h-full">

    <!-- 題目 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-pen text-morandi"></i> 題目 <span class="text-red-400">*</span>
        </label>
        <QuillField Value="@Stem" ValueChanged="v => { Stem = v; StemChanged.InvokeAsync(v); }" FieldLabel="題目" Placeholder="點擊此處開始編輯題目..." />
    </div>

    <!-- 文章內容 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-book-open text-morandi"></i> 文章內容 <span class="text-red-400">*</span>
        </label>
        <!-- 短文題組母題提醒 -->
        <div class="mb-3 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-sm">
            <p class="font-bold text-terracotta mb-1 flex items-center gap-1.5">
                <i class="fa-solid fa-circle-info"></i> 短文題組母題提醒
            </p>
            <p class="text-amber-700 text-xs leading-relaxed">
                母題包含「題目」與「文章內容」，兩者皆為必填；文章內容可附圖。子題請補上主向度與能力指標，方便後續審題判讀。
            </p>
        </div>
        <QuillField Value="@Passage" ValueChanged="v => { Passage = v; PassageChanged.InvokeAsync(v); }" FieldLabel="文章內容" Placeholder="點擊此處開始輸入文章內容..." />
    </div>

    <!-- 子題區 -->
    <div>
        <div class="flex items-center justify-between mb-3">
            <label class="text-sm font-bold text-gray-700 flex items-center gap-2">
                <i class="fa-solid fa-layer-group text-morandi"></i> 子題區
            </label>
            <button type="button" @onclick="AddSubQuestion"
                class="px-3 py-1.5 text-xs font-bold text-white bg-sage rounded-lg hover:bg-[#7a9a82] transition-colors cursor-pointer shadow-sm flex items-center gap-1">
                <i class="fa-solid fa-plus"></i> 新增子題
            </button>
        </div>

        <div class="space-y-4">
            @for (int i = 0; i < SubQuestions.Count; i++)
            {
                var idx = i;
                var sq = SubQuestions[idx];
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <!-- 子題標頭 -->
                    <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-main">第 @(idx + 1) 題</span>
                        @if (SubQuestions.Count > 1)
                        {
                            <button type="button" @onclick="() => RemoveSubQuestion(idx)"
                                class="text-xs text-red-400 hover:text-red-600 transition-colors cursor-pointer flex items-center gap-1">
                                <i class="fa-solid fa-trash-can"></i> 刪除
                            </button>
                        }
                    </div>
                    <div class="p-4 space-y-4">
                        <!-- 題目內容 -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">
                                題目內容 <span class="text-red-400">*</span>
                            </label>
                            <QuillField Value="@sq.Stem" ValueChanged="v => { sq.Stem = v; SubQuestionsChanged.InvokeAsync(SubQuestions); }" FieldLabel="@($"第 {idx + 1} 題 題目內容")"
                                Placeholder="點擊此處開始編輯題目內容..." />
                        </div>

                        <!-- 主向度 + 能力指標 -->
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">主向度 <span class="text-red-400">*</span></label>
                                <select @bind="sq.CoreAbility" @bind:after="() => OnCoreAbilityChanged(sq)"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer">
                                    <option value="">請選擇</option>
                                    @foreach (var dim in CoreAbilityOptions)
                                    {
                                        <option value="@dim">@dim</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-600 mb-1">能力指標 <span class="text-red-400">*</span></label>
                                <select @bind="sq.Indicator"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer @(string.IsNullOrEmpty(sq.CoreAbility) ? "bg-gray-50 text-gray-300" : "")"
                                    disabled="@(string.IsNullOrEmpty(sq.CoreAbility))">
                                    <option value="">@(string.IsNullOrEmpty(sq.CoreAbility) ? "先選主向度" : "請選擇")</option>
                                    @if (!string.IsNullOrEmpty(sq.CoreAbility) && CoreAbilityIndicatorMap.ContainsKey(sq.CoreAbility))
                                    {
                                        @foreach (var ind in CoreAbilityIndicatorMap[sq.CoreAbility])
                                        {
                                            <option value="@ind">@ind</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- 試題解析 -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">
                                試題解析（紀錄答案理由） <span class="text-red-400">*</span>
                            </label>
                            <QuillField Value="@sq.Analysis" ValueChanged="v => { sq.Analysis = v; SubQuestionsChanged.InvokeAsync(SubQuestions); }" FieldLabel="@($"第 {idx + 1} 題 解析")"
                                Placeholder="點擊此處開始編輯解析..." />
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public List<SubQuestionFreeResponse> SubQuestions { get; set; } = [new()];
    [Parameter] public EventCallback<List<SubQuestionFreeResponse>> SubQuestionsChanged { get; set; }

    private static readonly string[] CoreAbilityOptions = ["條列敘述", "歸納統整", "分析推理"];

    private static readonly Dictionary<string, string[]> CoreAbilityIndicatorMap = new()
    {
        ["條列敘述"] = [
            "1-1 條列敘述人、事、物特徵與特質",
            "1-2 條列敘述起始原因、發生情況、結論等時空先後順序",
            "1-3 條列敘述人、事、物的差異"
        ],
        ["歸納統整"] = [
            "2-1 歸納作者主張",
            "2-2 歸納文章主旨",
            "2-3 歸納共同特點"
        ],
        ["分析推理"] = [
            "3-1 分析線索",
            "3-2 推論緣由",
            "3-3 判斷結果",
            "3-4 判斷詞性、主語",
            "3-5 判斷字句的解釋、文意說明是否正確",
            "3-6 推測行為的原因或用意",
            "3-7 推測寫作手法的目的",
            "3-8 判斷文體、格律、風格"
        ]
    };

    private void OnCoreAbilityChanged(SubQuestionFreeResponse sq)
    {
        sq.Indicator = "";
    }

    private async Task AddSubQuestion()
    {
        var confirmed = await JS.InvokeAsync<bool>("swalInterop.confirm", new
        {
            title = "新增子題",
            text = $"確定要新增第 {SubQuestions.Count + 1} 題嗎？",
            icon = "question",
            showCancelButton = true,
            confirmButtonText = "新增",
            cancelButtonText = "取消",
            confirmButtonColor = "#8eab94"
        });
        if (confirmed)
        {
            SubQuestions.Add(new SubQuestionFreeResponse());
        }
    }

    private async Task RemoveSubQuestion(int idx)
    {
        if (SubQuestions.Count <= 1) return;
        var confirmed = await JS.InvokeAsync<bool>("swalInterop.confirm", new
        {
            title = "刪除子題",
            text = $"確定要刪除第 {idx + 1} 題嗎？已填寫的內容將無法復原。",
            icon = "warning",
            showCancelButton = true,
            confirmButtonText = "確定刪除",
            cancelButtonText = "取消",
            confirmButtonColor = "#d98a6c"
        });
        if (confirmed)
        {
            SubQuestions.RemoveAt(idx);
        }
    }

    public class SubQuestionFreeResponse
    {
        public string Stem { get; set; } = "";
        public string CoreAbility { get; set; } = "";
        public string Indicator { get; set; } = "";
        public string Analysis { get; set; } = "";
    }
}

