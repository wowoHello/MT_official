@* ====================================================================== *@
@*  QuestionFormLongText — 長文題目 命題表單                                *@
@*  結構：題目（Quill）+ 文章內容（Quill）+ 批閱說明（Quill）               *@
@*  屬性側欄：寫作模式（引導寫作 / 資訊整合）                               *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-6 lg:p-8 pb-16 max-w-4xl mx-auto space-y-6 min-h-full">

    <!-- 題目 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-pen text-morandi"></i> 題目
        </label>
        <QuillEditor Value="@Stem" ValueChanged="v => { Stem = v; StemChanged.InvokeAsync(v); }" FieldLabel="題目" Placeholder="點擊此處開始編輯題目..." />
    </div>

    <!-- 文章內容 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-book-open text-morandi"></i> 文章內容 <span class="text-red-400">*</span>
        </label>
        <!-- 附圖提醒 -->
        <div class="mb-3 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-sm">
            <p class="font-bold text-terracotta mb-1 flex items-center gap-1.5">
                <i class="fa-solid fa-image"></i> 文章內容可附圖
            </p>
            <p class="text-amber-700 text-xs leading-relaxed">
                點擊文章內容後，可用底部編輯器工具列插入圖片，適合放題幹情境圖或資料圖表。
            </p>
        </div>
        <QuillEditor Value="@Passage" ValueChanged="v => { Passage = v; PassageChanged.InvokeAsync(v); }" FieldLabel="文章內容" Placeholder="點擊此處開始輸入文章內容..." />
    </div>

    <!-- 批閱說明 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-lightbulb text-amber-500"></i> 批閱說明
        </label>
        <QuillEditor Value="@Analysis" ValueChanged="v => { Analysis = v; AnalysisChanged.InvokeAsync(v); }" FieldLabel="批閱說明" Placeholder="請簡要說明長文題目的批閱說明..." />
    </div>
</div>

@code {
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public string Analysis { get; set; } = "";
    [Parameter] public EventCallback<string> AnalysisChanged { get; set; }
}
