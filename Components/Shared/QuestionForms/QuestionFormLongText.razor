@* ====================================================================== *@
@*  QuestionFormLongText — 長文題目 命題表單                                *@
@*  結構：題目（Quill）+ 文章內容（Quill + 附圖）+ 批閱說明（Quill）        *@
@*  屬性側欄：寫作模式（引導寫作 / 資訊整合）                               *@
@*                                                                         *@
@*  附圖支援：文章內容下方嵌 QuestionImagesField（FieldType=ArticleContent） *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-5 lg:p-6 pb-16 max-w-4xl mx-auto space-y-4 min-h-full">

    @* 題目（Stem）目前 razor 標非必填，僅作 anchor *@
    <FormSectionCard Title="題目" Icon="fa-pen" DataField="Stem">
        <QuillField Value="@Stem" ValueChanged="v => { Stem = v; StemChanged.InvokeAsync(v); }" FieldLabel="題目" Placeholder="點擊此處開始編輯題目..." />
    </FormSectionCard>

    <FormSectionCard Title="文章內容" Icon="fa-book-open" Required="true"
        DataField="ArticleContent" ContainerClass="@InvalidRing("ArticleContent")">
        <QuillField Value="@Passage" ValueChanged="v => { Passage = v; PassageChanged.InvokeAsync(v); }" FieldLabel="文章內容" Placeholder="點擊此處開始輸入文章內容..." />
        <QuestionImagesField Images="ArticleImages" ImagesChanged="OnArticleImagesChanged" />
    </FormSectionCard>

    <FormSectionCard Title="批閱說明" Icon="fa-lightbulb" IconColor="text-amber-500" HintText="紀錄批閱重點"
        DataField="GradingNote" ContainerClass="@InvalidRing("GradingNote")">
        <QuillField Value="@GradingNote" ValueChanged="v => { GradingNote = v; GradingNoteChanged.InvokeAsync(v); }" FieldLabel="批閱說明" Placeholder="請輸入批閱說明，可條列評分重點、給分要件與常見錯誤..." />
    </FormSectionCard>
</div>

@code {
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public string GradingNote { get; set; } = "";
    [Parameter] public EventCallback<string> GradingNoteChanged { get; set; }

    /// <summary>題目附圖（母題層級，FieldType 6=ArticleContent）。</summary>
    [Parameter] public List<QuestionImage> Images { get; set; } = [];
    [Parameter] public EventCallback<List<QuestionImage>> ImagesChanged { get; set; }

    /// <summary>由父層傳入的驗證失敗欄位集合。</summary>
    [Parameter] public HashSet<string>? InvalidFields { get; set; }

    private string InvalidRing(string fieldKey) =>
        InvalidFields?.Contains(fieldKey) == true ? "ring-2 ring-red-400" : "";

    // ------------------------------------------------------------------
    //  附圖切片：依 FieldType 從 Images 抽出文章內容附圖
    // ------------------------------------------------------------------

    private List<QuestionImage> ArticleImages =>
        Images.Where(i => i.FieldType == (byte)QuestionImageField.ArticleContent && i.SubQuestionIndex == null)
              .OrderBy(i => i.SortOrder).ToList();

    private async Task OnArticleImagesChanged(List<QuestionImage> updated)
    {
        var others = Images.Where(i => !(i.FieldType == (byte)QuestionImageField.ArticleContent && i.SubQuestionIndex == null)).ToList();
        for (int i = 0; i < updated.Count; i++)
        {
            updated[i].FieldType = (byte)QuestionImageField.ArticleContent;
            updated[i].SubQuestionIndex = null;
            updated[i].SortOrder = (byte)(i + 1);
        }
        others.AddRange(updated);
        Images = others;
        await ImagesChanged.InvokeAsync(others);
    }
}
