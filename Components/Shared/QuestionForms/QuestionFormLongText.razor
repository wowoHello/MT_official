@* ====================================================================== *@
@*  QuestionFormLongText — 長文題目 命題表單                                *@
@*  結構：題目（Quill）+ 文章內容（Quill）+ 批閱說明（Quill）               *@
@*  屬性側欄：寫作模式（引導寫作 / 資訊整合）                               *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-6 lg:p-8 pb-16 max-w-4xl mx-auto space-y-6 min-h-full">

    <!-- 題目 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-file-lines text-morandi"></i> 題目 <span class="text-red-400">*</span>
        </label>
        <QuillEditor @bind-Value="Stem" FieldLabel="題目" Placeholder="請輸入長文題目..." />
    </div>

    <!-- 文章內容 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-book-open text-sage"></i> 文章內容 <span class="text-red-400">*</span>
        </label>
        <p class="text-xs text-gray-400 mb-2"><i class="fa-solid fa-circle-info mr-1"></i>可附加圖片，點擊編輯器工具列中的圖片按鈕上傳。</p>
        <QuillEditor @bind-Value="Passage" FieldLabel="文章內容" Placeholder="請輸入文章內容..." />
    </div>

    <!-- 批閱說明 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-lightbulb text-amber-500"></i> 批閱說明
        </label>
        <QuillEditor @bind-Value="Analysis" FieldLabel="批閱說明" Placeholder="請簡要說明長文題目的批閱說明..." />
    </div>
</div>

@code {
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public string Analysis { get; set; } = "";
    [Parameter] public EventCallback<string> AnalysisChanged { get; set; }
}
