@* ====================================================================== *@
@*  QuestionFormListenGroup — 聽力題組 命題表單                             *@
@*  結構：音檔上傳 + 語音內容（Quill）+ 固定 2 個子題（選擇題）            *@
@*  屬性側欄：音檔類型 + 語料素材                                           *@
@*  子題的等級/能力/指標為固定值（不可編輯）                                *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-6 lg:p-8 pb-16 max-w-4xl mx-auto space-y-6 min-h-full">

    <!-- 聽力音檔上傳 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-headphones text-purple-500"></i> 聽力音檔 <span class="text-red-400">*</span>
        </label>
        <div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-morandi hover:bg-morandi/5 transition-all cursor-pointer group">
            @if (string.IsNullOrEmpty(AudioFileName))
            {
                <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-300 group-hover:text-morandi mb-2 transition-colors"></i>
                <p class="text-sm text-gray-400 group-hover:text-gray-600">點擊或拖曳音檔至此上傳</p>
                <p class="text-xs text-gray-300 mt-1">支援 MP3、WAV、OGG 格式，檔案大小上限 10MB</p>
            }
            else
            {
                <div class="flex items-center justify-center gap-3">
                    <i class="fa-solid fa-file-audio text-2xl text-morandi"></i>
                    <span class="text-sm font-medium text-slate-main">@AudioFileName</span>
                    <button type="button" @onclick="() => { AudioFileName = string.Empty; }"
                        class="text-xs text-red-400 hover:text-red-600 ml-2">
                        <i class="fa-solid fa-xmark"></i> 移除
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- 語音內容 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-microphone text-sage"></i> 語音內容 <span class="text-red-400">*</span>
        </label>
        <QuillEditor @bind-Value="Passage" FieldLabel="語音內容" Placeholder="請輸入語音內容（逐字稿）..." />
    </div>

    <!-- 固定 2 個子題 -->
    <div>
        <label class="text-sm font-bold text-gray-700 mb-3 flex items-center gap-2">
            <i class="fa-solid fa-list-check text-terracotta"></i> 子題（固定 2 題）
        </label>

        <div class="space-y-4">
            @for (int i = 0; i < FixedSubConfigs.Length; i++)
            {
                var idx = i;
                var cfg = FixedSubConfigs[idx];
                var sq = SubQuestions[idx];

                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-main">第 @(idx + 1) 題</span>
                        <div class="flex items-center gap-2 text-xs">
                            <span class="px-2 py-0.5 rounded bg-blue-50 text-blue-600 font-bold">@cfg.Level</span>
                            <span class="px-2 py-0.5 rounded bg-purple-50 text-purple-600 font-bold">@cfg.Competency</span>
                            <span class="px-2 py-0.5 rounded bg-amber-50 text-amber-600 font-bold">@cfg.Indicator</span>
                        </div>
                    </div>
                    <div class="p-4 space-y-4">
                        <!-- 子題題幹 -->
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">題幹</label>
                            <input type="text" @bind="sq.Stem" placeholder="請輸入子題題幹..."
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi focus:border-morandi">
                        </div>

                        <!-- 選項與答案 -->
                        <div class="mb-2 px-3 py-2 bg-amber-50 border border-amber-200 rounded-lg text-xs text-amber-700 flex items-center gap-2">
                            <i class="fa-solid fa-triangle-exclamation text-amber-500 flex-shrink-0"></i>
                            請避免選項長短、語氣明顯差異，以免影響鑑別度。
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            @for (int j = 0; j < 4; j++)
                            {
                                var optIdx = j;
                                var optLabel = OptionLabels[optIdx];
                                <div class="flex items-center gap-2">
                                    <label class="flex items-center gap-1 cursor-pointer flex-shrink-0">
                                        <input type="radio" name="@($"lg-answer-{idx}")" value="@optLabel"
                                            checked="@(sq.Answer == optLabel)"
                                            @onchange="() => sq.Answer = optLabel"
                                            class="w-3.5 h-3.5 text-sage focus:ring-sage cursor-pointer">
                                        <span class="text-xs font-bold @(sq.Answer == optLabel ? "text-sage" : "text-gray-400")">@optLabel</span>
                                    </label>
                                    <input type="text" @bind="sq.Options[optIdx]" placeholder="@($"選項 ({optLabel})")"
                                        class="flex-grow px-2.5 py-1.5 text-sm border border-gray-200 rounded focus:outline-none focus:ring-1 focus:ring-morandi">
                                </div>
                            }
                        </div>

                        <!-- 解析 -->
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">解析</label>
                            <textarea @bind="sq.Analysis" rows="2" placeholder="解析（選填）..."
                                class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi resize-none"></textarea>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string AudioFileName { get; set; } = "";
    [Parameter] public EventCallback<string> AudioFileNameChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public List<ListenGroupSubQuestion> SubQuestions { get; set; } = [new(), new()];
    [Parameter] public EventCallback<List<ListenGroupSubQuestion>> SubQuestionsChanged { get; set; }

    private static readonly string[] OptionLabels = ["A", "B", "C", "D"];

    private record FixedConfig(string Level, string Competency, string Indicator);
    private static readonly FixedConfig[] FixedSubConfigs =
    [
        new("難度三", "推斷訊息", "推斷訊息邏輯性"),
        new("難度四", "歸納分析", "歸納或總結訊息內容")
    ];

    public class ListenGroupSubQuestion
    {
        public string Stem { get; set; } = "";
        public string[] Options { get; set; } = ["", "", "", ""];
        public string Answer { get; set; } = "";
        public string Analysis { get; set; } = "";
    }
}
