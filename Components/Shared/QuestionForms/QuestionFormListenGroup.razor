@* ====================================================================== *@
@*  QuestionFormListenGroup — 聽力題組 命題表單                             *@
@*  結構：音檔上傳 + 語音內容（Quill）+ 固定 2 個子題（選擇題）            *@
@*  屬性側欄：語音類型 + 素材分類（母題無難度）                             *@
@*  子題難度固定：第 1 題=難度三 (FixedDifficulty=3)、第 2 題=難度四 (=4)   *@
@*  子題核心能力與細目指標沿用 CoreAbilityLabels / DetailIndicatorLabels    *@
@*  全表碼，不另立編碼                                                       *@
@* ====================================================================== *@
@using MT.Components.Shared
@inject IJSRuntime JS

<div class="p-5 lg:p-6 pb-16 max-w-4xl mx-auto space-y-4 min-h-full">

    @if (IsFocusMode)
    {
        @* Focus 模式提示條（單一子題修題視角） *@
        <div class="px-4 py-2.5 bg-morandi/10 border border-morandi/25 rounded-lg text-sm text-morandi font-bold flex items-center gap-2">
            <i class="fa-solid fa-bullseye"></i>
            <span>正在編輯第 @FocusSubOrder 子題（母題音檔與語音內容作為上下文僅供參考、無法修改）</span>
        </div>
    }

    @* Focus 模式：母題音檔 + 語音內容皆唯讀（CascadingValue 蓋掉父層 IsFormReadOnly） *@
    @if (IsFocusMode)
    {
        <CascadingValue Name="IsFormReadOnly" Value="true" IsFixed="false">
            <FormSectionCard Title="聽力音檔" Icon="fa-headphones" HintText="僅供參考"
                DataField="AudioUrl" ContainerClass="@InvalidRing("AudioUrl")">
                <AudioUploadField AudioUrl="@AudioFileName"
                    AudioUrlChanged="v => { AudioFileName = v; AudioFileNameChanged.InvokeAsync(v); }" />
            </FormSectionCard>

            <FormSectionCard Title="語音內容" Icon="fa-microphone"
                DataField="ArticleContent" ContainerClass="@InvalidRing("ArticleContent")">
                <QuillField Value="@Passage" ValueChanged="v => { Passage = v; PassageChanged.InvokeAsync(v); }"
                    FieldLabel="語音內容" Placeholder="點擊此處開始輸入語音內容（逐字稿）..." />
            </FormSectionCard>
        </CascadingValue>
    }
    else
    {
        <FormSectionCard Title="聽力音檔" Icon="fa-headphones" HintText="可先命題，音檔之後再補上"
            DataField="AudioUrl" ContainerClass="@InvalidRing("AudioUrl")">
            <AudioUploadField AudioUrl="@AudioFileName"
                AudioUrlChanged="v => { AudioFileName = v; AudioFileNameChanged.InvokeAsync(v); }" />
        </FormSectionCard>

        <FormSectionCard Title="語音內容" Icon="fa-microphone" Required="true"
            DataField="ArticleContent" ContainerClass="@InvalidRing("ArticleContent")">
            <div class="mb-3 px-3 py-2 bg-amber-50 border border-amber-200 rounded-md text-sm flex items-start gap-2">
                <i class="fa-solid fa-circle-info text-amber-500 mt-0.5 flex-shrink-0"></i>
                <div class="text-xs leading-relaxed text-amber-700">
                    <span class="font-bold text-terracotta">聽力題組母題提醒</span>
                    — 母題不區分難度，僅需上傳音檔與語音內容。底下固定 2 個子題，各有獨立的難度、核心能力與細目指標。
                </div>
            </div>
            <QuillField Value="@Passage" ValueChanged="v => { Passage = v; PassageChanged.InvokeAsync(v); }" FieldLabel="語音內容" Placeholder="點擊此處開始輸入語音內容（逐字稿）..." />
        </FormSectionCard>
    }

    @* 修題「母題單元」視角（LockSubQuestions=true）：母題與每個子題是各自獨立的審題單元，
       開母題單元修題時子題一律唯讀（僅供上下文參考）；子題要修需從審修列表的子題列各自進入（focus 模式）。
       命題情境不傳 LockSubQuestions（預設 false），子題照常可編輯。
       SubReadOnly 同時餵給：① 子題區內「直接 markup」的 select ② 巢狀 CascadingValue → 子元件。 *@
    <CascadingValue Name="IsFormReadOnly" Value="@SubReadOnly" IsFixed="false">
    <FormSectionCard Title="子題區" Icon="fa-layer-group" HintText="固定 2 題">
        <div class="space-y-4">
            @for (int i = 0; i < SubQuestions.Count; i++)
            {
                var idx = i;
                var sq = SubQuestions[idx];
                var n = idx + 1;
                @* Focus 模式：只渲染被點開的子題；其他略過 *@
                if (IsFocusMode && sq.Id != FocusSubDbId!.Value) { continue; }
                var subLevelLabel = QuestionConstants.ListenLevelLabels.GetValueOrDefault(sq.FixedDifficulty, "");
                var coreKey      = $"ListenSub_{n}_CoreAbility";
                var indicatorKey = $"ListenSub_{n}_Indicator";
                var stemKey      = $"ListenSub_{n}_Stem";
                var analysisKey  = $"ListenSub_{n}_Analysis";
                var answerKey    = $"ListenSub_{n}_Answer";
                var optionAnyKey = new[] { $"ListenSub_{n}_Options_0", $"ListenSub_{n}_Options_1",
                                            $"ListenSub_{n}_Options_2", $"ListenSub_{n}_Options_3", answerKey };

                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    @* 子題標頭：第 N 題 + 子題碼（命題後配發） + 難度 badge *@
                    <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-main flex items-center gap-2">
                            第 @n 題
                            @if (!string.IsNullOrWhiteSpace(ParentQuestionCode))
                            {
                                <span class="text-xs text-gray-400 font-normal font-mono">@QuestionCodeHelper.SubCode(ParentQuestionCode, n)</span>
                            }
                        </span>
                        <span class="px-2 py-0.5 rounded bg-blue-50 text-blue-600 text-xs font-bold">@subLevelLabel</span>
                    </div>
                    <div class="p-4 space-y-4">
                        @* 核心能力 + 細目指標 *@
                        <div class="grid grid-cols-2 gap-3">
                            <div data-field="@coreKey" class="@InvalidRing(coreKey) rounded-lg p-1">
                                <label class="block text-xs font-medium text-gray-600 mb-1">核心能力 <span class="text-red-400">*</span></label>
                                <select @bind="sq.CoreAbility" @bind:after="() => OnSubCoreAbilityChanged(sq)"
                                    disabled="@SubReadOnly"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed">
                                    <option value="">請選擇</option>
                                    @if (QuestionConstants.ListenGroupSubFixedDifficultyCoreAbilityMap.TryGetValue(sq.FixedDifficulty, out var allowedAbilities))
                                    {
                                        @foreach (var ab in allowedAbilities)
                                        {
                                            <option value="@ab">@QuestionConstants.CoreAbilityLabels.GetValueOrDefault(ab, "")</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div data-field="@indicatorKey" class="@InvalidRing(indicatorKey) rounded-lg p-1">
                                <label class="block text-xs font-medium text-gray-600 mb-1">細目指標 <span class="text-red-400">*</span></label>
                                <select @bind="sq.DetailIndicator"
                                    class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-morandi bg-white cursor-pointer disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed @(sq.CoreAbility is null ? "bg-gray-50 text-gray-300" : "")"
                                    disabled="@(SubReadOnly || sq.CoreAbility is null)">
                                    <option value="">@(sq.CoreAbility is null ? "先選核心能力" : "請選擇")</option>
                                    @if (sq.CoreAbility is not null && QuestionConstants.CoreAbilityIndicatorMap.TryGetValue(sq.CoreAbility.Value, out var indicators))
                                    {
                                        @foreach (var ind in indicators)
                                        {
                                            <option value="@ind">@QuestionConstants.DetailIndicatorLabels.GetValueOrDefault(ind, "")</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        @* 題目內容 *@
                        <div data-field="@stemKey" class="@InvalidRing(stemKey) rounded-lg p-1">
                            <label class="block text-sm font-bold text-gray-700 mb-2">
                                題目內容 <span class="text-red-400">*</span>
                            </label>
                            <QuillField Value="@sq.Stem" ValueChanged="v => { sq.Stem = v; SubQuestionsChanged.InvokeAsync(SubQuestions); }" FieldLabel="@($"第 {n} 題 題目內容")"
                                Placeholder="點擊此處開始編輯題目內容..." />
                            <QuestionImagesField Images="SubStemImages(idx)"
                                ImagesChanged="upd => ApplyImageChange(QuestionImageField.Stem, idx, upd)" />
                        </div>

                        @* 選項與答案 *@
                        <div data-field="@answerKey" class="@InvalidRingAny(optionAnyKey) rounded-lg p-1">
                            <label class="block text-sm font-bold text-gray-700 mb-2">
                                <i class="fa-solid fa-list-ol text-morandi"></i> 選項與答案 <span class="text-red-400">*</span>
                            </label>
                            <OptionGroup Options="@sq.Options" OptionsChanged="v => SubQuestionsChanged.InvokeAsync(SubQuestions)"
                                Answer="@sq.Answer" AnswerChanged="v => { sq.Answer = v; SubQuestionsChanged.InvokeAsync(SubQuestions); }"
                                RadioName="@($"lg-answer-{idx}")" Layout="OptionGroup.OptionLayout.Vertical"
                                EnableImages="true"
                                OptionImages="SubOptionImagesByLetter(idx)"
                                OptionImageChanged="e => OnSubOptionImagesChanged(idx, e)" />
                        </div>

                        @* 試題解析（樣式對齊一般單選題：lightbulb 琥珀色 + 標題與 hint 分層） *@
                        <div data-field="@analysisKey" class="@InvalidRing(analysisKey) rounded-lg p-1">
                            <label class="text-sm font-bold text-gray-700 flex items-center gap-2 mb-2">
                                <i class="fa-solid fa-lightbulb text-amber-500"></i>
                                <span>試題解析</span>
                                <span class="text-red-400">*</span>
                                <span class="text-xs text-gray-400 font-normal">紀錄答案理由</span>
                            </label>
                            <QuillField Value="@sq.Analysis" ValueChanged="v => { sq.Analysis = v; SubQuestionsChanged.InvokeAsync(SubQuestions); }"
                                FieldLabel="@($"第 {n} 題 試題解析")"
                                Placeholder="請輸入解析內容，可說明正確答案依據與其他選項錯誤原因..." />
                        </div>
                    </div>
                </div>
            }
        </div>
    </FormSectionCard>
    </CascadingValue>
</div>

@code {
    [Parameter] public string AudioFileName { get; set; } = "";
    [Parameter] public EventCallback<string> AudioFileNameChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public List<ListenGroupSubQuestion> SubQuestions { get; set; }
        = [new() { FixedDifficulty = 3 }, new() { FixedDifficulty = 4 }];
    [Parameter] public EventCallback<List<ListenGroupSubQuestion>> SubQuestionsChanged { get; set; }

    /// <summary>母題編號（Q-{Year}-{NNNNN}），用於在子題卡頭顯示子題碼。新題尚未配發碼時可為空字串。</summary>
    [Parameter] public string ParentQuestionCode { get; set; } = "";

    /// <summary>題目附圖（子題層級：FieldType=Stem 或 OptionA-D + SubQuestionIndex=0/1）。母題的音檔/語音內容不支援圖。</summary>
    [Parameter] public List<QuestionImage> Images { get; set; } = [];
    [Parameter] public EventCallback<List<QuestionImage>> ImagesChanged { get; set; }

    /// <summary>由父層傳入的驗證失敗欄位集合。</summary>
    [Parameter] public HashSet<string>? InvalidFields { get; set; }

    /// <summary>
    /// Focus 模式：當 RevisionSlideOver 從子題列開啟時傳入該子題 DB Id。
    /// 設定後：只渲染對應子題、母題音檔/語音內容變唯讀。
    /// </summary>
    [Parameter] public int? FocusSubDbId { get; set; }

    /// <summary>
    /// 修題「母題單元」視角：母題與子題各為獨立審題單元，開母題單元修題時子題一律唯讀。
    /// 由 RevisionSlideOver 在 SubQuestionId 為 null（母題單元）時傳 true；命題情境維持 false。
    /// 與 IsFocusMode 互斥（focus 模式只渲染單一子題、用於子題單元修題）。
    /// </summary>
    [Parameter] public bool LockSubQuestions { get; set; }

    /// <summary>由父層（QuestionForm Modal）透過 CascadingValue 傳入，檢視模式時所有子題控件變唯讀。</summary>
    [CascadingParameter(Name = "IsFormReadOnly")] private bool IsFormReadOnly { get; set; }

    private bool IsFocusMode => FocusSubDbId is not null;

    /// <summary>子題區實際唯讀旗標：父層唯讀（檢視）或母題單元修題鎖子題時為 true。</summary>
    private bool SubReadOnly => IsFormReadOnly || LockSubQuestions;

    private int FocusSubOrder =>
        FocusSubDbId is int id ? SubQuestions.FindIndex(s => s.Id == id) + 1 : 0;

    private string InvalidRing(string fieldKey) =>
        InvalidFields?.Contains(fieldKey) == true ? "ring-2 ring-red-400" : "";

    private string InvalidRingAny(IEnumerable<string> keys) =>
        keys.Any(k => InvalidFields?.Contains(k) == true) ? "ring-2 ring-red-400" : "";

    private void OnSubCoreAbilityChanged(ListenGroupSubQuestion sq)
    {
        sq.DetailIndicator = null;
    }

    // ------------------------------------------------------------------
    //  附圖切片：子題層級 (SubQuestionIndex = idx)
    // ------------------------------------------------------------------

    private static QuestionImageField OptionFieldFor(int idx) =>
        (QuestionImageField)((byte)QuestionImageField.OptionA + idx);

    private List<QuestionImage> ImagesOf(QuestionImageField fieldType, int subIdx) =>
        Images.Where(i => i.FieldType == (byte)fieldType && i.SubQuestionIndex == subIdx)
              .OrderBy(i => i.SortOrder).ToList();

    private List<QuestionImage> SubStemImages(int subIdx) =>
        ImagesOf(QuestionImageField.Stem, subIdx);

    private List<List<QuestionImage>> SubOptionImagesByLetter(int subIdx) =>
        Enumerable.Range(0, 4).Select(j => ImagesOf(OptionFieldFor(j), subIdx)).ToList();

    private async Task ApplyImageChange(QuestionImageField fieldType, int? subIdx, List<QuestionImage> updated)
    {
        var others = Images.Where(i => !(i.FieldType == (byte)fieldType && i.SubQuestionIndex == subIdx)).ToList();
        for (int i = 0; i < updated.Count; i++)
        {
            updated[i].FieldType = (byte)fieldType;
            updated[i].SubQuestionIndex = subIdx;
            updated[i].SortOrder = (byte)(i + 1);
        }
        others.AddRange(updated);
        Images = others;
        await ImagesChanged.InvokeAsync(others);
    }

    private async Task OnSubOptionImagesChanged(int subIdx, (int Index, List<QuestionImage> Updated) e)
    {
        await ApplyImageChange(OptionFieldFor(e.Index), subIdx, e.Updated);
    }
}
