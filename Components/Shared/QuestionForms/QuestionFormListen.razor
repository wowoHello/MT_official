@* ====================================================================== *@
@*  QuestionFormListen — 聽力測驗 命題表單                                  *@
@*  結構：音檔上傳 + 題幹（Quill）+ 四選項（A-D）+ 解析（Quill）           *@
@*  屬性側欄：音檔類型 + 語料素材                                           *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-6 lg:p-8 pb-16 max-w-4xl mx-auto space-y-6 min-h-full">

    <!-- 聽力音檔上傳 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-headphones text-purple-500"></i> 聽力音檔 <span class="text-red-400">*</span>
        </label>
        <div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-morandi hover:bg-morandi/5 transition-all cursor-pointer group">
            @if (string.IsNullOrEmpty(AudioFileName))
            {
                <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-300 group-hover:text-morandi mb-2 transition-colors"></i>
                <p class="text-sm text-gray-400 group-hover:text-gray-600">點擊或拖曳音檔至此上傳</p>
                <p class="text-xs text-gray-300 mt-1">支援 MP3、WAV、OGG 格式，檔案大小上限 10MB</p>
            }
            else
            {
                <div class="flex items-center justify-center gap-3">
                    <i class="fa-solid fa-file-audio text-2xl text-morandi"></i>
                    <span class="text-sm font-medium text-slate-main">@AudioFileName</span>
                    <button type="button" @onclick="() => { AudioFileName = string.Empty; }"
                        class="text-xs text-red-400 hover:text-red-600 ml-2">
                        <i class="fa-solid fa-xmark"></i> 移除
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- 題幹 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-file-lines text-morandi"></i> 題幹 <span class="text-red-400">*</span>
        </label>
        <QuillEditor @bind-Value="Stem" FieldLabel="題幹" Placeholder="請輸入題幹內容..." />
    </div>

    <!-- 選項與答案 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-3 flex items-center gap-2">
            <i class="fa-solid fa-list-ol text-morandi"></i> 選項與答案 <span class="text-red-400">*</span>
            <span class="text-xs text-gray-400 font-normal ml-1">（請點選正確答案）</span>
        </label>
        <div class="mb-3 px-4 py-2.5 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-700 flex items-center gap-2">
            <i class="fa-solid fa-triangle-exclamation text-amber-500 flex-shrink-0"></i>
            請避免選項長短、語氣明顯差異，以免影響鑑別度。
        </div>
        <div class="space-y-3">
            @for (int i = 0; i < 4; i++)
            {
                var idx = i;
                var optLabel = OptionLabels[idx];
                <div class="flex items-start gap-3 group">
                    <label class="flex items-center gap-2 mt-3 cursor-pointer flex-shrink-0">
                        <input type="radio" name="@($"listen-answer-{Id}")" value="@optLabel"
                            checked="@(Answer == optLabel)"
                            @onchange="() => { Answer = optLabel; AnswerChanged.InvokeAsync(optLabel); }"
                            class="w-4 h-4 text-sage focus:ring-sage cursor-pointer">
                        <span class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold @(Answer == optLabel ? "bg-sage text-white" : "bg-gray-100 text-gray-500 group-hover:bg-gray-200") transition-colors">
                            @optLabel
                        </span>
                    </label>
                    <div class="flex-grow">
                        <QuillEditor @bind-Value="Options[idx]" FieldLabel="@($"選項 ({optLabel})")" Placeholder="@($"選項 ({optLabel})")" />
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- 解析 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-lightbulb text-amber-500"></i> 解析
        </label>
        <QuillEditor @bind-Value="Analysis" FieldLabel="解析" Placeholder="請輸入解析內容（選填）..." />
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("N")[..8];

    [Parameter] public string AudioFileName { get; set; } = "";
    [Parameter] public EventCallback<string> AudioFileNameChanged { get; set; }

    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string[] Options { get; set; } = ["", "", "", ""];
    [Parameter] public EventCallback<string[]> OptionsChanged { get; set; }

    [Parameter] public string Answer { get; set; } = "";
    [Parameter] public EventCallback<string> AnswerChanged { get; set; }

    [Parameter] public string Analysis { get; set; } = "";
    [Parameter] public EventCallback<string> AnalysisChanged { get; set; }

    private static readonly string[] OptionLabels = ["A", "B", "C", "D"];
}
