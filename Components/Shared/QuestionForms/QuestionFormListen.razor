@* ====================================================================== *@
@*  QuestionFormListen — 聽力測驗 命題表單                                  *@
@*  結構：音檔上傳 + 題幹（Quill）+ 四選項（A-D 2×2）+ 解析（Quill）       *@
@*  屬性側欄：核心能力（等級連動）+ 細目指標 + 語音類型 + 素材分類          *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-5 lg:p-6 pb-16 max-w-4xl mx-auto space-y-4 min-h-full">

    <FormSectionCard Title="聽力音檔" Icon="fa-headphones" Required="true">
        <div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center hover:border-morandi hover:bg-morandi/5 transition-all cursor-pointer group">
            @if (string.IsNullOrEmpty(AudioFileName))
            {
                <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-300 group-hover:text-morandi mb-2 transition-colors"></i>
                <p class="text-sm text-gray-400 group-hover:text-gray-600">點擊或拖曳音檔至此上傳</p>
                <p class="text-xs text-gray-300 mt-1">支援 MP3、WAV、OGG 格式，檔案大小上限 10MB</p>
            }
            else
            {
                <div class="flex items-center justify-center gap-3">
                    <i class="fa-solid fa-file-audio text-2xl text-morandi"></i>
                    <span class="text-sm font-medium text-slate-main">@AudioFileName</span>
                    <button type="button" @onclick="() => { AudioFileName = string.Empty; }"
                        class="text-xs text-red-400 hover:text-red-600 ml-2 cursor-pointer">
                        <i class="fa-solid fa-xmark"></i> 移除
                    </button>
                </div>
            }
        </div>
    </FormSectionCard>

    <FormSectionCard Title="題幹" Icon="fa-pen" Required="true">
        <QuillField Value="@Stem" ValueChanged="v => { Stem = v; StemChanged.InvokeAsync(v); }" FieldLabel="題幹" Placeholder="點擊此處開始編輯題幹內容..." />
    </FormSectionCard>

    <FormSectionCard Title="選項與答案" Icon="fa-list-ol" Required="true" HintText="請點選正確答案">
        <OptionGroup Options="@Options" OptionsChanged="OptionsChanged"
            Answer="@Answer" AnswerChanged="AnswerChanged"
            RadioName="@($"listen-answer-{Id}")" Layout="OptionGroup.OptionLayout.Grid" />
    </FormSectionCard>

    <FormSectionCard Title="試題解析" Icon="fa-lightbulb" IconColor="text-amber-500" Required="true" HintText="紀錄答案理由">
        <QuillField Value="@Analysis" ValueChanged="v => { Analysis = v; AnalysisChanged.InvokeAsync(v); }" FieldLabel="解析" Placeholder="點擊此處開始編輯解析，可說明正確答案依據與其他選項錯誤原因..." />
    </FormSectionCard>
</div>

@code {
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("N")[..8];

    [Parameter] public string AudioFileName { get; set; } = "";
    [Parameter] public EventCallback<string> AudioFileNameChanged { get; set; }

    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string[] Options { get; set; } = ["", "", "", ""];
    [Parameter] public EventCallback<string[]> OptionsChanged { get; set; }

    [Parameter] public string Answer { get; set; } = "";
    [Parameter] public EventCallback<string> AnswerChanged { get; set; }

    [Parameter] public string Analysis { get; set; } = "";
    [Parameter] public EventCallback<string> AnalysisChanged { get; set; }

}
