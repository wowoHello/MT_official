@* ====================================================================== *@
@*  QuestionFormListen — 聽力測驗 命題表單                                  *@
@*  結構：音檔上傳 + 題目（Quill）+ 內容（Quill，語音逐字稿）              *@
@*        + 四選項（A-D 2×2）+ 解析（Quill）                                *@
@*  屬性側欄：核心能力（等級連動）+ 細目指標 + 語音類型 + 素材分類          *@
@*  ※「內容」對應 MT_Questions.ArticleContent（DB 註解「文章/語音內容」）  *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-5 lg:p-6 pb-16 max-w-4xl mx-auto space-y-4 min-h-full">

    <FormSectionCard Title="聽力音檔" Icon="fa-headphones" HintText="可先命題，音檔之後再補上"
        DataField="AudioUrl" ContainerClass="@InvalidRing("AudioUrl")">
        <AudioUploadField AudioUrl="@AudioFileName"
            AudioUrlChanged="v => { AudioFileName = v; AudioFileNameChanged.InvokeAsync(v); }" />
    </FormSectionCard>

    <FormSectionCard Title="題目" Icon="fa-pen" Required="true"
        DataField="Stem" ContainerClass="@InvalidRing("Stem")">
        <QuillField Value="@Stem" ValueChanged="v => { Stem = v; StemChanged.InvokeAsync(v); }" FieldLabel="題目" Placeholder="點擊此處開始編輯題目內容..." />
    </FormSectionCard>

    <FormSectionCard Title="內容" Icon="fa-align-left" HintText="語音逐字稿或補充說明（選填）"
        DataField="ArticleContent" ContainerClass="@InvalidRing("ArticleContent")">
        <QuillField Value="@ArticleContent" ValueChanged="v => { ArticleContent = v; ArticleContentChanged.InvokeAsync(v); }" FieldLabel="內容" Placeholder="點擊此處輸入語音逐字稿或補充內容..." />
    </FormSectionCard>

    <FormSectionCard Title="選項與答案" Icon="fa-list-ol" Required="true" HintText="請點選正確答案"
        DataField="@OptionsFieldKey" ContainerClass="@InvalidRingAny(OptionsAndAnswerKeys)">
        <OptionGroup Options="@Options" OptionsChanged="OptionsChanged"
            Answer="@Answer" AnswerChanged="AnswerChanged"
            RadioName="@($"listen-answer-{Id}")" Layout="OptionGroup.OptionLayout.Vertical"
            EnableImages="true"
            OptionImages="OptionImagesByLetter"
            OptionImageChanged="OnOptionImagesChanged" />
    </FormSectionCard>

    <FormSectionCard Title="試題解析" Icon="fa-lightbulb" IconColor="text-amber-500" Required="true" HintText="紀錄答案理由"
        DataField="Analysis" ContainerClass="@InvalidRing("Analysis")">
        <QuillField Value="@Analysis" ValueChanged="v => { Analysis = v; AnalysisChanged.InvokeAsync(v); }" FieldLabel="解析" Placeholder="點擊此處開始編輯解析，可說明正確答案依據與其他選項錯誤原因..." />
    </FormSectionCard>
</div>

@code {
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString("N")[..8];

    [Parameter] public string AudioFileName { get; set; } = "";
    [Parameter] public EventCallback<string> AudioFileNameChanged { get; set; }

    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    /// <summary>語音逐字稿/補充內容（對應 MT_Questions.ArticleContent）。</summary>
    [Parameter] public string ArticleContent { get; set; } = "";
    [Parameter] public EventCallback<string> ArticleContentChanged { get; set; }

    [Parameter] public string[] Options { get; set; } = ["", "", "", ""];
    [Parameter] public EventCallback<string[]> OptionsChanged { get; set; }

    [Parameter] public string Answer { get; set; } = "";
    [Parameter] public EventCallback<string> AnswerChanged { get; set; }

    [Parameter] public string Analysis { get; set; } = "";
    [Parameter] public EventCallback<string> AnalysisChanged { get; set; }

    /// <summary>題目附圖（母題層級，FieldType 2~5 = OptionA~D。題幹保持文字、解析不支援圖）。</summary>
    [Parameter] public List<QuestionImage> Images { get; set; } = [];
    [Parameter] public EventCallback<List<QuestionImage>> ImagesChanged { get; set; }

    /// <summary>由父層傳入的驗證失敗欄位集合。</summary>
    [Parameter] public HashSet<string>? InvalidFields { get; set; }

    private static readonly string[] OptionsAndAnswerKeys =
        ["Options_0", "Options_1", "Options_2", "Options_3", "Answer"];

    private string OptionsFieldKey =>
        OptionsAndAnswerKeys.FirstOrDefault(k => InvalidFields?.Contains(k) == true)
        ?? "Options_0";

    private string InvalidRing(string fieldKey) =>
        InvalidFields?.Contains(fieldKey) == true ? "ring-2 ring-red-400" : "";

    private string InvalidRingAny(IEnumerable<string> keys) =>
        keys.Any(k => InvalidFields?.Contains(k) == true) ? "ring-2 ring-red-400" : "";

    // ------------------------------------------------------------------
    //  選項附圖切片：A=2 / B=3 / C=4 / D=5（母題層級，SubQuestionIndex=null）
    // ------------------------------------------------------------------

    private static QuestionImageField OptionFieldFor(int idx) =>
        (QuestionImageField)((byte)QuestionImageField.OptionA + idx);

    private List<QuestionImage> ImagesOf(QuestionImageField fieldType) =>
        Images.Where(i => i.FieldType == (byte)fieldType && i.SubQuestionIndex == null)
              .OrderBy(i => i.SortOrder).ToList();

    private List<List<QuestionImage>> OptionImagesByLetter =>
        Enumerable.Range(0, 4).Select(idx => ImagesOf(OptionFieldFor(idx))).ToList();

    private async Task OnOptionImagesChanged((int Index, List<QuestionImage> Updated) e)
    {
        var fieldType = OptionFieldFor(e.Index);
        var others = Images.Where(i => !(i.FieldType == (byte)fieldType && i.SubQuestionIndex == null)).ToList();
        for (int i = 0; i < e.Updated.Count; i++)
        {
            e.Updated[i].FieldType = (byte)fieldType;
            e.Updated[i].SubQuestionIndex = null;
            e.Updated[i].SortOrder = (byte)(i + 1);
        }
        others.AddRange(e.Updated);
        Images = others;
        await ImagesChanged.InvokeAsync(others);
    }
}
