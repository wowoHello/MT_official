@* ====================================================================== *@
@*  QuestionFormReadGroup — 閱讀題組 命題表單                               *@
@*  結構：標題（Quill）+ 文章內容（Quill）+ N 個子題（題幹+ABCD+解析）     *@
@*  屬性側欄：文體（文言文 / 應用文 / 語體文）                              *@
@* ====================================================================== *@
@using MT.Components.Shared

<div class="p-6 lg:p-8 pb-16 max-w-4xl mx-auto space-y-6 min-h-full">

    <!-- 標題 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-heading text-morandi"></i> 題組標題 <span class="text-red-400">*</span>
        </label>
        <QuillEditor @bind-Value="Stem" FieldLabel="題組標題" Placeholder="請輸入題組標題..." />
    </div>

    <!-- 文章內容 -->
    <div>
        <label class="block text-sm font-bold text-gray-700 mb-2 flex items-center gap-2">
            <i class="fa-solid fa-book-open text-sage"></i> 文章內容 <span class="text-red-400">*</span>
        </label>
        <p class="text-xs text-gray-400 mb-2"><i class="fa-solid fa-circle-info mr-1"></i>母題需要標題與文章內容，兩者皆為必填。</p>
        <QuillEditor @bind-Value="Passage" FieldLabel="文章內容" Placeholder="請輸入閱讀文章..." />
    </div>

    <!-- 子題列表 -->
    <div>
        <div class="flex items-center justify-between mb-3">
            <label class="text-sm font-bold text-gray-700 flex items-center gap-2">
                <i class="fa-solid fa-list-check text-terracotta"></i> 子題 <span class="text-red-400">*</span>
                <span class="text-xs text-gray-400 font-normal">（共 @SubQuestions.Count 題）</span>
            </label>
            <button type="button" @onclick="AddSubQuestion"
                class="px-3 py-1 text-xs font-bold text-sage bg-sage/10 rounded-lg hover:bg-sage/20 transition-colors cursor-pointer">
                <i class="fa-solid fa-plus mr-1"></i> 新增子題
            </button>
        </div>

        <div class="space-y-4">
            @for (int i = 0; i < SubQuestions.Count; i++)
            {
                var idx = i;
                var sq = SubQuestions[idx];
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-main">第 @(idx + 1) 題</span>
                        @if (SubQuestions.Count > 1)
                        {
                            <button type="button" @onclick="() => RemoveSubQuestion(idx)"
                                class="text-xs text-red-400 hover:text-red-600 transition-colors cursor-pointer">
                                <i class="fa-solid fa-trash-can mr-0.5"></i> 刪除
                            </button>
                        }
                    </div>
                    <div class="p-4 space-y-4">
                        <!-- 子題題幹 -->
                        <QuillEditor @bind-Value="sq.Stem" FieldLabel="@($"子題 {idx + 1} 題幹")" Placeholder="請輸入子題題幹..." />

                        <!-- 子題選項 A-D -->
                        <div class="space-y-2">
                            @for (int j = 0; j < 4; j++)
                            {
                                var optIdx = j;
                                var optLabel = OptionLabels[optIdx];
                                <div class="flex items-start gap-2 group">
                                    <label class="flex items-center gap-1.5 mt-2.5 cursor-pointer flex-shrink-0">
                                        <input type="radio" name="@($"sub-answer-{idx}")" value="@optLabel"
                                            checked="@(sq.Answer == optLabel)"
                                            @onchange="() => sq.Answer = optLabel"
                                            class="w-3.5 h-3.5 text-sage focus:ring-sage cursor-pointer">
                                        <span class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold @(sq.Answer == optLabel ? "bg-sage text-white" : "bg-gray-100 text-gray-500") transition-colors">
                                            @optLabel
                                        </span>
                                    </label>
                                    <div class="flex-grow">
                                        <QuillEditor @bind-Value="sq.Options[optIdx]" FieldLabel="@($"子題 {idx + 1} 選項 ({optLabel})")" Placeholder="@($"選項 ({optLabel})")" />
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- 子題解析 -->
                        <QuillEditor @bind-Value="sq.Analysis" FieldLabel="@($"子題 {idx + 1} 解析")" Placeholder="解析（選填）..." />
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public List<SubQuestionChoice> SubQuestions { get; set; } = [new()];
    [Parameter] public EventCallback<List<SubQuestionChoice>> SubQuestionsChanged { get; set; }

    private static readonly string[] OptionLabels = ["A", "B", "C", "D"];

    private void AddSubQuestion()
    {
        SubQuestions.Add(new SubQuestionChoice());
    }

    private void RemoveSubQuestion(int idx)
    {
        if (SubQuestions.Count > 1)
            SubQuestions.RemoveAt(idx);
    }

    public class SubQuestionChoice
    {
        public string Stem { get; set; } = "";
        public string[] Options { get; set; } = ["", "", "", ""];
        public string Answer { get; set; } = "";
        public string Analysis { get; set; } = "";
    }
}
