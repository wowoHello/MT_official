@* ====================================================================== *@
@*  QuestionFormReadGroup — 閱讀題組 命題表單                               *@
@*  結構：標題（Quill）+ 文章內容（Quill）+ N 個子題（題目內容+ABCD+解析） *@
@*  屬性側欄：文體（文言文 / 應用文 / 語體文）                              *@
@* ====================================================================== *@
@using MT.Components.Shared
@inject IJSRuntime JS

<div class="p-5 lg:p-6 pb-16 max-w-4xl mx-auto space-y-4 min-h-full">

    <FormSectionCard Title="標題" Icon="fa-pen" Required="true"
        DataField="Stem" ContainerClass="@InvalidRing("Stem")">
        <QuillField Value="@Stem" ValueChanged="v => { Stem = v; StemChanged.InvokeAsync(v); }" FieldLabel="標題" Placeholder="點擊此處開始編輯標題..." />
    </FormSectionCard>

    <FormSectionCard Title="文章內容" Icon="fa-book-open" Required="true"
        DataField="ArticleContent" ContainerClass="@InvalidRing("ArticleContent")">
        <!-- 閱讀題組母題提醒 -->
        <div class="mb-3 px-3 py-2 bg-amber-50 border border-amber-200 rounded-md text-sm flex items-start gap-2">
            <i class="fa-solid fa-circle-info text-amber-500 mt-0.5 flex-shrink-0"></i>
            <div class="text-xs leading-relaxed text-amber-700">
                <span class="font-bold text-terracotta">閱讀題組母題提醒</span>
                — 母題包含「標題」與「文章內容」，兩者皆為必填；文章內容可附圖。子題再補上選項、答案與解析即可。
            </div>
        </div>
        <QuillField Value="@Passage" ValueChanged="v => { Passage = v; PassageChanged.InvokeAsync(v); }" FieldLabel="文章內容" Placeholder="點擊此處開始輸入文章內容..." />
    </FormSectionCard>

    <FormSectionCard Title="子題區" Icon="fa-layer-group" BodyClass="p-5">
        <HeaderRight>
            @if (Status == QuestionStatus.Draft)
            {
                <button type="button" @onclick="AddSubQuestion"
                    class="px-3 py-1.5 text-xs font-bold text-white bg-sage rounded-lg hover:bg-[#7a9a82] transition-colors cursor-pointer shadow-sm flex items-center gap-1">
                    <i class="fa-solid fa-plus"></i> 新增子題
                </button>
            }
        </HeaderRight>
        <ChildContent>
            <div class="space-y-4">
            @for (int i = 0; i < SubQuestions.Count; i++)
            {
                var idx = i;
                var sq = SubQuestions[idx];
                var n = idx + 1;
                var stemKey     = $"ReadSub_{n}_Stem";
                var analysisKey = $"ReadSub_{n}_Analysis";
                var answerKey   = $"ReadSub_{n}_Answer";
                var optionAnyKey = new[] { $"ReadSub_{n}_Options_0", $"ReadSub_{n}_Options_1",
                                            $"ReadSub_{n}_Options_2", $"ReadSub_{n}_Options_3", answerKey };
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <!-- 子題標頭 -->
                    <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-main">第 @n 題</span>
                        @* 刪除子題僅在草稿狀態開放；命題完成後鎖定，避免送審/審題流程斷鏈 *@
                        @if (Status == QuestionStatus.Draft && SubQuestions.Count > 1)
                        {
                            <button type="button" @onclick="() => RemoveSubQuestion(idx)"
                                class="text-xs text-red-400 hover:text-red-600 transition-colors cursor-pointer flex items-center gap-1">
                                <i class="fa-solid fa-trash-can"></i> 刪除
                            </button>
                        }
                    </div>
                    <div class="p-4 space-y-4">
                        <!-- 題目內容 -->
                        <div data-field="@stemKey" class="@InvalidRing(stemKey) rounded-lg p-1">
                            <label class="block text-sm font-bold text-gray-700 mb-2">
                                題目內容 <span class="text-red-400">*</span>
                            </label>
                            <QuillField Value="@sq.Stem" ValueChanged="v => { sq.Stem = v; SubQuestionsChanged.InvokeAsync(SubQuestions); }" FieldLabel="@($"第 {n} 題 題目內容")"
                                Placeholder="點擊此處開始編輯題目內容，可插入圖片..." />
                        </div>

                        <!-- 選項與答案 -->
                        <div data-field="@answerKey" class="@InvalidRingAny(optionAnyKey) rounded-lg p-1">
                            <label class="block text-sm font-bold text-gray-700 mb-2">
                                <i class="fa-solid fa-list-ol text-morandi"></i> 選項與答案 <span class="text-red-400">*</span>
                            </label>
                            <OptionGroup Options="@sq.Options" OptionsChanged="v => SubQuestionsChanged.InvokeAsync(SubQuestions)"
                                Answer="@sq.Answer" AnswerChanged="v => { sq.Answer = v; SubQuestionsChanged.InvokeAsync(SubQuestions); }"
                                RadioName="@($"sub-answer-{idx}")" Layout="OptionGroup.OptionLayout.Grid" />
                        </div>

                        <!-- 試題解析 -->
                        <div data-field="@analysisKey" class="@InvalidRing(analysisKey) rounded-lg p-1">
                            <label class="block text-sm font-bold text-gray-700 mb-2">
                                試題解析（紀錄答案理由） <span class="text-red-400">*</span>
                            </label>
                            <QuillField Value="@sq.Analysis" ValueChanged="v => { sq.Analysis = v; SubQuestionsChanged.InvokeAsync(SubQuestions); }"
                                FieldLabel="@($"第 {n} 題 解析")"
                                Placeholder="點擊此處開始編輯解析，可說明正確答案依據與其他選項錯誤原因..." />
                        </div>
                    </div>
                </div>
            }
            </div>
        </ChildContent>
    </FormSectionCard>
</div>

@code {
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public EventCallback<string> StemChanged { get; set; }

    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public EventCallback<string> PassageChanged { get; set; }

    [Parameter] public List<SubQuestionChoice> SubQuestions { get; set; } = [new()];
    [Parameter] public EventCallback<List<SubQuestionChoice>> SubQuestionsChanged { get; set; }

    /// <summary>當前題目狀態，僅 Draft 開放刪除子題；其餘狀態（命題完成 / 送審後）按鈕隱藏</summary>
    [Parameter] public byte Status { get; set; } = QuestionStatus.Draft;

    /// <summary>由父層傳入的驗證失敗欄位集合。</summary>
    [Parameter] public HashSet<string>? InvalidFields { get; set; }

    private string InvalidRing(string fieldKey) =>
        InvalidFields?.Contains(fieldKey) == true ? "ring-2 ring-red-400" : "";

    private string InvalidRingAny(IEnumerable<string> keys) =>
        keys.Any(k => InvalidFields?.Contains(k) == true) ? "ring-2 ring-red-400" : "";

    private async Task AddSubQuestion()
    {
        var confirmed = await JS.InvokeAsync<bool>("swalInterop.confirm", new
        {
            title = "新增子題",
            text = $"確定要新增第 {SubQuestions.Count + 1} 題嗎？",
            icon = "question",
            showCancelButton = true,
            confirmButtonText = "新增",
            cancelButtonText = "取消",
            confirmButtonColor = "#8eab94"
        });
        if (confirmed)
        {
            SubQuestions.Add(new SubQuestionChoice());
        }
    }

    private async Task RemoveSubQuestion(int idx)
    {
        if (SubQuestions.Count <= 1) return;
        var confirmed = await JS.InvokeAsync<bool>("swalInterop.confirm", new
        {
            title = "刪除子題",
            text = $"確定要刪除第 {idx + 1} 題嗎？刪除後若要復原請聯繫管理員。",
            icon = "warning",
            showCancelButton = true,
            confirmButtonText = "確定刪除",
            cancelButtonText = "取消",
            confirmButtonColor = "#d98a6c"
        });
        if (confirmed)
        {
            SubQuestions.RemoveAt(idx);
        }
    }
}

