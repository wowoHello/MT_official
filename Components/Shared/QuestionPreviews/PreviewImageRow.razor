@* ====================================================================== *@
@*  PreviewImageRow — 考卷預覽用的附圖橫排                                  *@
@*                                                                          *@
@*  設計：                                                                  *@
@*    - 模擬考卷上「題幹下方夾圖」的閱讀感，比命題表單的縮圖大              *@
@*    - 多張：水平 flex + flex-wrap，自動換行                                *@
@*    - 點圖開新分頁看原圖（零 JS）                                          *@
@*    - 空清單則不渲染任何節點，不留白                                       *@
@* ====================================================================== *@

@if (Images is { Count: > 0 })
{
    <div class="my-3 flex flex-wrap gap-3">
        @foreach (var img in Images.OrderBy(i => i.SortOrder))
        {
            <a href="@img.ImagePath" target="_blank" rel="noopener"
               class="block border border-gray-200 rounded overflow-hidden bg-white hover:border-morandi transition-colors">
                <img src="@img.ImagePath" alt="附圖" loading="lazy"
                     class="max-h-48 max-w-full object-contain cursor-zoom-in" />
            </a>
        }
    </div>
}

@code {
    [Parameter] public List<QuestionImage>? Images { get; set; }
}
