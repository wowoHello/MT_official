@* 預覽：長文題目 — 模擬考生實際看到的試卷 *@
@using MT.Components.Shared.QuestionPreviews

<PreviewHeader QuestionType="長文題目" Level="@Level" Difficulty="@Difficulty" Tags="@Tags" />

<!-- 題號 + 題目 -->
<div class="flex items-baseline gap-3 mb-4 font-serif">
    <span class="text-xl font-bold text-gray-900 leading-none">1.</span>
    <div class="flex-1 prose prose-base max-w-none leading-relaxed text-gray-900">
        @if (HasContent(Stem))
        {
            @((MarkupString)Stem)
        }
        else
        {
            <p class="text-gray-400 italic text-sm font-sans">題目尚未填寫</p>
        }
    </div>
</div>

<!-- 文章內容（紙感引用樣式） -->
<PreviewPassage Content="@Passage" Label="文章內容" />

<!-- 作答區（模擬作答框） -->
<div class="mt-6 font-sans">
    <p class="text-xs font-bold text-gray-500 mb-2 tracking-wider">
        <i class="fa-regular fa-pen-to-square text-gray-400 mr-1"></i> 作答區
    </p>
    <div class="border border-gray-200 rounded-lg bg-gray-50/40 p-4 min-h-[160px] flex items-center justify-center text-xs text-gray-400 italic">
        本題為長文寫作，請於正式作答時於稿紙上撰寫文章。
    </div>
</div>

@code {
    [Parameter] public string Level { get; set; } = "";
    [Parameter] public string Difficulty { get; set; } = "";
    [Parameter] public Dictionary<string, string>? Tags { get; set; }
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public string Passage { get; set; } = "";

    private bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }
}
