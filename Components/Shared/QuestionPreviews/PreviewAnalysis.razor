@* 預覽共用：解析區塊（黃底） *@

<div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mt-4">
    <p class="font-bold text-yellow-700 text-sm mb-2">
        <i class="fa-solid fa-lightbulb mr-1"></i> @Label
    </p>
    <div class="prose prose-sm max-w-none text-gray-700 leading-relaxed">
        @if (HasContent(Content))
        {
            @((MarkupString)Content)
        }
        else
        {
            <p class="text-gray-400 italic">尚未填寫解析</p>
        }
    </div>
</div>

@code {
    [Parameter] public string Content { get; set; } = "";
    [Parameter] public string Label { get; set; } = "試題解析";

    private bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }
}
