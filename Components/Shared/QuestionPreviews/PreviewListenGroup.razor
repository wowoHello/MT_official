@* 預覽：聽力題組 — 模擬考生實際看到的試卷 *@
@using MT.Components.Shared.QuestionPreviews

<PreviewHeader QuestionType="聽力題組" HideLevel="true" Tags="@Tags" />

<!-- 音檔播放器 -->
<PreviewAudioSection AudioFileName="@AudioFileName" />

<!-- 語音內容（命題者預覽用，明顯標示「考生不可見」） -->
@if (HasContent(Passage))
{
    <details class="my-4 border border-amber-200 rounded-lg bg-amber-50/60 overflow-hidden">
        <summary class="px-4 py-2.5 cursor-pointer text-xs font-bold text-amber-700 flex items-center gap-1.5 hover:bg-amber-100/50 transition list-none font-sans">
            <i class="fa-solid fa-eye-slash text-amber-500"></i>
            語音內容（僅命題／審題者可見，考生不會看到）
            <i class="fa-solid fa-chevron-down ml-auto text-xs text-amber-500"></i>
        </summary>
        <div class="px-4 pb-3 pt-1">
            <div class="prose prose-sm max-w-none leading-relaxed text-gray-700 font-serif">
                @((MarkupString)Passage)
            </div>
        </div>
    </details>
}

<!-- 作答提示 -->
<p class="text-xs text-gray-500 italic mt-4 mb-2 font-sans">
    <i class="fa-solid fa-circle-info text-gray-400 mr-1"></i>請依據聆聽內容回答下列題目：
</p>

<!-- 子題（固定 2 題） -->
<div class="space-y-6 mt-2">
    @for (int i = 0; i < SubQuestions.Count; i++)
    {
        var idx = i;
        var sq = SubQuestions[idx];
        var num = idx + 1;
        var subStemImages = SubStemImagesOf(idx);
        <div class="@(idx > 0 ? "border-t border-gray-200 pt-5" : "")">
            <!-- 題號 + 題幹 -->
            <div class="flex items-baseline gap-3 mb-2 font-serif">
                <span class="text-lg font-bold text-gray-900 leading-none">@num.</span>
                <div class="flex-1 prose prose-base max-w-none leading-relaxed text-gray-900">
                    @if (HasContent(sq.Stem))
                    {
                        @((MarkupString)sq.Stem)
                    }
                    else if (subStemImages.Count == 0)
                    {
                        @* 文字與圖片都沒有才顯示佔位字 *@
                        <p class="text-gray-400 italic text-sm font-sans">子題題幹尚未填寫</p>
                    }
                </div>
            </div>
            <PreviewImageRow Images="subStemImages" />

            <PreviewChoiceOptions Options="@sq.Options" Answer="@sq.Answer"
                                  Images="@Images" SubQuestionIndex="idx" />
        </div>
    }
</div>

@code {
    [Parameter] public Dictionary<string, string>? Tags { get; set; }
    [Parameter] public string AudioFileName { get; set; } = "";
    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public List<SubQuestionData> SubQuestions { get; set; } = new();
    [Parameter] public List<QuestionImage> Images { get; set; } = [];

    public class SubQuestionData
    {
        public string Level { get; set; } = "";
        public string CoreAbility { get; set; } = "";
        public string DetailIndicator { get; set; } = "";
        public string Stem { get; set; } = "";
        public string[] Options { get; set; } = new string[4];
        public string Answer { get; set; } = "";
    }

    private List<QuestionImage> SubStemImagesOf(int subIdx) =>
        Images.Where(i => i.FieldType == (byte)QuestionImageField.Stem && i.SubQuestionIndex == subIdx)
              .OrderBy(i => i.SortOrder).ToList();

    private bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }
}
