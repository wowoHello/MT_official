@* 預覽：短文題組（題目 + 文章 + N子題自由作答） *@
@using MT.Components.Shared.QuestionPreviews

<PreviewHeader QuestionType="短文題組" Level="@Level" Difficulty="@Difficulty" Tags="@Tags" />

<div class="max-w-2xl mx-auto font-serif">
    <!-- 題目 -->
    @if (HasContent(Stem))
    {
        <div class="mb-4 prose prose-sm max-w-none leading-relaxed text-gray-800">
            @((MarkupString)Stem)
        </div>
    }

    <!-- 文章內容 -->
    <PreviewPassage Content="@Passage" />

    <!-- 子題 -->
    @for (int i = 0; i < SubQuestions.Count; i++)
    {
        var sq = SubQuestions[i];
        var num = i + 1;
        <div class="@(i > 0 ? "border-t border-gray-200 pt-5 mt-5" : "mt-6")">
            <div class="flex items-center gap-2 mb-3">
                <p class="font-bold text-gray-700">第 @num 題</p>
                @if (!string.IsNullOrEmpty(sq.Dimension))
                {
                    <span class="px-2 py-0.5 text-xs rounded-full bg-indigo-50 text-indigo-600 border border-indigo-200">
                        向度：@sq.Dimension
                    </span>
                }
                @if (!string.IsNullOrEmpty(sq.Indicator))
                {
                    <span class="px-2 py-0.5 text-xs rounded-full bg-teal-50 text-teal-600 border border-teal-200">
                        指標：@sq.Indicator
                    </span>
                }
            </div>

            <div class="prose prose-sm max-w-none leading-relaxed text-gray-800 mb-3">
                @if (HasContent(sq.Stem))
                {
                    @((MarkupString)sq.Stem)
                }
                else
                {
                    <p class="text-gray-400">子題題幹尚未填寫</p>
                }
            </div>

            <!-- 自由作答區 -->
            <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 bg-gray-50/50 text-center text-sm text-gray-400">
                <i class="fa-solid fa-pen-to-square mr-1"></i> 自由作答區
            </div>
        </div>
    }

    @if (SubQuestions.Count == 0)
    {
        <p class="text-gray-400 italic mt-6 text-center">尚未新增子題</p>
    }
</div>

@code {
    [Parameter] public string Level { get; set; } = "";
    [Parameter] public string Difficulty { get; set; } = "";
    [Parameter] public Dictionary<string, string>? Tags { get; set; }
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public List<SubQuestionData> SubQuestions { get; set; } = new();

    public class SubQuestionData
    {
        public string Stem { get; set; } = "";
        public string Dimension { get; set; } = "";
        public string Indicator { get; set; } = "";

    }

    private bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }
}
