@* 預覽：短文題組 — 模擬考生實際看到的試卷 *@
@using MT.Components.Shared.QuestionPreviews

<PreviewHeader QuestionType="短文題組" Level="@Level" Difficulty="@Difficulty" Tags="@Tags" />

<!-- 文章內容（實際考卷格式：不顯示「題目」，直接顯示文章；含附圖） -->
<PreviewPassage Content="@Passage" Label="閱讀文章" Images="ArticleImages" FieldKey="article" />

<!-- 作答提示 -->
<p class="text-xs text-gray-500 italic mt-4 mb-2 font-sans">
    <i class="fa-solid fa-pen text-gray-400 mr-1"></i>請依據上方文章內容回答下列問題：
</p>

<!-- 子題 -->
<div class="space-y-6 mt-4">
    @for (int i = 0; i < SubQuestions.Count; i++)
    {
        @* idx = 原始母題中的 index（StartIndex 控制起始；子題聚焦時 caller 傳該子題真實 index）；
           num 顯示題號；data-annot-target 用 idx 對齊審題端容器命名 *@
        var idx = i + StartIndex;
        var sq = SubQuestions[i];
        var num = idx + 1;
        var subStemImages = SubStemImagesOf(idx);
        <div class="@(i > 0 ? "border-t border-gray-200 pt-5" : "")">
            <!-- 題號 + 題幹 -->
            <div class="flex items-baseline gap-3 mb-3 font-serif">
                <span class="text-lg font-bold text-gray-900 leading-none">@num.</span>
                <div class="flex-1 prose prose-base max-w-none leading-relaxed text-gray-900" data-annot-target="@($"subStem.{idx}")">
                    @if (HasContent(sq.Stem))
                    {
                        @((MarkupString)sq.Stem)
                    }
                    else if (subStemImages.Count == 0)
                    {
                        @* 文字與圖片都沒有時才顯示佔位字 *@
                        <p class="text-gray-400 italic text-sm font-sans">子題題幹尚未填寫</p>
                    }
                </div>
            </div>
            <PreviewImageRow Images="subStemImages" />

            <!-- 自由作答框 -->
            <div class="border border-gray-200 rounded-md bg-gray-50/40 p-3 min-h-[80px] flex items-center justify-center text-xs text-gray-400 italic font-sans">
                自由作答區（請於正式考試時於稿紙填寫答案）
            </div>

            <!-- 命題端 metadata（給命題者驗收，淡化處理） -->
            <div class="mt-2 pt-2 border-t border-dashed border-gray-200 flex flex-wrap items-center gap-2 text-xs font-sans">
                <span class="text-gray-400"><i class="fa-solid fa-key mr-1"></i>命題者參考：</span>
                <span class="inline-flex items-center rounded-full border border-morandi/15 bg-morandi/5 px-2 py-0.5 text-morandi/80">
                    主向度：@(string.IsNullOrWhiteSpace(sq.Dimension) ? "未設定" : sq.Dimension)
                </span>
                <span class="inline-flex items-center rounded-full border border-sage/15 bg-sage/5 px-2 py-0.5 text-sage">
                    能力指標：@(string.IsNullOrWhiteSpace(sq.Indicator) ? "未設定" : sq.Indicator)
                </span>
            </div>
        </div>
    }

    @if (SubQuestions.Count == 0 && !HideEmptyHint)
    {
        <p class="text-gray-400 italic mt-6 text-center text-sm font-sans">尚未新增子題</p>
    }
</div>

@code {
    [Parameter] public string Level { get; set; } = "";
    [Parameter] public string Difficulty { get; set; } = "";
    [Parameter] public Dictionary<string, string>? Tags { get; set; }
    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public List<SubQuestionData> SubQuestions { get; set; } = new();
    [Parameter] public List<QuestionImage> Images { get; set; } = [];

    /// <summary>
    /// 子題在原母題中的起始 index（用於子題聚焦模式正確顯示題號 + data-annot-target 對齊）。預設 0。
    /// </summary>
    [Parameter] public int StartIndex { get; set; } = 0;

    /// <summary>
    /// true 時隱藏「尚未新增子題」空狀態佔位字。
    /// 用於 Overview 母題模式：呼叫端故意傳空 SubQuestions 讓 Preview 只渲染文章區，
    /// 子題清單由呼叫端自行的 RenderSubIndexCards 渲染（避免空狀態文案與索引卡並存）。
    /// </summary>
    [Parameter] public bool HideEmptyHint { get; set; } = false;

    public class SubQuestionData
    {
        public string Stem { get; set; } = "";
        public string Dimension { get; set; } = "";
        public string Indicator { get; set; } = "";
    }

    private List<QuestionImage> ArticleImages =>
        Images.Where(i => i.FieldType == (byte)QuestionImageField.ArticleContent && i.SubQuestionIndex == null)
              .OrderBy(i => i.SortOrder).ToList();

    private List<QuestionImage> SubStemImagesOf(int subIdx) =>
        Images.Where(i => i.FieldType == (byte)QuestionImageField.Stem && i.SubQuestionIndex == subIdx)
              .OrderBy(i => i.SortOrder).ToList();

    private bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }
}
