@* 預覽：閱讀題組 — 模擬考生實際看到的試卷 *@
@using MT.Components.Shared.QuestionPreviews

<PreviewHeader QuestionType="閱讀題組" Level="@Level" Difficulty="@Difficulty" Tags="@Tags" />

<!-- 題組標題 -->
@if (HasContent(Stem))
{
    <h3 class="text-lg font-bold text-gray-900 mb-3 font-serif border-b border-gray-200 pb-2">
        @((MarkupString)Stem)
    </h3>
}
else
{
    <p class="text-gray-400 italic text-sm font-sans mb-3">標題尚未填寫</p>
}

<!-- 文章內容 -->
<PreviewPassage Content="@Passage" Label="閱讀文章" />

<!-- 作答提示 -->
<p class="text-xs text-gray-500 italic mt-4 mb-2 font-sans">
    <i class="fa-solid fa-circle-info text-gray-400 mr-1"></i>請依據上方文章作答下列題目：
</p>

<!-- 子題 -->
<div class="space-y-6 mt-4">
    @for (int i = 0; i < SubQuestions.Count; i++)
    {
        var sq = SubQuestions[i];
        var num = i + 1;
        <div class="@(i > 0 ? "border-t border-gray-200 pt-5" : "")">
            <!-- 題號 + 題幹 -->
            <div class="flex items-baseline gap-3 mb-2 font-serif">
                <span class="text-lg font-bold text-gray-900 leading-none">@num.</span>
                <div class="flex-1 prose prose-base max-w-none leading-relaxed text-gray-900">
                    @if (HasContent(sq.Stem))
                    {
                        @((MarkupString)sq.Stem)
                    }
                    else
                    {
                        <p class="text-gray-400 italic text-sm font-sans">子題題幹尚未填寫</p>
                    }
                </div>
            </div>

            <PreviewChoiceOptions Options="@sq.Options" Answer="@sq.Answer" />
        </div>
    }

    @if (SubQuestions.Count == 0)
    {
        <p class="text-gray-400 italic mt-6 text-center text-sm font-sans">尚未新增子題</p>
    }
</div>

@code {
    [Parameter] public string Level { get; set; } = "";
    [Parameter] public string Difficulty { get; set; } = "";
    [Parameter] public Dictionary<string, string>? Tags { get; set; }
    [Parameter] public string Stem { get; set; } = "";
    [Parameter] public string Passage { get; set; } = "";
    [Parameter] public List<SubQuestionData> SubQuestions { get; set; } = new();

    public class SubQuestionData
    {
        public string Stem { get; set; } = "";
        public string[] Options { get; set; } = new string[4];
        public string Answer { get; set; } = "";
    }

    private bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }
}
