@* 預覽：聽力測驗 — 模擬考生實際看到的試卷 *@
@using MT.Components.Shared.QuestionPreviews

<PreviewHeader QuestionType="聽力測驗" Level="@Level" Difficulty="@Difficulty" Tags="@Tags" />

<!-- 音檔播放器（仿真實考卷上方音檔框） -->
<PreviewAudioSection AudioFileName="@AudioFileName" />

<!-- 題號 + 題目（data-annot-target 給審題劃記用） -->
<div class="flex items-baseline gap-3 mb-3 mt-6 font-serif">
    <span class="text-xl font-bold text-gray-900 leading-none">1.</span>
    <div class="flex-1 prose prose-base max-w-none leading-relaxed text-gray-900" data-annot-target="stem">
        @if (HasContent(Stem))
        {
            @((MarkupString)Stem)
        }
        else
        {
            <p class="text-gray-400 italic text-sm font-sans">題目尚未填寫</p>
        }
    </div>
</div>

<!-- 內容區（語音逐字稿/補充內容；文字或圖片其一存在即渲染） -->
@if (HasContent(Content) || ArticleImages.Count > 0)
{
    <PreviewPassage Content="@Content" Label="內容" FieldKey="article" Images="ArticleImages" />
}

<!-- ABCD 選項（含每選項附圖，SubQuestionIndex=null 表母題層級） -->
<PreviewChoiceOptions Options="@Options" Answer="@Answer" Images="@Images"
                      HideOptionAnswerMarker="@HideOptionAnswerMarker" />

@code {
    [Parameter] public string Level { get; set; } = "";
    [Parameter] public string Difficulty { get; set; } = "";
    [Parameter] public Dictionary<string, string>? Tags { get; set; }
    [Parameter] public string AudioFileName { get; set; } = "";
    [Parameter] public string Stem { get; set; } = "";

    /// <summary>語音逐字稿/補充內容（對應 MT_Questions.ArticleContent）。</summary>
    [Parameter] public string Content { get; set; } = "";

    [Parameter] public string[] Options { get; set; } = new string[4];
    [Parameter] public string Answer { get; set; } = "";
    [Parameter] public List<QuestionImage> Images { get; set; } = [];

    /// <summary>透通至 PreviewChoiceOptions：唯讀／審題／審修情境傳 true 可隱藏選項上的正解標記。</summary>
    [Parameter] public bool HideOptionAnswerMarker { get; set; } = false;

    /// <summary>內容（語音逐字稿）的附圖切片（FieldType=6 ArticleContent，母題層級）。</summary>
    private List<QuestionImage> ArticleImages =>
        Images.Where(i => i.FieldType == (byte)QuestionImageField.ArticleContent && i.SubQuestionIndex == null)
              .OrderBy(i => i.SortOrder).ToList();

    private bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }
}
