@* ====================================================================== *@
@*  ReviewDecisionBar — 審題 Modal 底部決策按鈕列                              *@
@*  依當前 Assignment.Stage 與 IsDecided 狀態切換 5 種按鈕配置：                *@
@*    1. 互審：[儲存意見]                                                     *@
@*    2. 專審：[儲存草稿] + [改後採用] + [採用]                                  *@
@*    3. 總審：[儲存草稿] + [改後採用] + [不採用] + [採用]                        *@
@*    4. 總審第 3 次：[儲存草稿] + [編輯題目] + [不採用] + [採用]                  *@
@*    5. 已決策：唯讀提示列                                                   *@
@*  destructive-emphasis：「不採用」用 red-700 + 視覺隔離                      *@
@* ====================================================================== *@

<div class="h-16 flex-shrink-0 border-t-2 border-gray-200 bg-white px-6 flex items-center justify-between">

    @if (Assignment is null)
    {
        <p class="text-xs text-gray-400 italic">
            <i class="fa-solid fa-circle-info mr-1"></i> 此題目尚未分配給您
        </p>
        <button type="button" @onclick="OnRequestClose"
                class="px-5 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition cursor-pointer">
            關閉
        </button>
    }
    else if (IsHistorical)
    {
        @* 階段已結束 — 唯讀追蹤模式：保留歷程查看，移除所有編輯/決策按鈕 *@
        var stageName = Assignment.Stage switch
        {
            ReviewStage.Mutual => "交互審題",
            ReviewStage.Expert => "專家審題",
            ReviewStage.Final  => "總召審題",
            _                  => "審題"
        };
        <div class="flex items-center gap-3 text-sm text-slate-main font-medium">
            <i class="fa-solid fa-clock-rotate-left text-morandi text-xl"></i>
            <span>
                <strong class="text-morandi">@stageName</strong> 階段已結束 — 此處保留供您追蹤後續修題與其他審題者的評論
            </span>
        </div>
        <button type="button" @onclick="OnRequestClose"
                class="px-5 py-2 text-sm bg-morandi hover:bg-[#5a7a99] text-white rounded-lg font-bold transition cursor-pointer">
            關閉
        </button>
    }
    else if (Assignment.IsCompleted && !CanFinalReviewerEdit)
    {
        @* Completed 且尚未解鎖總召自編（ReturnCount < 3）：
           已退回、等命題老師修題 — 意見唯讀、決策按鈕不亮，僅顯示唯讀提示列 *@
        var (completedLabel, completedColor) = Assignment.Decision switch
        {
            ReviewDecision.Approve => ("採用",     "text-sage"),
            ReviewDecision.Revise  => ("已退回，等命題老師修題", "text-terracotta"),
            ReviewDecision.Reject  => ("已退回（不採用），等命題老師修題", "text-red-700"),
            _                      => ("已完成",   "text-gray-500")
        };
        <div class="flex items-center gap-2 text-sm text-slate-main font-medium">
            <i class="fa-solid fa-hourglass-half text-terracotta text-xl"></i>
            <span>
                審題決策已記錄：<strong class="@completedColor">@completedLabel</strong>
                @if (Assignment.DecidedAt.HasValue)
                {
                    <span class="text-xs text-gray-400 ml-1">（@Assignment.DecidedAt.Value.ToString("MM/dd HH:mm")）</span>
                }
            </span>
        </div>
        <button type="button" @onclick="OnRequestClose"
                class="px-5 py-2 text-sm bg-morandi hover:bg-[#5a7a99] text-white rounded-lg font-bold transition cursor-pointer">
            關閉
        </button>
    }
    else if (Assignment.IsCompleted && CanFinalReviewerEdit)
    {
        @* Completed + 解鎖（ReturnCount >= 3）：
           「編輯題目」解鎖按鈕 + 採用 / 不採用最終決策
           意見區已唯讀（ReviewActionPanel 由 ReviewModal 控制），此處不顯示儲存草稿 *@
        <div class="flex items-center gap-2 text-xs text-gray-500 mr-4 shrink-0">
            <i class="fa-solid fa-unlock text-terracotta"></i>
            <span class="text-terracotta font-bold">已退回 3 次，請直接修改題目並下最終裁決</span>
        </div>
        <div class="flex items-center gap-3">
            <button type="button"
                    disabled="@IsSubmitting"
                    @onclick="() => OnRequestEdit.InvokeAsync()"
                    class="px-5 py-2.5 bg-terracotta hover:bg-[#c87a5d] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("edit"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>開啟中…</span>
                }
                else
                {
                    <i class="fa-solid fa-pen-to-square mr-1.5"></i>
                    <span>編輯題目</span>
                }
            </button>
            <span class="w-px h-8 bg-gray-300 mx-1"></span>
            <button type="button"
                    disabled="@IsSubmitting"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Reject)"
                    class="px-5 py-2.5 bg-red-700 hover:bg-red-800 text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("reject"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-ban mr-1.5"></i>
                    <span>不採用</span>
                }
            </button>
            <button type="button"
                    disabled="@IsSubmitting"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Approve)"
                    class="px-6 py-2.5 bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("approve"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-check mr-1.5"></i>
                    <span>採用</span>
                }
            </button>
        </div>
    }
    else
    {
        @* Pending（IsCompleted=false）— 正常審題流程：可輸入意見、下決策 *@
        @* IsDecided 記錄先前評定（理論上 Pending 行應無 IsDecided，但防禦性顯示） *@
        @if (Assignment.IsDecided)
        {
            var (decLabel, decColor) = Assignment.Decision switch
            {
                ReviewDecision.Approve => ("採用",     "text-sage"),
                ReviewDecision.Revise  => ("改後採用", "text-terracotta"),
                ReviewDecision.Reject  => ("不採用",   "text-red-700"),
                _                      => ("—",       "text-gray-500")
            };
            <div class="flex items-center gap-2 text-xs text-gray-500 mr-4 shrink-0">
                <i class="fa-solid fa-clock-rotate-left text-morandi"></i>
                <span>
                    先前評定：<strong class="@decColor">@decLabel</strong>
                    <span class="text-gray-400">（@(Assignment.DecidedAt?.ToString("MM/dd HH:mm") ?? "—")）</span>
                </span>
            </div>
        }

        @switch (Assignment.Stage)
        {
            case ReviewStage.Mutual:
                @RenderMutualButtons
                break;
            case ReviewStage.Expert:
                @RenderExpertButtons
                break;
            case ReviewStage.Final:
                if (CanFinalReviewerEdit)
                {
                    @RenderFinalThirdButtons
                }
                else
                {
                    @RenderFinalButtons
                }
                break;
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public ReviewAssignmentInfo? Assignment { get; set; }
    [Parameter] public bool CanFinalReviewerEdit { get; set; }

    /// <summary>
    /// 該分配的階段已不是專案目前進行中的審題階段（如互審結束後、原 mutual reviewer 仍能查看）。
    /// true 時顯示「階段已結束」唯讀提示列，移除所有編輯/決策按鈕。
    /// </summary>
    [Parameter] public bool IsHistorical { get; set; }

    /// <summary>儲存意見草稿（不下決策）</summary>
    [Parameter] public EventCallback OnSaveDraft { get; set; }

    /// <summary>提交決策（傳入 Decision 值）</summary>
    [Parameter] public EventCallback<ReviewDecision> OnSubmitDecision { get; set; }

    /// <summary>總審第 3 次「編輯題目」— 跳出 Modal 開啟命題 Modal（Plan_006 才實作真正流程）</summary>
    [Parameter] public EventCallback OnRequestEdit { get; set; }

    /// <summary>關閉 Modal（已決策狀態下的「關閉」按鈕）</summary>
    [Parameter] public EventCallback OnRequestClose { get; set; }

    /// <summary>父層通知正在儲存中 → 所有按鈕 disable + spinner 顯示</summary>
    [Parameter] public bool IsSubmitting { get; set; }

    /// <summary>父層通知目前哪個按鈕觸發儲存（控制 spinner 位置）</summary>
    [Parameter] public string? PendingAction { get; set; }

    /// <summary>
    /// 父層傳入的當前意見內容（雙向綁在 ReviewActionPanel 的 commentDraft）。
    /// 用於決策按鈕的 disabled 判定：意見字數不足時禁用送出按鈕，避免空白決策。
    /// 「儲存意見草稿」按鈕不受此限制。
    /// </summary>
    [Parameter] public string Comment { get; set; } = string.Empty;

    /// <summary>意見最小字數（trim 後）。低於此字數時送出/決策按鈕被禁用。</summary>
    [Parameter] public int MinCommentLength { get; set; } = 10;

    private int CommentLength => (Comment ?? string.Empty).Trim().Length;
    private bool IsCommentTooShort => CommentLength < MinCommentLength;

    /// <summary>給 disabled 按鈕的 title 提示，說明為何被禁用。</summary>
    private string ShortCommentTooltip
        => $"意見需至少 {MinCommentLength} 字（目前 {CommentLength} 字）";

    private bool IsBusy(string action) => IsSubmitting && PendingAction == action;

    /// <summary>意見不足提示徽章（決策按鈕禁用時顯示在按鈕群左側）。</summary>
    private RenderFragment ShortCommentHint => __builder =>
    {
        if (!IsCommentTooShort) return;
        <span class="text-xs text-terracotta font-bold flex items-center gap-1.5 mr-2 shrink-0"
              title="@ShortCommentTooltip">
            <i class="fa-solid fa-pen-clip"></i>
            <span class="tabular-nums">意見需至少 @MinCommentLength 字（目前 @CommentLength）</span>
        </span>
    };

    // ==========================================================
    //  各階段按鈕組（RenderFragment 屬性）
    // ==========================================================

    private RenderFragment RenderMutualButtons => __builder =>
    {
        @* 已完成可再編輯（直到互審階段截止才鎖定）：按鈕字面切換為「修改意見」 *@
        var isResubmit = Assignment?.IsCompleted ?? false;
        var label      = isResubmit ? "修改意見" : "儲存意見";
        var icon       = isResubmit ? "fa-pen-to-square" : "fa-floppy-disk";
        <p class="text-xs text-gray-500 italic flex items-center gap-1.5">
            <i class="fa-solid fa-circle-info text-morandi"></i>
            互審階段僅提供意見回饋，老師將依您的建議修題
        </p>
        <div class="flex items-center">
            @ShortCommentHint
            <button type="button"
                    disabled="@(IsSubmitting || IsCommentTooShort)"
                    title="@(IsCommentTooShort ? ShortCommentTooltip : null)"
                    @onclick="() => OnSaveDraft.InvokeAsync()"
                    class="px-6 py-2.5 bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("save"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>儲存中…</span>
                }
                else
                {
                    <i class="fa-solid @icon mr-1.5"></i>
                    <span>@label</span>
                }
            </button>
        </div>
    };

    private RenderFragment RenderExpertButtons => __builder =>
    {
        <button type="button"
                disabled="@IsSubmitting"
                @onclick="() => OnSaveDraft.InvokeAsync()"
                class="px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
            @if (IsBusy("save"))
            {
                <i class="fa-solid fa-spinner fa-spin mr-1"></i>
                <span>儲存中…</span>
            }
            else
            {
                <i class="fa-regular fa-floppy-disk mr-1"></i>
                <span>儲存意見草稿</span>
            }
        </button>
        <div class="flex items-center gap-3">
            @ShortCommentHint
            <button type="button"
                    disabled="@(IsSubmitting || IsCommentTooShort)"
                    title="@(IsCommentTooShort ? ShortCommentTooltip : null)"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Revise)"
                    class="px-5 py-2.5 bg-terracotta hover:bg-[#c87a5d] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("revise"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-rotate-left mr-1.5"></i>
                    <span>改後採用</span>
                }
            </button>
            <button type="button"
                    disabled="@(IsSubmitting || IsCommentTooShort)"
                    title="@(IsCommentTooShort ? ShortCommentTooltip : null)"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Approve)"
                    class="px-6 py-2.5 bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("approve"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-check mr-1.5"></i>
                    <span>採用</span>
                }
            </button>
        </div>
    };

    private RenderFragment RenderFinalButtons => __builder =>
    {
        <button type="button"
                disabled="@IsSubmitting"
                @onclick="() => OnSaveDraft.InvokeAsync()"
                class="px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
            @if (IsBusy("save"))
            {
                <i class="fa-solid fa-spinner fa-spin mr-1"></i>
                <span>儲存中…</span>
            }
            else
            {
                <i class="fa-regular fa-floppy-disk mr-1"></i>
                <span>儲存意見草稿</span>
            }
        </button>
        <div class="flex items-center gap-3">
            @ShortCommentHint
            <button type="button"
                    disabled="@(IsSubmitting || IsCommentTooShort)"
                    title="@(IsCommentTooShort ? ShortCommentTooltip : null)"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Revise)"
                    class="px-5 py-2.5 bg-terracotta hover:bg-[#c87a5d] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("revise"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-rotate-left mr-1.5"></i>
                    <span>改後採用</span>
                }
            </button>
            @* destructive-emphasis：不採用單獨 red-700 + 額外 gap *@
            <span class="w-px h-8 bg-gray-300 mx-2"></span>
            <button type="button"
                    disabled="@(IsSubmitting || IsCommentTooShort)"
                    title="@(IsCommentTooShort ? ShortCommentTooltip : null)"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Reject)"
                    class="px-5 py-2.5 bg-red-700 hover:bg-red-800 text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("reject"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-xmark mr-1.5"></i>
                    <span>不採用</span>
                }
            </button>
            <button type="button"
                    disabled="@(IsSubmitting || IsCommentTooShort)"
                    title="@(IsCommentTooShort ? ShortCommentTooltip : null)"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Approve)"
                    class="px-6 py-2.5 bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("approve"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-check mr-1.5"></i>
                    <span>採用</span>
                }
            </button>
        </div>
    };

    private RenderFragment RenderFinalThirdButtons => __builder =>
    {
        <button type="button"
                disabled="@IsSubmitting"
                @onclick="() => OnSaveDraft.InvokeAsync()"
                class="px-4 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
            @if (IsBusy("save"))
            {
                <i class="fa-solid fa-spinner fa-spin mr-1"></i>
                <span>儲存中…</span>
            }
            else
            {
                <i class="fa-regular fa-floppy-disk mr-1"></i>
                <span>儲存意見草稿</span>
            }
        </button>
        <div class="flex items-center gap-3">
            @ShortCommentHint
            <button type="button"
                    disabled="@IsSubmitting"
                    @onclick="() => OnRequestEdit.InvokeAsync()"
                    class="px-5 py-2.5 bg-morandi hover:bg-[#5a7a99] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("edit"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>開啟中…</span>
                }
                else
                {
                    <i class="fa-solid fa-pen-to-square mr-1.5"></i>
                    <span>編輯題目</span>
                }
            </button>
            <span class="w-px h-8 bg-gray-300 mx-2"></span>
            <button type="button"
                    disabled="@(IsSubmitting || IsCommentTooShort)"
                    title="@(IsCommentTooShort ? ShortCommentTooltip : null)"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Reject)"
                    class="px-5 py-2.5 bg-red-700 hover:bg-red-800 text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("reject"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-xmark mr-1.5"></i>
                    <span>不採用</span>
                }
            </button>
            <button type="button"
                    disabled="@(IsSubmitting || IsCommentTooShort)"
                    title="@(IsCommentTooShort ? ShortCommentTooltip : null)"
                    @onclick="() => OnSubmitDecision.InvokeAsync(ReviewDecision.Approve)"
                    class="px-6 py-2.5 bg-sage hover:bg-[#7a9a82] text-white rounded-lg font-bold text-sm transition shadow-sm cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                @if (IsBusy("approve"))
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1.5"></i>
                    <span>送出中…</span>
                }
                else
                {
                    <i class="fa-solid fa-check mr-1.5"></i>
                    <span>採用</span>
                }
            </button>
        </div>
    };
}
