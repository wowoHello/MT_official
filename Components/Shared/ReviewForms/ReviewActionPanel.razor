@* ====================================================================== *@
@*  ReviewActionPanel — 審題 Modal 右 30% 操作區                             *@
@*  審題意見：純 textarea + 8 罐頭訊息快速插入（不需富文本，不需字數統計）    *@
@*  歷程軌跡 + 相似題比對於下半部，獨立內捲                                   *@
@* ====================================================================== *@
@inject IJSRuntime JS

<div class="flex flex-col h-full overflow-hidden">

    @* ===== 區塊 1：意見編輯框 + 罐頭訊息（固定，不隨歷程捲動） ===== *@
    <div class="p-5 border-b border-gray-100 bg-gradient-to-b from-white to-gray-50/50 flex-shrink-0">
        <h3 class="text-sm font-bold text-slate-main mb-3 flex items-center gap-2">
            <i class="fa-solid fa-comment-dots text-morandi"></i>
            我的審題意見
            @if (IsReadOnly)
            {
                <span class="ml-auto text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full font-bold border border-gray-200">
                    <i class="fa-solid fa-lock mr-1"></i> @(string.IsNullOrEmpty(LockReason) ? "已決策" : LockReason)
                </span>
            }
        </h3>

        @* 罐頭訊息快速插入列 *@
        <div class="mb-3">
            <p class="text-xs text-gray-500 mb-2 font-medium">
                <i class="fa-solid fa-bolt-lightning text-morandi mr-1"></i>
                點擊插入常用評語：
            </p>
            <div class="flex flex-wrap gap-1.5">
                @foreach (var msg in CannedMessages)
                {
                    <button type="button"
                            disabled="@IsReadOnly"
                            @onclick="() => InsertCannedAsync(msg.Text)"
                            class="text-xs px-2.5 py-1 border rounded-md font-bold transition cursor-pointer focus:outline-none disabled:opacity-40 disabled:cursor-not-allowed @msg.ColorCss">
                        <i class="@msg.IconClass mr-1"></i>@msg.Label
                    </button>
                }
            </div>
        </div>

        @* 用 Blazor 內建 InputTextArea — 正確處理 IME composition，避免中文注音/拼音重複輸入
           瀏覽器原生輔助 + 擴充工具 (Grammarly/MS Editor) 防護仍保留 *@
        <InputTextArea id="@textareaId"
                       Value="@Comment"
                       ValueChanged="OnValueChangedAsync"
                       ValueExpression="@(() => Comment)"
                       readonly="@IsReadOnly"
                       placeholder="請輸入審題意見…"
                       lang="zxx"
                       spellcheck="false"
                       writingsuggestions="false"
                       autocomplete="off"
                       autocorrect="off"
                       autocapitalize="off"
                       data-gramm="false"
                       data-gramm_editor="false"
                       data-enable-grammarly="false"
                       data-ms-editor="false"
                       class="review-textarea no-underline w-full h-[200px] px-3 py-2 text-sm leading-relaxed text-slate-main border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-morandi focus:border-morandi resize-none read-only:bg-gray-50 read-only:cursor-not-allowed" />
    </div>

    @* ===== 下半部：歷程軌跡 + 相似題比對（共用同一個內捲容器） ===== *@
    <div class="flex-1 min-h-0 overflow-y-auto custom-scroll">
        <ReviewHistoryTimeline Entries="@History" />

        <ReviewSimilarityBanner @ref="similaritySection"
                                Entries="@SimilarQuestions"
                                Mode="ReviewSimilarityBanner.BannerMode.Section" />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Comment { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> CommentChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    /// <summary>唯讀時 lock 標籤上顯示的原因（null/空 → 預設「已決策」）</summary>
    [Parameter] public string? LockReason { get; set; }
    [Parameter] public List<ReviewHistoryEntry> History { get; set; } = new();
    [Parameter] public List<ReviewSimilarityEntry> SimilarQuestions { get; set; } = new();

    private readonly string textareaId = $"review-comment-{Guid.NewGuid():N}";
    private ReviewSimilarityBanner? similaritySection;

    /// <summary>讓父層（ReviewModal 頂部橫幅按鈕）能呼叫展開相似題列表</summary>
    public Task ExpandSimilarityAsync() => similaritySection?.ExpandAsync() ?? Task.CompletedTask;

    private async Task OnValueChangedAsync(string newValue)
        => await CommentChanged.InvokeAsync(newValue ?? string.Empty);

    private async Task InsertCannedAsync(string text)
    {
        if (IsReadOnly) return;
        // 由 JS 回傳插入後的新值，再由 Blazor 明確同步，避免 synthetic change 與 IME / Editor 打架。
        var nextValue = await JS.InvokeAsync<string?>("TextareaHelper.insertAtCursor", textareaId, text);
        if (nextValue is not null)
        {
            await OnValueChangedAsync(nextValue);
        }
    }

    /// <summary>
    /// 8 個罐頭訊息（依 Plan_003 Q1 確認的內容；Label 與插入文字分離以便管理）。
    /// 顏色語意：sage=正向 / terracotta=警示 / morandi=中性建議。
    /// 圖示採 Font Awesome 6（離線載入），不使用 emoji。
    /// </summary>
    private static readonly CannedMessage[] CannedMessages =
    [
        new("fa-solid fa-circle-check",        "題意清晰",     "題意清晰，選項設計合理。",                "bg-sage/10 text-sage border-sage/20 hover:bg-sage/20"),
        new("fa-solid fa-triangle-exclamation","答案有爭議",   "此題答案似有爭議，建議再確認。",          "bg-terracotta/10 text-terracotta border-terracotta/20 hover:bg-terracotta/20"),
        new("fa-solid fa-ruler-combined",      "選項長度差異", "選項長度差異過大，建議調整為相近字數。",  "bg-morandi/10 text-morandi border-morandi/20 hover:bg-morandi/20"),
        new("fa-solid fa-book",                "用詞不當",     "部分用詞不夠精確，建議修飾。",            "bg-morandi/10 text-morandi border-morandi/20 hover:bg-morandi/20"),
        new("fa-solid fa-calculator",          "計算錯誤",     "計算過程或答案數字有誤。",                "bg-terracotta/10 text-terracotta border-terracotta/20 hover:bg-terracotta/20"),
        new("fa-solid fa-bullseye",            "鑑別度偏低",   "鑑別度偏低，可能無法有效區分學生程度。",  "bg-morandi/10 text-morandi border-morandi/20 hover:bg-morandi/20"),
        new("fa-solid fa-scissors",            "文意冗長",     "題幹文意稍嫌冗長，建議精簡。",            "bg-morandi/10 text-morandi border-morandi/20 hover:bg-morandi/20"),
        new("fa-solid fa-image",               "圖片不清",     "附圖品質不佳或無法清楚辨識。",            "bg-terracotta/10 text-terracotta border-terracotta/20 hover:bg-terracotta/20"),
    ];

    private record CannedMessage(string IconClass, string Label, string Text, string ColorCss);
}
