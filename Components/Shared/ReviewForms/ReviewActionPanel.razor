@* ====================================================================== *@
@*  ReviewActionPanel — 審題 Modal 右 30% 操作區                             *@
@*  審題意見：純 textarea + 8 罐頭訊息快速插入（不需富文本，不需字數統計）    *@
@*  歷程軌跡 + 相似題比對於下半部，獨立內捲                                   *@
@* ====================================================================== *@
@inject IJSRuntime JS

<div class="flex flex-col h-full overflow-hidden">

    @* ===== 區塊 1：意見編輯框 + 罐頭訊息（固定，不隨歷程捲動） =====
       HideCommentSection=true（總召代修+裁決模式）：整段不渲染（無動畫需求）
       isHistoryExpanded=true（使用者點「展開大檢視」）：max-height + opacity 平滑收合動畫
       max-h-[640px] 大於本區實際高度（~450px）確保展開時不被截斷；隱藏時 0 → 完整收合 *@
    @if (!HideCommentSection)
    {
    <div class="overflow-hidden flex-shrink-0 transition-all duration-300 ease-in-out @(isHistoryExpanded ? "max-h-0 opacity-0" : "max-h-[640px] opacity-100")">
    <div class="p-5 border-b border-gray-100 bg-gradient-to-b from-white to-gray-50/50">
        <h3 class="text-sm font-bold text-slate-main mb-3 flex items-center gap-2">
            <i class="fa-solid fa-comment-dots text-morandi"></i>
            我的審題意見
            @if (IsReadOnly)
            {
                <span class="ml-auto text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full font-bold border border-gray-200">
                    <i class="fa-solid fa-lock mr-1"></i> @(string.IsNullOrEmpty(LockReason) ? "已決策" : LockReason)
                </span>
            }
        </h3>

        @* 罐頭訊息快速插入列 *@
        <div class="mb-3">
            <p class="text-xs text-gray-500 mb-2 font-medium">
                <i class="fa-solid fa-bolt-lightning text-morandi mr-1"></i>
                點擊插入常用評語：
            </p>
            <div class="flex flex-wrap gap-1.5">
                @foreach (var msg in ActiveCannedMessages)
                {
                    <button type="button"
                            disabled="@IsReadOnly"
                            @onclick="() => InsertCannedAsync(msg.Text)"
                            class="text-xs px-2.5 py-1 border rounded-md font-bold transition cursor-pointer focus:outline-none disabled:opacity-40 disabled:cursor-not-allowed @msg.ColorCss">
                        <i class="@msg.IconClass mr-1"></i>@msg.Label
                    </button>
                }
            </div>
        </div>

        @* 用 Blazor 內建 InputTextArea — 正確處理 IME composition，避免中文注音/拼音重複輸入
           瀏覽器原生輔助 + 擴充工具 (Grammarly/MS Editor) 防護仍保留 *@
        <InputTextArea id="@textareaId"
                       Value="@Comment"
                       ValueChanged="OnValueChangedAsync"
                       ValueExpression="@(() => Comment)"
                       readonly="@IsReadOnly"
                       placeholder="請輸入審題意見…"
                       lang="zxx"
                       spellcheck="false"
                       writingsuggestions="false"
                       autocomplete="off"
                       autocorrect="off"
                       autocapitalize="off"
                       data-gramm="false"
                       data-gramm_editor="false"
                       data-enable-grammarly="false"
                       data-ms-editor="false"
                       class="review-textarea no-underline w-full h-[200px] px-3 py-2 text-sm leading-relaxed text-slate-main border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-morandi focus:border-morandi resize-none read-only:bg-gray-50 read-only:cursor-not-allowed" />
    </div>
    </div>
    }

    @* ===== Toggle bar：固定在意見區與捲動區之間，整條 bar = 單一按鈕 =====
       點擊任意位置都觸發切換，移除冗餘的「模式指示」文字讓 UI 更乾淨
       HideCommentSection=true（總召代修+裁決模式）時不顯示——沒有意見區可隱藏，toggle 沒意義 *@
    @if (!HideCommentSection)
    {
        @* 莫蘭迪漸層底色（兩側 5% / 中央 20%）讓視線聚焦中央按鈕文字
           Hover：漸層加深 1.75 倍 + inner shadow + icon 微放大，視覺回饋疊加多重 *@
        <button type="button"
                @onclick="ToggleHistoryExpanded"
                title="@(isHistoryExpanded ? "收合，回意見編輯模式" : "展開大檢視，獲得完整歷程閱讀空間")"
                class="group w-full px-5 py-2.5 border-y border-morandi/20 hover:border-morandi/50
                       bg-gradient-to-r from-morandi/5 via-morandi/20 to-morandi/5
                       hover:from-morandi/20 hover:via-morandi/40 hover:to-morandi/20
                       focus:from-morandi/20 focus:via-morandi/40 focus:to-morandi/20
                       hover:shadow-[inset_0_0_8px_rgba(107,142,173,0.25)]
                       transition-all duration-200
                       flex items-center justify-center gap-2 text-sm font-bold text-morandi
                       cursor-pointer focus:outline-none flex-shrink-0">
            <i class="fa-solid @(isHistoryExpanded ? "fa-compress" : "fa-expand") transition-transform duration-200 group-hover:scale-125"></i>
            @(isHistoryExpanded ? "收合，回意見編輯模式" : "展開大檢視，閱讀歷程軌跡")
        </button>
    }

    @* ===== 下半部：劃記評語 + 歷程軌跡 + 相似題比對（共用同一個內捲容器） ===== *@
    <div class="flex-1 min-h-0 overflow-y-auto custom-scroll">

        @* 劃記評語清單（用 details 折疊，有內容預設展開） *@
        @if (Annotations.Count > 0)
        {
            <details open class="border-b border-gray-100">
                <summary class="px-5 py-3 cursor-pointer text-xs font-bold text-morandi flex items-center gap-1.5 hover:bg-morandi/5 transition list-none select-none">
                    <i class="fa-solid fa-pen-to-square"></i>
                    <span>劃記評語</span>
                    <span class="ml-1 px-1.5 py-0.5 text-xs rounded-full bg-morandi/15 text-morandi font-bold">@Annotations.Count</span>
                    <i class="fa-solid fa-chevron-down ml-auto text-xs text-gray-400"></i>
                </summary>
                <div class="px-4 pb-4 pt-1 space-y-2">
                    @for (int i = 0; i < Annotations.Count; i++)
                    {
                        var idx = i;
                        var annot = Annotations[idx];
                        var num = idx + 1;
                        var (stateLabel, stateCss) = DescribeState(annot);
                        var canDelete = annot.CreatedByUserId == CurrentUserId && annot.ResponseState is null;
                        <div class="bg-white border border-gray-200 rounded-lg p-3 text-xs hover:border-morandi/40 hover:shadow-sm transition group"
                             @onclick="() => ScrollToAnnotationAsync(annot.Id)">
                            <div class="flex items-start gap-2 mb-1.5">
                                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-morandi text-white text-xs font-bold flex-shrink-0">@num</span>
                                <div class="flex-1 min-w-0">
                                    @* 審題端：自己看自己的劃記，不顯示身份標籤（修題端會用 AnnotationActorLabel 顯示）；
                                       位置由左側題目區的高亮 mark 表達，這裡只列時間 + 摘要 + 評語 *@
                                    <div class="text-gray-400 text-xs mb-1">@annot.CreatedAt.ToString("MM/dd HH:mm")</div>
                                    <div class="bg-amber-50 border border-amber-200 rounded px-2 py-1 text-gray-800 font-serif leading-relaxed mb-1.5 max-h-16 overflow-y-auto" title="@annot.SelectedText">
                                        「@annot.SelectedText」
                                    </div>
                                    <div class="text-gray-700 leading-relaxed whitespace-pre-wrap">@annot.Comment</div>
                                    @if (annot.IsResponded)
                                    {
                                        <div class="mt-2 pt-2 border-t border-dashed border-gray-200">
                                            <span class="inline-block px-2 py-0.5 rounded text-xs font-bold border @stateCss">@stateLabel</span>
                                            @if (!string.IsNullOrWhiteSpace(annot.NoChangeReason))
                                            {
                                                <div class="mt-1 text-gray-500 text-xs">老師說明：@annot.NoChangeReason</div>
                                            }
                                        </div>
                                    }
                                </div>
                                @if (canDelete)
                                {
                                    <button type="button"
                                            @onclick="() => OnAnnotationDeleted.InvokeAsync(annot.Id)"
                                            @onclick:stopPropagation="true"
                                            title="刪除此劃記"
                                            class="opacity-0 group-hover:opacity-100 transition text-gray-400 hover:text-terracotta text-xs cursor-pointer focus:outline-none">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </details>
        }

        <ReviewHistoryTimeline Entries="@History" />

        <ReviewSimilarityBanner @ref="similaritySection"
                                Entries="@SimilarQuestions"
                                Mode="ReviewSimilarityBanner.BannerMode.Section" />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Comment { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> CommentChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    /// <summary>唯讀時 lock 標籤上顯示的原因（null/空 → 預設「已決策」）</summary>
    [Parameter] public string? LockReason { get; set; }

    /// <summary>
    /// 隱藏「我的審題意見」整段（標題 + 罐頭訊息 + 文字框）— 用於總召代修+裁決模式（CanFinalReviewerEdit=true）。
    /// 下半部歷程軌跡 / 相似題 / 劃記仍正常顯示。
    /// </summary>
    [Parameter] public bool HideCommentSection { get; set; }
    [Parameter] public List<ReviewHistoryEntry> History { get; set; } = new();
    [Parameter] public List<ReviewSimilarityEntry> SimilarQuestions { get; set; } = new();

    /// <summary>當前單元的劃記評語清單（審題者只看自己的）</summary>
    [Parameter] public List<ReviewAnnotation> Annotations { get; set; } = new();

    /// <summary>當前登入者 Id — 用於判斷劃記是否本人建立（決定是否顯示刪除按鈕）</summary>
    [Parameter] public int CurrentUserId { get; set; }

    /// <summary>劃記刪除事件，由父層 (ReviewModal) 呼叫 Service 完成刪除後 reload</summary>
    [Parameter] public EventCallback<int> OnAnnotationDeleted { get; set; }

    /// <summary>
    /// 目前題目的題型代碼（QuestionTypeCodes.Listen / ListenGroup 視為 LCT 罐頭組，其他視為 CWT 罐頭組）。
    /// 由 ReviewModal 從 ReviewModalData.Question.QuestionType 帶入。
    /// </summary>
    [Parameter] public string QuestionType { get; set; } = string.Empty;

    private readonly string textareaId = $"review-comment-{Guid.NewGuid():N}";
    private ReviewSimilarityBanner? similaritySection;

    /// <summary>
    /// 「展開大檢視」狀態：true 時暫時隱藏「我的審題意見」區，把整個 panel 高度讓給歷程軌跡閱讀。
    /// 由 ReviewHistoryTimeline summary 上的按鈕觸發 ToggleHistoryExpanded 切換。
    /// 切換新題目（透過 ReviewModal 重新開啟）時不主動重置——同次 modal session 內保持使用者選擇。
    /// </summary>
    private bool isHistoryExpanded;

    private void ToggleHistoryExpanded() => isHistoryExpanded = !isHistoryExpanded;

    /// <summary>讓父層（ReviewModal 頂部橫幅按鈕）能呼叫展開相似題列表</summary>
    public Task ExpandSimilarityAsync() => similaritySection?.ExpandAsync() ?? Task.CompletedTask;

    private async Task OnValueChangedAsync(string newValue)
        => await CommentChanged.InvokeAsync(newValue ?? string.Empty);

    private async Task InsertCannedAsync(string text)
    {
        if (IsReadOnly) return;
        // 由 JS 回傳插入後的新值，再由 Blazor 明確同步，避免 synthetic change 與 IME / Editor 打架。
        var nextValue = await JS.InvokeAsync<string?>("TextareaHelper.insertAtCursor", textareaId, text);
        if (nextValue is not null)
        {
            await OnValueChangedAsync(nextValue);
        }
    }

    /// <summary>
    /// CWT 全民中檢罐頭訊息（6 個）：題幹/選項/語文表達 + 鑑別度面向。
    /// 顏色語意：sage=正向 / terracotta=警示 / morandi=中性建議。
    /// </summary>
    private static readonly CannedMessage[] CwtCannedMessages =
    [
        new("fa-solid fa-circle-check",         "選項鑑別明確", "選項鑑別度明確、設計合理，能有效區分學生程度。",        "bg-sage/10 text-sage border-sage/20 hover:bg-sage/20"),
        new("fa-solid fa-bullseye",             "題幹情境清晰", "題幹情境陳述清晰，能引導學生掌握作答方向。",            "bg-sage/10 text-sage border-sage/20 hover:bg-sage/20"),
        new("fa-solid fa-book",                 "文句通順無誤", "題幹與選項文句通順、用字精準，符合語文檢定標準。",      "bg-sage/10 text-sage border-sage/20 hover:bg-sage/20"),
        new("fa-solid fa-ruler-combined",       "選項字數失衡", "各選項字數差異過大，建議調整為相近長度避免暗示。",      "bg-morandi/10 text-morandi border-morandi/20 hover:bg-morandi/20"),
        new("fa-solid fa-triangle-exclamation", "題幹資訊不足", "題幹提供的資訊不足以判斷答案，建議補充必要線索或情境。","bg-terracotta/10 text-terracotta border-terracotta/20 hover:bg-terracotta/20"),        
        new("fa-solid fa-scale-balanced",       "難度不符等級", "本題難度與專案設定等級不符，建議重新斟酌或調整。",      "bg-terracotta/10 text-terracotta border-terracotta/20 hover:bg-terracotta/20"),
    ];

    /// <summary>
    /// LCT 聽力中文檢定罐頭訊息（6 個）：聽辨邏輯/語音口語/誘答鑑別度面向。
    /// 顏色語意同 CWT 組。
    /// </summary>
    private static readonly CannedMessage[] LctCannedMessages =
    [
        new("fa-solid fa-circle-check",         "邏輯清晰合理", "題目邏輯清晰、推論合理，語境設計能正確對應正答。",      "bg-sage/10 text-sage border-sage/20 hover:bg-sage/20"),
        new("fa-solid fa-bullseye",             "選項鑑別度佳", "誘答選項與正答的鑑別度良好，能有效區分聽力理解程度。",  "bg-sage/10 text-sage border-sage/20 hover:bg-sage/20"),
        new("fa-solid fa-comment",              "語句通順口語", "語音逐字稿語句通順、用詞自然口語，符合實際聽力情境。",  "bg-sage/10 text-sage border-sage/20 hover:bg-sage/20"),
        new("fa-solid fa-triangle-exclamation", "答案易生爭議", "此題答案易生爭議，建議再確認語音內容與標準答案的對應。","bg-terracotta/10 text-terracotta border-terracotta/20 hover:bg-terracotta/20"),
        new("fa-solid fa-bullseye-arrow",       "選項誘答不足", "誘答選項的迷惑性不足，建議調整以提升鑑別度與測驗效度。","bg-morandi/10 text-morandi border-morandi/20 hover:bg-morandi/20"),
        new("fa-solid fa-scissors",             "文本字數偏多", "語音文本字數偏多，建議精簡內容以配合考試時間。",        "bg-morandi/10 text-morandi border-morandi/20 hover:bg-morandi/20"),
    ];

    /// <summary>
    /// 依當前題型挑選罐頭組：聽力測驗 / 聽力題組 → LCT 組；其他題型（一般單選 / 閱讀題組 / 長文 / 短文題組）→ CWT 組。
    /// QuestionType 為空字串（初始載入瞬間）時 fallback CWT 組，避免閃爍。
    /// </summary>
    private CannedMessage[] ActiveCannedMessages =>
        QuestionType is QuestionTypeCodes.Listen or QuestionTypeCodes.ListenGroup
            ? LctCannedMessages
            : CwtCannedMessages;

    private record CannedMessage(string IconClass, string Label, string Text, string ColorCss);

    /// <summary>劃記狀態徽章描述（與 annotation.js 高亮配色一致）</summary>
    private static (string Label, string Css) DescribeState(ReviewAnnotation annot) => annot.ResponseState switch
    {
        AnnotationResponseState.Accepted => ("命題者已確認修改", "bg-sage/15 text-sage border-sage/30"),
        AnnotationResponseState.Rejected => ("命題者不修改",     "bg-terracotta/15 text-terracotta border-terracotta/30"),
        _                                 => ("待回應",          "bg-amber-50 text-amber-700 border-amber-200")
    };

    /// <summary>點擊劃記列 → 卷動到對應的 mark 元素並 flash 提示</summary>
    private async Task ScrollToAnnotationAsync(int annotationId)
    {
        // 簡單實作：用 querySelector + scrollIntoView + 短暫加 ring class
        await JS.InvokeVoidAsync("eval", $$"""
            (function(){
                const m = document.querySelector('mark[data-annot-id="{{annotationId}}"]');
                if (!m) return;
                m.scrollIntoView({behavior:'smooth', block:'center'});
                m.style.transition = 'background-color .25s';
                const original = m.style.backgroundColor;
                m.style.backgroundColor = 'rgba(217,138,108,.55)';
                setTimeout(() => { m.style.backgroundColor = original; }, 900);
            })();
        """);
    }
}
