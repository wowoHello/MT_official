@* ====================================================================== *@
@*  ReviewModal — 審題專用 Modal 主容器（FullScreen）                        *@
@*  與 CwtList 命題 Modal 完全分離，避免互相干擾。                             *@
@*  結構：Header（h-16）+ Body（左 70% 題目 + 右 30% 操作）+ Footer（決策列） *@
@*  Phase 3.2：題目展示 OK；操作區 / 決策列待 3.3 / 3.5 補上。                *@
@* ====================================================================== *@
@implements IAsyncDisposable
@inject IReviewService ReviewService
@inject IAnnotationService AnnotationService
@inject ISimilarityService SimilarityService
@inject IJSRuntime JS
@inject ILogger<ReviewModal> Logger

@if (IsVisible)
{
    <div class="fixed inset-0 z-50 bg-gray-50 flex flex-col" style="animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);">

        @* ====== 相似題警示橫幅（依 Plan_003 Q4：頂部常駐） ====== *@
        @if (data is not null && data.SimilarQuestions.Count > 0)
        {
            <ReviewSimilarityBanner Entries="@data.SimilarQuestions"
                                    Mode="ReviewSimilarityBanner.BannerMode.Banner"
                                    OnExpandRequested="OnExpandSimilarityRequested" />
        }

        @* ====== Header（sticky h-16） ====== *@
        <div class="h-16 flex-shrink-0 px-6 flex items-center justify-between border-b border-gray-200 bg-white shadow-sm">
            <div class="flex items-center gap-3 flex-wrap min-w-0">
                <button type="button" @onclick="CloseAsync"
                        class="text-sm text-gray-500 hover:text-morandi font-bold flex items-center gap-1.5 transition shrink-0 cursor-pointer focus:outline-none">
                    <i class="fa-solid fa-arrow-left"></i> 返回列表
                </button>
                <div class="h-6 w-px bg-gray-300 shrink-0"></div>

                @if (isLoading)
                {
                    <span class="text-sm text-gray-400">
                        <i class="fa-solid fa-spinner fa-spin mr-1"></i> 載入中…
                    </span>
                }
                else if (data is not null)
                {
                    <span class="font-black text-slate-main text-base shrink-0">@HeaderDisplayCode</span>
                    <span class="px-2.5 py-0.5 bg-gray-100 text-gray-700 rounded-md text-xs font-bold border border-gray-200 shrink-0">
                        @QuestionConstants.TypeLabels.GetValueOrDefault(data.Question.QuestionType, "未知題型")
                    </span>
                    @if (!string.IsNullOrEmpty(LevelLabel))
                    {
                        <span class="px-2.5 py-0.5 bg-morandi/10 text-morandi rounded-md text-xs font-bold border border-morandi/20 shrink-0">@LevelLabel</span>
                    }
                    @if (!string.IsNullOrEmpty(DifficultyLabel))
                    {
                        <span class="px-2.5 py-0.5 bg-terracotta/10 text-terracotta rounded-md text-xs font-bold border border-terracotta/20 shrink-0">難度：@DifficultyLabel</span>
                    }
                    @* 階段標籤 *@
                    @if (data.MyAssignment is not null)
                    {
                        var stage = data.MyAssignment.Stage;
                        var stageCss = stage switch
                        {
                            ReviewStage.Mutual => "bg-morandi/15 text-morandi border-morandi/30",
                            ReviewStage.Expert => "bg-terracotta/15 text-terracotta border-terracotta/30",
                            ReviewStage.Final  => "bg-red-50 text-red-700 border-red-200",
                            _                  => "bg-gray-100 text-gray-500 border-gray-300"
                        };
                        var stageIcon = stage switch
                        {
                            ReviewStage.Mutual => "fa-clipboard-check",
                            ReviewStage.Expert => "fa-user-graduate",
                            ReviewStage.Final  => "fa-crown",
                            _                  => "fa-circle"
                        };
                        var stageName = stage switch
                        {
                            ReviewStage.Mutual => "交互審題",
                            ReviewStage.Expert => "專家審題",
                            ReviewStage.Final  => "總召審題",
                            _                  => ""
                        };
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold border ml-2 shrink-0 @stageCss">
                            <i class="fa-solid @stageIcon mr-1"></i> @stageName
                        </span>

                        @* 編輯時間：優先顯示 UpdatedAt，未編輯過則顯示 CreatedAt，均為 MinValue 顯示「—」 *@
                        <span class="text-xs text-gray-400 shrink-0 ml-1">
                            <i class="fa-solid fa-clock mr-1"></i>最後編輯時間：@EditedAtLabel
                        </span>

                        @* 三退階段徽章：
                           FinalReturnCount=2 → 預警「下次退回將解鎖」
                           FinalReturnCount>=3 → 真解鎖「解鎖修改並裁決」（第 4 次送審到總召手裡，必須最終決策）*@
                        @if (data.FinalReturnCount >= 2 && stage == ReviewStage.Final)
                        {
                            <span class="ml-2 inline-flex items-center px-2 py-0.5 bg-red-100 text-red-700 rounded-full text-xs font-bold border border-red-200 shrink-0">
                                <i class="fa-solid fa-triangle-exclamation mr-1"></i>
                                @if (data.FinalReturnCount >= 3)
                                {
                                    <span>已退回 3 次，解鎖修改並裁決</span>
                                }
                                else
                                {
                                    <span>已退回 2 次</span>
                                }
                            </span>
                        }
                    }
                }
            </div>

            <div class="flex items-center gap-2 shrink-0">
                @if (data is not null && !isLoading)
                {
                    <button type="button" @onclick="OpenSimilarityCheckAsync"
                            disabled="@isCheckingSimilarity"
                            title="比對本梯次同題型同等級的相似題目"
                            class="px-3 py-1.5 text-xs border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed flex items-center gap-1.5">
                        @if (isCheckingSimilarity)
                        {
                            <i class="fa-solid fa-spinner fa-spin"></i>
                            <span>比對中…</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-clone"></i>
                            <span>試題重複比對</span>
                        }
                    </button>
                }
                <button type="button" @onclick="CloseAsync"
                        title="關閉"
                        class="text-gray-400 hover:text-terracotta hover:bg-gray-100 text-2xl w-10 h-10 flex items-center justify-center rounded-lg transition cursor-pointer focus:outline-none">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        </div>

        @* ====== Body：左 70% 題目 + 右 30% 操作 ====== *@
        <div class="flex-grow flex overflow-hidden">

            @* ===== 左 70% — 題目展示 ===== *@
            <div class="w-[70%] flex flex-col overflow-hidden">
                @if (isLoading)
                {
                    <div class="flex-grow flex items-center justify-center text-gray-400">
                        <i class="fa-solid fa-spinner fa-spin text-2xl mr-3"></i> 載入題目中…
                    </div>
                }
                else if (loadError is not null)
                {
                    <div class="flex-grow flex items-center justify-center">
                        <div class="text-center text-terracotta">
                            <i class="fa-solid fa-circle-exclamation text-3xl mb-2"></i>
                            <p class="text-sm">@loadError</p>
                        </div>
                    </div>
                }
                else if (data is not null)
                {
                    <ReviewQuestionDisplay Question="@data.Question"
                                           CreatorName="@data.CreatorName"
                                           SubQuestionId="@currentSubId"
                                           SiblingUnits="@data.SiblingUnits"
                                           OnSubUnitClick="@SwitchSubUnitAsync" />
                }

                @* ========================================================== *@
                @*  新增劃記評語對話框（fixed center modal，覆蓋整個 ReviewModal）  *@
                @*  使用者選文字 → 浮層按鈕 → JS 回呼 OnAnnotationRequested → 顯示此對話框 *@
                @* ========================================================== *@
                @if (showAnnotDialog)
                {
                    <div class="fixed inset-0 z-[60] bg-black/40 flex items-center justify-center p-4"
                         @onclick="CancelAnnotationDialog">
                        <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg overflow-hidden" @onclick:stopPropagation="true">
                            <div class="px-5 py-3 border-b border-gray-200 bg-morandi/8 flex items-center gap-2">
                                <i class="fa-solid fa-pen-to-square text-morandi"></i>
                                <span class="font-bold text-slate-main text-sm">針對選取文字加註評語</span>
                                <button type="button" @onclick="CancelAnnotationDialog"
                                        class="ml-auto text-gray-400 hover:text-terracotta text-lg cursor-pointer focus:outline-none">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </div>
                            <div class="p-5 space-y-3">
                                <div class="text-xs text-gray-500">選取的文字：</div>
                                <div class="bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 text-sm text-gray-800 font-serif leading-relaxed max-h-32 overflow-y-auto">
                                    「@pendingAnnotation?.SelectedText」
                                </div>
                                <textarea @bind="annotCommentDraft"
                                          @bind:event="oninput"
                                          placeholder="輸入針對此段文字的評語（必填）"
                                          spellcheck="false"
                                          class="w-full h-28 px-3 py-2 text-sm leading-relaxed text-slate-main border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-morandi focus:border-morandi resize-none"></textarea>
                            </div>
                            <div class="px-5 py-3 border-t border-gray-100 bg-gray-50/50 flex items-center justify-end gap-2">
                                <button type="button" @onclick="CancelAnnotationDialog"
                                        class="px-4 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-100 text-gray-600 font-medium cursor-pointer focus:outline-none">
                                    取消
                                </button>
                                <button type="button" @onclick="SaveAnnotationAsync"
                                        disabled="@(string.IsNullOrWhiteSpace(annotCommentDraft) || isSavingAnnotation)"
                                        class="px-5 py-1.5 bg-morandi hover:bg-[#587a99] text-white rounded-lg font-bold text-sm transition cursor-pointer focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
                                    @if (isSavingAnnotation)
                                    {
                                        <i class="fa-solid fa-spinner fa-spin mr-1"></i>
                                    }
                                    <span>儲存劃記</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* ===== 右 30% — 操作區 ===== *@
            <div class="w-[30%] border-l border-gray-200 bg-white flex flex-col">
                @if (data is not null)
                {
                    @* 唯讀條件（三擇一）：
                       1. 未分配給此人
                       2. 階段已結束（IsHistorical）
                       3. 已決策 / 已退回（IsCompleted=true）— 不允許再輸入意見；
                          僅 Pending（IsCompleted=false）時才開放意見輸入與決策按鈕 *@
                    var isActionReadOnly = data.MyAssignment is null
                                       || IsHistoricalAssignment
                                       || (data.MyAssignment?.IsCompleted ?? false);
                    var lockReason = IsHistoricalAssignment
                        ? "階段已結束"
                        : (data.MyAssignment?.IsCompleted ?? false)
                            ? "審閱完成，待命題教師處理"
                            : (string?)null;
                    @* 總召代修+裁決模式（CanFinalReviewerEdit=true + Final stage）— 隱藏「我的審題意見」整段，
                       第 4 次送審到總召手裡時，總召直接編輯題目並下最終裁決，不需再寫意見 *@
                    var hideCommentSection = data.MyAssignment?.Stage == ReviewStage.Final && data.CanFinalReviewerEdit;
                    <ReviewActionPanel @ref="actionPanel"
                                       @bind-Comment="commentDraft"
                                       IsReadOnly="@isActionReadOnly"
                                       LockReason="@lockReason"
                                       HideCommentSection="@hideCommentSection"
                                       History="@data.History"
                                       SimilarQuestions="@data.SimilarQuestions"
                                       Annotations="@annotations"
                                       CurrentUserId="@CurrentUserId"
                                       QuestionType="@data.Question.QuestionType"
                                       OnAnnotationDeleted="OnAnnotationDeletedAsync" />
                }
                else
                {
                    <div class="flex-grow flex items-center justify-center text-gray-400 text-sm">
                        <i class="fa-solid fa-spinner fa-spin mr-2"></i> 等待題目載入…
                    </div>
                }
            </div>
        </div>

        @* ====== Footer：決策列 ====== *@
        @if (data is not null)
        {
            <ReviewDecisionBar Assignment="@data.MyAssignment"
                               CanFinalReviewerEdit="@data.CanFinalReviewerEdit"
                               IsHistorical="@IsHistoricalAssignment"
                               IsSubmitting="@isSubmitting"
                               PendingAction="@pendingAction"
                               Comment="@commentDraft"
                               MinCommentLength="@MinCommentLength"
                               OnSaveDraft="OnSaveDraftAsync"
                               OnSubmitDecision="OnSubmitDecisionAsync"
                               OnRequestEdit="OnRequestEditAsync"
                               OnRequestClose="CloseAsync" />
        }
        else
        {
            <div class="h-16 flex-shrink-0 border-t-2 border-gray-200 bg-white px-6 flex items-center justify-end">
                <button type="button" @onclick="CloseAsync"
                        class="px-5 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-600 font-medium transition cursor-pointer">
                    關閉
                </button>
            </div>
        }
    </div>
}

<!-- 相似題比對結果彈窗 (Plan A) -->
<SimilarityCheckModal @bind-IsVisible="showSimilarityModal"
                      Loading="@isCheckingSimilarity"
                      Results="@similarityResults"
                      SourceCode="@(data?.Question.QuestionCode ?? "")" />

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }

    /// <summary>要開啟的題目 Id（NULL 時不載入；切換到非 null 才觸發 Load）</summary>
    [Parameter] public int? QuestionId { get; set; }

    /// <summary>
    /// 要開啟的子題 Id（題組類用）；NULL = 開啟母題單元；非 NULL = 開啟該子題單元。
    /// 與 QuestionId 一起決定載入哪個審題單元，並由 ReviewQuestionDisplay 切換顯示模式。
    /// </summary>
    [Parameter] public int? SubQuestionId { get; set; }

    /// <summary>當前登入者 Id（用於撈自己的 Assignment / 決策權限判斷）</summary>
    [Parameter, EditorRequired] public int CurrentUserId { get; set; }

    /// <summary>當前梯次 Id（Plan A 相似度比對用於過濾範圍）</summary>
    [Parameter] public int ProjectId { get; set; }

    /// <summary>
    /// 由父層（Reviews.razor）傳入 Service 端已計算好的 IsHistorical 旗標。
    /// 取代舊的 CurrentProjectStage 自行比對邏輯，避免 PhaseCode=8（總修）時
    /// currentStage=null 導致所有 Final Stage 分配被誤標為歷史唯讀。
    /// </summary>
    [Parameter] public bool IsHistoricalFromService { get; set; }

    /// <summary>關閉後若有發生決策變動，通知父層 reload 列表</summary>
    [Parameter] public EventCallback OnDecisionMade { get; set; }

    /// <summary>
    /// 總召點擊「編輯題目」→ 通知父層（Reviews.razor）開啟命題編輯 Modal。
    /// 傳出題目 Id，讓父層去 GetByIdAsync 並關閉 ReviewModal、開啟 FinalEditModal。
    /// Plan_021：由父層統一管理兩個 Modal 的開關，ReviewModal 自身不做跨 Modal 操作。
    /// </summary>
    [Parameter] public EventCallback<int> OnRequestFinalEdit { get; set; }

    /// <summary>
    /// 歷史唯讀判斷：完全信任 Service 端算好的 IsHistorical 旗標。
    /// - MyAssignment is null → 此題未分配給當前使用者，唯讀
    /// - IsHistoricalFromService → Service 端判定此行為歷史行（stage != active stage），唯讀
    /// </summary>
    private bool IsHistoricalAssignment => data?.MyAssignment is null || IsHistoricalFromService;

    /// <summary>
    /// Header 顯示用題目編號：母題視角顯示母題碼；子題視角組合 {母題碼}-{SortOrder:D2}（例 Q-115-00044-01）。
    /// SortOrder 來自 data.SiblingUnits（Service 端已按 stage 撈出兄弟單元）。
    /// </summary>
    private string HeaderDisplayCode
    {
        get
        {
            if (data is null) return "";
            if (currentSubId is int subId)
            {
                var sortOrder = data.SiblingUnits.FirstOrDefault(s => s.SubQuestionId == subId)?.SortOrder;
                if (sortOrder is int so)
                    return QuestionCodeHelper.SubCode(data.Question.QuestionCode, so);
            }
            return data.Question.QuestionCode;
        }
    }

    private ReviewModalData? data;
    private bool isLoading;
    private string? loadError;
    private int? loadedQuestionId;
    private int? loadedSubQuestionId;   // 與 loadedQuestionId 一起判定是否需要 re-load（換單元也要重撈）

    // Plan A 相似題比對
    private bool showSimilarityModal = false;
    private bool isCheckingSimilarity = false;
    private IReadOnlyList<MT.Models.SimilarityCompareResult> similarityResults
        = Array.Empty<MT.Models.SimilarityCompareResult>();

    /// <summary>
    /// Modal 開啟期間使用者實際看到的子題單元 — 從 Parameter SubQuestionId 初始化，
    /// 但使用者在母題列點擊「子題索引卡」後切換到的子題，此本地狀態維持到 Modal 關閉，
    /// 不會被父層 Parameter 覆蓋（避免父層 re-render 把使用者切到的子題打回原點）。
    /// </summary>
    private int? currentSubId;

    // ====================================================================
    //  劃記評語（Annotation）狀態與 JS interop
    // ====================================================================

    /// <summary>當前單元的劃記評語清單；隨 (QuestionId, currentSubId) 切換重撈</summary>
    private List<ReviewAnnotation> annotations = new();

    /// <summary>annotation.js 回呼用的 .NET 物件參考（每個 Modal 實例獨立）</summary>
    private DotNetObjectReference<ReviewModal>? annotSelfRef;

    /// <summary>annotation.js 是否已初始化（避免 Modal 多次打開時重複 init）</summary>
    private bool annotJsInited;

    // 新增劃記對話框狀態
    private bool showAnnotDialog;
    private bool isSavingAnnotation;
    private AnnotationRequestPayload? pendingAnnotation;
    private string annotCommentDraft = string.Empty;

    /// <summary>JS 端傳來的選取資訊（與 annotation.js 內 payload 結構對應）</summary>
    public class AnnotationRequestPayload
    {
        public string FieldKey { get; set; } = "";
        public int AnchorStart { get; set; }
        public int AnchorEnd { get; set; }
        public string SelectedText { get; set; } = "";
    }

    /// <summary>JS 端浮層按鈕點擊後回呼 — 開「新增評語」對話框</summary>
    [JSInvokable]
    public Task OnAnnotationRequested(AnnotationRequestPayload payload)
    {
        // 若 Modal 為唯讀（如階段結束、已決策），不允許新增劃記
        if (data?.MyAssignment is null || IsHistoricalAssignment) return Task.CompletedTask;
        if ((data.MyAssignment?.IsCompleted ?? false)) return Task.CompletedTask;

        pendingAnnotation  = payload;
        annotCommentDraft  = string.Empty;
        showAnnotDialog    = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void CancelAnnotationDialog()
    {
        showAnnotDialog   = false;
        pendingAnnotation = null;
        annotCommentDraft = string.Empty;
    }

    private async Task SaveAnnotationAsync()
    {
        if (pendingAnnotation is null || data?.MyAssignment is null) return;
        var comment = (annotCommentDraft ?? string.Empty).Trim();
        if (comment.Length == 0 || isSavingAnnotation) return;

        isSavingAnnotation = true;
        try
        {
            var newId = await AnnotationService.CreateAsync(new SaveAnnotationRequest
            {
                AssignmentId = data.MyAssignment.Id,
                FieldKey     = pendingAnnotation.FieldKey,
                AnchorStart  = pendingAnnotation.AnchorStart,
                AnchorEnd    = pendingAnnotation.AnchorEnd,
                SelectedText = pendingAnnotation.SelectedText,
                Comment      = comment
            }, CurrentUserId);

            if (newId > 0)
            {
                CancelAnnotationDialog();
                await ReloadAnnotationsAsync();
                await ShowToastAsync("success", "劃記評語已新增");
            }
            else
            {
                await ShowToastAsync("error", "劃記新增失敗（可能權限不足）");
            }
        }
        catch (Exception ex)
        {
            await ShowToastAsync("error", $"劃記新增失敗：{ex.Message}");
        }
        finally
        {
            isSavingAnnotation = false;
        }
    }

    private async Task OnAnnotationDeletedAsync(int annotationId)
    {
        if (data?.MyAssignment is null) return;
        try
        {
            var ok = await AnnotationService.DeleteAsync(annotationId, CurrentUserId);
            if (ok)
            {
                await ReloadAnnotationsAsync();
                await ShowToastAsync("success", "劃記已刪除");
            }
            else
            {
                await ShowToastAsync("warning", "無法刪除（可能已被命題者回應或非本人劃記）");
            }
        }
        catch (Exception ex)
        {
            await ShowToastAsync("error", $"刪除失敗：{ex.Message}");
        }
    }

    /// <summary>重撈當前單元 annotations + 觸發 JS renderHighlights</summary>
    private async Task ReloadAnnotationsAsync()
    {
        if (data?.MyAssignment is null) { annotations = new(); return; }
        annotations = await AnnotationService.GetByAssignmentAsync(data.MyAssignment.Id);
        StateHasChanged();
        await PushHighlightsToJsAsync();
    }

    /// <summary>把 annotations 序列化為 JS 端期望的 camelCase 物件丟過去 render</summary>
    private async Task PushHighlightsToJsAsync()
    {
        if (!annotJsInited) return;
        var payload = annotations.Select(a => new
        {
            id            = a.Id,
            fieldKey      = a.FieldKey,
            anchorStart   = a.AnchorStart,
            anchorEnd     = a.AnchorEnd,
            selectedText  = a.SelectedText,
            comment       = a.Comment,
            responseState = a.ResponseState is null ? (byte?)null : (byte)a.ResponseState.Value
        }).ToArray();
        try
        {
            // ⚠️ params object?[] 陷阱：anonymous[] 共變性會被當 params 陣列「展開」成多個 JS args。
            // 必須轉 (object) 強制包裝，JS 端才會收到整個 array 而不是被攤平。
            // deferredRender 內部有 retry：等 DOM 容器就位才正式 wrap，避免 OnAfterRender 早於子元件 render 的 race
            await JS.InvokeVoidAsync("annotation.deferredRender", (object)payload);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[annotation] deferredRender failed: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (annotJsInited)
        {
            try { await JS.InvokeVoidAsync("annotation.dispose"); }
            catch { /* JS context 已關 */ }
        }
        annotSelfRef?.Dispose();
    }

    /// <summary>
    /// 意見草稿（雙向綁定到 ReviewActionPanel）。
    /// 載入時從 MyAssignment.Comment 灌入；Phase 3.5 才會將此值送到後端儲存/決策 API。
    /// </summary>
    private string commentDraft = string.Empty;

    private ReviewActionPanel? actionPanel;

    /// <summary>正在儲存/決策中 — 控制按鈕 disabled 與 spinner</summary>
    private bool isSubmitting;

    /// <summary>當前觸發儲存的按鈕識別（save / approve / revise / reject），用於 spinner 定位</summary>
    private string? pendingAction;

    /// <summary>
    /// 意見最小字數（trim 後）。低於此字數時：
    ///   - 互審「儲存意見/修改意見」、專/總審「採用 / 改後採用 / 不採用」按鈕全部 disable
    ///   - 「儲存意見草稿」與總審第 3 次「編輯題目」不受限
    /// 與 ReviewDecisionBar.MinCommentLength 同步。
    /// </summary>
    private const int MinCommentLength = 10;

    /// <summary>頂部相似題橫幅「展開比對」按鈕點擊 → 滾動右側列表進視野並展開</summary>
    private async Task OnExpandSimilarityRequested()
    {
        if (actionPanel is not null) await actionPanel.ExpandSimilarityAsync();
    }

    private async Task OnSaveDraftAsync()
    {
        if (data?.MyAssignment is null || isSubmitting) return;

        // 互審階段「儲存意見」即為最終送出 → 強制檢查字數（與 ReviewDecisionBar disabled 條件對齊，第二道防線）
        // 專/總審的「儲存意見草稿」純草稿允許留空，僅互審需擋
        if (data.MyAssignment.Stage == ReviewStage.Mutual
            && (commentDraft ?? string.Empty).Trim().Length < MinCommentLength)
        {
            await ShowToastAsync("warning", $"意見需至少 {MinCommentLength} 字才能送出");
            return;
        }

        isSubmitting = true;
        pendingAction = "save";
        try
        {
            var ok = await ReviewService.SaveCommentDraftAsync(new SaveReviewCommentRequest
            {
                AssignmentId = data.MyAssignment.Id,
                Comment      = commentDraft ?? string.Empty
            }, CurrentUserId);

            if (!ok)
            {
                await ShowToastAsync("error", "儲存失敗（題目可能已決策或不再分配給您）");
                return;
            }

            // 互審階段：儲存即完成 → 通知父層 reload 列表 + 關閉 Modal + toast
            // 專/總審階段：純草稿 → 留在 Modal + toast
            var isMutual = data.MyAssignment.Stage == ReviewStage.Mutual;
            if (isMutual)
            {
                await OnDecisionMade.InvokeAsync();   // 父層列表 reload（待處理 -1、列表狀態轉「已完成」）
                await CloseAsync();                    // 先關 Modal
                await ShowToastAsync("success", "審題意見已儲存");   // 再 toast
            }
            else
            {
                await ShowToastAsync("success", "審題意見已儲存");
            }
        }
        catch (Exception ex)
        {
            await ShowToastAsync("error", $"儲存失敗：{ex.Message}");
        }
        finally
        {
            isSubmitting = false;
            pendingAction = null;
        }
    }

    private async Task OnSubmitDecisionAsync(ReviewDecision decision)
    {
        // 明確拆兩段 check 讓編譯器 null-flow analysis 認得 data 與 data.MyAssignment 後續均非 null
        if (data is null || data.MyAssignment is null || isSubmitting) return;

        // 決策一律強制留意見（與 ReviewDecisionBar disabled 條件對齊，第二道防線）
        // 例外：總召代修+裁決模式（CanFinalReviewerEdit=true）不需要意見，直接決策
        if (!data.CanFinalReviewerEdit
            && (commentDraft ?? string.Empty).Trim().Length < MinCommentLength)
        {
            await ShowToastAsync("warning", $"意見需至少 {MinCommentLength} 字才能送出決策");
            return;
        }

        // 決策按鈕對應 spinner 位置
        pendingAction = decision switch
        {
            ReviewDecision.Approve => "approve",
            ReviewDecision.Revise  => "revise",
            ReviewDecision.Reject  => "reject",
            _                       => null
        };
        isSubmitting = true;

        try
        {
            var ok = await ReviewService.SubmitDecisionAsync(new SubmitReviewDecisionRequest
            {
                AssignmentId = data.MyAssignment.Id,
                Comment      = commentDraft ?? string.Empty,
                Decision     = decision
            }, CurrentUserId);

            if (ok)
            {
                var label = decision switch
                {
                    ReviewDecision.Approve => "採用",
                    ReviewDecision.Revise  => "改後採用",
                    ReviewDecision.Reject  => "不採用",
                    _                       => "已送出"
                };
                await ShowToastAsync("success", $"決策已提交：{label}");
                await OnDecisionMade.InvokeAsync();   // 通知父層 reload 列表
                await CloseAsync();
            }
            else
            {
                await ShowToastAsync("error", "提交失敗（題目可能已決策或不再分配給您）");
            }
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync("warning", ex.Message);
        }
        catch (Exception ex)
        {
            await ShowToastAsync("error", $"提交失敗：{ex.Message}");
        }
        finally
        {
            isSubmitting = false;
            pendingAction = null;
        }
    }

    /// <summary>
    /// 總審第 3 次「編輯題目」按鈕（Plan_021 正式實作）。
    /// 觸發父層 OnRequestFinalEdit EventCallback → 父層關閉 ReviewModal 並開啟命題編輯 Modal。
    /// Reviews.razor 統一管理兩個 Modal 的開關，ReviewModal 自身不做跨 Modal 操作。
    /// </summary>
    private async Task OnRequestEditAsync()
    {
        if (data?.Question?.Id is null or 0) return;
        // 先抓 id 再關閉：CloseAsync() 會把 data 清掉，先拷貝出來避免 NRE
        var questionId = data.Question.Id;
        await CloseAsync();
        await OnRequestFinalEdit.InvokeAsync(questionId);
    }

    private ValueTask ShowToastAsync(string icon, string title) =>
        JS.InvokeVoidAsync("Swal.fire", new
        {
            icon,
            title,
            toast = true,
            position = "top-end",
            showConfirmButton = false,
            timer = 2200
        });

    protected override async Task OnParametersSetAsync()
    {
        // 只在 IsVisible=true 且 QuestionId 切換時才重新載入；
        // 同題下切換子題單元由 SwitchSubUnitAsync 內部負責，不走 OnParametersSetAsync。
        // 父層 SubQuestionId 變化（只在「開新題」時才會跨 Modal 改變）會帶動 currentSubId 重設。
        if (!IsVisible || QuestionId is null) return;
        if (loadedQuestionId == QuestionId) return;

        loadedQuestionId    = QuestionId;
        currentSubId        = SubQuestionId;   // 開啟新題目時用父層指定的單元初始化
        loadedSubQuestionId = currentSubId;
        await LoadAsync(QuestionId.Value, currentSubId);
    }

    /// <summary>
    /// 在 Modal 內切換到不同的審題單元（母題索引卡點擊子題、或子題之間互跳）。
    /// 不關閉 Modal、不通知父層；只重撈該單元資料。
    /// </summary>
    public async Task SwitchSubUnitAsync(int? subQuestionId)
    {
        if (QuestionId is null) return;
        if (currentSubId == subQuestionId) return;   // 已是該單元，不重撈
        currentSubId        = subQuestionId;
        loadedSubQuestionId = currentSubId;
        await LoadAsync(QuestionId.Value, currentSubId);
    }

    private async Task LoadAsync(int questionId, int? subQuestionId)
    {
        isLoading = true;
        loadError = null;
        data = null;
        commentDraft = string.Empty;
        annotations = new();
        try
        {
            data = await ReviewService.GetModalDataAsync(questionId, subQuestionId, CurrentUserId);
            if (data is null) { loadError = "找不到此題目，可能已被刪除。"; return; }
            commentDraft = data.MyAssignment?.Comment ?? string.Empty;

            // 載入該單元的劃記評語（只看自己 stage 自己劃的；無 Assignment 則自然空）
            if (data.MyAssignment is not null)
            {
                annotations = await AnnotationService.GetByAssignmentAsync(data.MyAssignment.Id);
            }
        }
        catch (Exception ex)
        {
            loadError = $"載入失敗：{ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// 首次渲染後初始化 annotation.js（綁全域 selection 監聽 + 建浮層按鈕）。
    /// 之後每次 LoadAsync 完成、DOM 更新後 push 一次 highlights。
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsVisible || data is null) return;

        if (!annotJsInited)
        {
            annotSelfRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("annotation.init", annotSelfRef);
                annotJsInited = true;
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"[annotation] init failed: {ex.Message}");
                return;
            }
        }

        // 每次 render（含子題切換、annotations 變動）都重畫 highlights
        await PushHighlightsToJsAsync();
    }

    /// <summary>
    /// 頂部「等級」徽章標籤。
    /// 聽力題組（ListenGroup）母題 Level 固定為 NULL，子題各自帶 FixedDifficulty（題1=3、題2=4），
    /// 因此子題視角必須改從 ListenGroupSubQuestions[currentSubId].FixedDifficulty 取等級，
    /// 否則頂部 Header 會少一個「難度四」之類的徽章。
    /// </summary>
    private string LevelLabel
    {
        get
        {
            if (data?.Question is null) return "";
            var q = data.Question;

            if (q.QuestionType == QuestionTypeCodes.ListenGroup && currentSubId is int subId)
            {
                var sub = q.ListenGroupSubQuestions.FirstOrDefault(s => s.Id == subId);
                if (sub is not null)
                    return QuestionConstants.ListenLevelLabels.GetValueOrDefault(sub.FixedDifficulty, "");
            }

            if (q.Level is null) return "";
            return q.QuestionType is QuestionTypeCodes.Listen or QuestionTypeCodes.ListenGroup
                ? QuestionConstants.ListenLevelLabels.GetValueOrDefault(q.Level.Value, "")
                : QuestionConstants.GeneralLevelLabels.GetValueOrDefault(q.Level.Value, "");
        }
    }

    private string DifficultyLabel => data?.Question?.Difficulty is null
        ? ""
        : QuestionConstants.DifficultyLabels.GetValueOrDefault(data.Question.Difficulty.Value, "");

    /// <summary>
    /// 顯示題目最後編輯時間（命題老師真實操作的時間）。
    /// 資料來源：ReviewService.GetModalDataAsync 已從 MT_AuditLogs 查出命題老師最後真實編輯時間，
    /// 並覆蓋進 question.UpdatedAt，故此處直接讀 UpdatedAt 即可。
    /// 覆蓋邏輯說明：篩選 TargetType=3、UserId NOT NULL、Reason 非系統批次清單，取最大 CreatedAt；
    /// 若無紀錄（極舊資料無 AuditLog），fallback 為 question.CreatedAt（建立時間）。
    /// 舊資料（UpdatedAt 曾被審題決策污染）自此次查詢起自動呈現正確值，無需修改歷史資料。
    /// </summary>
    private string EditedAtLabel
    {
        get
        {
            if (data is null) return "—";

            // question.UpdatedAt 已由 ReviewService.GetModalDataAsync 校正為命題老師真實編輯時間
            var display = data.Question.UpdatedAt != DateTime.MinValue ? data.Question.UpdatedAt
                        : data.Question.CreatedAt  != DateTime.MinValue ? data.Question.CreatedAt
                        : DateTime.MinValue;
            return display == DateTime.MinValue
                ? "—"
                : display.ToString("yyyy/MM/dd HH:mm");
        }
    }

    /// <summary>
    /// 開啟「試題重複比對」彈窗 — Plan A 即時計算（不寫 DB）
    /// 從當前 data.Question 組裝 QuestionDraftSnapshot 給 SimilarityService 比對
    /// </summary>
    private async Task OpenSimilarityCheckAsync()
    {
        if (isCheckingSimilarity || data is null) return;

        isCheckingSimilarity = true;
        similarityResults = Array.Empty<MT.Models.SimilarityCompareResult>();
        showSimilarityModal = true;
        StateHasChanged();

        try
        {
            // 從審題端 data.Question 組裝 snapshot；ProjectId 從 Parameter 傳入
            var snapshot = data.Question.ToDraftSnapshot(ProjectId);
            var results = await SimilarityService.ComputeOnDemandAsync(snapshot, topN: 5);
            similarityResults = results;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "OpenSimilarityCheckAsync 失敗：QuestionId={Id}", data.Question.Id);
            similarityResults = Array.Empty<MT.Models.SimilarityCompareResult>();
        }
        finally
        {
            isCheckingSimilarity = false;
            StateHasChanged();
        }
    }

    private async Task CloseAsync()
    {
        // 不直接寫 IsVisible — 它是 [Parameter]，下次 OnParametersSetAsync 會被父層覆蓋。
        // 唯一可信賴的關閉路徑：通知父層 → 父層更新 state → 父層 re-render 把 IsVisible 變回 false
        loadedQuestionId    = null;   // 下次再開同題時強制重撈最新狀態
        loadedSubQuestionId = null;
        currentSubId        = null;
        data = null;
        commentDraft = string.Empty;
        await IsVisibleChanged.InvokeAsync(false);
    }
}
