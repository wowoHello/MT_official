@* ====================================================================== *@
@*  ReviewHistoryTimeline — 歷程軌跡（卡片 + timeline 連線版面）             *@
@*  資料源：MT_ReviewAssignments（審題意見）+ MT_RevisionReplies（修題說明） *@
@*  視覺：                                                                   *@
@*    - 每筆紀錄獨立成卡片，左側保留垂直連線與圓點節點                       *@
@*    - 兩色 Kind：ReviewComment (morandi)、RevisionReply (terracotta)        *@
@*  匿名行為：ShowActorName=false（預設，Reviews 用，公平性匿名）             *@
@*           ShowActorName=true（Overview 管理員視角，顯示真名）             *@
@*  單元歸屬：ShowUnitBadge=true（Overview 彙整視角，顯示題號 Q-XXX-XXXXX-NN）*@
@*           ShowUnitBadge=false（預設，Reviews 單元視角不需要）              *@
@* ====================================================================== *@

<details class="border-b border-gray-100" open>
    <summary class="px-5 py-4 cursor-pointer font-bold text-slate-main text-sm flex items-center gap-2 hover:bg-gray-50 transition list-none">
        <i class="fa-solid fa-clock-rotate-left text-morandi"></i>
        歷程軌跡
        <span class="text-xs bg-morandi/10 text-morandi px-2 py-0.5 rounded-full font-bold ml-1">@Entries.Count 筆</span>
        <i class="fa-solid fa-chevron-down ml-auto text-xs text-gray-400 transition-transform"></i>
    </summary>

    <div class="px-5 pb-5 bg-gray-50/30 pt-3">
        @if (Entries.Count == 0)
        {
            <p class="text-xs text-gray-400 italic text-center py-3">尚無歷程紀錄</p>
        }
        else
        {
            @* 外層容器：relative + pl-6 為左側連線與圓點預留空間 *@
            <div class="relative pl-6 space-y-3">

                @* 垂直軸線：從頂部延伸至底部，固定在 left-2 *@
                <span class="absolute left-2 top-3 bottom-3 w-px bg-gray-200"></span>

                @foreach (var entry in Entries)
                {
                    @* 依 Kind 決定 badge 配色 *@
                    var badgeCss = entry.Kind switch
                    {
                        ReviewHistoryKind.QuestionEvent => "bg-sage/10 text-sage border border-sage/30",
                        ReviewHistoryKind.ReviewComment => "bg-morandi/10 text-morandi border border-morandi/30",
                        ReviewHistoryKind.RevisionReply => "bg-terracotta/10 text-terracotta border border-terracotta/30",
                        _                               => "bg-gray-100 text-gray-500 border border-gray-200"
                    };

                    @* 決定圓點的背景色與 fa 圖示（搭配 Kind 三色） *@
                    var dotBgCss = entry.Kind switch
                    {
                        ReviewHistoryKind.QuestionEvent => "bg-sage",
                        ReviewHistoryKind.ReviewComment => "bg-morandi",
                        ReviewHistoryKind.RevisionReply => "bg-terracotta",
                        _                               => "bg-gray-400"
                    };
                    var dotIcon = entry.Kind switch
                    {
                        ReviewHistoryKind.QuestionEvent => "fa-pen",
                        ReviewHistoryKind.ReviewComment => "fa-comment",
                        ReviewHistoryKind.RevisionReply => "fa-reply",
                        _                               => "fa-circle"
                    };

                    @* 決定左側人物圖示顏色（與 badge 同系列） *@
                    var iconCss = entry.Kind switch
                    {
                        ReviewHistoryKind.QuestionEvent => "text-sage",
                        ReviewHistoryKind.ReviewComment => "text-morandi",
                        ReviewHistoryKind.RevisionReply => "text-terracotta",
                        _                               => "text-gray-400"
                    };

                    @* 匿名邏輯：ShowActorName=false 時依 Kind / Label 顯示角色稱謂
                       互審＝命題老師之間互評；專審＝審題委員；總審＝總召集人 *@
                    var anonymousName = entry.Kind switch
                    {
                        ReviewHistoryKind.QuestionEvent => "命題老師",
                        ReviewHistoryKind.RevisionReply => "命題老師",
                        ReviewHistoryKind.ReviewComment => entry.Label.Contains("互審") ? "命題老師"
                                                          : entry.Label.Contains("總審") ? "總召集人"
                                                          : "審題委員",
                        _                               => "操作人"
                    };
                    var displayName = ShowActorName && !string.IsNullOrWhiteSpace(entry.ActorName)
                        ? entry.ActorName
                        : anonymousName;

                    @* 卡片容器：relative 讓圓點可以 absolute 定位在左側 *@
                    <div class="relative bg-gray-50 border border-gray-200 rounded-lg p-3">

                        @* 圓點節點：absolute 定位在卡片左側外，疊在垂直軸線上方
                           -left-[18px] 讓圓點中心對齊 left-2 的軸線
                           ring-2 ring-white 讓圓點從灰線浮起 *@
                        <span class="absolute -left-[18px] top-3 w-4 h-4 rounded-full @dotBgCss ring-2 ring-white flex items-center justify-center z-10">
                            <i class="fa-solid @dotIcon text-white" style="font-size: 0.45rem;"></i>
                        </span>

                        @* 頂部列：左側（人物圖示 + 姓名 + 動作 badge）、右側（時間） *@
                        <div class="flex justify-between items-center flex-wrap gap-2">
                            <div class="flex items-center gap-2">
                                <i class="fa-solid fa-user-circle @iconCss text-base"></i>
                                <span class="text-xs font-bold text-slate-main">@displayName</span>
                                <span class="inline-block px-2 py-0.5 rounded text-xs font-bold border @badgeCss">@entry.Label</span>
                                @if (ShowUnitBadge && !string.IsNullOrEmpty(entry.UnitDisplayCode))
                                {
                                    <span class="inline-block px-2 py-0.5 rounded text-xs font-bold bg-slate-main/10 text-slate-main border border-slate-main/20 font-mono tracking-tight">
                                        @entry.UnitDisplayCode
                                    </span>
                                }
                            </div>
                            <span class="text-xs text-gray-500">@entry.At.ToString("yyyy/MM/dd HH:mm")</span>
                        </div>

                        @* 內容區：白色內框（意見文字）；總審「不採用」加紅字警示 *@
                        @if (!string.IsNullOrWhiteSpace(entry.ContentHtml))
                        {
                            @* 判斷是否為總審不採用意見（Label 含「不採用」且來自 ReviewComment 類型） *@
                            var isRejectComment = entry.Kind == ReviewHistoryKind.ReviewComment
                                                  && entry.Label.Contains("不採用");

                            @if (isRejectComment)
                            {
                                <div class="mt-1.5 text-xs font-semibold text-red-600 flex items-center gap-1">
                                    <i class="fa-solid fa-triangle-exclamation"></i>
                                    <span>總審決策：不採用 — 請注意以下意見</span>
                                </div>
                                <div class="mt-1 bg-red-50 border border-red-200 rounded-md px-3 py-2 text-sm text-red-700 leading-relaxed whitespace-pre-wrap not-italic font-medium">
                                    @entry.ContentHtml
                                </div>
                            }
                            else
                            {
                                <div class="mt-2 bg-white border border-gray-200 rounded-md px-3 py-2 text-sm text-slate-main leading-relaxed whitespace-pre-wrap not-italic">
                                    @entry.ContentHtml
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        }
    </div>
</details>

@code {
    [Parameter, EditorRequired] public List<ReviewHistoryEntry> Entries { get; set; } = new();

    /// <summary>
    /// true = 顯示真實姓名（管理員視角，如 Overview）；
    /// false = 顯示角色稱謂（審題公平性，如 Reviews）。預設 false 維持原行為。
    /// </summary>
    [Parameter] public bool ShowActorName { get; set; } = false;

    /// <summary>
    /// true = 顯示單元歸屬題號 badge（彙整視角，如 Overview，避免題組類多子題歷程混淆）；
    /// false = 不顯示（單元視角，如 Reviews modal 已知當前單元）。預設 false。
    /// </summary>
    [Parameter] public bool ShowUnitBadge { get; set; } = false;
}
