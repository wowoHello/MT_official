@* ====================================================================== *@
@*  ReviewQuestionDisplay — 審題 Modal 左 70% 題目展示                       *@
@*                                                                          *@
@*  設計原則：                                                              *@
@*    1. 改用 PreviewXxx 元件呈現考卷風格（與 Overview Slide-over 一致）      *@
@*    2. 隱藏 PreviewHeader 的「全民中文檢定」大標題（review-no-cwt-title）   *@
@*    3. 試題解析 / 批閱說明以 <details open> 折疊區置於題目下方              *@
@*       → 預設展開，審題者必須可見（這是審題判斷依據）                       *@
@*       → 折疊僅提供空間節省選項                                           *@
@*    4. 題組子題解析各自獨立顯示於每題下方的 details 區                     *@
@* ====================================================================== *@
@using MT.Components.Shared.QuestionPreviews

<div class="w-full bg-oatmeal overflow-y-auto custom-scroll">
    <div class="max-w-4xl mx-auto px-5 sm:px-6 py-5 sm:py-6 space-y-4">

        @* 考卷預覽區：外層加 review-no-cwt-title 隱藏「全民中文檢定」大標題 *@
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <p class="text-xs font-bold text-morandi uppercase tracking-wider mb-3">
                <i class="fa-solid fa-file-alt mr-1"></i> 題目內容
            </p>
            <div class="bg-gray-50 rounded-lg p-4 border border-gray-100 review-no-cwt-title">
                @switch (Question.QuestionType)
                {
                    case QuestionTypeCodes.Single:
                    case QuestionTypeCodes.Select:
                        @RenderChoicePreview
                        break;
                    case QuestionTypeCodes.LongText:
                        @RenderLongTextPreview
                        break;
                    case QuestionTypeCodes.ReadGroup:
                        @RenderReadGroupPreview
                        break;
                    case QuestionTypeCodes.ShortGroup:
                        @RenderShortGroupPreview
                        break;
                    case QuestionTypeCodes.Listen:
                        @RenderListenPreview
                        break;
                    case QuestionTypeCodes.ListenGroup:
                        @RenderListenGroupPreview
                        break;
                    default:
                        <p class="text-sm text-gray-500">未知題型：@Question.QuestionType</p>
                        break;
                }
            </div>
        </div>

        @* 批閱者輔助資訊折疊區（解析 / 批閱說明），預設展開 *@
        @RenderAnalysisSection

    </div>
</div>

@code {
    [Parameter, EditorRequired] public QuestionFormData Question { get; set; } = default!;
    [Parameter] public string CreatorName { get; set; } = string.Empty;

    // ==========================================================
    //  共用 Helper
    // ==========================================================

    /// <summary>判斷 HTML 字串是否有實質內容（非空標籤）</summary>
    private static bool HasContent(string? html)
    {
        if (string.IsNullOrWhiteSpace(html)) return false;
        var stripped = System.Text.RegularExpressions.Regex.Replace(html, "<[^>]*>", "").Trim();
        return !string.IsNullOrEmpty(stripped) || html.Contains("<img");
    }

    /// <summary>
    /// 解析折疊區（<details open>，預設展開）。
    /// amber 配色表示「審題者私有資訊」視覺位階。
    /// </summary>
    private RenderFragment InlineAnalysis(string label, string icon, string? content) => __builder =>
    {
        if (!HasContent(content)) return;
        <div class="pt-3 mt-3 border-t border-amber-100">
            <p class="text-xs font-bold text-amber-600 mb-2 tracking-wider">
                <i class="fa-solid @icon mr-1"></i> @label
            </p>
            <div class="pl-3 border-l-2 border-amber-200">
                <div class="prose prose-sm max-w-none font-serif text-sm leading-relaxed text-gray-700">
                    @((MarkupString)content!)
                </div>
            </div>
        </div>
    };

    /// <summary>依題型決定是否有解析內容（控制 details 是否顯示）</summary>
    private bool HaveAnyAnalysis() => Question.QuestionType switch
    {
        QuestionTypeCodes.LongText
            => HasContent(Question.GradingNote),
        QuestionTypeCodes.ReadGroup
            => Question.ReadSubQuestions.Any(sq => HasContent(sq.Analysis)),
        QuestionTypeCodes.ShortGroup
            => Question.ShortSubQuestions.Any(sq => HasContent(sq.Analysis)),
        QuestionTypeCodes.ListenGroup
            => Question.ListenGroupSubQuestions.Any(sq => HasContent(sq.Analysis)),
        _   => HasContent(Question.Analysis)
    };

    // ==========================================================
    //  BuildTags / LevelLabel（自包邏輯，與 OverviewService 相同但不依賴 Service 注入）
    //  ReviewQuestionDisplay 是純展示元件，不需要額外 DI
    // ==========================================================

    private Dictionary<string, string> BuildTags()
    {
        var tags = new Dictionary<string, string>();
        const string fallback = "未設定";
        string Lab(byte? v, IReadOnlyDictionary<byte, string> map)
            => v is null ? fallback : map.GetValueOrDefault(v.Value, fallback);

        switch (Question.QuestionType)
        {
            case QuestionTypeCodes.Single:
            case QuestionTypeCodes.Select:
                tags["主類"] = Lab(Question.Topic, QuestionConstants.TopicLabels);
                tags["次類"] = Lab(Question.Subtopic, QuestionConstants.SubtopicLabels);
                break;
            case QuestionTypeCodes.LongText:
                tags["寫作模式"] = Lab(Question.WritingMode, QuestionConstants.WritingModeLabels);
                break;
            case QuestionTypeCodes.ReadGroup:
                tags["文體"] = Lab(Question.Genre, QuestionConstants.GenreLabels);
                break;
            case QuestionTypeCodes.ShortGroup:
                tags["主類"] = "文意判讀";
                tags["次類"] = "篇章辨析";
                tags["文體"] = Lab(Question.Genre, QuestionConstants.GenreLabels);
                break;
            case QuestionTypeCodes.Listen:
                tags["核心能力"] = Lab(Question.CoreAbility, QuestionConstants.CoreAbilityLabels);
                tags["細目指標"] = Lab(Question.DetailIndicator, QuestionConstants.DetailIndicatorLabels);
                tags["語音類型"] = Lab(Question.AudioType, QuestionConstants.AudioTypeLabels);
                tags["素材分類"] = Lab(Question.Material, QuestionConstants.MaterialLabels);
                break;
            case QuestionTypeCodes.ListenGroup:
                tags["語音類型"] = Lab(Question.AudioType, QuestionConstants.AudioTypeLabels);
                tags["素材分類"] = Lab(Question.Material, QuestionConstants.MaterialLabels);
                break;
        }
        return tags;
    }

    private string LevelLabel()
    {
        if (Question.Level is null) return "";
        return Question.QuestionType is QuestionTypeCodes.Listen or QuestionTypeCodes.ListenGroup
            ? QuestionConstants.ListenLevelLabels.GetValueOrDefault(Question.Level.Value, "")
            : QuestionConstants.GeneralLevelLabels.GetValueOrDefault(Question.Level.Value, "");
    }

    private string TypeLabel()
        => QuestionConstants.TypeLabels.GetValueOrDefault(Question.QuestionType, "");

    private string DifficultyLabel()
        => Question.Difficulty is byte d
            ? QuestionConstants.DifficultyLabels.GetValueOrDefault(d, "")
            : "";

    // ==========================================================
    //  考卷預覽元件呼叫（7 種題型）
    // ==========================================================

    /// <summary>一般 / 精選：PreviewSingle + 解析 details</summary>
    private RenderFragment RenderChoicePreview => __builder =>
    {
        <PreviewSingle QuestionType="@TypeLabel()" Level="@LevelLabel()" Difficulty="@DifficultyLabel()"
                       Tags="@BuildTags()" Stem="@(Question.Stem ?? "")"
                       Options="@Question.Options" Answer="@(Question.Answer ?? "")" />
    };

    /// <summary>長文題目：PreviewLongText + 批閱說明 details</summary>
    private RenderFragment RenderLongTextPreview => __builder =>
    {
        <PreviewLongText Level="@LevelLabel()" Difficulty="@DifficultyLabel()"
                         Tags="@BuildTags()" Stem="@(Question.Stem ?? "")"
                         Passage="@(Question.ArticleContent ?? "")" />
    };

    /// <summary>閱讀題組：PreviewReadGroup + 各子題解析 details（於主 details 內依序）</summary>
    private RenderFragment RenderReadGroupPreview => __builder =>
    {
        <PreviewReadGroup Level="@LevelLabel()" Difficulty="@DifficultyLabel()"
                          Tags="@BuildTags()" Stem="@(Question.Stem ?? "")"
                          Passage="@(Question.ArticleContent ?? "")"
                          SubQuestions="@Question.ReadSubQuestions.Select(sq => new PreviewReadGroup.SubQuestionData {
                              Stem    = sq.Stem ?? "",
                              Options = sq.Options,
                              Answer  = sq.Answer ?? ""
                          }).ToList()" />
    };

    /// <summary>短文題組：PreviewShortGroup + 各子題解析 details（於主 details 內依序）</summary>
    private RenderFragment RenderShortGroupPreview => __builder =>
    {
        <PreviewShortGroup Level="@LevelLabel()" Difficulty="@DifficultyLabel()"
                           Tags="@BuildTags()" Stem="@(Question.Stem ?? "")"
                           Passage="@(Question.ArticleContent ?? "")"
                           SubQuestions="@Question.ShortSubQuestions.Select(sq => new PreviewShortGroup.SubQuestionData {
                               Stem      = sq.Stem ?? "",
                               Dimension = QuestionConstants.DecodeSubCoreAbility(sq.CoreAbility, QuestionTypeCodes.ShortGroup),
                               Indicator = QuestionConstants.DecodeSubIndicator(sq.Indicator, QuestionTypeCodes.ShortGroup)
                           }).ToList()" />
    };

    /// <summary>聽力題目：PreviewListen + 解析 details</summary>
    private RenderFragment RenderListenPreview => __builder =>
    {
        <PreviewListen Level="@LevelLabel()" Difficulty="@DifficultyLabel()"
                       Tags="@BuildTags()" AudioFileName="@(Question.AudioUrl ?? "")"
                       Stem="@(Question.Stem ?? "")" Options="@Question.Options"
                       Answer="@(Question.Answer ?? "")" />
    };

    /// <summary>聽力題組：PreviewListenGroup + 各子題解析 details（於主 details 內依序）</summary>
    private RenderFragment RenderListenGroupPreview => __builder =>
    {
        <PreviewListenGroup Tags="@BuildTags()" AudioFileName="@(Question.AudioUrl ?? "")"
                            Passage="@(Question.ArticleContent ?? "")"
                            SubQuestions="@Question.ListenGroupSubQuestions.Select(sq => new PreviewListenGroup.SubQuestionData {
                                Level           = QuestionConstants.ListenLevelLabels.GetValueOrDefault(sq.FixedDifficulty, ""),
                                CoreAbility     = QuestionConstants.DecodeSubCoreAbility(sq.CoreAbility, QuestionTypeCodes.ListenGroup),
                                DetailIndicator = QuestionConstants.DecodeSubIndicator(sq.DetailIndicator, QuestionTypeCodes.ListenGroup),
                                Stem    = sq.Stem ?? "",
                                Options = sq.Options,
                                Answer  = sq.Answer ?? ""
                            }).ToList()" />
    };

    // ==========================================================
    //  解析折疊區（全題型統一，預設展開）
    // ==========================================================

    /// <summary>
    /// 解析折疊區：僅在有內容時顯示。
    /// 長文題目顯示「批閱說明」；題組型則逐子題顯示各自解析。
    /// </summary>
    private RenderFragment RenderAnalysisSection => __builder =>
    {
        if (!HaveAnyAnalysis()) return;

        <details open class="bg-white rounded-xl shadow-sm border border-amber-100 overflow-hidden">
            <summary class="px-5 py-3 cursor-pointer text-xs font-bold text-amber-700 flex items-center gap-1.5 hover:bg-amber-50/60 transition list-none select-none">
                <i class="fa-solid fa-lock text-amber-500 text-xs"></i>
                <span>審題輔助資訊（解析 / 批閱說明）</span>
                <i class="fa-solid fa-chevron-down ml-auto text-xs text-amber-400"></i>
            </summary>
            <div class="px-5 pb-5 pt-1">
                @switch (Question.QuestionType)
                {
                    case QuestionTypeCodes.LongText:
                        @InlineAnalysis("批閱說明", "fa-list-check", Question.GradingNote)
                        break;

                    case QuestionTypeCodes.ReadGroup:
                        @for (int i = 0; i < Question.ReadSubQuestions.Count; i++)
                        {
                            var sq  = Question.ReadSubQuestions[i];
                            var num = i + 1;
                            if (HasContent(sq.Analysis))
                            {
                                @InlineAnalysis($"第 {num} 題試題解析", "fa-lightbulb", sq.Analysis)
                            }
                        }
                        break;

                    case QuestionTypeCodes.ShortGroup:
                        @for (int i = 0; i < Question.ShortSubQuestions.Count; i++)
                        {
                            var sq  = Question.ShortSubQuestions[i];
                            var num = i + 1;
                            if (HasContent(sq.Analysis))
                            {
                                @InlineAnalysis($"第 {num} 題試題解析", "fa-lightbulb", sq.Analysis)
                            }
                        }
                        break;

                    case QuestionTypeCodes.ListenGroup:
                        @for (int i = 0; i < Question.ListenGroupSubQuestions.Count; i++)
                        {
                            var sq  = Question.ListenGroupSubQuestions[i];
                            var num = i + 1;
                            if (HasContent(sq.Analysis))
                            {
                                @InlineAnalysis($"第 {num} 題試題解析", "fa-lightbulb", sq.Analysis)
                            }
                        }
                        break;

                    default:
                        @* 一般 / 精選 / 聽力：單一解析欄位 *@
                        @InlineAnalysis("試題解析", "fa-lightbulb", Question.Analysis)
                        break;
                }
            </div>
        </details>
    };
}
